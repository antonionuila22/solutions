---
/**
 * Outsource Web Development Landing Page
 * Keywords: outsource web development, web development outsourcing, outsource website development
 */

import Layout from "../layouts/Layout.astro";
import FAQ from "../components/FAQ.tsx";

const title = "Outsource Web Development | Codebrand";
const description = "Outsource your web development to a reliable partner. Senior developers, US timezone, transparent pricing. Save 60% vs US agencies while maintaining quality.";
const keywords = "outsource web development, web development outsourcing, outsource website development, outsource software development, offshore web development, outsourcing development partner, outsource coding, outsource programming";

const faqs = [
  {
    question: "Why should I outsource web development?",
    answer: "Outsourcing web development offers significant advantages: (1) Cost savings of 50-60% compared to in-house or local agencies. (2) Access to specialized skills without long-term hiring commitments. (3) Faster delivery through experienced teams. (4) Scalability—add or reduce capacity as needed. (5) Focus on your core business while experts handle development."
  },
  {
    question: "How do I ensure quality when outsourcing?",
    answer: "Quality depends on choosing the right partner. Look for: clear communication (same timezone helps), proven portfolio, code review processes, comprehensive testing, and transparent pricing. We guarantee quality through peer code reviews, TypeScript for type safety, automated testing, and regular demo sessions so you see progress throughout."
  },
  {
    question: "What's the difference between outsourcing and hiring?",
    answer: "Hiring means adding permanent employees with salaries, benefits, equipment, and management overhead—plus the risk of a bad hire. Outsourcing means paying for work completed, with no long-term commitment. You can scale up or down instantly, access specialized skills for specific projects, and avoid the time and cost of recruiting."
  },
  {
    question: "How do you handle communication across timezones?",
    answer: "We work US timezone hours (Central Time) specifically to enable real-time collaboration. You get instant Slack responses during business hours, live video calls when needed, and same-day code reviews. This is a key advantage over offshore teams in drastically different timezones that create 12-24 hour communication delays."
  },
  {
    question: "What types of projects can I outsource?",
    answer: "We handle all types of web development: custom websites, web applications, e-commerce stores, SaaS platforms, mobile apps, API development, and ongoing maintenance. Whether you need a complete project built from scratch or developers to augment your existing team, we can help."
  },
  {
    question: "How do you protect my intellectual property?",
    answer: "We sign NDAs before any project discussion. All code we write belongs to you—full ownership with no licensing fees. We use secure repositories, encrypted communication, and access controls. Our contracts include strong IP protection clauses. Your business ideas and code are completely protected."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer }
  }))
};

const benefits = [
  { icon: "💰", title: "60% Cost Savings", desc: "Senior developer quality at a fraction of US agency rates" },
  { icon: "🕐", title: "US Timezone", desc: "Real-time collaboration during your business hours" },
  { icon: "📈", title: "Scale On Demand", desc: "Add or reduce capacity instantly as needs change" },
  { icon: "🎯", title: "Focus on Core Business", desc: "Let experts handle development while you grow" },
  { icon: "⚡", title: "Faster Time to Market", desc: "Experienced teams deliver faster than new hires" },
  { icon: "🔒", title: "Full IP Protection", desc: "NDA, secure repos, and 100% code ownership" }
];

const comparison = [
  { aspect: "Cost", outsource: "$45-95/hr", inhouse: "$150-200/hr equiv." },
  { aspect: "Start Time", outsource: "1-2 weeks", inhouse: "3-6 months" },
  { aspect: "Scalability", outsource: "Instant", inhouse: "Slow & expensive" },
  { aspect: "Risk", outsource: "Pay per project", inhouse: "Long-term commitment" }
];

const stats = [
  { value: "60%", label: "Cost Savings" },
  { value: "1-2", label: "Weeks to Start" },
  { value: "500+", label: "Projects Done" },
  { value: "98%", label: "Satisfaction" }
];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  canonicalOverride="https://www.codebrand.us/outsource-web-development"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- ==================== HERO ==================== -->
  <section class="relative min-h-[90vh] flex items-center py-16 sm:py-20 lg:py-28 overflow-hidden bg-slate-950">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(6, 182, 212, 0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(6, 182, 212, 0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-orange-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
      <div class="max-w-4xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-slate-800/80 border border-cyan-500/30 rounded-full mb-8 backdrop-blur-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
          </span>
          <span class="text-sm font-medium text-cyan-400">Outsource Web Development</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight font-poppins">
          Outsource <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-amber-500">Development</span>
        </h1>

        <p class="text-lg sm:text-xl text-slate-300 leading-relaxed mb-8 max-w-2xl">
          Reliable development partner for your projects.<br class="hidden md:block" />
          Save 60% while maintaining quality.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 mb-16">
          <a
            href="/contact"
            class="group inline-flex items-center gap-2 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white font-bold px-8 py-4 rounded-2xl transition-all duration-300 shadow-lg shadow-orange-500/25 hover:shadow-orange-500/40 hover:-translate-y-1"
          >
            Start Outsourcing
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a
            href="#benefits"
            class="inline-flex items-center gap-2 px-8 py-4 bg-slate-800/80 hover:bg-slate-700/80 text-white font-semibold rounded-2xl border border-slate-700 hover:border-slate-600 transition-all duration-300"
          >
            Why Outsource
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {stats.map((stat) => (
            <div class="text-center p-6 bg-white/5 border border-white/10 rounded-2xl">
              <div class="text-3xl sm:text-4xl font-bold text-orange-500">{stat.value}</div>
              <div class="text-slate-400 text-sm mt-2">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== WHY OUTSOURCE ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-100 border border-cyan-200 rounded-full text-cyan-700 text-sm font-semibold mb-6">
        OVERVIEW
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-8">Smart businesses outsource</h2>
      <div class="prose prose-lg max-w-none text-slate-600 space-y-6">
        <p>
          Building an in-house development team is expensive. Salaries, benefits, equipment, office space, management overhead—it adds up fast. And if your needs change, you're stuck with fixed costs. <a href="/nearshore-development" class="text-cyan-600 hover:text-cyan-700 font-semibold">Nearshore development</a> offers a better path.
        </p>
        <p>
          <strong class="text-slate-900">Outsourcing gives you flexibility.</strong> Access senior developers when you need them, scale up for big projects, scale down when work slows. Pay for results, not overhead. <a href="/hire-remote-developers" class="text-cyan-600 hover:text-cyan-700 font-semibold">Hire remote developers</a> for any project size.
        </p>
        <p>
          The key is choosing the right partner. We work <strong class="text-slate-900">US timezone hours</strong> for real-time collaboration, communicate in fluent English, and deliver quality code with transparent pricing. Whether you need <a href="/react-development-agency" class="text-cyan-600 hover:text-cyan-700 font-semibold">React development</a>, <a href="/ecommerce-development-agency" class="text-cyan-600 hover:text-cyan-700 font-semibold">e-commerce</a>, or <a href="/custom-web-development-services" class="text-cyan-600 hover:text-cyan-700 font-semibold">custom solutions</a>—it's outsourcing done right.
        </p>
      </div>
    </div>
  </section>

  <!-- ==================== BENEFITS ==================== -->
  <section id="benefits" class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-orange-100 border border-orange-200 rounded-full text-orange-700 text-sm font-semibold mb-6">
          BENEFITS
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900">Benefits of <span class="text-orange-500">Outsourcing</span></h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map((b) => (
          <div class="group bg-white hover:bg-white rounded-2xl shadow-lg hover:shadow-xl p-6 border border-slate-200 hover:border-orange-300 transition-all duration-300 hover:-translate-y-1">
            <div class="w-14 h-14 bg-orange-500 rounded-2xl flex items-center justify-center mb-5 shadow-lg group-hover:scale-110 transition-transform duration-300">
              <span class="text-2xl">{b.icon}</span>
            </div>
            <h3 class="text-xl font-semibold text-slate-900 mb-3">{b.title}</h3>
            <p class="text-slate-600 leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== COMPARISON ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-100 border border-cyan-200 rounded-full text-cyan-700 text-sm font-semibold mb-6">
          COMPARE
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900">Outsourcing vs <span class="text-orange-500">In-House</span></h2>
      </div>
      <div class="bg-white rounded-2xl shadow-lg border border-slate-200 overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b-2 border-slate-200 bg-slate-50">
              <th class="text-left py-4 px-6 text-slate-500 font-medium">Aspect</th>
              <th class="text-left py-4 px-6 text-orange-600 font-semibold">Outsourcing</th>
              <th class="text-left py-4 px-6 text-slate-500 font-medium">In-House</th>
            </tr>
          </thead>
          <tbody>
            {comparison.map((row) => (
              <tr class="border-b border-slate-100 hover:bg-slate-50 transition-colors duration-300">
                <td class="py-5 px-6 text-slate-900 font-medium">{row.aspect}</td>
                <td class="py-5 px-6 text-orange-700 font-medium">{row.outsource}</td>
                <td class="py-5 px-6 text-slate-500">{row.inhouse}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ==================== FAQ ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-slate-200 border border-slate-300 rounded-full text-slate-700 text-sm font-semibold mb-6">
          FAQ
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4">Common <span class="text-orange-500">Questions</span></h2>
      </div>
      <div>
        <FAQ faqs={faqs} client:visible />
      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 relative overflow-hidden">
    <div class="absolute inset-0 bg-slate-950">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(6, 182, 212, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(6, 182, 212, 0.05) 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-r from-orange-500/20 via-amber-500/20 to-yellow-500/20 rounded-full blur-3xl"></div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative">
        <div class="absolute -inset-1 bg-gradient-to-r from-orange-500 via-amber-500 to-yellow-500 rounded-3xl blur-xl opacity-30"></div>
        <div class="relative bg-gradient-to-br from-orange-500 via-amber-500 to-yellow-500 rounded-3xl p-12 lg:p-16 text-center overflow-hidden">
          <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>
          <div class="relative z-10">
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight font-poppins">
              Ready to outsource?
            </h2>
            <p class="text-lg lg:text-xl text-white/90 mb-10 max-w-xl mx-auto">
              Free consultation. See how much you can save.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="/contact"
                class="group inline-flex items-center justify-center gap-3 px-10 py-5 bg-white text-orange-600 rounded-2xl font-bold text-lg hover:bg-slate-900 hover:text-white transform hover:-translate-y-1 transition-all duration-300 shadow-2xl"
              >
                Get Started
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
