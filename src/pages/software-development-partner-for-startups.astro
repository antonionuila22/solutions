---
/**
 * Software Development Partner for Startups Landing Page
 * Keywords: software development partner startups, startup development agency, MVP development
 */

import Layout from "../layouts/Layout.astro";
import FAQ from "../components/FAQ.tsx";

const title = "Startup Dev Partner | MVP Experts | Codebrand";
const description = "Software development partner for startups. MVP development, rapid prototyping, and scalable architecture. Startup-friendly pricing.";
const keywords = "software development partner startups, startup development agency, MVP development, startup software development, tech partner for startups, startup web development, build MVP, startup technical partner, early stage startup development";

const faqs = [
  {
    question: "Why do startups need a development partner?",
    answer: "Most startup founders aren't technical, and hiring a CTO or in-house team is expensive and time-consuming. A development partner gives you instant access to senior engineering talent, startup-experienced developers who understand MVP thinking, and the flexibility to scale without long-term commitments. We've helped dozens of startups go from idea to funded product."
  },
  {
    question: "How much does MVP development cost?",
    answer: "MVPs typically range from $10,000 to $50,000 depending on complexity. A simple MVP (landing page + waitlist + basic features) can be $10,000-$20,000. A functional MVP with user accounts, core features, and basic analytics runs $20,000-$35,000. More complex MVPs with multiple user types or integrations can reach $50,000+. We focus on building only what you need to validate your hypothesis."
  },
  {
    question: "How long does it take to build an MVP?",
    answer: "Most MVPs take 6-12 weeks from kick-off to launch. We work in 2-week sprints, delivering working features throughout. Week 1-2: design and architecture. Week 3-8: core development. Week 9-12: polish, testing, and launch prep. We prioritize ruthlessly to get you to market fast—additional features can come after validation."
  },
  {
    question: "What happens after the MVP launches?",
    answer: "After launch, we help you iterate based on user feedback. Most startups need 2-3 iteration cycles before finding product-market fit. We offer ongoing development retainers for continuous improvement, analytics implementation to measure what's working, and scaling support when you're ready to grow. Many clients stay with us through funding rounds and beyond."
  },
  {
    question: "Do you work with pre-funded startups?",
    answer: "Yes, we work with startups at all stages—from bootstrapped founders to Series B companies. For pre-funded startups, we offer flexible payment terms and can work within tight budgets by carefully scoping what's truly essential for your MVP. We've helped several clients build MVPs that led to successful funding rounds."
  },
  {
    question: "Can you help with technical due diligence?",
    answer: "Absolutely. We provide clean, well-documented code that stands up to investor scrutiny. Our architecture decisions are made with scalability in mind, so when investors ask 'can this scale?', the answer is yes. We've helped clients prepare for technical due diligence and can provide documentation to support your fundraising."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer }
  }))
};

const services = [
  { icon: "🚀", title: "MVP Development", desc: "Validate your idea fast with a focused minimum viable product" },
  { icon: "🎨", title: "Product Design", desc: "User research, wireframes, and UI design before coding" },
  { icon: "⚡", title: "Rapid Prototyping", desc: "Interactive prototypes to test with users and investors" },
  { icon: "📈", title: "Scalable Architecture", desc: "Built to grow—no rewrites needed when you scale" },
  { icon: "🔄", title: "Iteration Support", desc: "Continuous improvement based on user feedback" },
  { icon: "💼", title: "Investor-Ready Code", desc: "Clean code that passes technical due diligence" }
];

const process = [
  { num: "01", title: "Discovery", desc: "Understand your vision, users, and what 'success' looks like" },
  { num: "02", title: "Scope MVP", desc: "Identify the minimum features needed to validate your hypothesis" },
  { num: "03", title: "Design Sprint", desc: "Wireframes and UI design—approved before coding starts" },
  { num: "04", title: "Build & Launch", desc: "2-week sprints with demos, shipping working software fast" }
];

const stats = [
  { value: "30+", label: "Startups Helped" },
  { value: "6-12", label: "Weeks to MVP" },
  { value: "$10k", label: "MVP Starting" },
  { value: "5", label: "Funded Clients" }
];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  canonicalOverride="https://www.codebrand.us/software-development-partner-for-startups"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero Section -->
  <section class="relative bg-slate-950 pt-32 sm:pt-36 lg:pt-28 pb-16 sm:pb-20 lg:pb-28 font-poppins overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center max-w-4xl mx-auto">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-orange-500/10 text-orange-400 text-sm font-semibold rounded-full mb-6">
          <span class="w-2 h-2 rounded-full bg-orange-400 animate-pulse"></span>
          Development Partner for Startups
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          Startup <span class="bg-gradient-to-r from-orange-500 to-orange-600 bg-clip-text text-transparent">Partner</span>
        </h1>
        <p class="text-xl sm:text-2xl text-slate-300 mb-10 leading-relaxed max-w-2xl mx-auto">
          From idea to funded product.
          MVP development that investors love.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white rounded-2xl font-semibold text-lg shadow-lg hover:shadow-xl transition-all duration-300">
            Build Your MVP
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
          </a>
          <a href="#services" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 hover:border-white/40 text-white rounded-2xl font-semibold text-lg transition-all duration-300">
            How We Help
          </a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {stats.map((stat) => (
            <div class="text-center p-6 bg-white/5 border border-white/10 rounded-2xl">
              <div class="text-3xl sm:text-4xl font-bold text-orange-500">{stat.value}</div>
              <div class="text-slate-400 text-sm mt-2">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-8">Your technical co-founder, on demand</h2>
      <div class="prose prose-lg max-w-none text-slate-700 space-y-6">
        <p>
          You have the vision. You know the market. You have customers waiting. But building the product? That's where most non-technical founders get stuck. Our <a href="/nearshore-development" class="text-cyan-600 hover:text-cyan-700 font-semibold">nearshore team</a> is here to help.
        </p>
        <p>
          <strong class="text-slate-900">We've helped 30+ startups go from idea to launch.</strong> We understand startup constraints—limited budget, tight timelines, and the need to validate before scaling. We won't over-engineer or build features you don't need yet. Our <a href="/react-development-agency" class="text-cyan-600 hover:text-cyan-700 font-semibold">React developers</a> build lean, scalable MVPs.
        </p>
        <p>
          Our job is to get your MVP into users' hands fast, with clean code that scales when you're ready. Several of our clients have gone on to raise funding—and we're still their development partner. Need <a href="/custom-web-development-services" class="text-cyan-600 hover:text-cyan-700 font-semibold">custom development</a> or <a href="/ecommerce-development-agency" class="text-cyan-600 hover:text-cyan-700 font-semibold">e-commerce</a>? We've got you covered.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
          How We Help <span class="text-orange-500">Startups</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((s) => (
          <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-200 hover:-translate-y-1 transition-all duration-300">
            <div class="text-4xl mb-4">{s.icon}</div>
            <h3 class="text-xl font-semibold text-slate-900 mb-3">{s.title}</h3>
            <p class="text-slate-600">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
          Our <span class="text-orange-500">Process</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {process.map((step) => (
          <div class="bg-white rounded-2xl shadow-lg p-8 border border-slate-200">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-white font-bold mb-6">
              {step.num}
            </div>
            <h3 class="text-xl font-semibold text-slate-900 mb-3">{step.title}</h3>
            <p class="text-slate-600">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
          Startup <span class="text-orange-500">FAQ</span>
        </h2>
      </div>
      <FAQ faqs={faqs} client:visible />
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-950 font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">
        Ready to <span class="text-orange-400">launch?</span>
      </h2>
      <p class="text-xl text-slate-300 mb-10">Free startup consultation. Let's discuss your vision.</p>
      <a href="/contact" class="inline-flex items-center justify-center gap-2 px-10 py-5 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white rounded-2xl font-semibold text-lg shadow-lg hover:shadow-xl transition-all duration-300">
        Let's Talk
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
      </a>
    </div>
  </section>
</Layout>
