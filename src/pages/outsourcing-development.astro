---
export const prerender = true;
/**
 * White-Label Development for Agencies Landing Page
 * Keywords: white label development, development partner for agencies,
 * white label web development, agency subcontracting, NDA development partner
 */

import Layout from "../layouts/Layout.astro";
import FaqAccordion from "../components/FaqAccordion.astro";
import Icon from "../components/icons/Icon.astro";

// SEO
const title =
  "White-Label Development for Agencies | Codebrand";
const description =
  "White-label development partner for agencies and studios. We build under your brand, sign an NDA, and let your team resell dev work. Get a free quote.";
const keywords =
  "white label development, development partner for agencies, white label web development, agency subcontracting, NDA development partner, dedicated development team, staff augmentation, outsource web development";

// Schema
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Codebrand Development Outsourcing",
  url: "https://www.codebrand.us/outsourcing-development",
  description: description,
};

// FAQ Data - Expanded for SEO
const faqs = [
  {
    question: "How does white-label development partnership work?",
    answer:
      "White-label partnership means we work as an invisible extension of your team. We sign NDAs, use your branding on deliverables, and can join client calls representing your company. Your clients never know we exist. We integrate with your existing workflow—using your project management tools, communication channels, and processes. Think of us as your back-office development department.",
  },
  {
    question: "What technologies and frameworks do you specialize in?",
    answer:
      "Our core expertise includes React, Next.js, Node.js, TypeScript, and modern CSS frameworks like Tailwind. We also work with Vue.js, Astro, PostgreSQL, MongoDB, Redis, and cloud platforms (AWS, Vercel, Netlify). For e-commerce, we specialize in Shopify (Liquid, Hydrogen) and headless commerce solutions. We adapt to your tech stack rather than forcing you to adapt to ours.",
  },
  {
    question: "How fast can you start on a new project?",
    answer:
      "For staff augmentation, we can typically onboard developers within 1-2 weeks. For new projects, we can start immediately after a brief discovery call—usually within 2-3 business days. Rush projects can begin same-day with our Rush tier. We maintain bench capacity specifically to handle urgent client needs without delays.",
  },
  {
    question: "What's your development process like?",
    answer:
      "We follow agile methodology with 1-2 week sprints depending on project needs. Each sprint includes planning, daily standups (async or sync based on your preference), code reviews, and demos. We use Git with pull requests, automated testing, and CI/CD pipelines. You get full visibility into progress through your preferred project management tool—Jira, Linear, Asana, or others.",
  },
  {
    question: "How does pricing work?",
    answer:
      "We offer transparent hourly pricing: Standard at $45/hr (48h response time), Priority at $65/hr (24h response, dedicated developer, daily standups), and Rush at $95/hr (same-day start, emergency support). Volume discounts are available for 40+ hours monthly. No hidden fees, no surprise charges. You only pay for actual development time, and we provide detailed time tracking.",
  },
  {
    question: "What about code quality and testing?",
    answer:
      "Code quality is non-negotiable. Every pull request goes through peer review before merging. We write unit tests for critical functionality and integration tests for APIs. Our code follows industry best practices—TypeScript for type safety, ESLint for consistency, and Prettier for formatting. You receive clean, documented, maintainable code that your team can easily work with.",
  },
  {
    question: "How do you handle communication across timezones?",
    answer:
      "We work US timezone hours (Central Time) for maximum overlap with North American clients. Communication happens through Slack, Microsoft Teams, or your preferred platform. We offer daily async standups via Loom/written updates, or live standups if you prefer. Response time is guaranteed within 4 hours during business hours, or faster with Priority/Rush tiers.",
  },
  {
    question: "Do you provide ongoing maintenance and support?",
    answer:
      "Yes, we offer ongoing maintenance packages for projects we build. This includes bug fixes, security updates, performance monitoring, and minor enhancements. For larger ongoing work, we recommend our Priority tier which includes a dedicated developer who learns your codebase deeply. We also provide documentation and knowledge transfer if you want to bring development in-house later.",
  },
  {
    question: "What if we're not satisfied with the work?",
    answer:
      "Your satisfaction is guaranteed. If deliverables don't meet the agreed specifications, we'll revise until they do at no extra cost. We keep clients satisfied by focusing on clear communication upfront and iterative delivery. For new clients, we recommend starting with a small pilot project to ensure we're a good fit before committing to larger engagements.",
  },
  {
    question: "How do we get started?",
    answer:
      "Getting started is simple: book a free 30-minute discovery call where we discuss your needs, technical requirements, and timeline. Within 24 hours, you'll receive a proposal with team recommendations and pricing. Once approved, we handle onboarding—tool access, codebase familiarization, and workflow integration. Most clients are up and running within a week.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};

// How white-label works — under your brand, NDA, managed delivery
const howItWorks = [
  {
    icon: "tag",
    title: "Built Under Your Brand",
    desc: "Deliverables ship with your name on them. We can join client calls as your team — the work is yours to present and resell.",
  },
  {
    icon: "shield-check",
    title: "NDA-Backed & Invisible",
    desc: "We sign an NDA before any detailed discussion and stay behind the scenes. Your clients never know a partner was involved.",
  },
  {
    icon: "compass",
    title: "Managed Delivery",
    desc: "A project manager runs sprints, standups, and reporting inside your tools — Jira, Linear, Slack — so you don't micromanage devs.",
  },
];

// Services agencies can resell
const services = [
  { icon: "monitor", title: "Web Applications", desc: "Full-stack apps and portals your clients need — built to scale, delivered under your brand." },
  { icon: "shopping-cart", title: "E-commerce & Shopify", desc: "Shopify (Liquid, Hydrogen) and headless commerce storefronts you can resell as your own." },
  { icon: "rocket", title: "Marketing & Landing Pages", desc: "Pixel-perfect campaign sites and landing pages, Figma-to-code, on your timeline." },
  { icon: "layers", title: "SaaS Platforms", desc: "Feature development and scaling for the SaaS products your clients are building." },
  { icon: "link", title: "APIs & Integrations", desc: "Documented REST and GraphQL APIs plus integrations with the tools your clients already run." },
  { icon: "users", title: "Staff Augmentation", desc: "Drop senior developers straight into your team when you need extra throughput fast." },
];

// Detailed process steps
const processDetailed = [
  {
    num: "01",
    title: "Discovery Call",
    desc: "30-minute call to understand your project requirements, technical needs, and timeline. We'll discuss your current challenges and how we can help.",
    details: ["Project scope assessment", "Tech stack discussion", "Timeline planning", "Team sizing"],
  },
  {
    num: "02",
    title: "Proposal & Match",
    desc: "Within 24 hours, receive a detailed proposal with recommended team composition, pricing, and project approach tailored to your needs.",
    details: ["Developer profiles", "Pricing breakdown", "Project milestones", "Risk assessment"],
  },
  {
    num: "03",
    title: "Onboarding",
    desc: "Quick setup process—tool access, codebase familiarization, workflow integration. We adapt to your processes, not the other way around.",
    details: ["Tool integration", "Codebase review", "Process alignment", "Communication setup"],
  },
  {
    num: "04",
    title: "Build & Deliver",
    desc: "Agile development with continuous delivery. Regular updates, transparent progress tracking, and iterative releases you can review.",
    details: ["Sprint planning", "Daily standups", "Code reviews", "Continuous deployment"],
  },
];

// Why agencies partner with us
const whyAgencies = [
  { icon: "eye", title: "An Invisible Extension", desc: "We stay behind your brand and behind your NDA. Clients see only your team delivering great work." },
  { icon: "star", title: "Senior Engineers", desc: "Developers who have shipped for Fortune 500s, YC startups, and agencies — brought to every project." },
  { icon: "clock", title: "US Timezone Overlap", desc: "We work Central Time for real-time overlap, daily standups, and same-day reviews with North America." },
  { icon: "shield-check", title: "Peer-Reviewed Quality", desc: "Every pull request goes through code review, with TypeScript, tests, and consistent standards." },
  { icon: "trending-up", title: "Scale On Demand", desc: "Add or reduce capacity instantly — ramp up for a big client release, ramp down between projects." },
  { icon: "key", title: "You Own The Code", desc: "Clean, documented, maintainable code with full source ownership — no lock-in, no dependency on us." },
];

// Stats
const stats = [
  { value: "5.0★", label: "Google Rating" },
  { value: "24h", label: "Avg. Response Time" },
  { value: "50", label: "Five-Star Reviews" },
  { value: "8+", label: "Years Experience" },
];

// Pricing
const pricing = [
  {
    title: "Standard",
    price: "$45",
    period: "/hour",
    desc: "Quality development work",
    features: ["48h response time", "Code reviews included", "Source code ownership", "Email support"],
    highlighted: false,
  },
  {
    title: "Priority",
    price: "$65",
    period: "/hour",
    desc: "Dedicated attention",
    features: ["24h response time", "Dedicated developer", "Daily standups", "Slack/direct support", "Priority queue"],
    highlighted: true,
  },
  {
    title: "Rush",
    price: "$95",
    period: "/hour",
    desc: "Urgent projects",
    features: ["Same-day start", "12h turnaround", "Direct communication", "Weekend availability", "Emergency support"],
    highlighted: false,
  },
];

// Technologies
const technologies = [
  "React", "Next.js", "Node.js", "TypeScript", "Tailwind", "PostgreSQL",
  "MongoDB", "Shopify", "AWS", "Vercel", "GraphQL", "REST APIs"
];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  canonicalOverride="https://www.codebrand.us/outsourcing-development"
  breadcrumbNames={{ "outsourcing-development": "White-Label Development" }}
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(serviceSchema)}
  />
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(faqSchema)}
  />

  <!-- Hero Section -->
  <section class="relative bg-slate-950 pt-32 sm:pt-36 lg:pt-28 pb-16 sm:pb-20 lg:pb-28 font-poppins overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center max-w-4xl mx-auto">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-500/10 text-cyan-400 text-sm font-semibold rounded-full mb-6">
          <span class="w-2 h-2 rounded-full bg-cyan-400 animate-pulse"></span>
          White-Label Development Partner
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          Your White-Label <span class="bg-gradient-to-r from-orange-500 to-orange-600 bg-clip-text text-transparent">Dev Team</span>
        </h1>
        <p class="text-xl sm:text-2xl text-slate-300 mb-10 leading-relaxed max-w-2xl mx-auto">
          We build under your brand for agencies and studios. Your clients see
          only you — NDA-backed senior developers, US timezone.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
          <a href="/contact" data-magnetic data-magnetic-strength="0.4" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white rounded-2xl font-semibold text-lg shadow-lg hover:shadow-xl transition-all duration-300">
            Start Building
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
          </a>
          <a href="#services" data-magnetic data-magnetic-strength="0.3" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 hover:border-white/40 text-white rounded-2xl font-semibold text-lg transition-all duration-300">
            What You Can Resell
          </a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {stats.map((stat) => (
            <div class="text-center p-6 bg-white/5 border border-white/10 rounded-2xl">
              <div class="text-3xl sm:text-4xl font-bold text-orange-500">{stat.value}</div>
              <div class="text-slate-400 text-sm mt-2">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- What White-Label Means / Intro -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-8" data-anim="heading">Development you can resell as your own</h2>
      <div class="prose prose-lg max-w-none text-slate-700 space-y-6" data-anim="fade" data-delay="0.1">
        <p>
          <strong class="text-slate-900">Codebrand is a white-label development partner for agencies, studios, and consultancies.</strong> You win the client and own the relationship; we do the engineering behind your brand. Deliverables ship with your name on them, we sign an NDA before anything sensitive changes hands, and your clients never know a partner was involved.
        </p>
        <p>
          We become <strong class="text-slate-900">an invisible extension of your team</strong> — working inside your project management tools, your communication channels, and your processes. A project manager runs the sprints and reporting so you get predictable delivery without managing developers one at a time. Because we operate as a time-zone-aligned <a href="/nearshore-development" class="text-cyan-600 hover:text-cyan-700 font-semibold">nearshore development company</a>, your team gets real-time overlap and daily collaboration.
        </p>
        <p>
          Every line goes through <strong class="text-slate-900">peer review</strong>, and you receive clean, documented code with <strong class="text-slate-900">full source ownership</strong> — no lock-in, no dependency on us. Start with a single pilot project to test the fit, then scale up when you're ready. No long-term contracts, no minimums, no risk.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mt-14" data-anim="fade" data-delay="0.15">
        {howItWorks.map((item) => (
          <div class="bg-slate-50 rounded-2xl p-6 border border-slate-200 hover:-translate-y-1 hover:border-cyan-200 transition-all duration-300">
            <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-cyan-50 border border-cyan-100 mb-4">
              <Icon name={item.icon} class="w-6 h-6 text-cyan-900" />
            </div>
            <h3 class="text-lg font-semibold text-slate-900 mb-2">{item.title}</h3>
            <p class="text-slate-600 text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Services You Can Resell -->
  <section id="services" class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-100 border border-cyan-200 rounded-full text-cyan-700 text-sm font-semibold mb-6">
          WHAT YOU CAN RESELL
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6" data-anim="heading">
          Services Under <span class="text-orange-500">Your Brand</span>
        </h2>
        <p class="text-xl text-slate-600">Sell the full stack of development work to your clients — we deliver it invisibly.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" data-anim="fade">
        {services.map((s) => (
          <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-200 hover:-translate-y-1 transition-all duration-300">
            <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-orange-50 border border-orange-100 mb-4">
              <Icon name={s.icon} class="w-6 h-6 text-orange-500" />
            </div>
            <h3 class="text-xl font-semibold text-slate-900 mb-3">{s.title}</h3>
            <p class="text-slate-600">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works / Process -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-orange-100 border border-orange-200 rounded-full text-orange-700 text-sm font-semibold mb-6">
          HOW IT WORKS
        </span>
        <h2 data-anim="heading" class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">From call to code in <span class="text-orange-500">a week</span></h2>
        <p class="text-xl text-slate-600 max-w-3xl mx-auto">A streamlined process that gets you from first contact to working code fast. Here's exactly what to expect.</p>
      </div>

      <div class="grid md:grid-cols-2 gap-6" data-anim="fade">
        {processDetailed.map((step) => (
          <div class="group bg-white rounded-2xl shadow-lg p-6 border border-slate-200 hover:border-orange-300 hover:shadow-xl transition-all duration-300">
            <div class="flex items-start gap-6">
              <div class="w-14 h-14 flex-shrink-0 rounded-2xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-white font-bold shadow-lg group-hover:scale-110 transition-transform duration-300">
                {step.num}
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-semibold text-slate-900 mb-3">{step.title}</h3>
                <p class="text-slate-600 mb-4 leading-relaxed">{step.desc}</p>
                <ul class="grid grid-cols-2 gap-2">
                  {step.details.map((detail) => (
                    <li class="flex items-center gap-2 text-sm text-slate-500">
                      <span class="w-1.5 h-1.5 rounded-full bg-orange-500"></span>
                      {detail}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Agencies Partner With Us -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-100 border border-cyan-200 rounded-full text-cyan-700 text-sm font-semibold mb-6">
          WHY CODEBRAND
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6" data-anim="heading">
          Why Agencies <span class="text-orange-500">Partner With Us</span>
        </h2>
        <p class="text-xl text-slate-600">Your development team, without the hiring, overhead, or the risk of clients finding out.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8" data-anim="fade">
        {whyAgencies.map((item) => (
          <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-200 hover:-translate-y-1 transition-all duration-300">
            <div class="w-12 h-12 flex items-center justify-center rounded-xl bg-cyan-50 border border-cyan-100 mb-4">
              <Icon name={item.icon} class="w-6 h-6 text-cyan-900" />
            </div>
            <h3 class="text-xl font-semibold text-slate-900 mb-3">{item.title}</h3>
            <p class="text-slate-600">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Pricing -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-100 border border-cyan-200 rounded-full text-cyan-700 text-sm font-semibold mb-6">
          PRICING
        </span>
        <h2 data-anim="heading" class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900">Simple, <span class="text-orange-500">transparent</span> hourly rates</h2>
        <p class="text-xl text-slate-600 max-w-2xl mx-auto mt-6">Pay only for actual development time, with detailed tracking. Volume discounts for 40+ hours monthly.</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6" data-anim="fade">
        {pricing.map((plan) => (
          <div class:list={[
            "relative rounded-2xl p-8 transition-all duration-300 hover:-translate-y-2",
            plan.highlighted
              ? "bg-slate-900 text-white shadow-2xl scale-105 z-10"
              : "bg-white border border-slate-200 hover:border-slate-300 hover:shadow-xl"
          ]}>
            {plan.highlighted && (
              <span class="absolute -top-4 left-1/2 -translate-x-1/2 bg-orange-500 text-white text-xs font-bold px-4 py-2 rounded-full shadow-lg">
                Most Popular
              </span>
            )}
            <h3 class={plan.highlighted ? "text-2xl font-semibold mb-2 text-white" : "text-2xl font-semibold mb-2 text-slate-900"}>{plan.title}</h3>
            <p class={plan.highlighted ? "text-sm mb-6 text-slate-300" : "text-sm mb-6 text-slate-600"}>{plan.desc}</p>
            <div class="mb-8">
              <span class={plan.highlighted ? "text-5xl font-bold text-white" : "text-5xl font-bold text-slate-900"}>{plan.price}</span>
              <span class={plan.highlighted ? "text-slate-400 text-lg" : "text-slate-500 text-lg"}>{plan.period}</span>
            </div>
            <ul class="space-y-4 mb-8">
              {plan.features.map((feature) => (
                <li class="flex items-center gap-3">
                  <svg class={plan.highlighted ? "w-5 h-5 text-teal-400 flex-shrink-0" : "w-5 h-5 text-teal-500 flex-shrink-0"} fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span class={plan.highlighted ? "text-slate-300" : "text-slate-600"}>{feature}</span>
                </li>
              ))}
            </ul>
            <a
              href="/contact"
              class={plan.highlighted
                ? "block w-full py-4 text-center font-bold rounded-2xl bg-gradient-to-r from-orange-500 to-orange-600 text-white hover:from-orange-600 hover:to-orange-700 shadow-lg transition-all duration-300"
                : "block w-full py-4 text-center font-bold rounded-2xl bg-slate-900 text-white hover:bg-slate-800 transition-all duration-300"
              }
            >
              Get Started
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tech Stack Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4" data-anim="heading">
        Technologies We <span class="text-orange-500">Master</span>
      </h2>
      <p class="text-slate-600 text-lg mt-4" data-anim="fade" data-delay="0.05">We adapt to your stack, not the other way around.</p>
      <div class="flex flex-wrap justify-center gap-3 mt-10" data-anim="fade" data-delay="0.1">
        {technologies.map((t) => (
          <span class="px-4 py-2 rounded-full border border-slate-200 bg-white text-slate-700 text-sm font-medium hover:border-orange-300 hover:text-orange-600 transition-all duration-300">{t}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6" data-anim="heading">
          White-Label <span class="text-orange-500">FAQ</span>
        </h2>
