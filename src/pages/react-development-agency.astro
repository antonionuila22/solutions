---
/**
 * React Development Agency Landing Page
 * Keywords: react development agency, react developers, react js development
 */

import Layout from "../layouts/Layout.astro";
import FaqAccordion from "../components/FaqAccordion.astro";

const title = "React Development Agency | Codebrand";
const description = "Senior React engineers. Custom React apps, Next.js development, and React Native mobile apps. US timezone, 60% cost savings.";
const keywords = "react development agency, react developers for hire, react js development company, react development services, next js development agency, react native development, react consulting, react experts, senior react developers";

const faqs = [
  {
    question: "Why should I choose React for my project?",
    answer: "React is the most popular frontend framework, used by Meta, Netflix, Airbnb, and thousands of companies. Benefits include: reusable component architecture, excellent performance with virtual DOM, massive ecosystem of libraries, strong community support, and easy testing. It's ideal for complex UIs, single-page applications, and projects that need to scale."
  },
  {
    question: "Do you work with Next.js?",
    answer: "Yes, Next.js is our primary React framework. It adds server-side rendering, static site generation, API routes, and optimized performance out of the box. We use Next.js for most production React projects because it provides better SEO, faster page loads, and a superior developer experience compared to vanilla React."
  },
  {
    question: "Can you build mobile apps with React?",
    answer: "Yes, we build cross-platform mobile apps using React Native. One codebase runs on both iOS and Android, reducing development time by 40-50% compared to native development. React Native apps are performant and indistinguishable from native apps for most use cases."
  },
  {
    question: "What's your React development process?",
    answer: "We follow agile methodology with 1-2 week sprints. Each sprint includes planning, development, code review, and demo. We use TypeScript for type safety, write comprehensive tests, and follow React best practices (hooks, functional components, proper state management). You see working code every sprint."
  },
  {
    question: "How much do React developers cost?",
    answer: "Our senior React developers work at $45-95/hour, depending on project tier. This is 50-60% less than US agencies charging $150-200/hour for equivalent experience. You get the same quality—5+ years React experience, TypeScript expertise, testing skills—at significantly lower rates."
  },
  {
    question: "Can you work with our existing React codebase?",
    answer: "Absolutely. We regularly join existing projects for feature development, bug fixes, performance optimization, or team augmentation. We'll review your codebase, understand your patterns, and integrate seamlessly with your workflow and coding standards."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer }
  }))
};

const services = [
  { icon: "⚛️", title: "React Web Apps", desc: "Complex single-page applications with modern React patterns" },
  { icon: "▲", title: "Next.js Development", desc: "Server-rendered React apps with optimal SEO and performance" },
  { icon: "📱", title: "React Native", desc: "Cross-platform mobile apps for iOS and Android" },
  { icon: "🔄", title: "Migration to React", desc: "Modernize legacy apps by migrating to React" },
  { icon: "🧪", title: "Testing & QA", desc: "Comprehensive testing with Jest, React Testing Library, Cypress" },
  { icon: "🚀", title: "Performance Tuning", desc: "Optimize existing React apps for speed and efficiency" }
];

const stats = [
  { value: "100+", label: "React Projects" },
  { value: "5+", label: "Years React Exp" },
  { value: "TypeScript", label: "First" },
  { value: "CST", label: "Timezone" }
];

const stack = ["React 18", "Next.js 14", "TypeScript", "React Native", "Redux/Zustand", "TanStack Query", "Tailwind CSS", "Jest", "Cypress"];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  canonicalOverride="https://www.codebrand.us/react-development-agency"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero Section -->
  <section class="relative bg-slate-950 pt-32 sm:pt-36 lg:pt-28 pb-16 sm:pb-20 lg:pb-28 font-poppins overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center max-w-4xl mx-auto">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-orange-500/10 text-orange-400 text-sm font-semibold rounded-full mb-6">
          <span class="w-2 h-2 rounded-full bg-orange-400 animate-pulse"></span>
          React Development Agency
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          React <span class="bg-gradient-to-r from-orange-500 to-orange-600 bg-clip-text text-transparent">Development</span>
        </h1>
        <p class="text-xl sm:text-2xl text-slate-300 mb-10 leading-relaxed max-w-2xl mx-auto">
          Senior React developers for your next project.
          React, Next.js, React Native. US timezone.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white rounded-2xl font-semibold text-lg shadow-lg hover:shadow-xl transition-all duration-300">
            Hire React Devs
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
          </a>
          <a href="#services" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 hover:border-white/40 text-white rounded-2xl font-semibold text-lg transition-all duration-300">
            Our Services
          </a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {stats.map((stat) => (
            <div class="text-center p-6 bg-white/5 border border-white/10 rounded-2xl">
              <div class="text-3xl sm:text-4xl font-bold text-orange-500">{stat.value}</div>
              <div class="text-slate-400 text-sm mt-2">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-8">Expert React development</h2>
      <div class="prose prose-lg max-w-none text-slate-700 space-y-6">
        <p>
          React powers some of the world's most sophisticated web applications. But building with React effectively requires deep expertise—<strong class="text-slate-900">component architecture, state management, performance optimization, and testing</strong>. Our <a href="/nearshore-development" class="text-cyan-600 hover:text-cyan-700 font-semibold">nearshore team</a> specializes in complex React projects.
        </p>
        <p>
          Our React developers have <strong class="text-slate-900">5+ years of production experience</strong>. We've built dashboards, SaaS platforms, <a href="/ecommerce-development-agency" class="text-cyan-600 hover:text-cyan-700 font-semibold">e-commerce stores</a>, and mobile apps. We write TypeScript by default, test thoroughly, and follow best practices.
        </p>
        <p>
          Whether you need a <strong class="text-slate-900">new React application, Next.js website, React Native mobile app</strong>, or help with an existing codebase, we deliver production-ready code at <strong class="text-slate-900">60% less than US agency rates</strong>. <a href="/hire-remote-developers" class="text-cyan-600 hover:text-cyan-700 font-semibold">Hire our developers</a> or explore our <a href="/custom-web-development-services" class="text-cyan-600 hover:text-cyan-700 font-semibold">custom development services</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
          React <span class="text-orange-500">Services</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((s) => (
          <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-200 hover:-translate-y-1 transition-all duration-300">
            <div class="text-4xl mb-4">{s.icon}</div>
            <h3 class="text-xl font-semibold text-slate-900 mb-3">{s.title}</h3>
            <p class="text-slate-600">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tech Stack Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4">
        Our React <span class="text-orange-500">Stack</span>
      </h2>
      <div class="flex flex-wrap justify-center gap-3 mt-10">
        {stack.map((t) => (
          <span class="px-4 py-2 rounded-full border border-slate-200 bg-slate-50 text-slate-700 text-sm font-medium hover:border-orange-300 hover:text-orange-600 transition-all duration-300">{t}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
          React Development <span class="text-orange-500">FAQ</span>
        </h2>
      </div>
      <FaqAccordion faqs={faqs} />
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-950 font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">
        Need React <span class="text-orange-400">developers?</span>
      </h2>
      <p class="text-xl text-slate-300 mb-10">Free consultation. Start building in days.</p>
      <a href="/contact" class="inline-flex items-center justify-center gap-2 px-10 py-5 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white rounded-2xl font-semibold text-lg shadow-lg hover:shadow-xl transition-all duration-300">
        Get Started
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
      </a>
    </div>
  </section>
</Layout>
