---
/**
 * Nearshore Development Services Page
 * Premium landing page targeting US companies looking for nearshore development partners
 * Keywords: nearshore software development, nearshore development company, LATAM development team
 */

import Layout from "../layouts/Layout.astro";
import FAQ from "../components/FAQ.tsx";

// SEO
const title = "Nearshore Development | LATAM Team | Codebrand";
const description = "Nearshore software development in your timezone. Senior engineers, English-fluent, 60% cost savings. React, Node.js, TypeScript.";
const keywords = "nearshore software development, nearshore development company, nearshore development team, LATAM development team, nearshore outsourcing, nearshore vs offshore, nearshore software development services, US timezone developers, Central America development team, nearshore web development, nearshore app development, hire nearshore developers, nearshore software agency, nearshore development partner, software development outsourcing LATAM";

// Schema
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Codebrand Nearshore Development",
  url: "https://codebrand.us/nearshore-development",
  description: description,
  areaServed: {
    "@type": "Country",
    name: "United States"
  },
  provider: {
    "@type": "Organization",
    name: "Codebrand",
    url: "https://codebrand.us"
  }
};

// FAQ Data for SEO
const faqs = [
  {
    question: "What is nearshore software development?",
    answer: "Nearshore software development means partnering with a development team in a nearby country with similar timezones. For US companies, this typically means working with teams in Latin America (LATAM). Unlike offshore development (India, Eastern Europe), nearshore teams work during your business hours, enabling real-time collaboration, faster communication, and cultural alignment. You get the cost benefits of outsourcing without the timezone and communication challenges."
  },
  {
    question: "Why choose nearshore over offshore development?",
    answer: "Nearshore development offers three key advantages over offshore: (1) Timezone alignment—our team works US business hours (Central Time), so you get real-time collaboration instead of waiting 12+ hours for responses. (2) Cultural fit—Latin American business culture aligns closely with the US, making communication more natural and reducing misunderstandings. (3) Travel accessibility—if you ever need to meet in person, it's a short flight vs. 20+ hours to Asia. The cost savings are comparable to offshore, but the workflow is significantly smoother."
  },
  {
    question: "What timezone does your nearshore team work in?",
    answer: "Our team works US Central Time (CST/CDT), which overlaps with all US business hours. We're available 8 AM - 6 PM Central, which means full overlap with East Coast (9 AM - 7 PM ET) and significant overlap with West Coast (6 AM - 4 PM PT). This enables real-time Slack communication, live standups, and same-day code reviews—something impossible with offshore teams in drastically different timezones."
  },
  {
    question: "How much can I save with nearshore development?",
    answer: "Most clients save 50-60% compared to hiring US-based developers. A senior US developer costs $150,000-$200,000/year fully loaded (salary + benefits + equipment + overhead). Our nearshore rates of $45-95/hour translate to significant savings while maintaining the same quality standards. You also avoid recruitment costs, onboarding time, and the risk of a bad hire. Scale up or down as needed without long-term commitments."
  },
  {
    question: "Is your team fluent in English?",
    answer: "Yes, all our developers are fluent in English—both written and spoken. We communicate daily with US clients via Slack, Zoom, and written documentation. Our team members have worked with US companies for years and understand American business communication styles. No language barriers, no lost-in-translation moments. You'll feel like you're working with a local team."
  },
  {
    question: "What technologies does your nearshore team specialize in?",
    answer: "We specialize in modern web technologies: React, Next.js, Node.js, TypeScript, and Tailwind CSS for frontend and full-stack development. For databases, we work with PostgreSQL, MongoDB, and Redis. We're experienced with AWS, Vercel, and Netlify for deployment. For e-commerce, we build with Shopify (Liquid, Hydrogen) and headless commerce solutions. We adapt to your existing tech stack rather than forcing you to change."
  },
  {
    question: "How do you ensure code quality in a nearshore setup?",
    answer: "Code quality is non-negotiable. Every pull request goes through peer review before merging. We use TypeScript for type safety, ESLint for consistency, and Prettier for formatting. We write unit tests for critical functionality and integration tests for APIs. Our CI/CD pipelines catch issues before they reach production. You receive clean, documented, maintainable code that your team can easily work with—the same standards as any top US agency."
  },
  {
    question: "How fast can your nearshore team start on a project?",
    answer: "We can typically start within 1-2 weeks for most projects. For urgent needs, we have Rush availability that can begin same-day. Our process: (1) 30-minute discovery call to understand your needs, (2) proposal within 24 hours, (3) onboarding and tool setup within 2-3 days. We maintain bench capacity specifically to handle new client needs without long wait times."
  },
  {
    question: "What's the difference between nearshore and onshore development?",
    answer: "Onshore means working with developers in your same country (US developers for US companies). Nearshore means nearby countries with similar timezones (LATAM for US). The main differences: (1) Cost—nearshore is typically 50-60% less expensive than onshore. (2) Talent pool—nearshore gives you access to a larger pool of skilled developers. (3) Scalability—easier to scale teams up/down with nearshore. Quality can be identical when you work with the right partner. We deliver the same standards as US agencies at a fraction of the cost."
  },
  {
    question: "Do you sign NDAs and protect intellectual property?",
    answer: "Absolutely. We sign NDAs before any project discussion and our contracts include strong IP protections. All code we write belongs to you—full ownership, no strings attached. We can work under your company's standard agreements if preferred. We also follow security best practices: encrypted communications, secure code repositories, and access controls. Your IP is protected."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer }
  }))
};

// Comparison: Nearshore vs Offshore vs Onshore
const comparison = [
  {
    aspect: "Timezone Overlap",
    nearshore: "Full overlap with US business hours (8+ hours daily)",
    offshore: "Minimal overlap (1-3 hours, often at odd hours)",
    onshore: "Full overlap (same timezone)"
  },
  {
    aspect: "Communication",
    nearshore: "Real-time Slack/video, same-day responses",
    offshore: "Async mostly, 12-24 hour response cycles",
    onshore: "Real-time, immediate responses"
  },
  {
    aspect: "Cost (Senior Dev)",
    nearshore: "$45-65/hour (~$80-115k/year)",
    offshore: "$25-45/hour (~$45-80k/year)",
    onshore: "$100-150/hour (~$180-270k/year)"
  },
  {
    aspect: "Cultural Alignment",
    nearshore: "High—similar business culture to US",
    offshore: "Variable—different work culture, holidays, communication styles",
    onshore: "Identical—same culture"
  },
  {
    aspect: "Travel Time",
    nearshore: "3-5 hour flight from most US cities",
    offshore: "15-24 hour journey",
    onshore: "Domestic travel"
  },
  {
    aspect: "English Fluency",
    nearshore: "Fluent—daily business English",
    offshore: "Varies widely by region and individual",
    onshore: "Native speakers"
  }
];

// Process steps
const processDetailed = [
  {
    num: "01",
    title: "Discovery Call",
    desc: "30-minute call to understand your project, technical requirements, and timeline. We'll discuss your challenges and how nearshore development can help.",
    details: ["Project scope", "Tech stack review", "Timeline planning", "Team sizing"]
  },
  {
    num: "02",
    title: "Proposal & Match",
    desc: "Within 24 hours, receive a detailed proposal with developer profiles, pricing, and project approach tailored to your specific needs.",
    details: ["Developer profiles", "Detailed pricing", "Milestone planning", "Communication plan"]
  },
  {
    num: "03",
    title: "Onboarding",
    desc: "Quick setup—tool access, codebase review, workflow integration. We adapt to your processes, project management tools, and communication style.",
    details: ["Tool integration", "Codebase review", "Process alignment", "Slack/Teams setup"]
  },
  {
    num: "04",
    title: "Build & Deliver",
    desc: "Agile development with daily standups, continuous delivery, and transparent progress. You have full visibility and can adjust priorities anytime.",
    details: ["Daily standups", "Sprint reviews", "Code reviews", "Continuous deployment"]
  }
];

// Stats
const stats = [
  { value: "CST", label: "US Timezone" },
  { value: "60%", label: "Cost Savings" },
  { value: "24h", label: "Response Time" },
  { value: "5+", label: "Years Experience" }
];

// Benefits of Nearshore
const benefits = [
  {
    icon: "🕐",
    title: "Same Timezone",
    desc: "Work US Central Time hours. Real-time collaboration, live standups, same-day code reviews."
  },
  {
    icon: "💬",
    title: "English Fluent",
    desc: "Native-level English communication. No language barriers or misunderstandings."
  },
  {
    icon: "💰",
    title: "60% Cost Savings",
    desc: "Senior developer quality at a fraction of US rates. No hidden fees."
  },
  {
    icon: "⚡",
    title: "Fast Delivery",
    desc: "2-3 week average project turnaround. Rush options available."
  },
  {
    icon: "👨‍💻",
    title: "Senior Engineers",
    desc: "5+ years experience. React, Node.js, TypeScript experts."
  },
  {
    icon: "🔄",
    title: "Flexible Scaling",
    desc: "Scale team up or down instantly based on project needs."
  }
];

// Showcase project types
const showcase = [
  { title: "Web Applications", tag: "Applications" },
  { title: "E-commerce Platforms", tag: "Commerce" },
  { title: "SaaS Products", tag: "SaaS" },
  { title: "Mobile Apps", tag: "Mobile" }
];

// Pricing
const pricing = [
  {
    title: "Standard",
    price: "$45",
    period: "/hour",
    desc: "Quality nearshore development",
    features: ["48h response time", "Code reviews included", "Full source code ownership", "Email support"],
    highlighted: false
  },
  {
    title: "Priority",
    price: "$65",
    period: "/hour",
    desc: "Dedicated attention",
    features: ["24h response time", "Dedicated developer", "Daily standups", "Slack direct access", "Priority queue"],
    highlighted: true
  },
  {
    title: "Rush",
    price: "$95",
    period: "/hour",
    desc: "Urgent projects",
    features: ["Same-day start", "12h turnaround", "Direct communication", "Weekend availability", "Emergency support"],
    highlighted: false
  }
];

// Technologies
const technologies = [
  "React", "Next.js", "Node.js", "TypeScript", "Tailwind CSS", "PostgreSQL",
  "MongoDB", "AWS", "Vercel", "GraphQL", "REST APIs", "Shopify"
];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  canonicalOverride="https://codebrand.us/nearshore-development"
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(serviceSchema)}
  />
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(faqSchema)}
  />

  <!-- ==================== HERO ==================== -->
  <section class="relative min-h-[90vh] flex items-center py-16 sm:py-20 lg:py-28 overflow-hidden bg-slate-950">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(6, 182, 212, 0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(6, 182, 212, 0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-orange-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
      <div class="max-w-4xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-slate-800/80 border border-cyan-500/30 rounded-full mb-8 backdrop-blur-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
          </span>
          <span class="text-sm font-medium text-cyan-400">Nearshore Development Partner</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight font-poppins">
          Nearshore <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-amber-500">Development</span>
        </h1>

        <p class="text-lg sm:text-xl text-slate-300 leading-relaxed mb-8 max-w-2xl">
          US timezone. English fluent. 60% cost savings.<br class="hidden md:block" />
          Senior LATAM developers for your next project.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 mb-16">
          <a
            href="/contact"
            class="group inline-flex items-center gap-2 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white font-bold px-8 py-4 rounded-2xl transition-all duration-300 shadow-lg shadow-orange-500/25 hover:shadow-orange-500/40 hover:-translate-y-1"
          >
            Get Started
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a
            href="#comparison"
            class="inline-flex items-center gap-2 px-8 py-4 bg-slate-800/80 hover:bg-slate-700/80 text-white font-semibold rounded-2xl border border-slate-700 hover:border-slate-600 transition-all duration-300"
          >
            Compare Options
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {stats.map((stat) => (
            <div class="text-center p-6 bg-white/5 border border-white/10 rounded-2xl">
              <div class="text-3xl sm:text-4xl font-bold text-orange-500">{stat.value}</div>
              <div class="text-slate-400 text-sm mt-2">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== TECH MARQUEE ==================== -->
  <div class="bg-slate-900 border-y border-slate-800 py-6 overflow-hidden">
    <div class="flex items-center gap-8 justify-center flex-wrap max-w-7xl mx-auto px-4">
      {technologies.map((tech) => (
        <span class="text-slate-500 text-sm font-medium whitespace-nowrap">{tech}</span>
      ))}
    </div>
  </div>

  <!-- ==================== WHAT IS NEARSHORE ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-100 border border-cyan-200 rounded-full text-cyan-700 text-sm font-semibold mb-6">
        WHAT IS NEARSHORE?
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-8">The best of both worlds</h2>
      <div class="prose prose-lg max-w-none text-slate-600 space-y-6">
        <p>
          <strong class="text-slate-900">Nearshore software development</strong> means partnering with a development team in a nearby country with similar timezones. For US companies, this typically means working with skilled teams in Latin America (LATAM)—countries like Honduras, Mexico, Costa Rica, and Colombia.
        </p>
        <p>
          Unlike <strong class="text-slate-900">offshore development</strong> (India, Philippines, Eastern Europe) where timezone differences create 12-24 hour communication delays, nearshore teams work during your business hours. You get real-time collaboration, live code reviews, and immediate responses—just like working with a local team. Learn more about <a href="/outsource-web-development" class="text-cyan-600 hover:text-cyan-700 font-semibold">outsourcing web development</a> options.
        </p>
        <p>
          The cost advantage is significant: <strong class="text-slate-900">save 50-60% compared to US rates</strong> while maintaining the same quality standards. Senior developers with 5+ years of experience, fluent English, and expertise in modern technologies like <a href="/react-development-agency" class="text-cyan-600 hover:text-cyan-700 font-semibold">React</a>, Node.js, and TypeScript. Whether you need <a href="/custom-web-development-services" class="text-cyan-600 hover:text-cyan-700 font-semibold">custom web development</a> or <a href="/ecommerce-development-agency" class="text-cyan-600 hover:text-cyan-700 font-semibold">e-commerce solutions</a>, our team delivers.
        </p>
        <p>
          <strong class="text-slate-900">Why companies choose nearshore:</strong> Real-time collaboration, cultural alignment, cost savings, and no timezone headaches. You get offshore prices with onshore workflow. Ready to <a href="/hire-remote-developers" class="text-cyan-600 hover:text-cyan-700 font-semibold">hire remote developers</a>? We're here to help.
        </p>
      </div>
    </div>
  </section>

  <!-- ==================== BENEFITS ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-orange-100 border border-orange-200 rounded-full text-orange-700 text-sm font-semibold mb-6">
          WHY NEARSHORE
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900">The Codebrand <span class="text-orange-500">advantage</span></h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map((benefit) => (
          <div class="group bg-white hover:bg-white rounded-2xl shadow-lg hover:shadow-xl p-6 border border-slate-200 hover:border-orange-300 transition-all duration-300 hover:-translate-y-1">
            <div class="w-14 h-14 bg-orange-500 rounded-2xl flex items-center justify-center mb-5 shadow-lg group-hover:scale-110 transition-transform duration-300">
              <span class="text-2xl">{benefit.icon}</span>
            </div>
            <h3 class="text-xl font-semibold text-slate-900 mb-3">{benefit.title}</h3>
            <p class="text-slate-600 leading-relaxed">{benefit.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== COMPARISON TABLE ==================== -->
  <section id="comparison" class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-100 border border-cyan-200 rounded-full text-cyan-700 text-sm font-semibold mb-6">
          COMPARE OPTIONS
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">Nearshore vs Offshore vs Onshore</h2>
        <p class="text-xl text-slate-600 max-w-3xl mx-auto">
          See how nearshore development compares to other outsourcing options. The data speaks for itself.
        </p>
      </div>

      <!-- Comparison Table -->
      <div class="mt-16 overflow-x-auto">
        <table class="w-full min-w-[800px]">
          <thead>
            <tr class="border-b-2 border-slate-200">
              <th class="text-left py-4 px-4 text-slate-500 font-medium">Aspect</th>
              <th class="text-left py-4 px-4 text-orange-600 font-semibold bg-orange-50 rounded-t-lg">
                <span class="flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-orange-500"></span>
                  Nearshore (LATAM)
                </span>
              </th>
              <th class="text-left py-4 px-4 text-slate-500 font-medium">Offshore (Asia/Europe)</th>
              <th class="text-left py-4 px-4 text-slate-500 font-medium">Onshore (US)</th>
            </tr>
          </thead>
          <tbody>
            {comparison.map((row) => (
              <tr class="border-b border-slate-100 hover:bg-slate-50 transition-colors duration-300">
                <td class="py-5 px-4 text-slate-900 font-medium">{row.aspect}</td>
                <td class="py-5 px-4 text-orange-700 text-sm font-medium bg-orange-50/50">{row.nearshore}</td>
                <td class="py-5 px-4 text-slate-500 text-sm">{row.offshore}</td>
                <td class="py-5 px-4 text-slate-500 text-sm">{row.onshore}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Summary boxes -->
      <div class="grid md:grid-cols-3 gap-6 mt-12">
        <div class="bg-slate-50 rounded-2xl border border-slate-100 p-6 text-center">
          <div class="text-3xl font-bold text-orange-500 mb-2">8+ hrs</div>
          <p class="text-slate-600 text-sm">Daily timezone overlap with US clients</p>
        </div>
        <div class="bg-slate-50 rounded-2xl border border-slate-100 p-6 text-center">
          <div class="text-3xl font-bold text-orange-500 mb-2">60%</div>
          <p class="text-slate-600 text-sm">Cost savings vs US development rates</p>
        </div>
        <div class="bg-slate-50 rounded-2xl border border-slate-100 p-6 text-center">
          <div class="text-3xl font-bold text-orange-500 mb-2">3-5 hrs</div>
          <p class="text-slate-600 text-sm">Flight time from most US cities</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== PROJECT TYPES ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-950 font-poppins relative overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(6, 182, 212, 0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(6, 182, 212, 0.1) 1px, transparent 1px); background-size: 80px 80px;"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
        <div>
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-500/10 border border-cyan-500/20 rounded-full text-cyan-400 text-sm font-semibold mb-6">
            WHAT WE BUILD
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white">
            Code that <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-400">scales</span>
          </h2>
        </div>
        <p class="text-slate-400 max-w-sm">
          From MVPs to enterprise platforms—nearshore development that drives growth.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {showcase.map((item, i) => (
          <div class="group bg-slate-900/60 backdrop-blur-sm p-8 rounded-2xl border border-slate-800 hover:border-cyan-500/50 transition-all duration-300 hover:-translate-y-1">
            <div class="flex items-start gap-5">
              <div class="flex-shrink-0 w-14 h-14 bg-cyan-500 rounded-2xl flex items-center justify-center text-white font-bold text-xl shadow-lg group-hover:scale-110 transition-transform duration-300">
                {String(i + 1).padStart(2, '0')}
              </div>
              <div>
                <span class="text-xs font-semibold text-cyan-400 uppercase tracking-wider">{item.tag}</span>
                <h3 class="text-xl font-semibold text-white mt-1 group-hover:text-cyan-400 transition-colors duration-300">{item.title}</h3>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== HOW IT WORKS ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-orange-100 border border-orange-200 rounded-full text-orange-700 text-sm font-semibold mb-6">
          HOW IT WORKS
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">From call to <span class="text-orange-500">code</span></h2>
        <p class="text-xl text-slate-600 max-w-3xl mx-auto">
          Our streamlined process gets you from first contact to working code fast.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {processDetailed.map((step) => (
          <div class="group bg-white rounded-2xl shadow-lg p-6 border border-slate-200 hover:border-orange-300 hover:shadow-xl transition-all duration-300">
            <div class="flex items-start gap-6">
              <div class="w-14 h-14 flex-shrink-0 rounded-2xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-white font-bold shadow-lg group-hover:scale-110 transition-transform duration-300">
                {step.num}
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-semibold text-slate-900 mb-3">{step.title}</h3>
                <p class="text-slate-600 mb-4 leading-relaxed">{step.desc}</p>
                <ul class="grid grid-cols-2 gap-2">
                  {step.details.map((detail) => (
                    <li class="flex items-center gap-2 text-sm text-slate-500">
                      <span class="w-1.5 h-1.5 rounded-full bg-orange-500"></span>
                      {detail}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== PRICING ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-100 border border-cyan-200 rounded-full text-cyan-700 text-sm font-semibold mb-6">
          PRICING
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900">Simple, <span class="text-orange-500">transparent</span></h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {pricing.map((plan) => (
          <div class:list={[
            "relative rounded-2xl p-8 transition-all duration-300 hover:-translate-y-2",
            plan.highlighted
              ? "bg-slate-900 text-white shadow-2xl scale-105 z-10"
              : "bg-white border border-slate-200 hover:border-slate-300 hover:shadow-xl"
          ]}>
            {plan.highlighted && (
              <span class="absolute -top-4 left-1/2 -translate-x-1/2 bg-orange-500 text-white text-xs font-bold px-4 py-2 rounded-full shadow-lg">
                Most Popular
              </span>
            )}
            <h3 class={plan.highlighted ? "text-2xl font-semibold mb-2 text-white" : "text-2xl font-semibold mb-2 text-slate-900"}>{plan.title}</h3>
            <p class={plan.highlighted ? "text-sm mb-6 text-slate-300" : "text-sm mb-6 text-slate-600"}>{plan.desc}</p>
            <div class="mb-8">
              <span class={plan.highlighted ? "text-5xl font-bold text-white" : "text-5xl font-bold text-slate-900"}>{plan.price}</span>
              <span class={plan.highlighted ? "text-slate-400 text-lg" : "text-slate-500 text-lg"}>{plan.period}</span>
            </div>
            <ul class="space-y-4 mb-8">
              {plan.features.map((feature) => (
                <li class="flex items-center gap-3">
                  <svg class={plan.highlighted ? "w-5 h-5 text-green-400 flex-shrink-0" : "w-5 h-5 text-green-500 flex-shrink-0"} fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span class={plan.highlighted ? "text-slate-300" : "text-slate-600"}>{feature}</span>
                </li>
              ))}
            </ul>
            <a
              href="/contact"
              class={plan.highlighted
                ? "block w-full py-4 text-center font-bold rounded-2xl bg-gradient-to-r from-orange-500 to-orange-600 text-white hover:from-orange-600 hover:to-orange-700 shadow-lg transition-all duration-300"
                : "block w-full py-4 text-center font-bold rounded-2xl bg-slate-900 text-white hover:bg-slate-800 transition-all duration-300"
              }
            >
              Get Started
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== TECHNOLOGIES ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-flex items-center gap-2 px-4 py-2 bg-slate-100 border border-slate-200 rounded-full text-slate-700 text-sm font-semibold mb-6">
        TECH STACK
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4">Technologies we <span class="text-orange-500">master</span></h2>
      <p class="text-slate-600 text-lg mb-10">We adapt to your stack, not the other way around.</p>
      <div class="flex flex-wrap justify-center gap-3">
        {technologies.map((tech) => (
          <span class="px-4 py-2 rounded-full border border-slate-200 text-slate-600 text-sm font-medium hover:border-orange-300 hover:text-orange-600 transition-all duration-300">
            {tech}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FAQ ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-slate-200 border border-slate-300 rounded-full text-slate-700 text-sm font-semibold mb-6">
          FAQ
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4">Common <span class="text-orange-500">Questions</span></h2>
        <p class="text-slate-600 text-lg">Can't find what you're looking for? <a href="/contact" class="text-orange-500 hover:text-orange-600 font-semibold">Contact us</a> and we'll get back to you within 24 hours.</p>
      </div>
      <div>
        <FAQ faqs={faqs} client:visible />
      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 relative overflow-hidden">
    <div class="absolute inset-0 bg-slate-950">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(6, 182, 212, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(6, 182, 212, 0.05) 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-r from-orange-500/20 via-amber-500/20 to-yellow-500/20 rounded-full blur-3xl"></div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative">
        <div class="absolute -inset-1 bg-gradient-to-r from-orange-500 via-amber-500 to-yellow-500 rounded-3xl blur-xl opacity-30"></div>
        <div class="relative bg-gradient-to-br from-orange-500 via-amber-500 to-yellow-500 rounded-3xl p-12 lg:p-16 text-center overflow-hidden">
          <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>
          <div class="relative z-10">
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight font-poppins">
              Ready for nearshore?
            </h2>
            <p class="text-lg lg:text-xl text-white/90 mb-10 max-w-xl mx-auto">
              Free 30-min consultation. Discover how nearshore development can transform your business.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="/contact"
                class="group inline-flex items-center justify-center gap-3 px-10 py-5 bg-white text-orange-600 rounded-2xl font-bold text-lg hover:bg-slate-900 hover:text-white transform hover:-translate-y-1 transition-all duration-300 shadow-2xl"
              >
                Book a Call
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
