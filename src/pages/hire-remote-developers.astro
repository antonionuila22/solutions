---
/**
 * Hire Remote Developers Landing Page
 * Keywords: hire remote developers, remote development team, offshore developers
 */

import Layout from "../layouts/Layout.astro";
import FAQ from "../components/FAQ.tsx";

const title = "Hire Remote Developers | Codebrand";
const description = "Hire senior remote developers. US timezone, English fluent. React, Node.js, TypeScript. Staff augmentation and dedicated teams.";
const keywords = "hire remote developers, remote development team, hire offshore developers, staff augmentation, dedicated development team, remote software developers, hire developers, remote engineering team, outsource developers";

const faqs = [
  {
    question: "How does hiring remote developers work?",
    answer: "We offer two models: (1) Staff augmentation—our developers join your existing team, use your tools, and work under your direction. (2) Dedicated team—we provide a complete team that works on your project with our project management. Both models include developers who work your timezone hours with direct communication access."
  },
  {
    question: "What skills do your remote developers have?",
    answer: "Our developers are full-stack engineers with expertise in React, Next.js, Node.js, TypeScript, and modern databases (PostgreSQL, MongoDB). Most have 5+ years of experience and have worked with US companies. We also have specialists in mobile development (React Native), DevOps, and e-commerce (Shopify)."
  },
  {
    question: "What timezone do your developers work?",
    answer: "Our team works US Central Time (CST/CDT) hours, providing full overlap with US East Coast and significant overlap with West Coast. This enables real-time collaboration through Slack, video calls, and instant code reviews—unlike offshore teams with 12-hour delays."
  },
  {
    question: "How much does it cost to hire remote developers?",
    answer: "Our rates range from $45-95/hour depending on seniority and engagement type. This represents 50-60% savings compared to US developer rates of $100-200/hour. For dedicated monthly engagements, we offer discounted rates. You pay only for productive work hours with detailed time tracking."
  },
  {
    question: "How quickly can developers start?",
    answer: "For staff augmentation, we can typically onboard developers within 1-2 weeks. We have pre-vetted developers ready to go, so there's no lengthy recruitment process. For dedicated teams, we can assemble a team within 2-3 weeks depending on skill requirements."
  },
  {
    question: "How do you ensure quality and communication?",
    answer: "Quality: All code goes through peer review, we use TypeScript for type safety, and we follow testing best practices. Communication: Direct Slack access to developers, daily standups (async or live), and weekly progress reports. You have full visibility into work through your preferred project management tool."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer }
  }))
};

const benefits = [
  { icon: "🕐", title: "US Timezone", desc: "Work Central Time hours for real-time collaboration" },
  { icon: "💬", title: "English Fluent", desc: "Clear communication, no language barriers" },
  { icon: "💰", title: "60% Cost Savings", desc: "Senior talent at a fraction of US rates" },
  { icon: "⚡", title: "Fast Onboarding", desc: "Start in 1-2 weeks, not months" },
  { icon: "📈", title: "Scalable", desc: "Scale team up or down as needed" },
  { icon: "🔄", title: "Flexible Engagement", desc: "Staff aug, dedicated team, or project-based" }
];

const roles = [
  "Full-Stack Developers", "React Developers", "Node.js Developers", "TypeScript Engineers",
  "Mobile Developers", "DevOps Engineers", "UI/UX Designers", "QA Engineers"
];

const stats = [
  { value: "50+", label: "Active Developers" },
  { value: "1-2", label: "Weeks to Start" },
  { value: "5+", label: "Years Avg Experience" },
  { value: "CST", label: "Timezone" }
];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  canonicalOverride="https://codebrand.us/hire-remote-developers"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- ==================== HERO ==================== -->
  <section class="relative min-h-[90vh] flex items-center py-16 sm:py-20 lg:py-28 overflow-hidden bg-slate-950">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(6, 182, 212, 0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(6, 182, 212, 0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-orange-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
      <div class="max-w-4xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-slate-800/80 border border-cyan-500/30 rounded-full mb-8 backdrop-blur-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
          </span>
          <span class="text-sm font-medium text-cyan-400">Hire Remote Developers</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight font-poppins">
          Hire <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-amber-500">Developers</span>
        </h1>

        <p class="text-lg sm:text-xl text-slate-300 leading-relaxed mb-8 max-w-2xl">
          Senior remote developers for your team.<br class="hidden md:block" />
          US timezone. English fluent. 60% cost savings.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 mb-16">
          <a
            href="/contact"
            class="group inline-flex items-center gap-2 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white font-bold px-8 py-4 rounded-2xl transition-all duration-300 shadow-lg shadow-orange-500/25 hover:shadow-orange-500/40 hover:-translate-y-1"
          >
            Hire Developers
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a
            href="#benefits"
            class="inline-flex items-center gap-2 px-8 py-4 bg-slate-800/80 hover:bg-slate-700/80 text-white font-semibold rounded-2xl border border-slate-700 hover:border-slate-600 transition-all duration-300"
          >
            Learn More
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {stats.map((stat) => (
            <div class="text-center p-6 bg-white/5 border border-white/10 rounded-2xl">
              <div class="text-3xl sm:text-4xl font-bold text-orange-500">{stat.value}</div>
              <div class="text-slate-400 text-sm mt-2">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== OVERVIEW ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <span class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-100 border border-cyan-200 rounded-full text-cyan-700 text-sm font-semibold mb-6">
        OVERVIEW
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-8">Scale your team without the hassle</h2>
      <div class="prose prose-lg max-w-none text-slate-600 space-y-6">
        <p>
          Hiring developers is expensive and slow. Between recruiting, interviewing, and onboarding, it takes months to add capacity. And if the project ends or needs change, you're stuck with fixed costs. That's why many companies choose to <a href="/outsource-web-development" class="text-cyan-600 hover:text-cyan-700 font-semibold">outsource web development</a>.
        </p>
        <p>
          <strong class="text-slate-900">Remote developers solve this.</strong> Add senior engineers to your team in 1-2 weeks. Scale up for busy periods, scale down when work slows. Pay only for productive hours with no long-term commitments. Our <a href="/nearshore-development" class="text-cyan-600 hover:text-cyan-700 font-semibold">nearshore development</a> model makes this possible.
        </p>
        <p>
          Our developers work <strong class="text-slate-900">US timezone hours</strong>, communicate in fluent English, and integrate seamlessly with your existing workflow. Whether you need <a href="/react-development-agency" class="text-cyan-600 hover:text-cyan-700 font-semibold">React developers</a>, <a href="/ecommerce-development-agency" class="text-cyan-600 hover:text-cyan-700 font-semibold">e-commerce specialists</a>, or <a href="/custom-web-development-services" class="text-cyan-600 hover:text-cyan-700 font-semibold">custom development</a>, it's like having local talent at 60% of the cost.
        </p>
      </div>
    </div>
  </section>

  <!-- ==================== BENEFITS ==================== -->
  <section id="benefits" class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-orange-100 border border-orange-200 rounded-full text-orange-700 text-sm font-semibold mb-6">
          WHY CODEBRAND
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900">Why hire through <span class="text-orange-500">Codebrand</span></h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {benefits.map((b) => (
          <div class="group bg-white hover:bg-white rounded-2xl shadow-lg hover:shadow-xl p-6 border border-slate-200 hover:border-orange-300 transition-all duration-300 hover:-translate-y-1">
            <div class="w-14 h-14 bg-orange-500 rounded-2xl flex items-center justify-center mb-5 shadow-lg group-hover:scale-110 transition-transform duration-300">
              <span class="text-2xl">{b.icon}</span>
            </div>
            <h3 class="text-xl font-semibold text-slate-900 mb-3">{b.title}</h3>
            <p class="text-slate-600 leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== AVAILABLE ROLES ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-100 border border-cyan-200 rounded-full text-cyan-700 text-sm font-semibold mb-6">
        ROLES
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4">Available <span class="text-orange-500">Roles</span></h2>
      <div class="flex flex-wrap justify-center gap-3 mt-10">
        {roles.map((r) => (
          <span class="px-4 py-2 rounded-full border border-slate-200 text-slate-600 text-sm font-medium hover:border-orange-300 hover:text-orange-600 transition-all duration-300">
            {r}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== FAQ ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-slate-200 border border-slate-300 rounded-full text-slate-700 text-sm font-semibold mb-6">
          FAQ
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4">Common <span class="text-orange-500">Questions</span></h2>
      </div>
      <div>
        <FAQ faqs={faqs} client:visible />
      </div>
    </div>
  </section>

  <!-- ==================== CTA ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 relative overflow-hidden">
    <div class="absolute inset-0 bg-slate-950">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(6, 182, 212, 0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(6, 182, 212, 0.05) 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-r from-orange-500/20 via-amber-500/20 to-yellow-500/20 rounded-full blur-3xl"></div>

    <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="relative">
        <div class="absolute -inset-1 bg-gradient-to-r from-orange-500 via-amber-500 to-yellow-500 rounded-3xl blur-xl opacity-30"></div>
        <div class="relative bg-gradient-to-br from-orange-500 via-amber-500 to-yellow-500 rounded-3xl p-12 lg:p-16 text-center overflow-hidden">
          <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 24px 24px;"></div>
          <div class="relative z-10">
            <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6 leading-tight font-poppins">
              Ready to scale?
            </h2>
            <p class="text-lg lg:text-xl text-white/90 mb-10 max-w-xl mx-auto">
              Free consultation. Start in 1-2 weeks.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a
                href="/contact"
                class="group inline-flex items-center justify-center gap-3 px-10 py-5 bg-white text-orange-600 rounded-2xl font-bold text-lg hover:bg-slate-900 hover:text-white transform hover:-translate-y-1 transition-all duration-300 shadow-2xl"
              >
                Get Started
                <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
