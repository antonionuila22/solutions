---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import Whyus from "../components/whyus.astro";
import Faq from "../components/Faq.astro";
import CardService from "../components/CardService.astro";
import Button from "../components/Button.astro";
import Testimonial from "../components/Testimonial.astro";
import RelatedServices from "../components/RelatedServices.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { createServicePageSchema } from "../utils/schema";

const title = "E-commerce Development | Codebrand";
const description =
  "Launch your online store with expert e-commerce development. Shopify, WooCommerce, payment integrations, and conversion-optimized designs.";
const keywords =
  "e-commerce development, online store development, e-commerce website design, Shopify development, WooCommerce development, online shop, e-commerce solutions, shopping cart development, payment gateway integration, product catalog, e-commerce platform, online retail, digital commerce, e-commerce SEO, conversion optimization";
const image = "/photos/diseñoweb.webp";

// Service Schema for E-commerce
const serviceSchema = createServicePageSchema({
  serviceType: "E-commerce Development",
  name: "E-commerce Development & Online Store Design",
  description: description,
  url: "https://www.codebrand.us/e-commerce",
  image: "https://www.codebrand.us/photos/diseñoweb.webp",
  catalogName: "E-commerce Services",
  catalogItems: [
    {
      name: "Shopify Development",
      description: "Custom Shopify stores with premium themes and apps",
    },
    {
      name: "WooCommerce Development",
      description: "WordPress-based e-commerce solutions",
    },
    {
      name: "Payment Gateway Integration",
      description:
        "Secure payment processing with Stripe, PayPal, and more",
    },
    {
      name: "Custom E-commerce Platforms",
      description: "Tailored online stores for unique business needs",
    },
  ],
});
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
  breadcrumbNames={{ "e-commerce": "E-commerce Development" }}
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(serviceSchema)}
  />
  <!-- Hero Section -->
  <PageHero
    eyebrow="E-commerce Development"
    title='Build an Online Store That <span class="text-orange-400">Drives Sales</span>'
    subtitle="Grow your retail business with online stores that turn browsers into buyers. We build fast, secure, high-converting shops that scale as you grow."
    stats={[
      { value: "5.0", label: "Client Rating", counterTo: 5, decimals: 1, color: "orange" },
      { value: "50", label: "Five-Star Reviews", counterTo: 50, color: "cyan" },
      { value: "8+", label: "Years Experience", counterTo: 8, suffix: "+", color: "cyan" },
      { value: "100%", label: "Custom-Built", color: "orange" },
    ]}
    ctaPrimary={{ text: "Launch Your Store", href: "/contact" }}
    ctaSecondary={{ text: "View Solutions", href: "#services" }}
  />

  <!-- Introduction Section -->
  <section class="py-16 lg:py-24 bg-white font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2
            class="text-display-2 font-bold text-cyan-900 mb-6"
            data-anim="heading"
          >
            E-commerce Solutions That Scale Your Business
          </h2>
          <div class="prose prose-lg text-slate-700 space-y-4" data-anim="fade" data-delay="0.1">
            <p>
              Online selling is more competitive than ever. It is also full of
              opportunity. More shoppers now prefer to buy online. That opens
              huge potential for any business that offers a great shopping
              experience. At Codebrand, we build online stores that do more than
              look good. They turn visitors into customers and grow your revenue.
              Our <a
                href="/services/web-development"
                class="text-cyan-600 hover:text-cyan-700 font-semibold"
                >web development team</a
              > creates custom stores backed by <a
                href="/services/ux-ui"
                class="text-cyan-600 hover:text-cyan-700 font-semibold"
                >conversion-focused UX/UI design</a
              >.
            </p>
            <p>
              We build much more than a basic online catalog. We create full
              storefronts with smart product recommendations, one-click
              checkout, and abandoned cart recovery. You also get inventory
              management, customer accounts, and wishlists. Your store connects
              smoothly with shipping carriers and payment processors. We design
              every part to boost sales, from the product page to the checkout.
            </p>
            <p>
              A successful store takes more than good code. It also takes smart
              thinking about user experience, buyer behavior, and daily
              operations. Our team studies your audience, your competitors, and
              your business model. Then we design a shopping experience that
              removes friction, builds trust, and guides people from browsing to
              buying. We use proven tactics like customer reviews, clear
              deadlines, security badges, and simple checkouts. These small
              details lift your sales. Paired with our <a
                href="/digital-marketing"
                class="text-cyan-600 hover:text-cyan-700 font-semibold"
                >digital marketing expertise</a
              > and <a
                href="/digital-marketing"
                class="text-cyan-600 hover:text-cyan-700 font-semibold"
                >persuasive copywriting</a
              >, we build stores that truly sell.
            </p>
            <p>
              We deliver results at every stage. Launch your first store, move
              from another platform, or scale a growing business. We help
              companies of all sizes. That includes small boutiques with curated
              collections and large merchants with thousands of products. We
              build on trusted platforms like Shopify, WooCommerce, and Magento,
              plus custom stores made for your needs. Your store handles today's
              demand and scales with ease as you grow.
            </p>
          </div>
        </div>
        <div class="relative" data-anim="fade" data-fade-from="right" data-delay="0.1">
          <div
            class="relative bg-slate-100 rounded-3xl p-8 shadow-xl"
            data-parallax
            data-parallax-speed="0.2"
            data-parallax-range="44"
          >
            <div class="space-y-4">
              <div
                class="bg-white rounded-2xl p-6 shadow-lg transform hover:scale-[1.03] transition-transform duration-300"
              >
                <div class="flex items-center gap-4">
                  <div
                    class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-teal-500 to-teal-600 rounded-xl flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6 text-white"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z"
                        clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <div>
                    <div class="text-2xl font-bold text-cyan-900 tabular-nums"><span data-counter="8" data-counter-suffix="+">8+</span></div>
                    <div class="text-sm text-slate-600">Years of Experience</div>
                  </div>
                </div>
              </div>
              <div
                class="bg-white rounded-2xl p-6 shadow-lg transform hover:scale-105 transition-transform"
              >
                <div class="flex items-center gap-4">
                  <div
                    class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6 text-white"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zM16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <div class="text-2xl font-bold text-cyan-900 tabular-nums"><span data-counter="50">50</span></div>
                    <div class="text-sm text-slate-600">Five-Star Reviews</div>
                  </div>
                </div>
              </div>
              <div
                class="bg-white rounded-2xl p-6 shadow-lg transform hover:scale-105 transition-transform"
              >
                <div class="flex items-center gap-4">
                  <div
                    class="flex-shrink-0 w-12 h-12 bg-orange-500 rounded-xl flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6 text-white"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"
                      ></path>
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z"
                        clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <div>
                    <div class="text-2xl font-bold text-cyan-900">100%</div>
                    <div class="text-sm text-slate-600">
                      Custom-Built
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-16 lg:py-24 bg-slate-50 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        class="mb-12 sm:mb-16"
        eyebrow="What We Offer"
        title='Complete E-commerce <span class="text-orange-500">Solutions</span>'
        subtitle="From first setup to ongoing tuning, we handle every step. Our e-commerce services drive sales and grow your business."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-anim="fade">
        <CardService
          icon="/icons/ecommerce-website-commerce-and-shopping-2-svgrepo-com.svg"
          title="Custom E-commerce Development"
          description="Get an online store built around your exact business needs. We add the custom features, integrations, and workflows that standard platforms can't offer."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/sitio-web.webp"
          title="Shopify Development"
          description="Launch a beautiful Shopify store with custom themes and features. We design, build, and fine-tune your site to boost sales and delight shoppers."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/website-program-svgrepo-com.svg"
          title="WooCommerce Development"
          description="Sell right from your WordPress site with WooCommerce. We build flexible, SEO-friendly stores that connect smoothly with your existing content and marketing."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/login-page-svgrepo-com.svg"
          title="Payment Gateway Integration"
          description="Accept payments safely through Stripe, PayPal, Square, and more. We set up PCI-compliant checkout with fraud protection and support for payments from around the world."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/host-website-se-svgrepo-com.svg"
          title="Inventory Management"
          description="Track stock, manage variants, automate reordering, and sync inventory across every sales channel. We build reliable systems that prevent overselling and simplify daily work."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/mobile-phone-app-svgrepo-com.svg"
          title="Mobile Commerce"
          description="We tune your store for phones using responsive design and progressive web app technology. A mobile-first build works perfectly on phones and tablets."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/data-graphics-analysis-svgrepo-com.svg"
          title="Conversion Rate Optimization"
          description="Earn more from every visitor with smart conversion optimization. We improve product pages, checkout flows, and calls to action using data and A/B testing."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/seo.webp"
          title="E-commerce SEO"
          description="Rank higher in search and attract ready-to-buy shoppers. We optimize product pages, add structured data, improve site structure, and plan content that drives organic traffic."
          learnMoreUrl="/seo"
        />

        <CardService
          icon="/icons/redes-sociales.webp"
          title="Marketing Automation"
          description="Win back abandoned carts and keep customers coming back for more. Automated emails, personal recommendations, and targeted offers respond to what each shopper does."
          learnMoreUrl="/digital-marketing"
        />
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-16 lg:py-24 bg-white font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        class="mb-12 sm:mb-16"
        eyebrow="Built In"
        title='Essential E-commerce <span class="text-orange-500">Features</span>'
        subtitle="We build online stores with all the features needed to compete and win in today's digital marketplace."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6" data-anim="fade">
        <div
          class="bg-slate-50 rounded-xl p-6 shadow-md border border-cyan-100"
        >
          <h4 class="font-bold text-cyan-900 mb-2">Product Management</h4>
          <p class="text-sm text-slate-600">
            Unlimited products, variants, categories, and flexible pricing
            options
          </p>
        </div>
        <div
          class="bg-slate-50 rounded-xl p-6 shadow-md border border-orange-100"
        >
          <h4 class="font-bold text-cyan-900 mb-2">Shopping Cart</h4>
          <p class="text-sm text-slate-600">
            Intuitive cart with saved items, quantity updates, and coupon codes
          </p>
        </div>
        <div
          class="bg-gradient-to-br from-blue-50 to-white rounded-xl p-6 shadow-md border border-blue-100"
        >
          <h4 class="font-bold text-cyan-900 mb-2">Secure Checkout</h4>
          <p class="text-sm text-slate-600">
            SSL encrypted, PCI compliant checkout with guest and account options
          </p>
        </div>
        <div
          class="bg-gradient-to-br from-teal-50 to-white rounded-xl p-6 shadow-md border border-teal-100"
        >
          <h4 class="font-bold text-cyan-900 mb-2">Multi-Currency</h4>
          <p class="text-sm text-slate-600">
            Sell globally with automatic currency conversion and localized
            pricing
          </p>
        </div>
        <div
          class="bg-gradient-to-br from-cyan-50 to-white rounded-xl p-6 shadow-md border border-cyan-100"
        >
          <h4 class="font-bold text-cyan-900 mb-2">Shipping Integration</h4>
          <p class="text-sm text-slate-600">
            Real-time rates from carriers, label printing, and tracking
          </p>
        </div>
        <div
          class="bg-gradient-to-br from-orange-50 to-white rounded-xl p-6 shadow-md border border-orange-100"
        >
          <h4 class="font-bold text-cyan-900 mb-2">Customer Accounts</h4>
          <p class="text-sm text-slate-600">
            Order history, wishlists, saved addresses, and loyalty programs
          </p>
        </div>
        <div
          class="bg-slate-50 rounded-xl p-6 shadow-md border border-cyan-100"
        >
          <h4 class="font-bold text-cyan-900 mb-2">Reviews & Ratings</h4>
          <p class="text-sm text-slate-600">
            Customer reviews, star ratings, and user-generated content
          </p>
        </div>
        <div
          class="bg-slate-50 rounded-xl p-6 shadow-md border border-orange-100"
        >
          <h4 class="font-bold text-cyan-900 mb-2">Analytics Dashboard</h4>
          <p class="text-sm text-slate-600">
            Sales reports, traffic analysis, and customer insights
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section
    class="py-16 lg:py-24 bg-slate-50 font-poppins"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        class="mb-12 sm:mb-16"
        eyebrow="Our Process"
        title='Our E-commerce <span class="text-orange-500">Process</span>'
        subtitle="A structured approach that ensures successful store launches and sustainable growth."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" data-anim="fade">
        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div
            class="w-12 h-12 bg-cyan-900 rounded-xl flex items-center justify-center mb-4"
          >
            <span class="text-2xl font-bold text-white">1</span>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">
            Strategy & Planning
          </h3>
          <p class="text-slate-700">
            We define your goals, pick the right platform, and plan every
            feature. Each spec ties back to your business objectives.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div
            class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center mb-4"
          >
            <span class="text-2xl font-bold text-white">2</span>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">
            Design & Development
          </h3>
          <p class="text-slate-700">
            We design for conversions and build a reliable, scalable store. It
            ships with every feature and integration you need.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div
            class="w-12 h-12 bg-orange-500 rounded-xl flex items-center justify-center mb-4"
          >
            <span class="text-2xl font-bold text-white">3</span>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">Testing & Launch</h3>
          <p class="text-slate-700">
            We test checkout flows, payments, and features in full. Then we
            launch with SEO and marketing ready to go.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div
            class="w-12 h-12 bg-gradient-to-br from-teal-500 to-teal-600 rounded-xl flex items-center justify-center mb-4"
          >
            <span class="text-2xl font-bold text-white">4</span>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">
            Growth & Optimization
          </h3>
          <p class="text-slate-700">
            Monitor performance, optimize conversions, add features, and scale
            infrastructure as your business grows.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <Whyus />

  <!-- Google Reviews Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-950 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        class="mb-8 sm:mb-12"
        theme="dark"
        eyebrowColor="orange"
        eyebrow="Google Reviews"
        title='What Our <span class="text-orange-500">Clients Say</span>'
        subtitle="Real reviews from real clients on Google. See why businesses trust Codebrand for their e-commerce development needs."
      />
    </div>
    <Testimonial />
  </section>

  <!-- Case Studies Section -->
  <section class="py-16 lg:py-24 bg-slate-50 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        class="mb-12 sm:mb-16"
        eyebrow="Case Studies"
        title='E-commerce <span class="text-orange-500">Success Stories</span>'
        subtitle="Real revenue growth and conversions. See how we've helped online stores scale their businesses."
      />

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8" data-anim="fade">
        <div class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
          <div class="h-48 bg-gradient-to-br from-cyan-600 to-cyan-800 flex items-center justify-center transition-transform duration-500 group-hover:scale-105">
            <svg class="w-20 h-20 text-white/30" fill="currentColor" viewBox="0 0 20 20">
              <path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zM16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"></path>
            </svg>
          </div>
          <div class="p-6">
            <span class="text-xs font-semibold text-cyan-700 uppercase tracking-wide">Fashion</span>
            <h3 class="text-xl font-bold text-cyan-900 mt-2 mb-3">Clothing Brand Store</h3>
            <p class="text-slate-600 mb-4">A custom Shopify store with advanced filtering, size guides, and Instagram integration. It transformed their online sales.</p>
            <div class="flex gap-4 text-sm">
              <div>
                <div class="font-bold text-orange-500">+250%</div>
                <div class="text-slate-500">Online Revenue</div>
              </div>
              <div>
                <div class="font-bold text-orange-500">-40%</div>
                <div class="text-slate-500">Cart Abandonment</div>
              </div>
              <div>
                <div class="font-bold text-orange-500">3.5%</div>
                <div class="text-slate-500">Conversion Rate</div>
              </div>
            </div>
          </div>
        </div>

        <div class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
          <div class="h-48 bg-gradient-to-br from-teal-600 to-teal-800 flex items-center justify-center transition-transform duration-500 group-hover:scale-105">
            <svg class="w-20 h-20 text-white/30" fill="currentColor" viewBox="0 0 20 20">
              <path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zM16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"></path>
            </svg>
          </div>
          <div class="p-6">
            <span class="text-xs font-semibold text-teal-700 uppercase tracking-wide">Food & Beverage</span>
            <h3 class="text-xl font-bold text-cyan-900 mt-2 mb-3">Specialty Food Store</h3>
            <p class="text-slate-600 mb-4">WooCommerce store with subscription boxes, gift options, and loyalty program for a gourmet food company.</p>
            <div class="flex gap-4 text-sm">
              <div>
                <div class="font-bold text-orange-500">+180%</div>
                <div class="text-slate-500">Monthly Revenue</div>
              </div>
              <div>
                <div class="font-bold text-orange-500">45%</div>
                <div class="text-slate-500">Subscription Rate</div>
              </div>
              <div>
                <div class="font-bold text-orange-500">$85</div>
                <div class="text-slate-500">Avg Order Value</div>
              </div>
            </div>
          </div>
