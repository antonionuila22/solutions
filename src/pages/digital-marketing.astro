---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
import Whyus from "../components/whyus.astro";
import Faq from "../components/Faq.astro";
import CardService from "../components/CardService.astro";
import Button from "../components/Button.astro";
import Testimonial from "../components/Testimonial.astro";
import RelatedServices from "../components/RelatedServices.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { createServicePageSchema } from "../utils/schema";

const title =
  "Digital Marketing | SEO, PPC & Social | Codebrand";
const description =
  "Grow your business with expert SEO, PPC, social media marketing, content strategy, and conversion optimization that drive real ROI.";
const keywords =
  "digital marketing, SEO services, PPC advertising, social media marketing, content marketing, email marketing, conversion optimization, Google Ads, Facebook Ads, Instagram marketing, digital marketing agency, online marketing services, marketing strategy, lead generation, brand awareness, marketing automation, influencer marketing, video marketing, analytics and reporting";
const image = "/photos/socialmedia.webp";

// Service Schema for Digital Marketing
const serviceSchema = createServicePageSchema({
  serviceType: "Digital Marketing Services",
  name: "Comprehensive Digital Marketing Solutions",
  description: description,
  url: "https://www.codebrand.us/digital-marketing",
  image: "https://www.codebrand.us/photos/socialmedia.webp",
  catalogName: "Digital Marketing Services",
  catalogItems: [
    {
      name: "PPC Advertising",
      description: "Google Ads and paid search campaign management",
    },
    {
      name: "Social Media Marketing",
      description: "Facebook, Instagram, LinkedIn, and TikTok marketing",
    },
    {
      name: "Content Marketing",
      description: "Strategic content creation and distribution",
    },
    {
      name: "Email Marketing",
      description: "Email campaigns, automation, and lead nurturing",
    },
  ],
});
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
  breadcrumbNames={{ "digital-marketing": "Digital Marketing" }}
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(serviceSchema)}
  />
  <!-- Hero Section -->
  <PageHero
    eyebrow="Digital Marketing Excellence"
    title='Grow Your Business with <span class="text-orange-400">Data-Driven Marketing</span>'
    subtitle="Turn your online presence into a revenue engine. We combine SEO, paid ads, social media, and content to bring in qualified leads and grow your ROI."
    stats={[
      { value: "5.0", label: "Client Rating", counterTo: 5, decimals: 1, color: "orange" },
      { value: "50", label: "Five-Star Reviews", counterTo: 50, color: "cyan" },
      { value: "8+", label: "Years Experience", counterTo: 8, suffix: "+", color: "cyan" },
      { value: "100%", label: "Custom-Built", color: "orange" },
    ]}
    ctaPrimary={{ text: "Get Free Marketing Audit", href: "/contact" }}
    ctaSecondary={{ text: "Explore Services", href: "#services" }}
  />

  <!-- Introduction Section -->
  <section class="py-16 lg:py-24 bg-white font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2
            class="text-display-2 font-bold text-cyan-900 mb-6"
            data-anim="heading"
          >
            Strategic Digital Marketing That Delivers Measurable Results
          </h2>
          <div class="prose prose-lg text-slate-700 space-y-4" data-anim="fade" data-delay="0.1">
            <p>
              Digital marketing is now much more than banner ads and social
              posts. To win today, you need the right mix of strategy,
              creativity, data, and technical skill. At Codebrand, we build
              marketing campaigns that grow your business. They bring in
              qualified leads and boost your return on investment. Our <a
                href="/team"
                class="text-cyan-600 hover:text-cyan-700 font-semibold"
                >expert marketing team</a
              > combines <a
                href="/services/seo"
                class="text-cyan-600 hover:text-cyan-700 font-semibold"
                >SEO expertise</a
              > with <a
                href="/digital-marketing"
                class="text-cyan-600 hover:text-cyan-700 font-semibold"
                >conversion copywriting</a
              > to get great results.
            </p>
            <p>
              We bring all your marketing together in one plan. This includes
              SEO, pay-per-click ads (PPC), social media, content, email, and
              conversion rate optimization. We don't use one-size-fits-all
              solutions. Instead, we take time to learn your industry, your
              audience, your competitors, and your goals. Then we build a custom
              plan that gets real results.
            </p>
            <p>
              We stand out because we are open and we track everything. Every
              campaign comes with clear analytics and regular reports. You'll
              always know how your budget is spent and what it earns. We focus on
              the numbers that matter most to you. That means more traffic,
              better search rankings, more conversions, and more revenue. Our
              campaigns work hand in hand with <a
                href="/landing-pages"
                class="text-cyan-600 hover:text-cyan-700 font-semibold"
                >high-converting landing pages</a
              > and <a
                href="/services/web-development"
                class="text-cyan-600 hover:text-cyan-700 font-semibold"
                >optimized websites</a
              > for maximum impact.
            </p>
            <p>
              Maybe you're a startup building your first online presence. Maybe
              you're a growing business that wants more customers. Or maybe
              you're an established company that wants to lead its market. Our
              team has the skill and experience to help you reach your goals. We
              keep up with new trends, algorithm updates, and platform changes.
              This keeps your marketing strong and ahead of the competition.
            </p>
          </div>
        </div>
        <div class="relative" data-anim="fade" data-fade-from="right" data-delay="0.1">
          <div
            class="relative bg-slate-100 rounded-3xl p-8 shadow-xl"
            data-parallax
            data-parallax-speed="0.2"
            data-parallax-range="44"
          >
            <div class="space-y-4">
              <div
                class="bg-white rounded-2xl p-6 shadow-lg transform hover:scale-[1.03] transition-transform duration-300"
              >
                <div class="flex items-center gap-4">
                  <div
                    class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-teal-500 to-teal-600 rounded-xl flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6 text-white"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M12 7a1 1 0 110-2h5a1 1 0 011 1v5a1 1 0 11-2 0V8.414l-4.293 4.293a1 1 0 01-1.414 0L8 10.414l-4.293 4.293a1 1 0 01-1.414-1.414l5-5a1 1 0 011.414 0L11 10.586 14.586 7H12z"
                        clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <div>
                    <div class="text-2xl font-bold text-cyan-900 tabular-nums"><span data-counter="8" data-counter-suffix="+">8+</span></div>
                    <div class="text-sm text-slate-600">
                      Years of Experience
                    </div>
                  </div>
                </div>
              </div>
              <div
                class="bg-white rounded-2xl p-6 shadow-lg transform hover:scale-105 transition-transform"
              >
                <div class="flex items-center gap-4">
                  <div
                    class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6 text-white"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <div class="text-2xl font-bold text-cyan-900 tabular-nums"><span data-counter="50">50</span></div>
                    <div class="text-sm text-slate-600">Five-Star Reviews</div>
                  </div>
                </div>
              </div>
              <div
                class="bg-white rounded-2xl p-6 shadow-lg transform hover:scale-105 transition-transform"
              >
                <div class="flex items-center gap-4">
                  <div
                    class="flex-shrink-0 w-12 h-12 bg-orange-500 rounded-xl flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6 text-white"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <div class="text-2xl font-bold text-cyan-900">100%</div>
                    <div class="text-sm text-slate-600">Custom-Built</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-16 lg:py-24 bg-slate-50 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        class="mb-12 sm:mb-16"
        eyebrow="What We Offer"
        title='Complete Digital Marketing <span class="text-orange-500">Services</span>'
        subtitle="We handle it all, from strategy to launch to optimization. Our full-service digital marketing is built to grow your business."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-anim="fade">
        <CardService
          icon="/icons/seo.webp"
          title="Search Engine Optimization (SEO)"
          description="Climb the search rankings with a full SEO plan. We fix technical issues, write strong content, build quality backlinks, and research keywords to bring you organic traffic and qualified leads."
          learnMoreUrl="/seo"
        />

        <CardService
          icon="/icons/target-focus-svgrepo-com.svg"
          title="Pay-Per-Click Advertising (PPC)"
          description="Get more from your ad spend with managed PPC campaigns on Google Ads, Microsoft Ads, and social platforms. We handle keyword research, ad creation, and bids to make every dollar count."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/redes-sociales.webp"
          title="Social Media Marketing"
          description="Build engaged communities and drive sales with smart social media campaigns. We create content, manage your community, run targeted ads, and track results on every major platform."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/brainstorming-svgrepo-com.svg"
          title="Content Marketing"
          description="Attract and convert your audience with useful, relevant content. Our team creates blog posts, videos, infographics, ebooks, and case studies that build authority and drive action."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/email-chat-svgrepo-com.svg"
          title="Email Marketing Campaigns"
          description="Nurture leads and keep customers with personal email campaigns. We design clean templates, group your audience, set up automated workflows, and boost open rates and conversions."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/financial-report-svgrepo-com.svg"
          title="Conversion Rate Optimization"
          description="Turn more visitors into customers with data-driven CRO. We run A/B tests, study user behavior, improve landing pages, and refine the experience to lift your conversion rate."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/data-graphics-analysis-svgrepo-com.svg"
          title="Marketing Analytics & Reporting"
          description="Make smart decisions with clear marketing analytics. We track KPIs, build custom dashboards, share detailed reports, and give you insights to keep improving each campaign."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/operating-system-svgrepo-com.svg"
          title="Marketing Automation"
          description="Grow your marketing with smart automation. We set up and fine-tune tools like HubSpot, Marketo, and ActiveCampaign to handle lead nurturing, scoring, and the customer journey."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/edicion-de-video.webp"
          title="Video Marketing"
          description="Engage your audience with strong video content. From strategy and scripts to filming and sharing, we make videos that tell your story, show your products, and drive sales on every channel."
          learnMoreUrl="/contact"
        />
      </div>
    </div>
  </section>

  <!-- Channels Section -->
  <section class="py-16 lg:py-24 bg-white font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        class="mb-12 sm:mb-16"
        eyebrow="Channels"
        title='Multi-Channel <span class="text-orange-500">Marketing Expertise</span>'
        subtitle="We use the best marketing channels to reach your audience wherever they are online."
      />

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8" data-anim="fade">
        <div
          class="flex flex-col items-center gap-3 p-6 bg-slate-50 rounded-xl hover:shadow-lg transition-shadow"
        >
          <div
            class="w-16 h-16 bg-gradient-to-br from-red-500 to-red-600 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-8 h-8 text-white"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
              ></path>
            </svg>
          </div>
          <span class="text-sm font-semibold text-slate-700">YouTube</span>
        </div>

        <div
          class="flex flex-col items-center gap-3 p-6 bg-slate-50 rounded-xl hover:shadow-lg transition-shadow"
        >
          <div
            class="w-16 h-16 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-8 h-8 text-white"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"
              ></path>
            </svg>
          </div>
          <span class="text-sm font-semibold text-slate-700">Twitter/X</span>
        </div>

        <div
          class="flex flex-col items-center gap-3 p-6 bg-slate-50 rounded-xl hover:shadow-lg transition-shadow"
        >
          <div
            class="w-16 h-16 bg-gradient-to-br from-pink-500 to-pink-600 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-8 h-8 text-white"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
              ></path>
            </svg>
          </div>
          <span class="text-sm font-semibold text-slate-700">Instagram</span>
        </div>

        <div
          class="flex flex-col items-center gap-3 p-6 bg-slate-50 rounded-xl hover:shadow-lg transition-shadow"
        >
          <div
            class="w-16 h-16 bg-gradient-to-br from-blue-600 to-blue-700 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-8 h-8 text-white"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M22.676 0H1.324C.593 0 0 .593 0 1.324v21.352C0 23.408.593 24 1.324 24h11.494v-9.294H9.689v-3.621h3.129V8.41c0-3.099 1.894-4.785 4.659-4.785 1.325 0 2.464.097 2.796.141v3.24h-1.921c-1.5 0-1.792.721-1.792 1.771v2.311h3.584l-.465 3.63H16.56V24h6.115c.733 0 1.325-.592 1.325-1.324V1.324C24 .593 23.408 0 22.676 0"
              ></path>
            </svg>
          </div>
          <span class="text-sm font-semibold text-slate-700">Facebook</span>
        </div>

        <div
          class="flex flex-col items-center gap-3 p-6 bg-slate-50 rounded-xl hover:shadow-lg transition-shadow"
        >
          <div
            class="w-16 h-16 bg-gradient-to-br from-blue-700 to-blue-800 rounded-xl flex items-center justify-center"
          >
            <svg
              class="w-8 h-8 text-white"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path>
            </svg>
          </div>
          <span class="text-sm font-semibold text-slate-700">LinkedIn</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section
    class="py-16 lg:py-24 bg-slate-50 font-poppins"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        class="mb-12 sm:mb-16"
        eyebrow="Our Process"
        title='Our Marketing <span class="text-orange-500">Methodology</span>'
        subtitle="We follow a proven process that delivers steady results and keeps improving."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" data-anim="fade">
        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div
            class="w-12 h-12 bg-cyan-900 rounded-xl flex items-center justify-center mb-4"
          >
            <span class="text-2xl font-bold text-white">1</span>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">
            Research & Analysis
          </h3>
          <p class="text-slate-700">
            We study your market, competitors, audience, and current results.
            This shows us the best opportunities and how to win.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div
            class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center mb-4"
          >
            <span class="text-2xl font-bold text-white">2</span>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">
            Strategy Development
          </h3>
          <p class="text-slate-700">
            We build a clear marketing plan for your business. It sets goals,
            tactics, channels, budget, and the metrics we'll use to measure
            success.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div
            class="w-12 h-12 bg-orange-500 rounded-xl flex items-center justify-center mb-4"
          >
            <span class="text-2xl font-bold text-white">3</span>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">
            Campaign Execution
          </h3>
          <p class="text-slate-700">
            Our team runs your campaigns across every channel. We create
            content, manage ads, and connect with your audience at each step.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div
            class="w-12 h-12 bg-gradient-to-br from-teal-500 to-teal-600 rounded-xl flex items-center justify-center mb-4"
          >
            <span class="text-2xl font-bold text-white">4</span>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">Optimize & Scale</h3>
          <p class="text-slate-700">
            We watch performance closely and run A/B tests. Then we use the data
            to improve results and scale what works.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <Whyus />

  <!-- Google Reviews Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-950 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        class="mb-8 sm:mb-12"
        theme="dark"
        eyebrowColor="orange"
        eyebrow="Google Reviews"
        title='What Our <span class="text-orange-500">Clients Say</span>'
        subtitle="Real reviews from real clients on Google. See why businesses trust Codebrand for their digital marketing needs."
      />
    </div>
    <Testimonial />
  </section>

  <!-- Case Studies Section -->
  <section class="py-16 lg:py-24 bg-slate-50 font-poppins">
