---
/**
 * Graphic Design Outsourcing Services Page
 * White-label design partner for agencies and businesses
 */

import Layout from "../layouts/Layout.astro";
import FAQ from "../components/FAQ.tsx";

// SEO
const title =
  "Design Outsourcing | White-Label Partner | Codebrand";
const description =
  "White-label graphic design partner for agencies and businesses. Brand identity, social media graphics, marketing materials, and print design.";
const keywords =
  "white label design, design outsourcing, graphic design partner, brand design agency, social media design, outsource graphic design, hire designer for agency, design agency partnership, white label branding, outsourced creative services, remote design team, offshore design services, design team for hire, freelance design agency, marketing design outsourcing, print design services, brand identity outsourcing, UI design outsourcing, creative agency partner, design studio outsourcing";

// Schema
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Codebrand Design Outsourcing",
  url: "https://codebrand.us/outsourcing-design",
  description: description,
};

// FAQ - Expanded for SEO
const faqs = [
  {
    question: "How does design outsourcing work?",
    answer:
      "Design outsourcing is simple: you send us your creative briefs and brand guidelines, and we deliver polished, client-ready designs. Everything is white-label and NDA-protected, meaning your clients never know we exist. We integrate with your workflow using tools like Slack, Asana, or your preferred project management platform. You review, we revise until perfect, and you deliver to your clients as your own work.",
  },
  {
    question: "What file formats do you deliver?",
    answer:
      "We deliver all source files including Adobe Illustrator (AI), Photoshop (PSD), and Figma files. Export formats include PNG, JPG, PDF, SVG, and any specific format you need. For print projects, we provide print-ready files with proper bleeds, crop marks, and color profiles (CMYK). Web assets come optimized for fast loading with multiple resolution options for retina displays.",
  },
  {
    question: "How fast is turnaround?",
    answer:
      "Turnaround depends on project complexity. Social media graphics: 24-48 hours. Marketing materials (brochures, flyers): 2-3 days. Brand identity packages: 1-2 weeks. Presentation decks: 2-4 days. We also offer rush delivery for urgent projects at a premium rate, with same-day delivery available for simple requests.",
  },
  {
    question: "What about revisions?",
    answer:
      "Our Priority and Rush tiers include unlimited revisions until you're 100% satisfied. Standard tier includes 2 revision rounds. We believe great design requires iteration, so we never rush you to approve. Each revision round typically takes 24 hours or less to complete.",
  },
  {
    question: "How does pricing work?",
    answer:
      "We offer transparent hourly pricing: Standard at $65/hr (48h turnaround), Priority at $85/hr (24h turnaround with unlimited revisions and dedicated designer), and Rush at $120/hr (same-day delivery). Volume discounts are available for 20+ hours monthly. No hidden fees, no surprise charges. You only pay for actual design time.",
  },
  {
    question: "Is my work confidential?",
    answer:
      "Absolutely. Every project is protected by our standard NDA. We never share, showcase, or reference your work without explicit permission. Your clients will never know you outsourced the work. We can also sign custom NDAs if your clients require specific confidentiality terms.",
  },
  {
    question: "What industries do you work with?",
    answer:
      "We work with agencies and businesses across all industries including technology, healthcare, finance, real estate, e-commerce, hospitality, and professional services. Our designers have experience creating industry-specific designs that resonate with target audiences while meeting regulatory requirements where applicable.",
  },
  {
    question: "Can you match our client's brand guidelines?",
    answer:
      "Yes, brand consistency is our specialty. Send us the brand guidelines, style guide, or even just examples of previous work, and we'll match the visual language perfectly. We create designs that look like they came from your client's internal team, maintaining fonts, colors, imagery style, and tone of voice.",
  },
  {
    question: "What if I'm not satisfied with the work?",
    answer:
      "Your satisfaction is guaranteed. If the initial concepts don't meet your expectations, we'll revise until they do. In the rare case we can't reach a satisfactory outcome, we offer a full refund for that project. We've maintained a 98% client satisfaction rate by focusing on communication and understanding your vision from the start.",
  },
  {
    question: "How do I get started?",
    answer:
      "Getting started is easy: simply contact us with your first project brief. We'll review the requirements, provide a time estimate, and begin work immediately upon approval. No long-term contracts required—start with a single project and scale up as needed. Most clients start with a small test project before committing to ongoing work.",
  },
];

// Comparison data for SEO
const comparison = [
  {
    aspect: "Cost",
    inHouse: "High ($60-100k/year salary + benefits + tools)",
    freelancer: "Variable ($30-150/hr, inconsistent)",
    outsourcing: "Predictable ($65-120/hr, no overhead)",
  },
  {
    aspect: "Availability",
    inHouse: "Limited to business hours, PTO affects output",
    freelancer: "Often juggling multiple clients",
    outsourcing: "Dedicated capacity, consistent delivery",
  },
  {
    aspect: "Scalability",
    inHouse: "Slow to hire, expensive to scale",
    freelancer: "Limited bandwidth per person",
    outsourcing: "Scale up/down instantly as needed",
  },
  {
    aspect: "Quality Control",
    inHouse: "Single perspective, potential blind spots",
    freelancer: "Varies greatly by individual",
    outsourcing: "Team review process, consistent standards",
  },
  {
    aspect: "Tools & Software",
    inHouse: "You pay for all licenses",
    freelancer: "Usually included but limited",
    outsourcing: "Full suite included in rate",
  },
];

// Detailed process steps
const processDetailed = [
  {
    num: "01",
    title: "Submit Your Brief",
    desc: "Share your project requirements, brand guidelines, and any reference materials. The more context you provide, the better we can nail it on the first try.",
    details: ["Project scope & objectives", "Brand assets & guidelines", "Timeline & budget", "Reference examples"],
  },
  {
    num: "02",
    title: "We Create",
    desc: "Our designers get to work, typically delivering first concepts within 24-48 hours. We focus on understanding your vision and translating it into compelling visuals.",
    details: ["Concept development", "Multiple directions if needed", "Progress updates", "24-48h first draft"],
  },
  {
    num: "03",
    title: "You Review",
    desc: "Review the designs at your pace. Provide feedback through your preferred channel—marked-up PDFs, Loom videos, or a quick call. We make revisions fast.",
    details: ["Detailed review process", "Feedback integration", "Unlimited revisions (Priority)", "Quick turnaround"],
  },
  {
    num: "04",
    title: "We Deliver",
    desc: "Once approved, you receive all files in every format you need. Source files, exports, and organized assets ready to hand off to your clients or send to print.",
    details: ["All source files", "Multiple export formats", "Organized file structure", "Print-ready when needed"],
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};

// Services with icons
const services = [
  {
    title: "Brand Identity",
    desc: "Logos, guidelines, visual systems",
    icon: "◆",
  },
  { title: "Social Media", desc: "Posts, stories, ads, templates", icon: "◐" },
  { title: "Marketing", desc: "Decks, brochures, one-pagers", icon: "▲" },
  { title: "Print Design", desc: "Cards, packaging, signage", icon: "■" },
  { title: "Web Graphics", desc: "Banners, icons, UI elements", icon: "●" },
  { title: "Illustration", desc: "Custom art, infographics", icon: "✦" },
];

// Work showcase
const showcase = [
  { title: "Brand Systems", tag: "Branding" },
  { title: "Social Campaigns", tag: "Social" },
  { title: "Pitch Decks", tag: "Presentations" },
  { title: "Packaging", tag: "Print" },
];

// Stats
const designStats = [
  { value: "500+", label: "Designs Delivered" },
  { value: "24h", label: "Avg. Turnaround" },
  { value: "∞", label: "Revisions" },
  { value: "100%", label: "Satisfaction" },
];

// Pricing
const pricingPlans = [
  {
    title: "Standard",
    price: "$65",
    period: "/hour",
    desc: "Quality design work",
    features: ["48h turnaround", "2 revision rounds", "Source files included", "Email support"],
    highlighted: false,
  },
  {
    title: "Priority",
    price: "$85",
    period: "/hour",
    desc: "Dedicated attention",
    features: ["24h turnaround", "Unlimited revisions", "All source files", "Slack/direct support", "Dedicated designer"],
    highlighted: true,
  },
  {
    title: "Rush",
    price: "$120",
    period: "/hour",
    desc: "Need it yesterday?",
    features: ["Same-day delivery", "12h turnaround", "Priority queue", "Direct communication", "Weekend availability"],
    highlighted: false,
  },
];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  canonicalOverride="https://codebrand.us/outsourcing-design"
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(serviceSchema)}
  />
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(faqSchema)}
  />

  <!-- ==================== HERO ==================== -->
  <section class="relative min-h-[90vh] flex items-center py-16 sm:py-20 lg:py-28 overflow-hidden bg-slate-950">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(6, 182, 212, 0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(6, 182, 212, 0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse"></div>
    <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-orange-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
      <div class="max-w-4xl">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-slate-800/80 border border-cyan-500/30 rounded-full mb-8 backdrop-blur-sm">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
          </span>
          <span class="text-sm font-medium text-cyan-400">Design Partner for Agencies</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight font-poppins">
          Design <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-amber-500">On Demand</span>
        </h1>

        <p class="text-lg sm:text-xl text-slate-300 leading-relaxed mb-8 max-w-2xl">
          White-label design for agencies. Fast turnaround.<br class="hidden md:block" />
          Unlimited revisions. Your brand, our craft.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 mb-16">
          <a
            href="/contact"
            class="group inline-flex items-center gap-2 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white font-bold px-8 py-4 rounded-2xl transition-all duration-300 shadow-lg shadow-orange-500/25 hover:shadow-orange-500/40 hover:-translate-y-1"
          >
            Start Creating
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a
            href="#work"
            class="inline-flex items-center gap-2 px-8 py-4 bg-slate-800/80 hover:bg-slate-700/80 text-white font-semibold rounded-2xl border border-slate-700 hover:border-slate-600 transition-all duration-300"
          >
            View Our Work
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {designStats.map((stat) => (
            <div class="text-center p-6 bg-white/5 border border-white/10 rounded-2xl">
              <div class="text-3xl sm:text-4xl font-bold text-orange-500">{stat.value}</div>
              <div class="text-slate-400 text-sm mt-2">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== WORK SHOWCASE ==================== -->
  <section id="work" class="py-16 sm:py-20 lg:py-28 bg-slate-950 font-poppins relative overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(6, 182, 212, 0.1) 1px, transparent 1px), linear-gradient(90deg, rgba(6, 182, 212, 0.1) 1px, transparent 1px); background-size: 80px 80px;"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16">
        <div>
          <span class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-500/10 border border-cyan-500/20 rounded-full text-cyan-400 text-sm font-semibold mb-6">
            WHAT WE CREATE
          </span>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white">
            Work that <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-400">converts</span>
          </h2>
        </div>
        <p class="text-slate-400 max-w-sm">
          From brand identities to campaign assets — design that makes an impact.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {showcase.map((item, i) => (
          <div class="group bg-slate-900/60 backdrop-blur-sm p-8 rounded-2xl border border-slate-800 hover:border-cyan-500/50 transition-all duration-300 hover:-translate-y-1">
            <div class="flex items-start gap-5">
              <div class="flex-shrink-0 w-14 h-14 bg-cyan-500 rounded-2xl flex items-center justify-center text-white font-bold text-xl shadow-lg group-hover:scale-110 transition-transform duration-300">
                {String(i + 1).padStart(2, '0')}
              </div>
              <div>
                <span class="text-xs font-semibold text-cyan-400 uppercase tracking-wider">{item.tag}</span>
                <h3 class="text-xl font-semibold text-white mt-1 group-hover:text-cyan-400 transition-colors duration-300">{item.title}</h3>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== SERVICES ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-orange-100 border border-orange-200 rounded-full text-orange-700 text-sm font-semibold mb-6">
          SERVICES
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900">
          Everything you <span class="text-orange-500">need</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <div class="group bg-white hover:bg-white rounded-2xl shadow-lg hover:shadow-xl p-6 border border-slate-200 hover:border-orange-300 transition-all duration-300 hover:-translate-y-1">
            <div class="w-14 h-14 bg-orange-500 rounded-2xl flex items-center justify-center mb-5 shadow-lg group-hover:scale-110 transition-transform duration-300">
              <span class="text-xl text-white">{service.icon}</span>
            </div>
            <h3 class="text-xl font-semibold text-slate-900 mb-3">{service.title}</h3>
            <p class="text-slate-600 leading-relaxed">{service.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== HOW IT WORKS ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-100 border border-cyan-200 rounded-full text-cyan-700 text-sm font-semibold mb-6">
          HOW IT WORKS
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
          From brief to <span class="text-orange-500">delivery</span>
        </h2>
        <p class="text-xl text-slate-600 max-w-3xl mx-auto">
          Our streamlined process ensures fast turnaround without sacrificing quality. Here's exactly what happens when you work with us.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {processDetailed.map((step) => (
          <div class="group bg-white rounded-2xl shadow-lg p-6 border border-slate-200 hover:border-orange-300 hover:shadow-xl transition-all duration-300">
            <div class="flex items-start gap-6">
              <div class="w-14 h-14 flex-shrink-0 rounded-2xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-white font-bold shadow-lg group-hover:scale-110 transition-transform duration-300">
                {step.num}
              </div>
              <div class="flex-1">
                <h3 class="text-xl font-semibold text-slate-900 mb-3">{step.title}</h3>
                <p class="text-slate-600 mb-4 leading-relaxed">{step.desc}</p>
                <ul class="grid grid-cols-2 gap-2">
                  {step.details.map((detail) => (
                    <li class="flex items-center gap-2 text-sm text-slate-500">
                      <span class="w-1.5 h-1.5 rounded-full bg-orange-500"></span>
                      {detail}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== COMPARISON ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-cyan-100 border border-cyan-200 rounded-full text-cyan-700 text-sm font-semibold mb-6">
          COMPARE OPTIONS
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
          Why outsource <span class="text-orange-500">design?</span>
        </h2>
        <p class="text-xl text-slate-600 max-w-3xl mx-auto">
          Compare the real costs and benefits of hiring in-house, working with freelancers, or partnering with a dedicated design outsourcing team.
        </p>
      </div>

      <!-- Comparison Table -->
      <div class="mt-16 overflow-x-auto">
        <table class="w-full min-w-[700px]">
          <thead>
            <tr class="border-b-2 border-slate-200">
              <th class="text-left py-4 px-4 text-slate-500 font-medium">Aspect</th>
              <th class="text-left py-4 px-4 text-slate-500 font-medium">In-House Designer</th>
              <th class="text-left py-4 px-4 text-slate-500 font-medium">Freelancers</th>
              <th class="text-left py-4 px-4 text-orange-600 font-semibold bg-orange-50 rounded-t-lg">
                <span class="flex items-center gap-2">
                  <span class="w-2 h-2 rounded-full bg-orange-500"></span>
                  Design Outsourcing
                </span>
              </th>
            </tr>
          </thead>
          <tbody>
            {comparison.map((row) => (
              <tr class="border-b border-slate-100 hover:bg-slate-50 transition-colors duration-300">
                <td class="py-5 px-4 text-slate-900 font-medium">{row.aspect}</td>
                <td class="py-5 px-4 text-slate-500 text-sm">{row.inHouse}</td>
                <td class="py-5 px-4 text-slate-500 text-sm">{row.freelancer}</td>
                <td class="py-5 px-4 text-orange-700 text-sm font-medium bg-orange-50/50">{row.outsourcing}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <!-- Summary boxes -->
      <div class="grid md:grid-cols-3 gap-6 mt-12">
        <div class="bg-slate-50 rounded-2xl border border-slate-100 p-6 text-center">
          <div class="text-3xl font-bold text-orange-500 mb-2">70%</div>
          <p class="text-slate-600 text-sm">Average cost savings vs in-house designer</p>
        </div>
        <div class="bg-slate-50 rounded-2xl border border-slate-100 p-6 text-center">
          <div class="text-3xl font-bold text-orange-500 mb-2">0</div>
          <p class="text-slate-600 text-sm">HR headaches, benefits, or equipment costs</p>
        </div>
        <div class="bg-slate-50 rounded-2xl border border-slate-100 p-6 text-center">
          <div class="text-3xl font-bold text-orange-500 mb-2">∞</div>
          <p class="text-slate-600 text-sm">Scalability—ramp up or down instantly</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== PRICING ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-orange-100 border border-orange-200 rounded-full text-orange-700 text-sm font-semibold mb-6">
          PRICING
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900">
          Simple, <span class="text-orange-500">transparent</span>
        </h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {pricingPlans.map((plan) => (
          <div class:list={[
            "relative rounded-2xl p-8 transition-all duration-300 hover:-translate-y-2",
            plan.highlighted
              ? "bg-slate-900 text-white shadow-2xl scale-105 z-10"
              : "bg-white border border-slate-200 hover:border-slate-300 hover:shadow-xl"
          ]}>
            {plan.highlighted && (
              <span class="absolute -top-4 left-1/2 -translate-x-1/2 bg-orange-500 text-white text-xs font-bold px-4 py-2 rounded-full shadow-lg">
                Most Popular
              </span>
            )}
            <h3 class={plan.highlighted ? "text-2xl font-semibold mb-2 text-white" : "text-2xl font-semibold mb-2 text-slate-900"}>{plan.title}</h3>
            <p class={plan.highlighted ? "text-sm mb-6 text-slate-300" : "text-sm mb-6 text-slate-600"}>{plan.desc}</p>
            <div class="mb-8">
              <span class={plan.highlighted ? "text-5xl font-bold text-white" : "text-5xl font-bold text-slate-900"}>{plan.price}</span>
              <span class={plan.highlighted ? "text-slate-400 text-lg" : "text-slate-500 text-lg"}>{plan.period}</span>
            </div>
            <ul class="space-y-4 mb-8">
              {plan.features.map((feature) => (
                <li class="flex items-center gap-3">
                  <svg class={plan.highlighted ? "w-5 h-5 text-green-400 flex-shrink-0" : "w-5 h-5 text-green-500 flex-shrink-0"} fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                  <span class={plan.highlighted ? "text-slate-300" : "text-slate-600"}>{feature}</span>
                </li>
              ))}
            </ul>
            <a
              href="/contact"
              class={plan.highlighted
                ? "block w-full py-4 text-center font-bold rounded-2xl bg-gradient-to-r from-orange-500 to-orange-600 text-white hover:from-orange-600 hover:to-orange-700 shadow-lg transition-all duration-300"
                : "block w-full py-4 text-center font-bold rounded-2xl bg-slate-900 text-white hover:bg-slate-800 transition-all duration-300"
              }
            >
              Get Started
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== WHY CODEBRAND ==================== -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
