---
import ServiciosLayout from "../../layouts/ServiciosLayout.astro";
import logoWhite from "../../assets/codebrand-white.svg";
import WhatsAppWidget from "../../components/WhatsAppWidget.astro";

import ServicesCatalog from "../../components/expo-producciones/ServicesCatalog.tsx";
import CodebrandSalesShowcase from "../../components/expo-producciones/CodebrandSalesShowcase.tsx";
import ServiciosFaq from "../../components/expo-producciones/ServiciosFaq.tsx";
import QuoteModal from "../../components/expo-producciones/QuoteModal.tsx";

import {
  SERVICES,
  ICON_PATHS,
  PROCESS_STEPS,
  TESTIMONIALS,
  TRUST_STATS,
  BRAND,
} from "../../data/expoProducciones";

const pageTitle =
  "Servicios Digitales a la Medida | Desarrollo, Sistemas, CRM y Branding · Codebrand";
const pageDescription =
  "Todos los servicios de Codebrand en un solo lugar: desarrollo web y apps, sistemas a medida, automatizaciones, CRM, SEO y branding. Selecciona lo que necesitas y recibe tu cotización.";

// Iniciales para los avatares de testimonios (sin imágenes externas).
const initialsOf = (name: string) =>
  name
    .split(" ")
    .slice(0, 2)
    .map((n) => n[0])
    .join("")
    .toUpperCase();

// ── Clases reutilizables (SOLO Tailwind) ───────────────────────────────────
const btnPrimary =
  "inline-flex items-center justify-center gap-2 min-h-[44px] cursor-pointer rounded-xl px-6 py-3 font-semibold text-white bg-gradient-to-b from-orange-400 to-orange-600 shadow-[inset_0_1px_0_rgb(255_255_255/0.22),0_10px_28px_-10px_rgb(249_115_22/0.6)] transition duration-200 hover:-translate-y-px hover:brightness-105 active:translate-y-0 active:scale-[0.985] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-400 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a0a0f] motion-reduce:transition-none motion-reduce:hover:translate-y-0";
const btnPrimarySm =
  "inline-flex items-center justify-center gap-2 min-h-[44px] cursor-pointer rounded-xl px-4 py-2 text-[0.9rem] font-semibold text-white bg-gradient-to-b from-orange-400 to-orange-600 shadow-[inset_0_1px_0_rgb(255_255_255/0.22),0_10px_28px_-10px_rgb(249_115_22/0.6)] transition duration-200 hover:-translate-y-px hover:brightness-105 active:scale-[0.985] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-400 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a0a0f] motion-reduce:transition-none motion-reduce:hover:translate-y-0";
const btnGhost =
  "inline-flex items-center justify-center gap-2 min-h-[44px] cursor-pointer rounded-xl px-6 py-3 font-semibold text-white/80 bg-white/[0.035] border border-white/[0.12] transition-colors duration-200 hover:bg-white/[0.07] hover:text-white hover:border-white/20 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/50 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a0a0f]";
const eyebrow =
  "inline-flex items-center text-[0.78rem] font-semibold text-orange-300 px-3.5 py-1.5 rounded-full bg-orange-500/[0.08] border border-orange-500/20";
---

<ServiciosLayout title={pageTitle} description={pageDescription} noindex={true}>
  <!-- #ep-page: todo el contenido de la página (se vuelve `inert` con el modal abierto) -->
  <div id="ep-page">
    <!-- Cola de clics previa a la hidratación: si alguien toca un CTA antes de
         que el modal hidrate, guardamos la intención para no perderla. -->
    <script is:inline>
      (function () {
        if (window.__epQuoteInit) return;
        window.__epQuoteInit = true;
        function onClick(e) {
          var el =
            e.target && e.target.closest
              ? e.target.closest("[data-quote-open]")
              : null;
          if (!el) return;
          window.__epQuotePending = {
            serviceId: el.getAttribute("data-service-id") || undefined,
          };
        }
        document.addEventListener("click", onClick);
        document.addEventListener(
          "astro:before-swap",
          function () {
            document.removeEventListener("click", onClick);
            window.__epQuoteInit = undefined;
            window.__epQuotePending = undefined;
          },
          { once: true },
        );
      })();
    </script>

    <!-- Fondo decorativo silencioso (Tailwind puro): grid sutil + glows + viñeta -->
    <div class="fixed inset-0 -z-10 overflow-hidden point
    er-events-none" aria-hidden="true">
      <div class="absolute inset-0 bg-[linear-gradient(rgb(255_255_255/0.022)_1px,transparent_1px),linear-gradient(90deg,rgb(255_255_255/0.022)_1px,transparent_1px)] bg-[size:60px_60px] [mask-image:radial-gradient(ellipse_90%_55%_at_50%_-5%,#000_35%,transparent_72%)]"></div>
      <div class="absolute -top-[260px] left-1/2 -translate-x-1/2 w-[760px] h-[540px] rounded-full bg-[radial-gradient(circle,rgb(249_115_22/0.12),transparent_70%)]"></div>
      <div class="absolute -bottom-[200px] -left-[160px] w-[540px] h-[540px] rounded-full bg-[radial-gradient(circle,rgb(45_212_191/0.06),transparent_70%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_100%_100%_at_50%_0%,transparent_55%,rgb(0_0_0/0.45)_100%)]"></div>
    </div>

    <!-- Navigation -->
    <nav class="fixed top-0 inset-x-0 z-50 bg-[#08080c] border-b border-white/[0.08]">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 h-16 flex items-center justify-between">
        <a href="/" class="shrink-0" aria-label="Codebrand inicio">
          <img src={logoWhite.src} alt="Codebrand" width="118" height="34" loading="eager" decoding="async" />
        </a>
        <div class="hidden md:flex items-center gap-9 text-[0.9rem] text-white/65">
          <a href="#servicios" class="relative transition-colors hover:text-white after:absolute after:left-0 after:-bottom-1.5 after:h-px after:w-0 after:bg-orange-500 after:transition-[width] after:duration-300 hover:after:w-full focus-visible:outline-none focus-visible:text-white focus-visible:after:w-full">Servicios</a>
          <a href="#producto" class="relative transition-colors hover:text-white after:absolute after:left-0 after:-bottom-1.5 after:h-px after:w-0 after:bg-orange-500 after:transition-[width] after:duration-300 hover:after:w-full focus-visible:outline-none focus-visible:text-white focus-visible:after:w-full">Codebrand Sales</a>
          <a href="#proceso" class="relative transition-colors hover:text-white after:absolute after:left-0 after:-bottom-1.5 after:h-px after:w-0 after:bg-orange-500 after:transition-[width] after:duration-300 hover:after:w-full focus-visible:outline-none focus-visible:text-white focus-visible:after:w-full">Cómo trabajamos</a>
          <a href="#faq" class="relative transition-colors hover:text-white after:absolute after:left-0 after:-bottom-1.5 after:h-px after:w-0 after:bg-orange-500 after:transition-[width] after:duration-300 hover:after:w-full focus-visible:outline-none focus-visible:text-white focus-visible:after:w-full">FAQ</a>
        </div>
        <button type="button" data-quote-open class={btnPrimarySm}>
          Cotizar
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </button>
      </div>
    </nav>

    <!-- ───────────────────────── HERO (asimétrico, mobile-first) ───────────────────────── -->
    <section class="relative pt-28 sm:pt-32 lg:pt-36 pb-16 sm:pb-20">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <div class="grid lg:grid-cols-12 gap-12 lg:gap-10 lg:items-center">
          <!-- Columna de mensaje -->
          <div class="lg:col-span-7">
            <span class={eyebrow}>Tu equipo digital, en un solo lugar</span>

            <h1 class="mt-6 text-hero text-balance lg:text-[3.4rem] lg:leading-[1.07] xl:text-[3.85rem]">
              Desarrollo, sistemas y marca para <span class="text-orange-400">hacer crecer</span> tu negocio
            </h1>

            <p class="mt-6 text-lead text-white/65 max-w-xl">
              Un solo equipo para tu web, apps, sistemas a medida, automatizaciones, CRM y branding.
            </p>

            <div class="mt-9 flex flex-col sm:flex-row sm:items-center gap-3">
              <button type="button" data-quote-open class={btnPrimary}>
                Armar mi cotización
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </button>
              <a href="#servicios" class={btnGhost}>Ver servicios</a>
            </div>
          </div>

          <!-- Quick-pick: empieza por un servicio -->
          <div class="lg:col-span-5">
            <div class="relative rounded-3xl border border-white/[0.09] bg-[#121219] p-5 sm:p-6 shadow-[inset_0_1px_0_rgb(255_255_255/0.06),0_30px_80px_-40px_rgb(0_0_0/0.9)]">
              <div class="flex items-baseline justify-between gap-3 px-1">
                <div class="min-w-0">
                  <h2 class="text-base font-semibold text-white">Empieza por un servicio</h2>
                  <p class="mt-0.5 text-sm text-white/55">Toca uno para pedir tu cotización.</p>
                </div>
                <span class="inline-flex items-center gap-1 text-xs text-white/55 whitespace-nowrap shrink-0">
                  <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.07 3.29a1 1 0 00.95.69h3.46c.97 0 1.37 1.24.59 1.81l-2.8 2.03a1 1 0 00-.37 1.12l1.07 3.29c.3.92-.75 1.69-1.54 1.12l-2.8-2.03a1 1 0 00-1.17 0l-2.8 2.03c-.78.57-1.84-.2-1.54-1.12l1.07-3.29a1 1 0 00-.36-1.12l-2.8-2.03c-.79-.57-.39-1.81.58-1.81h3.46a1 1 0 00.95-.69l1.07-3.29z"/></svg>
                  <strong class="text-white">5.0</strong> Google
                </span>
              </div>

              <ul class="mt-5 flex flex-col gap-1.5">
                {SERVICES.map((s) => (
                  <li>
                    <button
                      type="button"
                      data-quote-open
                      data-service-id={s.id}
                      class="group flex items-center gap-3 w-full min-h-[44px] cursor-pointer p-3 rounded-[0.85rem] border border-transparent text-left transition-colors duration-200 hover:bg-white/[0.045] hover:border-orange-500/30 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-orange-400/70"
                      aria-label={`Cotizar: ${s.shortLabel}`}
                    >
                      <span class="inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-[0.7rem] text-orange-300 bg-orange-500/10 border border-orange-500/20 transition-colors duration-200 group-hover:bg-orange-500/[0.18] group-hover:text-orange-200">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="h-[18px] w-[18px]" aria-hidden="true">
                          <path d={ICON_PATHS[s.icon]} stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                      </span>
                      <span class="flex-1 min-w-0">
                        <span class="block text-sm font-medium text-white truncate">{s.shortLabel}</span>
                      </span>
                      <svg class="h-4 w-4 shrink-0 text-white/25 -translate-x-1 opacity-0 transition-all duration-200 group-hover:translate-x-0 group-hover:opacity-100 group-hover:text-orange-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                      </svg>
                    </button>
                  </li>
                ))}
              </ul>

              <button type="button" data-quote-open class={`${btnPrimary} w-full mt-5`}>
                Armar cotización a medida
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </button>
              <p class="mt-3 text-center text-xs text-white/55">Respuesta en 24 h · Sin compromiso</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────────────────────── Trust band ───────────────────────── -->
    <section class="border-y border-white/[0.07] bg-white/[0.015]">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 py-9 sm:py-10">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-8">
          {TRUST_STATS.map((stat) => (
            <div class="px-4 sm:px-6 text-center lg:border-l lg:border-white/[0.07] lg:first:border-l-0">
              <div class="text-3xl sm:text-4xl font-bold tracking-tight text-white">{stat.value}</div>
              <div class="mt-1 text-xs sm:text-sm text-white/55">{stat.label}</div>
            </div>
          ))}
        </div>
        <p class="mt-7 text-center text-sm text-white/55">
          Equipo bilingüe que trabaja en tu zona horaria, con acompañamiento real en cada etapa.
        </p>
      </div>
    </section>

    <!-- Services catalog (componente, ya en Tailwind) -->
    <ServicesCatalog
      client:visible
      title="Soluciones para cada etapa de tu negocio"
      subtitle="Cada servicio incluye precio de referencia, qué incluye y cómo trabajamos. Combina los que necesites."
    />

    <!-- Codebrand Sales (componente) -->
    <div class="bg-white/[0.015] border-y border-white/[0.07]">
      <CodebrandSalesShowcase client:visible id="producto" />
    </div>

    <!-- ───────────────────────── Proceso: timeline conectada ───────────────────────── -->
    <section id="proceso" class="scroll-mt-24 py-20 sm:py-28">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <div class="max-w-2xl mb-14 sm:mb-16">
          <span class={eyebrow}>Cómo trabajamos</span>
          <h2 class="mt-5 text-display-2 text-balance">Un proceso claro, de principio a fin</h2>
          <p class="mt-4 text-white/55 max-w-lg">
            Sin sorpresas: sabes qué sigue en cada paso, desde la primera conversación hasta el soporte.
          </p>
        </div>

        <ol class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-10">
          {PROCESS_STEPS.map((step) => (
            <li class="relative lg:before:content-[''] lg:before:absolute lg:before:top-6 lg:before:left-[3.4rem] lg:before:right-[-2rem] lg:before:h-px lg:before:bg-gradient-to-r lg:before:from-orange-500/40 lg:before:to-white/[0.06] lg:last:before:hidden">
              <span class="relative z-[1] inline-flex h-12 w-12 items-center justify-center rounded-full text-[0.95rem] font-bold text-orange-300 bg-orange-500/[0.08] border border-orange-500/25">{step.num}</span>
              <h3 class="mt-5 text-lg font-semibold text-white">{step.title}</h3>
              <p class="mt-2 text-sm text-white/55 leading-relaxed">{step.desc}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ───────────────────────── Testimonios ───────────────────────── -->
    <section class="py-20 sm:py-28 bg-white/[0.015] border-y border-white/[0.07]">
      <div class="mx-auto max-w-7xl px-4 sm:px-6">
        <div class="max-w-2xl mb-14 sm:mb-16">
          <h2 class="text-display-2 text-balance">Lo que dicen nuestros clientes</h2>
          <p class="mt-4 text-white/55">Resultados reales de negocios que confiaron en nosotros.</p>
        </div>
        <div class="grid md:grid-cols-3 gap-5">
          {TESTIMONIALS.map((t) => (
            <figure class="relative flex flex-col h-full rounded-[1.25rem] border border-white/[0.08] bg-[#101015] p-6 sm:p-7 transition duration-300 hover:border-white/15 hover:bg-[#15151b] hover:-translate-y-1 motion-reduce:transition-none motion-reduce:hover:translate-y-0">
              <svg class="h-6 w-6 text-orange-500/55 mb-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M9.5 7C6.46 7 4 9.46 4 12.5V18h6v-6H7.5c0-1.38 1.12-2.5 2.5-2.5V7zm10 0c-3.04 0-5.5 2.46-5.5 5.5V18h6v-6h-2.5c0-1.38 1.12-2.5 2.5-2.5V7z"/></svg>
              <blockquote class="text-[0.95rem] text-white/75 leading-relaxed flex-1">{t.text}</blockquote>
              <figcaption class="mt-6 pt-5 border-t border-white/[0.08] flex items-center gap-3">
                <span class="inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-[0.8rem] font-bold text-orange-200 bg-orange-500/[0.12] border border-orange-500/[0.22]">{initialsOf(t.name)}</span>
                <span class="min-w-0">
                  <span class="block font-semibold text-white text-sm truncate">{t.name}</span>
                  <span class="block text-xs text-white/55 truncate">{t.role}</span>
                </span>
                <span class="ml-auto flex gap-0.5 shrink-0">
                  {Array.from({ length: t.rating }).map(() => (
                    <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.07 3.29a1 1 0 00.95.69h3.46c.97 0 1.37 1.24.59 1.81l-2.8 2.03a1 1 0 00-.37 1.12l1.07 3.29c.3.92-.75 1.69-1.54 1.12l-2.8-2.03a1 1 0 00-1.17 0l-2.8 2.03c-.78.57-1.84-.2-1.54-1.12l1.07-3.29a1 1 0 00-.36-1.12l-2.8-2.03c-.79-.57-.39-1.81.58-1.81h3.46a1 1 0 00.95-.69l1.07-3.29z"/></svg>
                  ))}
                </span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ (componente) -->
    <div id="faq">
      <ServiciosFaq client:visible />
    </div>

    <!-- ───────────────────────── Final CTA ───────────────────────── -->
    <section class="py-20 sm:py-28">
      <div class="mx-auto max-w-5xl px-4 sm:px-6">
        <div class="relative overflow-hidden rounded-[1.75rem] border border-white/10 bg-[#0f0f15] p-8 sm:p-14">
          <div aria-hidden="true" class="absolute inset-0 bg-[radial-gradient(120%_120%_at_0%_0%,rgb(249_115_22/0.12),transparent_55%)]"></div>
          <div aria-hidden="true" class="absolute -top-[40%] -right-[10%] w-[460px] h-[460px] rounded-full bg-[radial-gradient(circle,rgb(249_115_22/0.18),transparent_70%)] pointer-events-none"></div>
          <div class="relative">
            <h2 class="text-display-2 text-balance max-w-2xl">¿Listo para llevar tu negocio al siguiente nivel?</h2>
            <p class="mt-4 text-white/60 text-base sm:text-lg max-w-xl">
              Selecciona tus servicios y recibe una cotización personalizada. Sin compromiso.
            </p>
            <div class="mt-8 flex flex-col sm:flex-row sm:items-center gap-3">
              <button type="button" data-quote-open class={btnPrimary}>
                Armar mi cotización
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              </button>
              <a href={`${BRAND.whatsappUrl}?text=${encodeURIComponent("Hola, quiero información sobre sus servicios.")}`} target="_blank" rel="noopener noreferrer" class={btnGhost}>
                Escríbenos por WhatsApp
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="border-t border-white/[0.07] py-10">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
        <img src={logoWhite.src} alt="Codebrand" width="110" height="32" loading="lazy" decoding="async" />
        <p class="text-xs text-white/55">© 2026 Codebrand. Todos los derechos reservados.</p>
        <div class="flex items-center gap-4 text-xs text-white/55">
          <a href="/terms" class="hover:text-white transition-colors">Términos</a>
          <a href="/privacy" class="hover:text-white transition-colors">Privacidad</a>
          <a href={`mailto:${BRAND.email}`} class="hover:text-white transition-colors">{BRAND.email}</a>
        </div>
      </div>
    </footer>

    <WhatsAppWidget />
  </div>

  <!-- Quote modal — montado fuera de #ep-page para que nunca se vuelva inert -->
  <QuoteModal client:load />
</ServiciosLayout>

<style is:global>
  /* CSS global FUNCIONAL del modal (no es diseño): bloqueo de scroll sin salto,
     ocultar el widget de WhatsApp con el modal abierto, y offset de anclas para
     la nav fija (los ids viven dentro de islas React). */
  html { scrollbar-gutter: stable; }
  html.ep-modal-open { overflow: hidden; }
  html.ep-modal-open #whatsapp-widget {
    visibility: hidden;
    pointer-events: none;
  }
  #empezar, #servicios, #producto, #faq { scroll-margin-top: 6rem; }
</style>
