  <script>
    // @ts-nocheck
    function initPage() {
      // ── Fade-up observer ──────────────────────────────────────
      const fadeObs = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("visible");
            fadeObs.unobserve(e.target);
          }
        }),
        { threshold: 0.07, rootMargin: "0px 0px -40px 0px" }
      );
      document.querySelectorAll(".fade-up").forEach((el) => {
        // If already in viewport (e.g. on resize / fast load), mark visible immediately
        const rect = el.getBoundingClientRect();
        if (rect.top < window.innerHeight && rect.bottom > 0) {
          el.classList.add("visible");
        } else {
          fadeObs.observe(el);
        }
      });

      // ── Performance widget: ring + counter ────────────────────
      const ring    = document.getElementById("perf-ring");
      const counter = document.getElementById("perf-counter");
      const widget  = document.getElementById("perf-widget");
      if (ring && counter && widget) {
        // Reset state on each page load so animation replays
        ring.style.strokeDashoffset = "326.7";
        counter.textContent = "0";
        const TARGET       = 98;
        const CIRCUMFERENCE = 326.7;
        const endOffset    = CIRCUMFERENCE * (1 - TARGET / 100);
        const perfObs = new IntersectionObserver(function(entries) {
          if (!entries[0].isIntersecting) return;
          perfObs.disconnect();
          ring.style.strokeDashoffset = String(endOffset);
          var duration = 1600;
          var start    = performance.now();
          function tick(now) {
            var elapsed = Math.min(now - start, duration);
            var ease    = 1 - Math.pow(1 - elapsed / duration, 4);
            counter.textContent = String(Math.round(ease * TARGET));
            if (elapsed < duration) requestAnimationFrame(tick);
          }
          requestAnimationFrame(tick);
        }, { threshold: 0.4 });
        perfObs.observe(widget);
      }

      // ── Sticky mobile CTA ─────────────────────────────────────
      var cta  = document.getElementById("sticky-cta");
      var hero = document.querySelector("section");
      if (cta && hero) {
        var ctaObs = new IntersectionObserver(function(entries) {
          cta.classList.toggle("translate-y-full", entries[0].isIntersecting);
        }, { threshold: 0.1 });
        ctaObs.observe(hero);
      }
    }

    // Run on hard load AND on Astro view-transition navigation
    document.addEventListener("astro:page-load", initPage);
    // Fallback for pages without view transitions
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initPage);
    } else {
      initPage();
    }
  </script>
