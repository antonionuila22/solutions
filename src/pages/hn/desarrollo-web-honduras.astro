    @keyframes trust-scroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* ─── Performance widget ────────────────────────────────── */
    .perf-card {
      background: rgba(10,10,18,0.85);
      border: 1px solid rgba(255,255,255,0.09);
      backdrop-filter: blur(24px);
