            <h2 class="text-4xl md:text-6xl font-bold text-white">Equipo dedicado vs. planilla vs. freelancers</h2>
            <p class="text-neutral-400 text-xl mt-4">Toda la capacidad, sin el peso ni el descontrol de las otras opciones.</p>
          </div>

          <div class="grid md:grid-cols-3 gap-5 items-start">
            {comparison.map((col, i) => (
              <div class={`fade-up glass p-8 ${col.featured ? "border-blue-500/30" : ""}`} style={`transition-delay: ${i * 0.06}s`}>
                <h3 class={`text-xl font-bold mb-6 ${col.featured ? "text-gradient" : "text-white"}`}>{col.label}</h3>
                <ul class="space-y-3">
                  {col.points.map((point) => (
                    <li class="flex items-start gap-3 text-neutral-300">
                      {col.featured ? (
                        <svg class="w-5 h-5 text-blue-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                      ) : (
                        <svg class="w-5 h-5 text-neutral-500 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                      )}
                      {point}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- TEAM COMPOSITION -->
      <section class="py-28 px-6">
        <div class="max-w-7xl mx-auto">
