---
/**
 * Honduras Index Page
 * Hub para todas las páginas de servicios en Honduras
 */
import HnLayout from "../../layouts/HnLayout.astro";
import { BUSINESS_INFO } from "../../configs/business";

const title = "Codebrand Honduras | Agencia Digital Full-Service — Web, Branding y SEO";
const description = "Agencia digital en Honduras con estándares de calidad americana. Creamos sitios web, tiendas online, branding, SEO y marketing digital para empresas hondureñas. 127+ reseñas 5 estrellas. Precios en Lempiras.";
const keywords = "agencia digital honduras, desarrollo web honduras, diseño web tegucigalpa, tienda online honduras, seo honduras, páginas web honduras, branding honduras, marketing digital honduras, diseño web san pedro sula";

const services = [
  {
    title: "Sitios Web Profesionales",
    description: "Páginas web empresariales rápidas, modernas y optimizadas para Google. Diseño a medida que transmite confianza y convierte visitantes en clientes.",
    href: "/hn/sitios-web-empresas-honduras",
    icon: "💻",
    price: "Desde L. 12,500"
  },
  {
    title: "Tienda Online Honduras",
    description: "E-commerce completo con carrito de compras, pagos en línea e inventario. Vende tus productos o servicios las 24 horas del día.",
    href: "/hn/tienda-online-honduras",
    icon: "🛒",
    price: "Desde L. 62,500"
  },
  {
    title: "SEO Honduras",
    description: "Posicionamiento en Google para que tus clientes te encuentren primero. Estrategia local, nacional o regional con reportes mensuales.",
    href: "/hn/seo-honduras",
    icon: "🔍",
    price: "Desde L. 5,000/mes"
  },
  {
    title: "Diseño, Branding y Marketing",
    description: "Logotipo, identidad de marca, redes sociales, video y diseño gráfico. Todo lo que necesita tu negocio para destacar, bajo un mismo equipo.",
    href: "/contact",
    icon: "🎨",
    price: "Cotización personalizada"
  }
];

const benefits = [
  { icon: "🏆", title: "Calidad de Agencia Americana", desc: "Trabajamos con los mismos estándares que agencias de EE.UU., con más de 127 reseñas de 5 estrellas que lo respaldan." },
  { icon: "💬", title: "Comunicación en Español", desc: "Sin intermediarios ni barreras. WhatsApp directo, en tu idioma y en tu zona horaria." },
  { icon: "💰", title: "Precios en Lempiras", desc: "Costos transparentes en HNL, sin sorpresas cambiarias ni conversiones. Planes de pago flexibles." },
  { icon: "⚡", title: "Entrega en Semanas", desc: "Sitios web en 2-4 semanas, no meses. Revisiones semanales para que veas el avance." },
  { icon: "🔧", title: "Agencia Full-Service", desc: "Web, SEO, branding, redes sociales y video bajo un mismo equipo. No necesitas contratar a varios proveedores." },
  { icon: "🔒", title: "Soporte Post-Entrega", desc: "No desaparecemos al entregar el proyecto. Planes de mantenimiento, actualizaciones y soporte técnico continuo." }
];

const faqs = [
  {
    question: "¿Cuánto cuesta un sitio web en Honduras?",
    answer: "Los precios varían según el tipo de proyecto. Un sitio web básico comienza en L. 12,500. Un sitio empresarial con más páginas y funcionalidades desde L. 37,500. Una tienda online completa desde L. 62,500. Todos los precios incluyen dominio, hosting y SSL por 1 año. Ofrecemos planes de pago flexibles."
  },
  {
    question: "¿En cuánto tiempo entregan un sitio web?",
    answer: "Un sitio web básico lo entregamos en 2-3 semanas. Un sitio empresarial en 4-6 semanas. Una tienda online en 6-8 semanas. Trabajamos con revisiones semanales para que veas el avance en todo momento."
  },
  {
    question: "¿Puedo pagar en Lempiras?",
    answer: "Sí, todos nuestros precios están en Lempiras hondureños. Aceptamos transferencias bancarias, depósitos y pagos con tarjeta. Ofrecemos facilidades de pago para proyectos grandes."
  },
  {
    question: "¿Qué incluye el precio del sitio web?",
    answer: "Incluye: diseño personalizado, desarrollo completo, dominio por 1 año, hosting profesional por 1 año, SSL (candado de seguridad), capacitación para administrar tu contenido, y soporte técnico por 3 meses después del lanzamiento."
  },
  {
    question: "¿Cuánto cuesta el SEO en Honduras?",
    answer: "Nuestros planes de SEO comienzan en L. 5,000/mes e incluyen análisis de palabras clave, optimización técnica, creación de contenido, SEO local en Google Maps y reportes mensuales. El precio varía según la competencia de tu industria y alcance geográfico. Ofrecemos evaluaciones gratuitas."
  },
  {
    question: "¿Solo hacen sitios web o también otros servicios digitales?",
    answer: "Somos una agencia full-service. Además de sitios web y e-commerce, ofrecemos SEO, branding, diseño de logotipos, redes sociales, producción de video, animación y diseño gráfico. Puedes contratar servicios por separado o un paquete completo."
  },
  {
    question: "¿Cómo es el proceso de trabajo?",
    answer: "1) Nos contactas por WhatsApp. 2) Agendamos una llamada para entender tu proyecto. 3) Te enviamos propuesta y precio detallado. 4) Diseñamos y desarrollamos con revisiones semanales. 5) Lanzamos tu sitio y te capacitamos para administrarlo."
  },
  {
    question: "¿Ofrecen mantenimiento después de la entrega?",
    answer: "Sí, ofrecemos planes de mantenimiento desde L. 2,500/mes que incluyen actualizaciones de seguridad, respaldos automáticos, soporte técnico y cambios menores de contenido. No te dejamos solo después del lanzamiento."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer }
  }))
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://www.codebrand.us/hn/#organization",
  name: "Codebrand Honduras",
  description: description,
  url: "https://www.codebrand.us/hn/",
  telephone: BUSINESS_INFO.hn.phone,
  email: BUSINESS_INFO.hn.email,
  address: {
    "@type": "PostalAddress",
    addressLocality: "San Pedro Sula",
    addressRegion: "Cortés",
    addressCountry: "HN"
  },
  areaServed: {
    "@type": "Country",
    name: "Honduras"
  },
  priceRange: "L. 12,500 - L. 250,000",
  paymentAccepted: "Transferencia Bancaria, Tarjeta de Crédito, Efectivo",
  currenciesAccepted: "HNL",
  openingHours: "Mo-Fr 08:00-18:00",
  sameAs: [
    BUSINESS_INFO.social.facebook,
    BUSINESS_INFO.social.instagram,
    BUSINESS_INFO.social.linkedin
  ]
};
---

<HnLayout
  title={title}
  description={description}
  keywords={keywords}
  canonicalOverride="https://www.codebrand.us/hn/"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

  <style>
    .page-bg { background: linear-gradient(135deg, #030303 0%, #0a1628 100%); }
    .gradient-orbs { position: fixed; inset: 0; overflow: hidden; pointer-events: none; z-index: 0; }
    .orb { position: absolute; border-radius: 50%; filter: blur(80px); opacity: 0.4; animation: float 20s ease-in-out infinite; }
    .orb-1 { width: 600px; height: 600px; background: linear-gradient(135deg, #0891b2, #06b6d4); top: -200px; left: -100px; }
    .orb-2 { width: 500px; height: 500px; background: linear-gradient(135deg, #f59e0b, #0891b2); top: 60%; right: -150px; animation-delay: -7s; }
    @keyframes float { 0%, 100% { transform: translate(0, 0) scale(1); } 50% { transform: translate(30px, -30px) scale(1.05); } }
    .noise { position: fixed; inset: 0; background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E"); opacity: 0.03; pointer-events: none; z-index: 1; }
    .text-display { font-size: clamp(2.5rem, 10vw, 7rem); line-height: 0.95; letter-spacing: -0.03em; font-weight: 800; }
    .text-gradient { background: linear-gradient(135deg, #06b6d4 0%, #0891b2 50%, #f59e0b 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .glass { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(20px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 24px; }
    .glass-hover { transition: all 0.4s ease; }
    .glass-hover:hover { background: rgba(255, 255, 255, 0.06); transform: translateY(-6px); border-color: rgba(6, 182, 212, 0.3); }
    .btn-whatsapp { background: linear-gradient(135deg, #25D366, #128C7E); color: #fff; font-weight: 600; padding: 1.25rem 2.5rem; border-radius: 100px; transition: all 0.4s ease; display: inline-flex; align-items: center; gap: 0.75rem; }
    .btn-whatsapp:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 20px 40px rgba(37, 211, 102, 0.3); }
    .btn-outline { color: #fff; font-weight: 500; padding: 1.25rem 2.5rem; border-radius: 100px; border: 1px solid rgba(255, 255, 255, 0.2); transition: all 0.4s ease; }
    .btn-outline:hover { border-color: rgba(6, 182, 212, 0.5); background: rgba(6, 182, 212, 0.1); }
    .fade-up { opacity: 0; transform: translateY(40px); transition: opacity 0.8s ease, transform 0.8s ease; }
    .fade-up.visible { opacity: 1; transform: translateY(0); }
    .service-card { position: relative; overflow: hidden; }
    .service-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: linear-gradient(90deg, #06b6d4, #f59e0b); transform: scaleX(0); transition: transform 0.4s ease; }
    .service-card:hover::before { transform: scaleX(1); }
    .faq-item { border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
    .faq-item:last-child { border-bottom: none; }
  </style>

  <div class="page-bg min-h-screen relative overflow-hidden text-white">
    <div class="gradient-orbs"><div class="orb orb-1"></div><div class="orb orb-2"></div></div>
    <div class="noise"></div>

    <div class="relative z-10">
      <!-- Hero Section -->
      <section class="min-h-screen flex flex-col justify-center px-6 pt-32 pb-20">
        <div class="max-w-7xl mx-auto w-full">
          <div class="fade-up mb-8">
            <span class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full glass border border-cyan-500/30">
              <span class="text-2xl">🇭🇳</span>
              <span class="text-cyan-300 text-sm font-medium">Agencia Digital en Honduras</span>
            </span>
          </div>

          <h1 class="text-display mb-6">
            <span class="fade-up block text-white">Desarrollo Web</span>
            <span class="fade-up block text-gradient">Honduras</span>
          </h1>

          <p class="fade-up text-xl md:text-2xl text-neutral-300 max-w-2xl mb-12 leading-relaxed">
            Sitios web, tiendas online, branding y marketing digital para empresas hondureñas.<br class="hidden md:block" />
            <strong class="text-white">Calidad de agencia americana, precios en Lempiras.</strong>
          </p>

          <div class="fade-up flex flex-wrap gap-4 mb-16">
            <a href={`https://wa.me/${BUSINESS_INFO.hn.whatsapp}?text=Hola,%20me%20interesa%20un%20sitio%20web`} class="btn-whatsapp">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Cotizar por WhatsApp
            </a>
            <a href="#servicios" class="btn-outline">Ver Servicios</a>
          </div>

          <!-- Quick Stats -->
          <div class="fade-up grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="text-center p-5 glass rounded-2xl">
              <div class="text-3xl md:text-4xl font-bold text-gradient">127+</div>
              <div class="text-neutral-400 text-sm mt-1">Reseñas 5 Estrellas</div>
            </div>
            <div class="text-center p-5 glass rounded-2xl">
              <div class="text-3xl md:text-4xl font-bold text-gradient">5+</div>
              <div class="text-neutral-400 text-sm mt-1">Años de Experiencia</div>
            </div>
            <div class="text-center p-5 glass rounded-2xl">
              <div class="text-3xl md:text-4xl font-bold text-gradient">&lt;24h</div>
              <div class="text-neutral-400 text-sm mt-1">Primera Respuesta</div>
            </div>
            <div class="text-center p-5 glass rounded-2xl">
              <div class="text-3xl md:text-4xl font-bold text-gradient">L.12,500</div>
              <div class="text-neutral-400 text-sm mt-1">Precio Inicial</div>
            </div>
          </div>
        </div>
      </section>

      <!-- Services Section -->
      <section id="servicios" class="py-24 px-6">
        <div class="max-w-7xl mx-auto">
          <div class="fade-up text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Todo lo que tu negocio necesita</h2>
            <p class="text-xl text-neutral-400 max-w-2xl mx-auto">
              Soluciones digitales completas bajo un mismo equipo, sin necesidad de múltiples proveedores
            </p>
          </div>

          <div class="grid md:grid-cols-2 gap-6">
            {services.map((service, i) => (
              <a href={service.href} class="fade-up service-card glass glass-hover p-8 block" style={`transition-delay: ${i * 0.1}s`}>
                <div class="flex items-start gap-4">
                  <div class="text-4xl">{service.icon}</div>
                  <div class="flex-1">
                    <h3 class="text-2xl font-bold text-white mb-2">{service.title}</h3>
                    <p class="text-neutral-400 mb-4">{service.description}</p>
                    <div class="flex items-center justify-between">
                      <span class="text-cyan-400 font-semibold">{service.price}</span>
                      <span class="text-neutral-500 text-sm flex items-center gap-1">
                        Ver más
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                      </span>
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- Benefits Section -->
      <section class="py-24 px-6">
        <div class="max-w-7xl mx-auto">
          <div class="fade-up text-center mb-16">
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">¿Por Qué Codebrand?</h2>
            <p class="text-xl text-neutral-400">Calidad de agencia americana con la cercanía y precios del mercado hondureño</p>
          </div>

          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
            {benefits.map((benefit, i) => (
              <div class="fade-up glass p-6 rounded-2xl" style={`transition-delay: ${i * 0.08}s`}>
                <div class="text-3xl mb-3">{benefit.icon}</div>
                <h3 class="text-lg font-semibold text-white mb-2">{benefit.title}</h3>
                <p class="text-neutral-400 text-sm">{benefit.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Prose Section for SEO -->
      <section class="py-24 px-6">
        <div class="max-w-4xl mx-auto">
          <div class="fade-up">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-8">Agencia Digital en Honduras con Estándares Internacionales</h2>
            <div class="prose prose-lg prose-invert max-w-none space-y-6">
              <p class="text-neutral-300 leading-relaxed">
                En <strong class="text-white">Codebrand</strong> somos una agencia digital con sede en San Pedro Sula que trabaja para clientes en EE.UU., Latinoamérica y Honduras. Eso significa que traemos los mismos procesos, tecnologías y estándares de calidad que usamos con nuestros clientes americanos — pero con atención directa en español, precios en Lempiras y comunicación en tu zona horaria.
              </p>
              <p class="text-neutral-300 leading-relaxed">
                Nuestro equipo ha completado <strong class="text-white">más de 127 proyectos con calificación de 5 estrellas</strong> para empresas de salud, e-commerce, bienes raíces, restaurantes, y más. Ya sea que necesites un <a href="/hn/sitios-web-empresas-honduras" class="text-cyan-400 hover:text-cyan-300">sitio web para tu empresa</a>, una <a href="/hn/tienda-online-honduras" class="text-cyan-400 hover:text-cyan-300">tienda online</a> o mejorar tu <a href="/hn/seo-honduras" class="text-cyan-400 hover:text-cyan-300">posicionamiento en Google</a>, tenemos la experiencia para hacerlo bien.
              </p>
              <p class="text-neutral-300 leading-relaxed">
                Desarrollamos con tecnologías modernas — <strong class="text-white">React, Next.js, TypeScript y Node.js</strong> — garantizando que tu sitio sea rápido, seguro, escalable y fácil de administrar. No usamos plantillas genéricas; cada proyecto es diseñado y desarrollado a medida para reflejar tu marca y atraer a tus clientes.
              </p>
              <p class="text-neutral-300 leading-relaxed">
                Además del desarrollo web, ofrecemos <strong class="text-white">branding, diseño de logotipos, redes sociales, producción de video y SEO</strong> — todo bajo el mismo equipo para que no tengas que coordinar con múltiples proveedores. Un socio digital completo para hacer crecer tu negocio en Honduras.
              </p>
              <p class="text-neutral-300 leading-relaxed">
                Desde San Pedro Sula atendemos a clientes en todo Honduras: Tegucigalpa, La Ceiba, Choluteca, Comayagua, Santa Rosa de Copán y más. Trabajamos 100% de forma remota por WhatsApp y videollamada, sin necesidad de reuniones presenciales.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQ Section -->
      <section class="py-24 px-6">
        <div class="max-w-4xl mx-auto">
          <div class="fade-up text-center mb-12">
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-4">Preguntas Frecuentes</h2>
          </div>

          <div class="fade-up glass p-8 rounded-3xl">
            {faqs.map((faq, i) => (
              <div class="faq-item py-6">
                <h3 class="text-lg font-semibold text-white mb-3">{faq.question}</h3>
                <p class="text-neutral-400">{faq.answer}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA Section -->
      <section class="py-32 px-6 relative overflow-hidden">
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
          <div class="w-[600px] h-[600px] bg-cyan-500/20 rounded-full blur-[120px]"></div>
        </div>
        <div class="max-w-4xl mx-auto text-center relative">
          <div class="fade-up">
            <h2 class="text-4xl md:text-6xl font-bold text-white mb-6">¿Listo para<br /><span class="text-gradient">empezar?</span></h2>
            <p class="text-xl text-neutral-400 mb-10">Cotización gratis. Sin compromiso. Respuesta en menos de 24 horas.</p>
            <a href={`https://wa.me/${BUSINESS_INFO.hn.whatsapp}?text=Hola,%20me%20interesa%20una%20cotización%20para%20mi%20proyecto%20web`} class="btn-whatsapp text-lg px-10 py-5">
              <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Escribir por WhatsApp
            </a>
          </div>
        </div>
      </section>
    </div>
  </div>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => { if (entry.isIntersecting) entry.target.classList.add("visible"); });
    }, { threshold: 0.1 });
    document.querySelectorAll(".fade-up").forEach((el) => observer.observe(el));
  </script>
</HnLayout>
