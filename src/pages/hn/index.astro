---
import Hero from "../../components/Hero.astro";
import Layout from "../../layouts/Layout.astro";
import CardService from "../../components/CardService.astro";
import Pricing from "../../components/Pricing.astro";
import Faq from "../../components/Faq.astro";
import Testimonial from "../../components/Testimonial.astro";
import TechMarquee from "../../components/TechMarquee.astro";
import Ourteam from "../../components/Ourteam.astro";
import PartnershipBanner from "../../components/PartnershipBanner.astro";
import BannerSecond from "../../components/BannerSecondOptimized.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import DesignRushSection from "../../components/DesignRushSection.astro";
import HowWeWork from "../../components/HowWeWork.astro";
import ValueProposition from "../../components/ValueProposition.astro";
import CaseStudies from "../../components/CaseStudies.astro";

const reviewsSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Codebrand",
  "url": "https://www.codebrand.us/hn",
  "review": [
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Astrid Euceda" },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Code Brand ofrece un excelente servicio en el desarrollo técnico y creativo. Lograron cumplir con mis necesidades entregando un resultado mejor de lo esperado.",
      "datePublished": "2024-08-15"
    },
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Nelson Nuñez" },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Excelente Servicio, Eficaz y Responsables.",
      "datePublished": "2024-10-05"
    },
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Jose Castro Urquia" },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Lo mejor de lo mejor..",
      "datePublished": "2024-11-12"
    },
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Virginia Denisse Alfaro Reyes" },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Excelente trabajo creando sitios webs",
      "datePublished": "2024-07-10"
    },
    {
      "@type": "Review",
      "author": { "@type": "Person", "name": "Mayelin Canelas" },
      "reviewRating": { "@type": "Rating", "ratingValue": "5", "bestRating": "5" },
      "reviewBody": "Excelente !!",
      "datePublished": "2024-06-28"
    }
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5.0",
    "reviewCount": "25",
    "bestRating": "5",
    "worstRating": "1"
  }
};

const industries = [
  "Automotriz", "Construcción", "Creadores de Contenido", "E-commerce",
  "Fitness", "Salud", "Bufetes de Abogados", "Bienes Raíces",
  "Restaurantes", "Agencia de Viajes", "Otro",
];

const services = [
  "Desarrollo Web", "Diseño UX/UI", "Branding", "SEO",
  "Redes Sociales", "Edición de Video", "Renderizado 3D", "Animación",
  "Diseño Gráfico", "Fotografía",
];
---

<Layout
  title="Agencia de Desarrollo Web en Honduras | Sitios Web y Apps | Codebrand"
  description="Agencia de desarrollo web hondureña. Creamos sitios web, apps y tiendas en línea con calidad internacional. Expertos en React y Next.js con 5+ años y 25 reseñas de 5 estrellas. Consulta gratis."
  image="/photos/bannercodebrand.webp"
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(reviewsSchema)} />

  <Hero config={{
    badge: "Calidad Internacional · Desde Honduras",
    headline: "Tu Agencia de Desarrollo Web,",
    headlineHighlight: "Aquí en Honduras.",
    subheadline: 'Creamos <span class="text-white font-semibold">sitios web rápidos, apps y tiendas en línea</span> para empresas hondureñas y del mundo. Calidad de exportación, atención local. Sin intermediarios, sin sorpresas.',
    stats: [
      { value: "5+", label: "Años de Experiencia", color: "cyan" },
      { value: "25+", label: "Reseñas 5 Estrellas", color: "orange" },
      { value: "&lt; 24h", label: "Tiempo de Respuesta", color: "cyan" },
      { value: "5/5", label: "Calificación", color: "orange" },
    ],
    ctaPrimary: { text: "Solicitar Cotización Gratis", href: "/contact" },
    ctaSecondary: { text: "Ver Nuestro Trabajo", href: "/projects" },
    techLabel: "Tecnologías que Usamos",
  }} />

  <!-- Testimonios -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 sm:mb-12">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-slate-800 border border-cyan-500/30 rounded-full mb-6">
          <svg class="w-4 h-4 text-cyan-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <span class="text-sm font-medium text-cyan-400">Historias de Éxito</span>
        </span>
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-3 sm:mb-4 px-2 sm:px-0">
          Lo Que Dicen <span class="text-orange-500">Nuestros Clientes</span>
        </h2>
        <p class="text-base sm:text-lg text-slate-300 max-w-2xl mx-auto px-2 sm:px-0">
          25 reseñas verificadas de clientes en Honduras, EE.UU. y Latinoamérica
        </p>
      </div>
    </div>
    <Testimonial />
  </section>

  <TrustBadges />

  <CaseStudies config={{
    badge: "Resultados Reales",
    title: "Resultados Reales para",
    titleHighlight: "Negocios Reales",
    subtitle: "Cada proyecto está diseñado para generar impacto medible. Esto es lo que lograron nuestros clientes.",
    studies: [
      {
        industry: "Restaurante",
        headline: "200% Más Pedidos en Línea",
        description: "Creamos una plataforma de pedidos en línea que reemplazó apps de terceros. Cero comisiones significa que el cliente se queda con el 100% de las ganancias.",
        metrics: [
          { label: "Pedidos/Mes", value: "2,400+" },
          { label: "Ahorro Anual", value: "$18K" },
          { label: "Tiempo de Lanzamiento", value: "3 semanas" },
        ],
        gradient: "from-orange-500 to-amber-500",
        badgeColor: "bg-orange-50 text-orange-700 border-orange-200",
      },
      {
        industry: "Salud",
        headline: "45% Menos Tiempo Administrativo",
        description: "Portal de pacientes con agendamiento automático, recordatorios y facturación integrada para una clínica con múltiples sucursales.",
        metrics: [
          { label: "Pacientes Atendidos", value: "12,000+" },
          { label: "Citas Perdidas", value: "-60%" },
          { label: "Horas Ahorradas", value: "25hrs/sem" },
        ],
        gradient: "from-cyan-500 to-blue-500",
        badgeColor: "bg-cyan-50 text-cyan-700 border-cyan-200",
      },
      {
        industry: "E-Commerce",
        headline: "3x Ingresos en 6 Meses",
        description: "Rediseño completo de tienda en línea con SEO, checkout más rápido y diseño mobile-first que triplicó los ingresos mensuales.",
        metrics: [
          { label: "Ingresos/Mes", value: "$85K+" },
          { label: "Tasa de Conversión", value: "+180%" },
          { label: "Velocidad Web", value: "95/100" },
        ],
        gradient: "from-violet-500 to-purple-500",
        badgeColor: "bg-violet-50 text-violet-700 border-violet-200",
      },
    ],
  }} />

  <ValueProposition config={{
    flagLeft: "\u{1F1ED}\u{1F1F3}",
    flagRight: "\u{1F30E}",
    flagLabel: "Honduras → El Mundo",
    title: "Desarrollo Web de Clase Mundial",
    titleHighlight: "Hecho en Honduras",
    subtitle: 'Somos una agencia hondureña con estándares internacionales. Creamos <a href="/services/web-development" class="text-cyan-500 hover:text-cyan-600 font-semibold">sitios web y aplicaciones</a> con la misma calidad que agencias de EE.UU., pero con la ventaja de ser tu equipo local.',
    stats: [
      { value: "5+", title: "Años de Experiencia", description: "Más de 50 proyectos entregados a clientes en Honduras, EE.UU. y Latinoamérica." },
      { value: "100%", title: "Calidad de Exportación", description: "Usamos las mismas tecnologías y estándares que las mejores agencias del mundo." },
      { value: "Local", title: "Equipo en Honduras", description: "Reuniones presenciales, soporte inmediato y comunicación directa sin barreras." },
    ],
    benefitsTitle: "¿Por Qué Elegir Codebrand en Honduras?",
    benefits: [
      { title: "Equipo Profesional Certificado", description: "Nuestros desarrolladores tienen certificaciones de Udemy, Platzi y Adobe, con experiencia en tecnologías modernas." },
      { title: "Calidad Internacional", description: "Trabajamos con clientes en EE.UU. y Latinoamérica. Tu proyecto recibe el mismo nivel de calidad que exportamos." },
      { title: "Atención Local y Personalizada", description: "Somos de aquí. Reuniones en persona, soporte directo por WhatsApp y entendemos el mercado hondureño." },
      { title: "Comunicación Bilingüe", description: "Equipo 100% bilingüe. Si tu negocio necesita presencia en inglés y español, lo manejamos sin problema." },
      { title: "Resultados Comprobados", description: "50+ proyectos exitosos entregados a clientes locales e internacionales en diversas industrias." },
    ],
    priceComparison: {
      competitorLabel: "Agencia en EE.UU.",
      competitorPrice: "$25,000",
      competitorNote: "Precio promedio en el mercado estadounidense",
      ourLabel: "Codebrand Honduras",
      ourPrice: "$10,000",
      ourNote: "Misma calidad, equipo local",
      savingsAmount: "$15,000+",
      savingsPercent: "60% de ahorro",
    },
    ctaText: "Solicitar Cotización Gratis",
    ctaSubtext: "Más de 50 empresas confían en nosotros para su desarrollo web",
  }} />

  <TechMarquee config={{
    badge: "Stack Tecnológico",
    title: "Construido Con",
    titleHighlight: "Tecnología de Punta",
    subtitle: "Usamos las mejores herramientas y frameworks de la industria para entregar soluciones rápidas, escalables y mantenibles",
    stats: [
      { value: "20+", label: "Tecnologías", color: "text-cyan-400" },
      { value: "50+", label: "Proyectos Entregados", color: "text-orange-500" },
      { value: "100%", label: "Satisfacción del Cliente", color: "text-emerald-400" },
      { value: "24h", label: "Tiempo de Respuesta", color: "text-violet-400" },
    ],
  }} />

  <!-- Servicios -->
  <section class="py-16 sm:py-20 lg:py-28 bg-gradient-to-b from-white via-slate-50/50 to-slate-100/80 relative overflow-hidden">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute -top-40 -right-40 w-80 h-80 bg-orange-200/30 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-cyan-200/20 rounded-full blur-3xl"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="text-center mb-8 sm:mb-12 lg:mb-16">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-orange-50 to-amber-50 border border-orange-200/60 rounded-full mb-6 shadow-sm">
          <span class="flex items-center justify-center w-5 h-5 bg-gradient-to-br from-orange-500 to-amber-500 rounded-full">
            <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </span>
          <span class="text-sm font-semibold text-orange-700">Agencia Digital de Servicio Completo</span>
        </span>
        <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl font-bold text-slate-900 mb-3 sm:mb-5 leading-tight px-2 sm:px-0">
          Todo lo que Tu Marca Necesita
          <span class="block sm:inline"> </span>
          <span class="bg-gradient-to-r from-orange-500 to-amber-500 bg-clip-text text-transparent">para Crecer</span>
        </h2>
        <p class="text-base sm:text-lg md:text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed px-2 sm:px-0">
          Desde desarrollo web hasta branding, producción de video y renderizado 3D — todo bajo un mismo techo.
        </p>
      </div>

      <div class="mb-6 sm:mb-8">
        <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-slate-900 text-white rounded-full text-xs font-semibold tracking-wide uppercase">
          <svg class="w-3.5 h-3.5 text-orange-400" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          Lo Que Mejor Hacemos
        </span>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 sm:gap-6 lg:gap-7">
        <CardService
          icon="/icons/sitio-web.webp"
          title="Desarrollo Web y Apps"
          description="Sitios web rápidos, optimizados para SEO y apps móviles. React, Next.js y Expo para web, iOS y Android."
          learnMoreUrl="/services/web-development"
        />
        <CardService
          icon="/icons/interfaz-de-usuario.webp"
          title="Diseño UX/UI"
          description="Interfaces intuitivas que convierten visitantes en clientes. Diseño centrado en el usuario que mantiene a la gente enganchada."
          learnMoreUrl="/services/ux-ui"
        />
        <CardService
          icon="/icons/diseno-grafico.webp"
          title="Branding e Identidad"
          description="Logos, sistemas de color y guías de marca que hacen tu negocio memorable y profesional."
          learnMoreUrl="/services/branding"
        />
      </div>

      <div class="my-10 sm:my-12 lg:my-14 flex items-center gap-4">
        <div class="flex-1 h-px bg-gradient-to-r from-transparent via-slate-300 to-transparent"></div>
      </div>

      <div class="mb-6 sm:mb-8">
        <span class="inline-flex items-center gap-2 px-3 py-1.5 bg-slate-100 border border-slate-200/80 text-slate-600 rounded-full text-xs font-semibold tracking-wide uppercase">
          <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16" />
          </svg>
          Más Servicios
        </span>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-3 sm:gap-4 lg:gap-5">
        <CardService
          icon="/icons/seo.webp"
          title="Optimización SEO"
          description="Posicionate más alto en Google con SEO técnico, estrategia de contenido y optimización de rendimiento."
          learnMoreUrl="/services/seo"
        />
        <CardService
          icon="/icons/redes-sociales.webp"
          title="Marketing en Redes Sociales"
          description="Creación de contenido, campañas publicitarias y gestión de comunidades que hacen crecer tu audiencia."
          learnMoreUrl="/services/social-media"
        />
        <CardService
          icon="/icons/edicion-de-video.webp"
          title="Producción de Video"
          description="Edición profesional de video, comerciales y contenido para redes que captura la atención."
          learnMoreUrl="/services/video-production"
        />
        <CardService
          icon="/icons/animacion.webp"
          title="Motion y Animación"
          description="Animaciones 2D/3D, motion graphics y videos explicativos que dan vida a tus ideas."
          learnMoreUrl="/services/animation"
        />
        <CardService
          icon="/icons/modelo-3d.webp"
          title="Renderizado 3D"
          description="Renders fotorrealistas para arquitectura, productos y visualizaciones de marketing."
          learnMoreUrl="/services/3d-rendering"
        />
        <CardService
          icon="/icons/camiseta.webp"
          title="Artículos Promocionales"
          description="Productos promocionales personalizados con sublimación, impresión digital y grabado láser."
          learnMoreUrl="/services/promotional-products"
        />
      </div>

      <div class="text-center mt-8 sm:mt-10">
        <a href="/services" class="group inline-flex items-center gap-2 text-sm font-semibold text-slate-600 hover:text-orange-600 transition-colors duration-300">
          Ver Todos los Servicios
          <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <div class="text-center mt-10 sm:mt-14 lg:mt-16 px-2 sm:px-0">
        <div class="inline-flex flex-col items-center gap-3 sm:gap-4 p-5 sm:p-6 md:p-8 bg-white/60 backdrop-blur-sm rounded-2xl border border-slate-200/50 shadow-lg">
          <p class="text-sm sm:text-base text-slate-700 font-medium">¿Necesitas algo específico?</p>
          <a href="/contact" class="group inline-flex items-center gap-2 sm:gap-3 px-5 sm:px-7 py-3 sm:py-3.5 bg-gradient-to-r from-slate-900 to-slate-800 hover:from-slate-800 hover:to-slate-700 text-white text-sm sm:text-base font-semibold rounded-xl shadow-lg shadow-slate-900/20 hover:shadow-xl hover:shadow-slate-900/30 transition-all duration-300 hover:-translate-y-0.5 active:scale-[0.97]">
            Hablemos de Tu Proyecto
            <svg class="w-4 h-4 sm:w-5 sm:h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <HowWeWork config={{
    badge: "Nuestro Proceso",
    title: "Cómo",
    titleHighlight: "Trabajamos",
    subtitle: "Un proceso transparente, basado en hitos, desde la primera llamada hasta el lanzamiento",
    steps: [
      { number: 1, title: "Llamada de Descubrimiento", time: "30 min · Gratis", description: "Consulta gratuita para entender tu negocio, objetivos y definir juntos el alcance completo del proyecto.", hoverColor: "hover:border-cyan-500/50 active:border-cyan-500/70", bgColor: "bg-cyan-500" },
      { number: 2, title: "Propuesta", time: "2-5 días", description: "Alcance claro, precio fijo y cronograma realista. Sin sorpresas — sabes exactamente qué vas a recibir.", hoverColor: "hover:border-orange-500/50 active:border-orange-500/70", bgColor: "bg-orange-500" },
      { number: 3, title: "Diseño UX/UI", time: "1-2 semanas", description: "Prototipos interactivos en Figma para todos los dispositivos. Apruebas el diseño antes de que escribamos código.", hoverColor: "hover:border-violet-500/50 active:border-violet-500/70", bgColor: "bg-violet-500" },
      { number: 4, title: "Desarrollo", time: "2-4 semanas", description: "Código limpio y de alto rendimiento, construido exactamente según las especificaciones. Actualizaciones semanales en video.", hoverColor: "hover:border-emerald-500/50 active:border-emerald-500/70", bgColor: "bg-emerald-500" },
      { number: 5, title: "Revisión y QA", time: "3-5 días", description: "Pruebas exhaustivas en todos los dispositivos. Corregimos, refinamos y pulimos hasta que quede perfecto.", hoverColor: "hover:border-blue-500/50 active:border-blue-500/70", bgColor: "bg-blue-500" },
      { number: 6, title: "Lanzamiento", time: "+ 30 días soporte", description: "Desplegamos, te entregamos todos los archivos y credenciales, y brindamos 30 días de soporte post-lanzamiento gratis.", hoverColor: "hover:border-amber-500/50 active:border-amber-500/70", bgColor: "bg-amber-500" },
    ],
    schemaTitle: "Cómo Codebrand Construye Tu Sitio Web",
    schemaDescription: "Nuestro proceso de desarrollo web de 6 pasos, desde el descubrimiento hasta el lanzamiento.",
    ctaText: "Iniciar Tu Proyecto",
    ctaSubtext: "Llamada de descubrimiento gratis · Sin compromiso",
  }} />

  <!-- Por Qué Codebrand -->
  <section class="py-16 sm:py-20 lg:py-24 bg-slate-950">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-slate-800 border border-cyan-500/30 rounded-full mb-6">
          <span class="w-2 h-2 bg-cyan-400 rounded-full animate-pulse"></span>
          <span class="text-sm font-medium text-cyan-400">¿Por qué elegirnos?</span>
        </span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
          La Ventaja de Trabajar con<br class="hidden sm:block" />
          <span class="text-orange-400">un Equipo Local de Clase Mundial</span>
        </h2>
        <p class="text-slate-300 text-base sm:text-lg max-w-2xl mx-auto">
          Somos hondureños con experiencia internacional. Combinamos la cercanía de un equipo local con la calidad que exige el mercado global.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        <div class="bg-slate-900 border border-slate-800 rounded-2xl p-6 lg:p-8 hover:border-cyan-500/40 transition-colors duration-300">
          <div class="w-12 h-12 bg-cyan-500/10 border border-cyan-500/20 rounded-xl flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
