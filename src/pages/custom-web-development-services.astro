---
/**
 * Custom Web Development Services Landing Page
 * Keywords: custom web development, custom website development, bespoke web development
 */

import Layout from "../layouts/Layout.astro";
import FAQ from "../components/FAQ.tsx";

const title = "Custom Web Development | Codebrand";
const description = "Bespoke websites and web applications tailored to your business. Senior developers, US timezone, transparent pricing.";
const keywords = "custom web development, custom website development, bespoke web development, tailored web solutions, custom web applications, custom software development, made-to-order websites, personalized web development, custom coded websites, hand-coded websites";

const faqs = [
  {
    question: "What is custom web development?",
    answer: "Custom web development means building a website or web application from scratch, specifically designed for your business needs. Unlike templates or website builders, custom development gives you complete control over design, functionality, and performance. Every line of code is written to serve your specific requirements, resulting in a unique solution that perfectly fits your business."
  },
  {
    question: "Why choose custom development over templates?",
    answer: "Templates are limited by their pre-built structure—you're forced to work within their constraints. Custom development offers: unique design that matches your brand perfectly, features built exactly how you need them, better performance (no bloated code), easier scalability as your business grows, full ownership with no recurring template fees, and competitive advantage through differentiation."
  },
  {
    question: "How much does custom web development cost?",
    answer: "Custom projects typically range from $5,000 to $50,000+, depending on complexity. Simple custom websites start around $5,000-$10,000. Web applications with user accounts, databases, and custom features range from $15,000-$50,000+. Enterprise solutions can exceed $100,000. We provide detailed quotes after understanding your specific requirements."
  },
  {
    question: "How long does custom development take?",
    answer: "Timeline depends on project scope. Simple custom websites: 4-8 weeks. Web applications with moderate complexity: 8-16 weeks. Complex enterprise solutions: 4-6+ months. We work in agile sprints, delivering working features every 1-2 weeks so you see progress throughout and can provide feedback."
  },
  {
    question: "What technologies do you use for custom development?",
    answer: "We specialize in modern, proven technologies: React and Next.js for frontend, Node.js with TypeScript for backend, PostgreSQL and MongoDB for databases, and cloud platforms like AWS and Vercel for hosting. We choose the best stack for each project based on requirements, scalability needs, and your team's future maintenance capabilities."
  },
  {
    question: "Will I own the code?",
    answer: "Yes, 100%. All custom code we write belongs to you. You receive full source code, documentation, and deployment instructions. There are no licensing fees, no lock-in, and no ongoing costs for code ownership. You can modify, extend, or hand off the code to another team at any time."
  },
  {
    question: "Do you provide ongoing support after launch?",
    answer: "Yes. We offer maintenance packages that include bug fixes, security updates, performance monitoring, and minor enhancements. We also provide documentation and training so your team can handle day-to-day updates. Many clients continue working with us long-term as their development partner."
  },
  {
    question: "Can you integrate with our existing systems?",
    answer: "Absolutely. Custom development excels at integration. We can connect your new solution with CRMs (Salesforce, HubSpot), payment processors (Stripe, PayPal), ERPs, inventory systems, marketing tools, and virtually any system with an API. We also build custom APIs to enable integrations."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer }
  }))
};

const services = [
  { icon: "🎯", title: "Tailored Design", desc: "Unique designs that perfectly match your brand and business goals" },
  { icon: "⚡", title: "Custom Functionality", desc: "Features built exactly how you need them, no compromises" },
  { icon: "🔗", title: "System Integration", desc: "Connect with CRMs, ERPs, payment systems, and third-party APIs" },
  { icon: "📈", title: "Scalable Architecture", desc: "Built to grow with your business, handling increased traffic and features" },
  { icon: "🔒", title: "Security First", desc: "Enterprise-grade security practices baked into every project" },
  { icon: "📱", title: "Responsive & Fast", desc: "Optimized for all devices with exceptional performance" }
];

const process = [
  { num: "01", title: "Discovery", desc: "Deep dive into your business, goals, users, and technical requirements" },
  { num: "02", title: "Architecture", desc: "Design the technical foundation, database schema, and system architecture" },
  { num: "03", title: "Design", desc: "Create wireframes and high-fidelity designs for your approval" },
  { num: "04", title: "Development", desc: "Build in agile sprints with regular demos and feedback loops" },
  { num: "05", title: "Testing & Launch", desc: "Thorough QA, performance optimization, and smooth deployment" }
];

const stats = [
  { value: "100%", label: "Code Ownership" },
  { value: "0", label: "Template Limitations" },
  { value: "∞", label: "Customization" },
  { value: "5+", label: "Years Experience" }
];

const technologies = ["React", "Next.js", "Node.js", "TypeScript", "PostgreSQL", "MongoDB", "AWS", "Vercel", "GraphQL", "REST APIs"];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  canonicalOverride="https://codebrand.us/custom-web-development-services"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero Section -->
  <section class="relative bg-slate-950 pt-32 sm:pt-36 lg:pt-28 pb-16 sm:pb-20 lg:pb-28 font-poppins overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center max-w-4xl mx-auto">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-orange-500/10 text-orange-400 text-sm font-semibold rounded-full mb-6">
          <span class="w-2 h-2 rounded-full bg-orange-400 animate-pulse"></span>
          Custom Web Development
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          Custom <span class="bg-gradient-to-r from-orange-500 to-orange-600 bg-clip-text text-transparent">Development</span>
        </h1>
        <p class="text-xl sm:text-2xl text-slate-300 mb-10 leading-relaxed max-w-2xl mx-auto">
          Tailored web solutions built from scratch.
          Your vision, your features, your code.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white rounded-2xl font-semibold text-lg shadow-lg hover:shadow-xl transition-all duration-300">
            Start Your Project
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
          </a>
          <a href="#services" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 hover:border-white/40 text-white rounded-2xl font-semibold text-lg transition-all duration-300">
            Our Approach
          </a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {stats.map((stat) => (
            <div class="text-center p-6 bg-white/5 border border-white/10 rounded-2xl">
              <div class="text-3xl sm:text-4xl font-bold text-orange-500">{stat.value}</div>
              <div class="text-slate-400 text-sm mt-2">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-8">Why custom development?</h2>
      <div class="prose prose-lg max-w-none text-slate-700 space-y-6">
        <p>
          <strong class="text-slate-900">Templates limit your business.</strong> They force you into pre-built structures, bloat your site with unused features, and make you look like everyone else. When your competitors use the same template, differentiation becomes impossible. That's why businesses choose <a href="/nearshore-development" class="text-cyan-600 hover:text-cyan-700 font-semibold">custom development</a>.
        </p>
        <p>
          <strong class="text-slate-900">Custom development gives you freedom.</strong> Every feature is designed around your specific workflows. Your design reflects your unique brand. Performance is optimized because there's no bloat. And as your business evolves, your website evolves with it. Our <a href="/react-development-agency" class="text-cyan-600 hover:text-cyan-700 font-semibold">React experts</a> make it happen.
        </p>
        <p>
          We build <strong class="text-slate-900">web applications, SaaS platforms, <a href="/ecommerce-development-agency" class="text-cyan-600 hover:text-cyan-700 font-semibold">e-commerce stores</a>, and corporate websites</strong> from the ground up. Using modern technologies like React, Next.js, and Node.js, we create solutions that are fast, secure, and built to scale. <a href="/hire-remote-developers" class="text-cyan-600 hover:text-cyan-700 font-semibold">Hire our developers</a> for your next project.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
          What We <span class="text-orange-500">Deliver</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((s) => (
          <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-200 hover:-translate-y-1 transition-all duration-300">
            <div class="text-4xl mb-4">{s.icon}</div>
            <h3 class="text-xl font-semibold text-slate-900 mb-3">{s.title}</h3>
            <p class="text-slate-600">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
          Our <span class="text-orange-500">Process</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {process.map((step) => (
          <div class="bg-white rounded-2xl shadow-lg p-8 border border-slate-200">
            <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-white font-bold mb-6">
              {step.num}
            </div>
            <h3 class="text-xl font-semibold text-slate-900 mb-3">{step.title}</h3>
            <p class="text-slate-600">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Technologies Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4">
        <span class="text-orange-500">Technologies</span>
      </h2>
      <div class="flex flex-wrap justify-center gap-3 mt-10">
        {technologies.map((tech) => (
          <span class="px-4 py-2 rounded-full border border-slate-200 bg-white text-slate-700 text-sm font-medium hover:border-orange-300 hover:text-orange-600 transition-all duration-300">{tech}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
          Custom Development <span class="text-orange-500">FAQ</span>
        </h2>
      </div>
      <FAQ faqs={faqs} client:visible />
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-950 font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">
        Ready for <span class="text-orange-400">custom?</span>
      </h2>
      <p class="text-xl text-slate-300 mb-10">Free consultation. Detailed quote within 48 hours.</p>
      <a href="/contact" class="inline-flex items-center justify-center gap-2 px-10 py-5 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white rounded-2xl font-semibold text-lg shadow-lg hover:shadow-xl transition-all duration-300">
        Get Started
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
      </a>
    </div>
  </section>
</Layout>
