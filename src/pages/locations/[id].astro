---
export const prerender = true;
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/Button.astro";
import Whyus from "../../components/whyus.astro";
import Faq from "../../components/Faq.astro";
import PageHero from "../../components/PageHero.astro";
import { createLocalBusinessSchema } from "../../utils/schema";
import { sanitizeHtml } from "../../lib/sanitize-html";
import { isLocationHub } from "../../lib/seo/geo-tiers";
import { testimonials } from "../../data/testimonials";

export async function getStaticPaths() {
  const locations = await getCollection("locations", ({ data }) => !data.draft);

  return locations.map((location) => ({
    params: { id: location.id },
    props: { location },
  }));
}

const { location } = Astro.props;
const { data } = location;
const {
  title,
  description,
  city,
  state,
  stateCode,
  region,
  img,
  imageAlt,
  population,
  timezone,
  keywords,
  // New SEO fields
  metaTitle,
  longDescription,
  industries,
  marketHighlights,
  faqs,
  whyChooseUs,
  nearbyAreas,
  localStats,
  // Differentiation fields (per-city unique content + structure)
  techScene,
  localServices,
  localCaseStudy,
  localTestimonial
} = data;

// ── Regional design accent ─────────────────────────────────────────────────
// Give pages a visual identity that varies by region/state so no two look like
// byte-identical clones. Derived deterministically from the region or stateCode.
// Complete class strings only (Tailwind can't generate interpolated names, but it
// DOES detect these literal tokens in this file).
const ACCENTS = [
  { sectionGrad: "bg-gradient-to-br from-cyan-900 to-cyan-800", ctaBg: "bg-cyan-900", chip: "bg-cyan-50 text-cyan-800 border-cyan-200" },
  { sectionGrad: "bg-gradient-to-br from-indigo-900 to-indigo-800", ctaBg: "bg-indigo-900", chip: "bg-indigo-50 text-indigo-800 border-indigo-200" },
  { sectionGrad: "bg-gradient-to-br from-emerald-900 to-emerald-800", ctaBg: "bg-emerald-900", chip: "bg-emerald-50 text-emerald-800 border-emerald-200" },
  { sectionGrad: "bg-gradient-to-br from-violet-900 to-violet-800", ctaBg: "bg-violet-900", chip: "bg-violet-50 text-violet-800 border-violet-200" },
  { sectionGrad: "bg-gradient-to-br from-rose-900 to-rose-800", ctaBg: "bg-rose-900", chip: "bg-rose-50 text-rose-800 border-rose-200" },
  { sectionGrad: "bg-gradient-to-br from-sky-900 to-sky-800", ctaBg: "bg-sky-900", chip: "bg-sky-50 text-sky-800 border-sky-200" },
];
const accentKey = (region || stateCode || city || "x").toLowerCase();
let accentHash = 0;
for (let i = 0; i < accentKey.length; i++) accentHash = (accentHash * 31 + accentKey.charCodeAt(i)) >>> 0;
const accent = ACCENTS[accentHash % ACCENTS.length];

// Alternate the section order per city (deterministic) so the page flow itself
// differs, not just the words — another anti-duplication signal.
const industriesFirst = accentHash % 2 === 0;

// ── Real, honest social proof — rotated per city ────────────────────────────
// We NEVER fabricate reviews or results. We surface genuine Google reviews and
// real delivered projects, rotated deterministically so no two city pages show
// an identical block. They are labelled as real reviews / real work, not as local.
const pickRotated = <T,>(arr: T[], count: number, seed: number): T[] => {
  if (!arr.length) return [];
  const out: T[] = [];
  const n = Math.min(count, arr.length);
  for (let i = 0; i < n; i++) out.push(arr[(seed + i) % arr.length]);
  return out;
};
const substantialReviews = testimonials.filter((t) => t.body.length >= 70);
const cityReviews = pickRotated(substantialReviews, 3, accentHash);

const realProjects = (await getCollection("projects", ({ data }) => !data.draft))
  .sort((a, b) => (a.id < b.id ? -1 : 1));
const rotatedProject = pickRotated(realProjects, 1, accentHash)[0];
// Prefer an explicit per-city case study; otherwise use a real project (honest,
// not claimed to be local).
const caseStudy = localCaseStudy
  ? { ...localCaseStudy, href: "/projects" }
  : rotatedProject
    ? {
        title: rotatedProject.data.title,
        summary: rotatedProject.data.description,
        metric: rotatedProject.data.results?.metric1,
        metricLabel: rotatedProject.data.client ? `Client: ${rotatedProject.data.client}` : undefined,
        href: `/projects/${rotatedProject.id}`,
      }
    : null;

// Check if we have enhanced content
const hasEnhancedContent = longDescription || industries?.length || marketHighlights?.length || faqs?.length;

// ── "Why choose us" cards: prefer per-city `whyChooseUs`; fall back to a
//    city-interpolated default so we never regress to an empty section. ──
const WHY_ICONS = [
  "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
  "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
  "M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129",
  "M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4",
  "M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z",
  "M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z",
];
const whyCards = (whyChooseUs && whyChooseUs.length)
  ? whyChooseUs
  : [
      { title: "60% Cost Savings", description: `Get the same quality as ${city} agencies at a fraction of the cost—without compromising quality.` },
      { title: "Same Timezone", description: `Honduras operates on CST, aligned with ${city}. Real-time collaboration, no overnight waits.` },
      { title: "Fluent English", description: "Our entire team speaks fluent English. Clear communication, no language barriers." },
      { title: "Latest Technologies", description: `React, Next.js, Astro, Node.js, TypeScript—the same modern stack as top ${city} shops.` },
      { title: "Proven Track Record", description: "Custom web projects delivered across the US, Honduras, Spain, and Mexico." },
      { title: "You Own Everything", description: "Complete source code ownership, no vendor lock-in. Your website, your code." },
    ];

// City-specific services override the generic block when provided.
const serviceCards = (localServices && localServices.length)
  ? localServices
  : [
      { title: "Custom Web Development", description: `Tailored web apps built with React, Next.js, or Astro—scalable, fast, and designed for ${city} businesses.`, href: "/web-development" },
      { title: "E-commerce Development", description: "Full-featured online stores with Shopify, WooCommerce, or custom platforms.", href: "/e-commerce" },
      { title: "Web Design & UI/UX", description: `Conversion-focused designs that represent your ${city} brand professionally.`, href: "/web-design" },
    ];

// SEO optimization — keep title ≤ 70 chars and description ≤ 160 chars
// to satisfy Google's snippet limits and SE Ranking guidelines.
const seoTitle = metaTitle || `Web Development in ${city}, ${stateCode} | Codebrand`;
const seoDescription = description.length > 160
  ? description.slice(0, 157).trimEnd() + "…"
  : description;
const seoKeywords = [
  `web development ${city}`,
  `web development company ${city}`,
  `custom web development ${city}`,
  `affordable web developers ${city}`,
  `web development services ${city} ${state}`,
  `web development agency ${city}`,
  ...(keywords || [])
].join(", ");

// Ensure absolute URL for images
const baseUrl = "https://www.codebrand.us";
const absoluteImage = img ? (img.startsWith('http') ? img : `${baseUrl}${img}`) : `${baseUrl}/photos/webservice.webp`;

// Structured Data for Local Business Service
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Web Development",
  "provider": {
    "@type": "Organization",
    "name": "Codebrand",
    "url": "https://www.codebrand.us",
    "logo": "https://www.codebrand.us/iconcodebrand.svg",
    "address": {
      "@type": "PostalAddress",
      "addressCountry": "HN",
      "addressRegion": "Cortés"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "telephone": "+504-8738-0714",
      "contactType": "Sales",
      "email": "info@codebrand.es",
      "availableLanguage": ["English", "Spanish"]
    }
  },
  "areaServed": {
    "@type": "City",
    "name": city,
    "containedIn": {
      "@type": "State",
      "name": state
    }
  },
  "description": description,
  "url": `${baseUrl}/locations/${location.id}`,
  "image": absoluteImage
};

// LocalBusiness Schema for enhanced local SEO
const localBusinessSchema = createLocalBusinessSchema(city, state, stateCode, description);

// FAQ Schema for SEO (only if custom FAQs exist)
const faqSchema = faqs?.length ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;
---

<Layout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  image={absoluteImage}
  noindex={!isLocationHub(location.id)}
>
  <!-- Service Structured Data -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

  <!-- LocalBusiness Schema for enhanced local SEO -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(localBusinessSchema)} />

  <!-- FAQ Schema for SEO (only if custom FAQs exist) -->
  {faqSchema && (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  )}

  <!-- Hero Section -->
  <PageHero
    eyebrow={`${city}, ${state}`}
    title={`Professional Web Development in <span class="text-orange-400">${city}</span>`}
    subtitle={description}
    stats={[
      { value: "5.0", label: "Client Rating", counterTo: 5, decimals: 1, color: "orange" },
      { value: "50", label: "Five-Star Reviews", counterTo: 50, color: "cyan" },
      { value: "8+", label: "Years Experience", counterTo: 8, suffix: "+", color: "cyan" },
      { value: "100%", label: "Custom-Built", color: "orange" },
    ]}
    ctaPrimary={{ text: "Get Free Quote", href: "/contact" }}
    ctaSecondary={{ text: "Why Choose Us", href: "#why-codebrand" }}
  />

  <!-- Extended Description Section (SEO Content) -->
  {longDescription && (
    <section class="py-16 lg:py-24 bg-slate-50 font-poppins">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="prose prose-lg prose-cyan max-w-none">
          <h2 class="text-display-2 font-bold text-cyan-900 mb-8 text-center" data-anim="heading">
            Web Development Services in {city}, {state}
          </h2>
          <div class="text-slate-700 leading-relaxed text-lg space-y-6" data-anim="fade" set:html={sanitizeHtml(longDescription || '')} />
        </div>
      </div>
    </section>
  )}

  <!-- Local Industries Section -->
  {industries && industries.length > 0 && (
    <section class="py-16 lg:py-24 bg-white font-poppins">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-display-2 font-bold text-cyan-900 mb-4" data-anim="heading">
            Industries We Serve in {city}
          </h2>
          <p class="text-xl text-slate-600 max-w-3xl mx-auto" data-anim="fade" data-delay="0.1">
            We understand the unique digital needs of {city}'s diverse business landscape.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-anim="fade">
          {industries.map((industry) => (
            <div class="bg-slate-50 p-6 rounded-xl border border-slate-100 hover:border-cyan-200 hover:shadow-md transition-all">
              <h3 class="text-xl font-bold text-cyan-900 mb-2">{industry.name}</h3>
              {industry.description && (
                <p class="text-slate-600">{industry.description}</p>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Market Highlights Section -->
  {marketHighlights && marketHighlights.length > 0 && (
    <section class={`py-16 lg:py-20 ${accent.sectionGrad} font-poppins`}>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-display-2 font-bold text-white mb-4" data-anim="heading">
            Why {city} is a Great Place for Digital Business
          </h2>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto" data-anim="fade">
          {marketHighlights.map((highlight) => (
            <div class="flex items-start gap-4 bg-white/10 backdrop-blur-sm p-5 rounded-xl">
              <div class="flex-shrink-0 w-8 h-8 bg-orange-500 rounded-full flex items-center justify-center">
                <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                </svg>
              </div>
              <p class="text-white text-lg">{highlight}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Local Stats Section -->
  {localStats && (localStats.techCompanies || localStats.averageProjectCost || localStats.businessGrowth) && (
    <section class="py-12 bg-white font-poppins border-b border-slate-100">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-center" data-anim="fade">
          {localStats.techCompanies && (
            <div>
              <div class="text-4xl font-bold text-orange-500 mb-2">{localStats.techCompanies}</div>
              <div class="text-slate-600">Tech Companies in {city}</div>
            </div>
          )}
          {localStats.averageProjectCost && (
            <div>
              <div class="text-4xl font-bold text-orange-500 mb-2">{localStats.averageProjectCost}</div>
              <div class="text-slate-600">Avg. Local Agency Cost</div>
            </div>
          )}
          {localStats.businessGrowth && (
            <div>
              <div class="text-4xl font-bold text-orange-500 mb-2">{localStats.businessGrowth}</div>
              <div class="text-slate-600">Business Growth Rate</div>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- Local Tech / Business Scene (unique per city) -->
  {techScene && (
    <section class="py-16 lg:py-20 bg-white font-poppins">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="rounded-3xl border border-slate-100 bg-slate-50 p-8 sm:p-12">
          <h2 class="text-display-2 font-bold text-cyan-900 mb-6" data-anim="heading">
            The {city} Tech &amp; Business Scene
          </h2>
          <div class="prose prose-lg max-w-none text-slate-700 leading-relaxed" data-anim="fade" set:html={sanitizeHtml(techScene)} />
        </div>
      </div>
    </section>
  )}

  <!-- Why Codebrand for [City] Section -->
  <section class="py-16 lg:py-24 bg-white font-poppins" id="why-codebrand">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-display-2 font-bold text-cyan-900 mb-6" data-anim="heading">
          Why {city} Businesses Choose Codebrand
        </h2>
        <p class="text-xl text-slate-700 max-w-3xl mx-auto" data-anim="fade" data-delay="0.1">
          We're a Honduras-based web development agency serving {city} businesses with premium quality at 60% less than US rates. Same timezone, bilingual team, export-quality work.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-anim="fade">
        {whyCards.map((card, i) => (
          <div class="bg-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-shadow">
            <div class="w-12 h-12 bg-orange-500 rounded-xl flex items-center justify-center mb-4">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={WHY_ICONS[i % WHY_ICONS.length]}></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-cyan-900 mb-3">{card.title}</h3>
            <p class="text-slate-700">{card.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Services -->
  <section class="py-16 lg:py-24 bg-slate-50 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <h2 class="text-display-2 font-bold text-cyan-900 mb-6" data-anim="heading">
          Web Development Services for {city} Businesses
        </h2>
        <p class="text-xl text-slate-700 max-w-3xl mx-auto" data-anim="fade" data-delay="0.1">
          From startups to established companies, we provide comprehensive web development solutions tailored to {city}'s business landscape.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-anim="fade">
        {serviceCards.map((svc) => (
          <div class="bg-white p-8 rounded-2xl shadow-lg">
            <h3 class="text-2xl font-bold text-cyan-900 mb-4">{svc.title}</h3>
            <p class="text-slate-700 mb-6">{svc.description}</p>
            <a href={svc.href || "/contact"} class="text-orange-600 hover:text-orange-700 font-semibold inline-flex items-center gap-2">
              Learn More
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Us Component -->
  <Whyus />

  <!-- Real Client Success Story (a genuine delivered project, rotated per city) -->
  {caseStudy && (
    <section class="py-16 lg:py-20 bg-slate-50 font-poppins">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid md:grid-cols-3 gap-8 items-center rounded-3xl bg-white border border-slate-100 shadow-lg p-8 sm:p-12">
          <div class="md:col-span-2">
            <span class="inline-block text-xs font-bold uppercase tracking-wider text-orange-600 mb-3">
              Real Client Success Story
            </span>
            <h2 class="text-2xl sm:text-3xl font-bold text-cyan-900 mb-4" data-anim="heading">
              {caseStudy.title}
            </h2>
            <p class="text-slate-700 text-lg leading-relaxed mb-5" data-anim="fade">{caseStudy.summary}</p>
            <a href={caseStudy.href} class="text-orange-600 hover:text-orange-700 font-semibold inline-flex items-center gap-2">
              View this project
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </a>
          </div>
          {caseStudy.metric && (
            <div class="text-center md:border-l md:border-slate-100 md:pl-8">
              <div class="text-3xl xl:text-4xl font-bold text-orange-500">{caseStudy.metric}</div>
              {caseStudy.metricLabel && (
                <div class="text-slate-600 mt-2 text-sm">{caseStudy.metricLabel}</div>
              )}
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- Real Google reviews (genuine, rotated per city — not claimed to be local) -->
  {cityReviews.length > 0 && (
    <section class="py-16 lg:py-20 bg-white font-poppins">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-display-2 font-bold text-cyan-900 mb-3" data-anim="heading">
            What Our Clients Say
          </h2>
          <p class="text-slate-600" data-anim="fade" data-delay="0.1">
            Verified 5-star reviews from businesses we've built for.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6" data-anim="fade">
          {cityReviews.map((review) => (
            <figure class="flex flex-col h-full rounded-2xl border border-slate-100 bg-slate-50 p-6 shadow-sm">
              <div class="flex gap-0.5 mb-3" aria-hidden="true">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.05 2.93c.3-.92 1.6-.92 1.9 0l1.07 3.29a1 1 0 00.95.69h3.46c.97 0 1.37 1.24.59 1.81l-2.8 2.03a1 1 0 00-.37 1.12l1.07 3.29c.3.92-.75 1.69-1.54 1.12l-2.8-2.03a1 1 0 00-1.17 0l-2.8 2.03c-.78.57-1.84-.2-1.54-1.12l1.07-3.29a1 1 0 00-.36-1.12l-2.8-2.03c-.79-.57-.39-1.81.58-1.81h3.46a1 1 0 00.95-.69l1.07-3.29z"/></svg>
                ))}
              </div>
              <blockquote class="text-slate-700 leading-relaxed flex-1">{review.body}</blockquote>
              <figcaption class="mt-4 pt-4 border-t border-slate-200 flex items-center gap-2">
                <span class="font-semibold text-cyan-900 text-sm">{review.name}</span>
                <span class="ml-auto inline-flex items-center gap-1 text-xs text-slate-400">
                  <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.24 10.4V14h5.05c-.22 1.3-.9 2.4-1.92 3.14v2.6h3.1c1.82-1.67 2.86-4.14 2.86-7.07 0-.68-.06-1.34-.18-1.97h-8.9z"/><path d="M12.24 22c2.6 0 4.78-.86 6.37-2.33l-3.1-2.4c-.86.58-1.96.92-3.27.92-2.5 0-4.62-1.69-5.38-3.96H3.66v2.48A9.6 9.6 0 0012.24 22z"/></svg>
                  {review.username}
                </span>
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Section -->
  <section class={`py-16 lg:py-24 ${accent.ctaBg} font-poppins`}>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-display-2 font-bold text-white mb-6" data-anim="heading">
        Ready to Start Your {city} Web Development Project?
      </h2>
      <p class="text-xl text-cyan-100 mb-8" data-anim="fade" data-delay="0.1">
        Get a free consultation and detailed project quote. No commitment required.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center" data-anim="fade" data-delay="0.18">
        <a href="/contact" data-magnetic data-magnetic-strength="0.3" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-orange-500 hover:bg-orange-600 text-white rounded-2xl font-bold text-lg shadow-lg hover:shadow-xl transform hover:-translate-y-0.5 transition-all duration-300">
          Get Free Quote
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a href="/projects" data-magnetic data-magnetic-strength="0.3" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white hover:bg-slate-100 text-cyan-900 rounded-2xl font-bold text-lg shadow-lg transition-all duration-300">
          View Our Work
        </a>
      </div>
    </div>
  </section>

  <!-- Nearby Areas Section -->
  {nearbyAreas && nearbyAreas.length > 0 && (
    <section class="py-12 bg-slate-50 font-poppins">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h2 class="text-display-2 font-bold text-cyan-900 mb-4" data-anim="heading">
            Also Serving Nearby Areas
          </h2>
          <p class="text-slate-600 mb-6" data-anim="fade" data-delay="0.1">
            We provide web development services throughout the {city} metropolitan area.
          </p>
          <div class="flex flex-wrap justify-center gap-3" data-anim="fade" data-delay="0.15">
            {nearbyAreas.map((area) => (
              <span class="px-4 py-2 bg-white rounded-full text-slate-700 border border-slate-200 hover:border-cyan-300 transition-colors">
                {area}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- FAQ Section -->
  {faqs && faqs.length > 0 ? (
    <section class="py-16 lg:py-24 bg-white font-poppins">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
          <h2 class="text-display-2 font-bold text-cyan-900 mb-4" data-anim="heading">
            Frequently Asked Questions About Web Development in {city}
          </h2>
          <p class="text-xl text-slate-600" data-anim="fade" data-delay="0.1">
            Common questions from {city} businesses about our web development services.
          </p>
        </div>
        <div class="space-y-6" data-anim="fade">
          {faqs.map((faq, index) => (
            <details class="group bg-slate-50 rounded-xl border border-slate-200 overflow-hidden">
              <summary class="flex items-center justify-between cursor-pointer p-6 font-semibold text-cyan-900 hover:bg-slate-100 transition-colors">
                <span class="pr-4">{faq.question}</span>
                <svg class="w-5 h-5 text-cyan-600 transform group-open:rotate-180 transition-transform flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                </svg>
              </summary>
              <div class="px-6 pb-6 text-slate-700 leading-relaxed">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  ) : (
    <Faq />
  )}
</Layout>
