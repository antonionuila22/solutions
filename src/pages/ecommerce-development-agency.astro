---
/**
 * E-commerce Development Agency Landing Page
 * Keywords: ecommerce development agency, online store development, shopify development
 */

import Layout from "../layouts/Layout.astro";
import FAQ from "../components/FAQ.tsx";

const title = "E-commerce Agency | Store Experts | Codebrand";
const description = "Shopify, custom stores, and headless commerce. High-converting online stores. US timezone, 60% cost savings vs US agencies.";
const keywords = "ecommerce development agency, online store development, shopify development agency, ecommerce website development, custom ecommerce development, headless commerce development, woocommerce development, online shop development, ecommerce solutions";

const faqs = [
  {
    question: "What e-commerce platforms do you work with?",
    answer: "We specialize in Shopify (including Shopify Plus), custom e-commerce solutions built with React/Next.js, and headless commerce architectures. We also work with WooCommerce for WordPress-based stores. We recommend the best platform based on your specific needs, product catalog size, and growth plans."
  },
  {
    question: "How much does e-commerce development cost?",
    answer: "E-commerce projects typically range from $5,000 to $50,000+. Basic Shopify stores start around $5,000-$10,000. Custom e-commerce with advanced features ranges from $15,000-$30,000. Enterprise headless commerce solutions can exceed $50,000. We provide detailed quotes based on your specific requirements."
  },
  {
    question: "How long does it take to build an online store?",
    answer: "Timeline depends on complexity. A standard Shopify store takes 3-6 weeks. Custom e-commerce solutions take 8-12 weeks. Complex multi-vendor marketplaces or headless implementations can take 3-6 months. We work in sprints, delivering working features regularly."
  },
  {
    question: "Can you migrate my existing store?",
    answer: "Yes. We handle complete migrations from any platform to Shopify or custom solutions. This includes product data, customer accounts, order history, and SEO preservation (redirects, URLs). We ensure zero downtime and no loss of search rankings during migration."
  },
  {
    question: "What payment gateways can you integrate?",
    answer: "We integrate all major payment gateways: Stripe, PayPal, Square, Authorize.net, and Shopify Payments. We also set up Apple Pay, Google Pay, and buy-now-pay-later options like Klarna and Affirm. For international stores, we configure multi-currency support."
  },
  {
    question: "Do you provide ongoing e-commerce support?",
    answer: "Yes. We offer e-commerce maintenance packages that include: performance monitoring, security updates, conversion optimization, new feature development, and technical support. Many clients retain us for ongoing growth and optimization work."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer }
  }))
};

const services = [
  { icon: "🛍️", title: "Shopify Development", desc: "Custom Shopify themes, apps, and Shopify Plus enterprise solutions" },
  { icon: "⚡", title: "Headless Commerce", desc: "Decoupled frontends with Shopify, BigCommerce, or custom backends" },
  { icon: "🎨", title: "Custom Stores", desc: "Fully custom e-commerce built with React and Node.js" },
  { icon: "📦", title: "Inventory & Fulfillment", desc: "Integration with inventory systems, 3PLs, and shipping carriers" },
  { icon: "💳", title: "Payment Integration", desc: "All major gateways, multi-currency, and BNPL options" },
  { icon: "📈", title: "Conversion Optimization", desc: "A/B testing, checkout optimization, and growth strategies" }
];

const stats = [
  { value: "50+", label: "Stores Launched" },
  { value: "300%", label: "Avg Revenue Growth" },
  { value: "98%", label: "Client Retention" },
  { value: "24h", label: "Support Response" }
];

const platforms = ["Shopify", "Shopify Plus", "Headless Commerce", "WooCommerce", "Custom Solutions", "BigCommerce"];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  canonicalOverride="https://www.codebrand.us/ecommerce-development-agency"
>
  <script is:inline type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- Hero Section -->
  <section class="relative bg-slate-950 pt-32 sm:pt-36 lg:pt-28 pb-16 sm:pb-20 lg:pb-28 font-poppins overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center max-w-4xl mx-auto">
        <span class="inline-flex items-center gap-2 px-4 py-2 bg-orange-500/10 text-orange-400 text-sm font-semibold rounded-full mb-6">
          <span class="w-2 h-2 rounded-full bg-orange-400 animate-pulse"></span>
          E-commerce Development Agency
        </span>
        <h1 class="text-4xl sm:text-5xl lg:text-7xl font-bold text-white mb-6 leading-tight">
          E-commerce <span class="bg-gradient-to-r from-orange-500 to-orange-600 bg-clip-text text-transparent">Development</span>
        </h1>
        <p class="text-xl sm:text-2xl text-slate-300 mb-10 leading-relaxed max-w-2xl mx-auto">
          Online stores that convert visitors into customers.
          Shopify, custom builds, and headless commerce.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white rounded-2xl font-semibold text-lg shadow-lg hover:shadow-xl transition-all duration-300">
            Launch Your Store
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
          </a>
          <a href="#services" class="inline-flex items-center justify-center gap-2 px-8 py-4 border border-white/20 hover:border-white/40 text-white rounded-2xl font-semibold text-lg transition-all duration-300">
            Our Services
          </a>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {stats.map((stat) => (
            <div class="text-center p-6 bg-white/5 border border-white/10 rounded-2xl">
              <div class="text-3xl sm:text-4xl font-bold text-orange-500">{stat.value}</div>
              <div class="text-slate-400 text-sm mt-2">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Content Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-8">E-commerce that drives revenue</h2>
      <div class="prose prose-lg max-w-none text-slate-700 space-y-6">
        <p>
          Your online store is your 24/7 salesperson. A poorly designed store loses sales every day—slow loading, confusing navigation, and checkout friction drive customers to competitors. <strong class="text-slate-900">We build stores that convert.</strong> Our <a href="/nearshore-development" class="text-cyan-600 hover:text-cyan-700 font-semibold">nearshore team</a> specializes in high-performance e-commerce.
        </p>
        <p>
          Whether you need a <strong class="text-slate-900">Shopify store</strong> with custom functionality, a <strong class="text-slate-900">headless commerce</strong> solution for ultimate flexibility, or a <a href="/custom-web-development-services" class="text-cyan-600 hover:text-cyan-700 font-semibold">fully custom e-commerce platform</a>, we have the expertise to deliver. Built with <a href="/react-development-agency" class="text-cyan-600 hover:text-cyan-700 font-semibold">React and Next.js</a> for optimal performance.
        </p>
        <p>
          Our e-commerce clients see an average of <strong class="text-slate-900">300% revenue growth</strong> after launch. We focus on conversion optimization, fast page loads, seamless checkout, and mobile-first design—the factors that actually drive sales. <a href="/hire-remote-developers" class="text-cyan-600 hover:text-cyan-700 font-semibold">Hire our developers</a> to build your store.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
          E-commerce <span class="text-orange-500">Services</span>
        </h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((s) => (
          <div class="bg-white rounded-2xl shadow-lg p-6 border border-slate-200 hover:-translate-y-1 transition-all duration-300">
            <div class="text-4xl mb-4">{s.icon}</div>
            <h3 class="text-xl font-semibold text-slate-900 mb-3">{s.title}</h3>
            <p class="text-slate-600">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Platforms Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4">
        Platforms We <span class="text-orange-500">Work With</span>
      </h2>
      <div class="flex flex-wrap justify-center gap-3 mt-10">
        {platforms.map((p) => (
          <span class="px-5 py-2.5 rounded-full border border-slate-200 bg-slate-50 text-slate-700 text-sm font-medium hover:border-orange-300 hover:text-orange-600 transition-all duration-300">{p}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-50 font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
          E-commerce <span class="text-orange-500">FAQ</span>
        </h2>
      </div>
      <FAQ faqs={faqs} client:visible />
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-950 font-poppins">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">
        Ready to <span class="text-orange-400">sell online?</span>
      </h2>
      <p class="text-xl text-slate-300 mb-10">Free e-commerce consultation. Let's grow your revenue.</p>
      <a href="/contact" class="inline-flex items-center justify-center gap-2 px-10 py-5 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white rounded-2xl font-semibold text-lg shadow-lg hover:shadow-xl transition-all duration-300">
        Get Started
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg>
      </a>
    </div>
  </section>
</Layout>
