---
import Layout from "../layouts/Layout.astro";
import Whyus from "../components/whyus.astro";
import Faq from "../components/Faq.astro";
import CardService from "../components/CardService.astro";
import Button from "../components/Button.astro";
import Testimonial from "../components/Testimonial.astro";
import RelatedServices from "../components/RelatedServices.astro";
import PageHero from "../components/PageHero.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { createServicePageSchema } from "../utils/schema";

const title = "Landing Page Design & Development | Codebrand";
const description =
  "High-converting landing pages optimized for mobile and fast loading. Custom design, A/B testing, and lead generation that turn visitors into customers.";
const keywords =
  "landing page design, landing page development, high converting landing pages, custom landing pages, lead generation pages, sales funnel pages, squeeze pages, campaign landing pages, mobile landing pages, responsive landing pages, A/B testing landing pages, conversion rate optimization, landing page optimization, professional landing pages, landing page templates, landing page services";
const image = "/photos/uxservice.webp";

// Service Schema for Landing Pages
const serviceSchema = createServicePageSchema({
  serviceType: "Landing Page Development",
  name: "High-Converting Landing Page Design & Development",
  description: description,
  url: "https://www.codebrand.us/landing-pages",
  image: "https://www.codebrand.us/photos/uxservice.webp",
  catalogName: "Landing Page Services",
  catalogItems: [
    {
      name: "Lead Generation Pages",
      description: "Optimized landing pages for capturing leads",
    },
    {
      name: "Sales Funnel Pages",
      description: "Conversion-focused pages for sales funnels",
    },
    {
      name: "A/B Testing",
      description: "Split testing to maximize conversion rates",
    },
    {
      name: "Campaign Landing Pages",
      description: "Custom pages for marketing campaigns",
    },
  ],
});
---

<Layout title={title} description={description} keywords={keywords} image={image}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} />
  <!-- Hero Section -->
  <PageHero
    eyebrow="High-Converting Landing Pages"
    title='Landing Pages That <span class="text-orange-400">Convert Visitors Into Customers</span>'
    subtitle="Drive more leads and sales with professionally designed landing pages optimized for maximum conversions. We create laser-focused pages that capture attention, build trust, and turn clicks into customers with proven conversion strategies."
    stats={[
      { value: "5.0", label: "Client Rating", counterTo: 5, decimals: 1, color: "orange" },
      { value: "50", label: "Five-Star Reviews", counterTo: 50, color: "cyan" },
      { value: "8+", label: "Years Experience", counterTo: 8, suffix: "+", color: "cyan" },
      { value: "100%", label: "Custom-Built", color: "orange" },
    ]}
    ctaPrimary={{ text: "Get Your Landing Page", href: "/contact" }}
    ctaSecondary={{ text: "View Our Services", href: "#services" }}
  />

  <!-- Introduction Section -->
  <section class="py-16 lg:py-24 bg-white font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <h2
            class="text-display-2 font-bold text-cyan-900 mb-6"
            data-anim="heading"
          >
            Turn Traffic Into Revenue with Strategic Landing Page Design
          </h2>
          <div class="prose prose-lg text-slate-700 space-y-4" data-anim="fade" data-delay="0.1">
            <p>
              Your landing page has one job: convert visitors into leads or
              customers. Every element, every word, and every design choice must
              work together to guide visitors toward taking action. At
              Codebrand, we specialize in creating high-converting landing pages
              that combine persuasive copy, compelling design, and proven
              conversion optimization techniques to maximize your return on
              investment. Our <a href="/services/ux-ui" class="text-cyan-600 hover:text-cyan-700 font-semibold">UX/UI designers</a> work closely with our <a href="/digital-marketing" class="text-cyan-600 hover:text-cyan-700 font-semibold">expert copywriters</a> to create pages that convert.
            </p>
            <p>
              Whether you're running paid ads, email campaigns, social media
              promotions, or product launches, a well-designed landing page is
              the difference between wasted ad spend and profitable campaigns.
              Our landing pages are built with conversion rate optimization
              (CRO) at their core, featuring clear value propositions, strategic
              calls-to-action, trust signals, and mobile-responsive designs that
              perform across all devices.
            </p>
            <p>
              We understand that different campaigns require different
              approaches. From lead generation pages and sales pages to webinar
              registrations and product launches, we create custom landing pages
              tailored to your specific goals and target audience. Our data-driven
              approach includes A/B testing capabilities, analytics integration,
              and ongoing optimization to continuously improve your conversion
              rates.
            </p>
            <p>
              Our landing pages load blazingly fast, follow SEO best practices,
              and integrate seamlessly with your marketing tools and CRM
              systems. With mobile-first design, persuasive copywriting, and
              conversion-focused layouts, we ensure every visitor has a smooth
              path to conversion, helping you get the most from your marketing
              budget. Perfect for <a href="/digital-marketing" class="text-cyan-600 hover:text-cyan-700 font-semibold">digital marketing campaigns</a>, <a href="/e-commerce" class="text-cyan-600 hover:text-cyan-700 font-semibold">product launches</a>, and <a href="/services/web-development" class="text-cyan-600 hover:text-cyan-700 font-semibold">lead generation</a>.
            </p>
          </div>
        </div>
        <div class="relative" data-anim="fade" data-fade-from="right" data-delay="0.1">
          <div
            class="relative bg-slate-100 rounded-3xl p-8 shadow-xl"
            data-parallax
            data-parallax-speed="0.2"
            data-parallax-range="44"
          >
            <div class="space-y-4">
              <div
                class="bg-white rounded-2xl p-6 shadow-lg transform hover:scale-[1.03] transition-transform duration-300"
              >
                <div class="flex items-center gap-4">
                  <div
                    class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-teal-500 to-teal-600 rounded-xl flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6 text-white"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <div>
                    <div class="text-2xl font-bold text-cyan-900 tabular-nums"><span data-counter="8" data-counter-suffix="+">8+</span></div>
                    <div class="text-sm text-slate-600">Years of Experience</div>
                  </div>
                </div>
              </div>
              <div
                class="bg-white rounded-2xl p-6 shadow-lg transform hover:scale-105 transition-transform"
              >
                <div class="flex items-center gap-4">
                  <div
                    class="flex-shrink-0 w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6 text-white"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <div class="text-2xl font-bold text-cyan-900 tabular-nums"><span data-counter="50">50</span></div>
                    <div class="text-sm text-slate-600">Five-Star Reviews</div>
                  </div>
                </div>
              </div>
              <div
                class="bg-white rounded-2xl p-6 shadow-lg transform hover:scale-105 transition-transform"
              >
                <div class="flex items-center gap-4">
                  <div
                    class="flex-shrink-0 w-12 h-12 bg-orange-500 rounded-xl flex items-center justify-center"
                  >
                    <svg
                      class="w-6 h-6 text-white"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"
                        clip-rule="evenodd"></path>
                    </svg>
                  </div>
                  <div>
                    <div class="text-2xl font-bold text-cyan-900">100%</div>
                    <div class="text-sm text-slate-600">Custom-Built</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Section -->
  <section id="services" class="py-16 lg:py-24 bg-slate-50 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        class="mb-12 sm:mb-16"
        eyebrow="What We Offer"
        title='Complete Landing Page <span class="text-orange-500">Solutions</span>'
        subtitle="From concept to conversion, we provide comprehensive landing page services designed to maximize your marketing ROI and achieve your campaign goals."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-anim="fade">
        <CardService
          icon="/icons/login-page-svgrepo-com.svg"
          title="Lead Generation Landing Pages"
          description="Capture qualified leads with strategically designed pages optimized for form submissions. Perfect for building email lists, generating qualified prospects, and growing your customer database."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/ecommerce-website-commerce-and-shopping-2-svgrepo-com.svg"
          title="Sales & Product Launch Pages"
          description="Drive direct sales with persuasive product landing pages that highlight benefits, overcome objections, and guide visitors to purchase. Ideal for product launches and promotional campaigns."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/responsive-svgrepo-com.svg"
          title="Mobile-Optimized Design"
          description="Ensure maximum conversions across all devices with mobile-first landing pages. Your pages will look stunning and convert effectively on smartphones, tablets, and desktops."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/data-graphics-analysis-svgrepo-com.svg"
          title="A/B Testing & Optimization"
          description="Continuously improve conversion rates with built-in A/B testing capabilities. We test headlines, CTAs, images, and layouts to identify what drives the best results for your campaigns."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/website-seo-promotion-svgrepo-com.svg"
          title="PPC Campaign Landing Pages"
          description="Maximize your paid advertising ROI with landing pages specifically designed for Google Ads, Facebook Ads, and other PPC campaigns. Message-matched pages that improve Quality Scores and conversions."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/website-program-svgrepo-com.svg"
          title="Event & Webinar Registration"
          description="Boost event attendance and webinar signups with compelling registration pages. Create urgency, showcase speaker value, and streamline the registration process for maximum attendance."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/mobile-phone-app-svgrepo-com.svg"
          title="App Download Pages"
          description="Drive mobile app installations with dedicated landing pages that highlight app features, showcase screenshots, and provide direct download links for iOS and Android platforms."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/platform-program-svgrepo-com.svg"
          title="Marketing Automation Integration"
          description="Seamlessly connect your landing pages with email marketing platforms, CRMs, and marketing automation tools. Integrate with HubSpot, Mailchimp, Salesforce, and more."
          learnMoreUrl="/contact"
        />

        <CardService
          icon="/icons/host-website-se-svgrepo-com.svg"
          title="Analytics & Conversion Tracking"
          description="Track every interaction and conversion with comprehensive analytics integration. Monitor visitor behavior, identify drop-off points, and make data-driven optimization decisions."
          learnMoreUrl="/contact"
        />
      </div>
    </div>
  </section>

  <!-- Conversion Elements Section -->
  <section class="py-16 lg:py-24 bg-white font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        class="mb-12 sm:mb-16"
        eyebrow="Conversion Anatomy"
        title='Key Elements for <span class="text-orange-500">High Conversions</span>'
        subtitle="Every landing page we create includes these proven conversion elements to maximize your results."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-anim="fade">
        <div
          class="bg-slate-50 p-8 rounded-2xl shadow-lg hover:shadow-xl transition-shadow"
        >
          <div
            class="w-12 h-12 bg-cyan-900 rounded-xl flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">
            Compelling Headlines
          </h3>
          <p class="text-slate-700">
            Attention-grabbing headlines that immediately communicate your
            unique value proposition and hook visitors in the first 3 seconds.
          </p>
        </div>

        <div
          class="bg-slate-50 p-8 rounded-2xl shadow-lg hover:shadow-xl transition-shadow"
        >
          <div
            class="w-12 h-12 bg-orange-500 rounded-xl flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">
            Strategic CTAs
          </h3>
          <p class="text-slate-700">
            Prominent, action-oriented call-to-action buttons with persuasive
            copy that drives clicks and conversions at optimal positions.
          </p>
        </div>

        <div
          class="bg-gradient-to-br from-blue-50 to-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-shadow"
        >
          <div
            class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">Trust Signals</h3>
          <p class="text-slate-700">
            Social proof, testimonials, security badges, client logos, and
            guarantees that build credibility and overcome visitor objections.
          </p>
        </div>

        <div
          class="bg-gradient-to-br from-teal-50 to-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-shadow"
        >
          <div
            class="w-12 h-12 bg-gradient-to-br from-teal-500 to-teal-600 rounded-xl flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">
            Visual Hierarchy
          </h3>
          <p class="text-slate-700">
            Strategic use of colors, whitespace, and visual elements that guide
            visitors' eyes toward conversion actions and key information.
          </p>
        </div>

        <div
          class="bg-gradient-to-br from-cyan-50 to-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-shadow"
        >
          <div
            class="w-12 h-12 bg-gradient-to-br from-cyan-500 to-cyan-600 rounded-xl flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">
            Fast Load Times
          </h3>
          <p class="text-slate-700">
            Optimized code and assets ensure pages load in under 2 seconds,
            reducing bounce rates and improving conversion rates significantly.
          </p>
        </div>

        <div
          class="bg-gradient-to-br from-blue-50 to-white p-8 rounded-2xl shadow-lg hover:shadow-xl transition-shadow"
        >
          <div
            class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center mb-4"
          >
            <svg
              class="w-6 h-6 text-white"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">
            Simplified Forms
          </h3>
          <p class="text-slate-700">
            User-friendly forms that ask for only essential information,
            reducing friction and increasing completion rates with smart validation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process Section -->
  <section
    class="py-16 lg:py-24 bg-slate-50 font-poppins"
  >
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        class="mb-12 sm:mb-16"
        eyebrow="How We Work"
        title='Our Landing Page <span class="text-orange-500">Process</span>'
        subtitle="We follow a proven methodology to create landing pages that consistently deliver exceptional conversion rates."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8" data-anim="fade">
        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div
            class="w-12 h-12 bg-cyan-900 rounded-xl flex items-center justify-center mb-4"
          >
            <span class="text-2xl font-bold text-white">1</span>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">
            Strategy & Research
          </h3>
          <p class="text-slate-700">
            We analyze your target audience, campaign goals, and competitors to
            develop a conversion-focused strategy and messaging framework.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div
            class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center mb-4"
          >
            <span class="text-2xl font-bold text-white">2</span>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">
            Design & Copywriting
          </h3>
          <p class="text-slate-700">
            Our team creates compelling designs and persuasive copy that speaks
            directly to your audience's pain points and desired outcomes.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div
            class="w-12 h-12 bg-orange-500 rounded-xl flex items-center justify-center mb-4"
          >
            <span class="text-2xl font-bold text-white">3</span>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">
            Development & Testing
          </h3>
          <p class="text-slate-700">
            We build your landing page with clean code, integrate tracking and
            forms, then rigorously test across devices and browsers.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-lg">
          <div
            class="w-12 h-12 bg-gradient-to-br from-teal-500 to-teal-600 rounded-xl flex items-center justify-center mb-4"
          >
            <span class="text-2xl font-bold text-white">4</span>
          </div>
          <h3 class="text-xl font-bold text-cyan-900 mb-3">
            Launch & Optimize
          </h3>
          <p class="text-slate-700">
            We deploy your page, monitor performance metrics, and continuously
            optimize elements to improve conversion rates over time.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <Whyus />

  <!-- Google Reviews Section -->
  <section class="py-16 sm:py-20 lg:py-28 bg-slate-950 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        class="mb-8 sm:mb-12"
        theme="dark"
        eyebrowColor="orange"
        eyebrow="Google Reviews"
        title='What Our <span class="text-orange-500">Clients Say</span>'
        subtitle="Real reviews from real clients on Google. See why businesses trust Codebrand for their landing page needs."
      />
    </div>
    <Testimonial />
  </section>

  <!-- Case Studies Section -->
  <section class="py-16 lg:py-24 bg-slate-50 font-poppins">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading
        class="mb-12 sm:mb-16"
        eyebrow="Case Studies"
        title='Landing Page <span class="text-orange-500">Success Stories</span>'
        subtitle="Real conversion improvements and lead generation. See how our landing pages have driven results for businesses."
      />

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8" data-anim="fade">
        <div class="group bg-white rounded-2xl overflow-hidden shadow-lg hover:shadow-xl transition-shadow">
          <div class="h-48 bg-gradient-to-br from-cyan-600 to-cyan-800 flex items-center justify-center transition-transform duration-500 group-hover:scale-105">
