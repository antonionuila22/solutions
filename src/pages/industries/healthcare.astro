---
export const prerender = true;
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Whyus from "../../components/whyus.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import RelatedServices from "../../components/RelatedServices.astro";
import IndustryHero from "../../components/IndustryHero.astro";
import IndustryIntro from "../../components/IndustryIntro.astro";
import IndustryServices from "../../components/IndustryServices.astro";
import IndustryProcess from "../../components/IndustryProcess.astro";
import IndustryWhyChoose from "../../components/IndustryWhyChoose.astro";
import IndustryTestimonials from "../../components/IndustryTestimonials.astro";
import IndustryTechStack from "../../components/IndustryTechStack.astro";
import IndustryChallenges from "../../components/IndustryChallenges.astro";
import IndustryFAQ from "../../components/IndustryFAQ.astro";
import IndustryCTA from "../../components/IndustryCTA.astro";
import { createFAQSchema, createBreadcrumbSchema } from "../../utils/schema";

const title = "Healthcare Software Development & EHR | Codebrand";
const description = "HIPAA-compliant healthcare software for clinics and hospitals: patient portals, telemedicine, EMR/EHR, and appointment scheduling. Get a free quote.";
const keywords = "healthcare software development, medical practice management software, HIPAA compliant software, telemedicine platform, patient portal development, EMR software, EHR systems, healthcare app development, medical appointment scheduling, telehealth solutions, hospital management system, healthcare IT solutions";
const image = "/photos/teamcode.webp";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Healthcare Software Development",
  "name": "Healthcare Software Development & Medical Practice Solutions",
  "description": description,
  "url": "https://www.codebrand.us/industries/healthcare",
  "provider": {
    "@type": "Organization",
    "name": "Codebrand",
    "url": "https://www.codebrand.us",
    "logo": "https://www.codebrand.us/iconcodebrand.svg"
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Healthcare Web Solutions",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Patient Portal Development", "description": "HIPAA-compliant patient portals" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Telemedicine Platforms", "description": "Video consultation and telehealth solutions" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Appointment Scheduling", "description": "Medical appointment booking systems" }}
    ]
  }
};

// Healthcare FAQ data
const healthcareFaqs = [
  {
    question: "Are your healthcare solutions HIPAA compliant?",
    answer: "Yes. We build every healthcare solution to meet HIPAA rules from day one. We use encryption, access controls, and audit logs. We also follow secure data practices that protect patient health information (PHI)."
  },
  {
    question: "How much does healthcare software development cost?",
    answer: "Basic patient portals typically start at $15,000. Telemedicine platforms range from $25,000 to $75,000. Full EMR/EHR systems start at $50,000. We give you a detailed quote once we understand your compliance and feature needs."
  },
  {
    question: "Can you integrate with existing EMR/EHR systems?",
    answer: "Yes. We connect healthcare systems using HL7, FHIR, and direct API links. We integrate with Epic, Cerner, Allscripts, and other major EMR/EHR systems. This keeps your data flowing smoothly between tools."
  },
  {
    question: "How long does it take to build a patient portal?",
    answer: "A basic HIPAA-compliant patient portal takes 8 to 12 weeks. Complex portals with telemedicine, billing, and EMR integration take 16 to 24 weeks. We never cut corners on security or compliance to save time."
  },
  {
    question: "Do you offer telemedicine development?",
    answer: "Yes. We build custom telemedicine platforms with video visits, secure messaging, e-prescriptions, and payments. Our solutions work on the web, iOS, and Android."
  },
  {
    question: "What about ongoing maintenance and support?",
    answer: "Healthcare software needs ongoing care to stay secure and compliant. We offer monthly support plans that cover security updates, compliance monitoring, and bug fixes. Critical systems also get 24/7 emergency support."
  }
];

const faqSchema = createFAQSchema(healthcareFaqs);
const breadcrumbSchema = createBreadcrumbSchema([
  { name: "Home", url: "https://www.codebrand.us" },
  { name: "Industries", url: "https://www.codebrand.us/industries" },
  { name: "Healthcare", url: "https://www.codebrand.us/industries/healthcare" }
]);

// Hero stats
const stats = [
  { value: "5.0★", label: "Google Rating" },
  { value: "HIPAA", label: "Compliant" },
  { value: "24/7", label: "Online Scheduling" },
  { value: "100%", label: "Custom-Built" }
];

// Intro highlights
const introHighlights = [
  { value: "5.0★", label: "Google Reviews", gradient: "from-teal-500 to-teal-500", iconPath: "M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" },
  { value: "8+ yrs", label: "Development Experience", gradient: "from-blue-500 to-blue-500", iconPath: "M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z" },
  { value: "EHR", label: "System Integrations", gradient: "from-orange-500 to-orange-500", iconPath: "M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" },
  { value: "24/7", label: "Critical Support", gradient: "from-cyan-500 to-blue-500", iconPath: "M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z" }
];

// Services data
const services = [
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>`,
    title: "Patient Portal Development",
    description: "Give patients secure portals to view medical records, book appointments, and message their providers.",
    features: ["Secure health record access", "Online appointment scheduling", "Secure messaging with providers"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>`,
    title: "Telemedicine Platforms",
    description: "Expand access to care with secure video visits and remote health monitoring tools.",
    features: ["HD video consultations", "E-prescribing integration", "Mobile and web access"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>`,
    title: "EMR/EHR Systems",
    description: "Speed up clinical work with electronic medical records that cut the time spent on documentation.",
    features: ["Clinical documentation templates", "ICD-10 and CPT coding support", "Lab and imaging integration"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>`,
    title: "Appointment Scheduling",
    description: "Cut no-shows and fill your calendar with smart appointment scheduling systems.",
    features: ["24/7 online booking", "Automated SMS/email reminders", "Calendar synchronization"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>`,
    title: "Medical Billing Software",
    description: "Get paid faster with automated billing and claims management that improve cash flow.",
    features: ["Electronic claims submission", "Insurance verification", "Payment processing"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>`,
    title: "Healthcare Mobile Apps",
    description: "Engage patients with mobile apps built in Expo React Native that run on iOS and Android.",
    features: ["iOS & Android native apps", "Wearable device integration", "Push notification reminders"]
  }
];

// Process steps
const processSteps = [
  { title: "Clinical Workflow & HIPAA Discovery", description: "We meet with your providers, front-desk staff, and billing coordinators. Together we map your real patient journey, from intake forms and insurance checks to charting and follow-ups. We note every PHI touchpoint, the Business Associate Agreements you need, and how your current EHR fits in. This works for Epic, Cerner, athenahealth, or DrChrono." },
  { title: "Patient & Provider Experience Design", description: "We design portals and scheduling flows for anxious patients and busy clinicians alike. Screens use large touch targets, plain-language consent forms, and accessible layouts that meet WCAG and ADA standards. We prototype every screen for the waiting-room tablet and the physician's phone. This happens before we write a single line of code." },
  { title: "Secure, Interoperable Build", description: "We build on HIPAA-eligible infrastructure. Data is protected with AES-256 encryption at rest and TLS in transit. We add role-based access controls and log every PHI view. Integrations use HL7 and FHIR APIs to sync appointments, lab results, and patient details with your EHR and clearinghouse. That way your staff never enter data twice." },
  { title: "Compliance Testing & Validation", description: "Before launch, we run penetration tests and access-control reviews. We also complete a HIPAA Security Rule audit that covers encryption, audit trails, and breach-notification readiness. Then we check e-prescribing, eligibility, and EHR data flow with your clinical team. We test with realistic sample records, never live PHI." },
  { title: "Staff Training & Ongoing Compliance Support", description: "We train your front-desk, clinical, and billing teams with role-specific walkthroughs and quick-reference guides. We then monitor round-the-clock the systems patients rely on. Ongoing support includes security patches, dependency updates, and compliance reviews. We adjust as HIPAA guidance and your EHR integrations change." }
];

// Why choose reasons
const whyChooseReasons = [
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>`,
    title: "HIPAA Compliance Expertise",
    description: "Every solution meets HIPAA security and privacy rules. We use encryption, access controls, and audit trails."
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path></svg>`,
    title: "Healthcare Industry Focus",
    description: "We build for hospitals, clinics, and specialty practices. Our team studies clinical workflows and daily operations. So the software fits how your staff actually work."
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"></path></svg>`,
    title: "Interoperability Standards",
    description: "Our systems connect smoothly with your current setup. We use HL7, FHIR, DICOM, and other standards."
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M2 10a8 8 0 018-8v8h8a8 8 0 11-16 0z"></path><path d="M12 2.252A8.014 8.014 0 0117.748 8H12V2.252z"></path></svg>`,
    title: "Built to Reduce Busywork",
    description: "We automate the admin work that slows clinics down. That means fewer manual schedules and fewer no-shows from missed reminders. The result is a smoother experience for patients and staff alike."
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-2 0c0 .993-.241 1.929-.668 2.754l-1.524-1.525a3.997 3.997 0 00.078-2.183l1.562-1.562C15.802 8.249 16 9.1 16 10zm-5.165 3.913l1.58 1.58A5.98 5.98 0 0110 16a5.976 5.976 0 01-2.516-.552l1.562-1.562a4.006 4.006 0 001.789.027zm-4.677-2.796a4.002 4.002 0 01-.041-2.08l-.08.08-1.53-1.533A5.98 5.98 0 004 10c0 .954.223 1.856.619 2.657l1.54-1.54zm1.088-6.45A5.974 5.974 0 0110 4c.954 0 1.856.223 2.657.619l-1.54 1.54a4.002 4.002 0 00-2.346.033L7.246 4.668zM12 10a2 2 0 11-4 0 2 2 0 014 0z" clip-rule="evenodd"></path></svg>`,
    title: "24/7 Critical Support",
    description: "Healthcare never sleeps, and neither does our support team. We monitor mission-critical systems around the clock."
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"></path></svg>`,
    title: "Data-Driven Insights",
    description: "Clear analytics and reports help you make smart decisions about patient care and how you use resources."
  }
];

// Technologies
const technologies = [
  { name: "HL7 / FHIR", icon: "hospital" },
  { name: "React", icon: "atom" },
  { name: "Node.js", icon: "server" },
  { name: "PostgreSQL", icon: "database" },
  { name: "AWS HIPAA", icon: "cloud" },
  { name: "AES-256", icon: "lock" }
];

// Challenges
const challenges = [
  {
    problem: "Administrative Burden",
    description: "Too much paperwork, phone tag with patients, manual scheduling, and insurance checks eat up hours.",
    solution: "Automated workflows, online scheduling, patient portals, and connected billing take repetitive admin work off your staff's plate."
  },
  {
    problem: "Poor Patient Engagement",
    description: "Few ways to reach you, hard-to-access records, and no online scheduling frustrate patients.",
    solution: "Patient portals, mobile apps, telemedicine, and automatic reminders keep patients engaged and satisfied."
  },
  {
    problem: "Data Silos & Integration",
    description: "Disconnected systems force staff to re-enter data and lose information between departments.",
    solution: "Connected systems built on HL7 and FHIR standards link EMR, lab, imaging, and billing in one platform."
  },
  {
    problem: "Compliance & Security Risks",
    description: "HIPAA violations, data breaches, and non-compliant systems put practices at risk of huge fines.",
    solution: "HIPAA-compliant design with encryption, audit trails, BAAs, regular security audits, and staff training."
  }
];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <IndustryHero
    badgeText="Healthcare Technology Solutions"
    headingTop="Modernize"
    headingBottom="Healthcare Delivery"
    subtitle="HIPAA-compliant healthcare software that improves patient care, streamlines operations, and supports your medical team."
    stats={stats}
    accentGradient="from-blue-400 via-cyan-400 to-blue-400"
    buttonGradient="from-blue-500 to-cyan-500"
    buttonHoverGradient="hover:from-blue-600 hover:to-cyan-600"
    buttonShadow="shadow-blue-500/25"
    buttonHoverShadow="hover:shadow-blue-500/40"
  />

  <Breadcrumbs
    items={[
      { name: "Home", href: "/" },
      { name: "Industries", href: "/industries" },
      { name: "Healthcare", href: "" }
    ]}
    variant="dark"
    class="bg-slate-900 border-y border-slate-800"
  />

  <TrustBadges />

  <IndustryIntro
    title="Digital Healthcare Solutions for Modern Practices"
    paragraphs={[
      "Healthcare is going digital fast. Medical practices need a technology partner who understands both clinical workflows and the rules you have to follow. At CodeBrand, we build HIPAA-compliant software for hospitals, clinics, and healthcare organizations.",
      "We create custom healthcare apps, patient portals, telemedicine platforms, and practice management systems. They help you improve patient outcomes and cut down on admin work."
    ]}
    highlights={introHighlights}
  />

  <IndustryServices
    title="Comprehensive Healthcare"
    titleAccent="Solutions"
    subtitle="HIPAA-compliant technology designed to improve patient care and practice efficiency"
    services={services}
    accentGradient="from-blue-500 to-cyan-500"
  />

  <IndustryProcess
    title="Healthcare Development"
    titleAccent="Process"
    subtitle="A proven, compliant methodology that delivers secure healthcare solutions on time"
    steps={processSteps}
    accentGradient="from-blue-500 to-cyan-500"
  />

  <IndustryWhyChoose
    title="Why Healthcare Providers"
    titleAccent="Choose CodeBrand"
    subtitle="Trusted expertise in healthcare technology and regulatory compliance"
    reasons={whyChooseReasons}
    accentGradient="from-blue-500 to-cyan-500"
  />

  <IndustryTestimonials />

  <IndustryTechStack
    title="Healthcare-Grade"
    titleAccent="Technology Stack"
    subtitle="Proven, secure technologies and healthcare standards to build compliant solutions"
    technologies={technologies}
  />

  <IndustryChallenges
    title="Healthcare Challenges"
    titleAccent="We Solve"
    subtitle="Technology solutions designed specifically for healthcare's unique needs"
    challenges={challenges}
  />

  <IndustryFAQ
    title="Healthcare"
    titleAccent="FAQ"
    subtitle="Common questions about our healthcare software development services"
    faqs={healthcareFaqs}
  />

  <IndustryCTA
    title="Ready to Modernize Your Healthcare Practice?"
    subtitle="Let's talk about how HIPAA-compliant software can improve patient care, cut admin work, and ready your practice for the future."
    ctaGradient="from-blue-600 via-cyan-600 to-blue-600"
    supportText="No commitment required • Free HIPAA compliance consultation • Response within 24 hours"
  />

  <Whyus />

  <RelatedServices currentService="web-development" />
</Layout>
