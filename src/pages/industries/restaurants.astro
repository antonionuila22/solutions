  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>`,
    title: "Restaurant Websites",
    description: "Beautiful, mobile-responsive websites that showcase your food, ambiance, and story. SEO-optimized to rank for local searches, integrated with Google Maps, and designed to drive reservations and orders.",
    features: ["Local SEO optimization", "Professional food photography", "Google My Business integration"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"></path></svg>`,
    title: "Loyalty & Rewards Programs",
    description: "Build customer loyalty with digital rewards programs. Points for purchases, birthday rewards, exclusive offers, and mobile app integration that keep customers coming back.",
    features: ["Points-based rewards", "Automated marketing campaigns", "Customer analytics dashboard"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>`,
    title: "Restaurant Mobile Apps",
    description: "Cross-platform mobile apps built with Expo React Native for iOS and Android. Order ahead, earn rewards, get push notifications for specials, and provide a branded experience in customers' pockets.",
    features: ["Expo React Native for iOS & Android", "Push notification marketing", "Integrated loyalty program"]
  }
];

// Process steps
const processSteps = [
  { title: "Menu & Operations Review", description: "We study your menu, ordering workflow, kitchen operations, and current tech setup to design the perfect solution." },
  { title: "Custom Design & Branding", description: "Beautiful designs that match your restaurant's personality — from colors and fonts to food photography layouts." },
  { title: "Development & Integration", description: "Building your site and ordering platform with POS integration, payment processing, and delivery zone configuration." },
  { title: "Testing & Menu Setup", description: "Thorough testing of order flows, payment processing, and menu accuracy before launch. Staff training included." },
  { title: "Launch & Ongoing Support", description: "Go live with monitoring, real-time support during peak hours, and ongoing menu updates as your business grows." }
];

// Technologies
const technologies = [
  { name: "React / Next.js", icon: "\u269B\uFE0F" },
  { name: "Node.js", icon: "\uD83D\uDFE2" },
  { name: "Stripe / Square", icon: "\uD83D\uDCB3" },
  { name: "PostgreSQL", icon: "\uD83D\uDD37" },
  { name: "AWS / Vercel", icon: "\u2601\uFE0F" },
  { name: "Google Maps API", icon: "\uD83D\uDCCD" }
];

// Challenges
const challenges = [
  {
    problem: "High Third-Party Commissions",
    description: "Delivery apps like UberEats and DoorDash take 15-30% of every order, destroying your margins.",
    solution: "Own your ordering platform with 0% commission. Keep all your profits and build direct customer relationships."
  },
  {
    problem: "Outdated or No Online Presence",
    description: "No website or an outdated one means lost customers who search online before choosing where to eat.",
    solution: "Mobile-responsive, SEO-optimized restaurant websites that rank for 'restaurants near me' and drive walk-ins and orders."
  },
  {
    problem: "No-Shows & Empty Tables",
    description: "Phone-only reservations lead to forgotten bookings, no-shows, and revenue loss from empty tables.",
    solution: "Online reservation systems with automated SMS confirmations and reminders that reduce no-shows by 60%."
  },
  {
    problem: "Inefficient Order Management",
    description: "Manual order entry from phone calls leads to errors, slow service, and frustrated customers.",
    solution: "Integrated online ordering that sends orders directly to your kitchen display or POS, eliminating manual entry errors."
  }
];

// Why Choose Us reasons
const whyChooseReasons = [
  {
    icon: `<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M6 3a1 1 0 011-1h.01a1 1 0 010 2H7a1 1 0 01-1-1zm2 3a1 1 0 00-2 0v1a2 2 0 00-2 2v1a2 2 0 00-2 2v.683a3.7 3.7 0 011.055.485 1.704 1.704 0 001.89 0 3.704 3.704 0 014.11 0 1.704 1.704 0 001.89 0 3.704 3.704 0 014.11 0 1.704 1.704 0 001.89 0A3.7 3.7 0 0118 12.683V12a2 2 0 00-2-2V9a2 2 0 00-2-2V6a1 1 0 10-2 0v1h-1V6a1 1 0 10-2 0v1H8V6zm10 8.868a3.704 3.704 0 01-4.055-.036 1.704 1.704 0 00-1.89 0 3.704 3.704 0 01-4.11 0 1.704 1.704 0 00-1.89 0A3.704 3.704 0 012 14.868V17a1 1 0 001 1h14a1 1 0 001-1v-2.132zM9 3a1 1 0 011-1h.01a1 1 0 110 2H10a1 1 0 01-1-1zm3 0a1 1 0 011-1h.01a1 1 0 110 2H13a1 1 0 01-1-1z"></path></svg>`,
    title: "Restaurant Specialists",
    description: "We've built 800+ restaurant websites and ordering systems. We understand food service operations, POS integration, and what drives orders."
  },
  {
    icon: `<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"></path><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"></path></svg>`,
    title: "Zero Commission",
    description: "Unlike third-party apps that take 30%, our ordering systems have zero commission. Keep 100% of every order and build your own customer database."
  },
  {
    icon: `<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"></path></svg>`,
