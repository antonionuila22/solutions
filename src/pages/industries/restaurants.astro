<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <IndustryHero
    badgeText="Restaurant Technology Solutions"
    headingTop="Grow Your Restaurant"
    headingBottom="Business with CodeBrand"
    subtitle="Custom restaurant websites, online ordering systems, digital menus, and reservation platforms designed to increase orders, fill tables, and delight diners."
    stats={stats}
    accentGradient="from-red-400 via-orange-400 to-amber-400"
    buttonGradient="from-orange-500 to-red-500"
    buttonHoverGradient="hover:from-orange-600 hover:to-red-600"
    buttonShadow="shadow-orange-500/25"
    buttonHoverShadow="hover:shadow-orange-500/40"
  />

  <Breadcrumbs
    items={[
      { name: "Home", href: "/" },
      { name: "Industries", href: "/industries" },
      { name: "Restaurants", href: "" }
    ]}
    variant="dark"
    class="bg-slate-900 border-y border-slate-800"
  />

  <TrustBadges />

  <IndustryIntro
    title="Digital Solutions for Modern Restaurants"
    paragraphs={introParagraphs}
    highlights={introHighlights}
  />

  <IndustryServices
    title="Complete Restaurant Technology"
    titleAccent="Solutions"
    subtitle="Everything you need to take your restaurant digital and increase revenue"
    services={services}
    accentGradient="from-red-500 to-orange-500"
  />

  <IndustryProcess
    title="Restaurant Development"
    titleAccent="Process"
    subtitle="From concept to launch — a streamlined process built for restaurant businesses"
    steps={processSteps}
    accentGradient="from-red-500 to-orange-500"
  />

  <IndustryCTA
    title="Stop Paying 30% Commission to Third-Party Apps"
    subtitle="Build your own online ordering system and keep 100% of the profits. We'll have you up and running in 2 weeks."
    ctaGradient="from-orange-600 via-red-600 to-orange-600"
    supportText="No commitment required \u2022 Free initial consultation \u2022 Go live in 2-3 weeks"
  />

  <IndustryWhyChoose
    title="Why Restaurants Choose"
    titleAccent="CodeBrand"
    subtitle="Specialized restaurant technology with proven results"
    reasons={whyChooseReasons}
    accentGradient="from-red-500 to-orange-500"
  />

  <IndustryTestimonials />

  <IndustryTechStack
    title="Restaurant-Grade"
    titleAccent="Technology Stack"
    subtitle="Proven, modern technologies to power your restaurant's digital operations"
    technologies={technologies}
  />

  <IndustryChallenges
    title="Restaurant Challenges"
    titleAccent="We Solve"
    subtitle="Technology solutions designed specifically for the food service industry"
    challenges={challenges}
  />

  <IndustryCTA
    title="Ready to Stop Paying 30% Commission?"
    subtitle="Let's build your custom online ordering system and website. Keep 100% of your profits, own your customer data, and grow your restaurant business. Schedule a free consultation with our restaurant technology experts today."
    ctaGradient="from-orange-600 via-red-600 to-orange-600"
    supportText="No commitment required \u2022 Free initial consultation \u2022 Go live in 2-3 weeks"
  />

  <IndustryFAQ
    title="Restaurant Development"
    titleAccent="FAQ"
    subtitle="Common questions about our restaurant website and ordering systems"
    faqs={restaurantFaqs}
  />

  <Whyus />

  <RelatedServices currentService="web-development" />
</Layout>
