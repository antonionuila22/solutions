---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import IndustryHero from "../../components/IndustryHero.astro";
import IndustryIntro from "../../components/IndustryIntro.astro";
import IndustryServices from "../../components/IndustryServices.astro";
import IndustryProcess from "../../components/IndustryProcess.astro";
import IndustryWhyChoose from "../../components/IndustryWhyChoose.astro";
import IndustryTechStack from "../../components/IndustryTechStack.astro";
import IndustryChallenges from "../../components/IndustryChallenges.astro";
import IndustryTestimonials from "../../components/IndustryTestimonials.astro";
import IndustryCTA from "../../components/IndustryCTA.astro";
import IndustryFAQ from "../../components/IndustryFAQ.astro";
import Whyus from "../../components/whyus.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import RelatedServices from "../../components/RelatedServices.astro";
import { createFAQSchema, createBreadcrumbSchema } from "../../utils/schema";

const title = "Restaurant Website Design & Online Ordering Systems | CodeBrand";
const description =
  "Transform your restaurant with custom websites, online ordering systems, digital menus, QR code menus, reservation software, and delivery platforms. Solutions for restaurants, cafes, bars, and food service businesses.";
const keywords =
  "restaurant website design, online ordering system for restaurants, digital menu software, QR code menu, restaurant reservation system, food delivery platform, restaurant management software, restaurant app development, online food ordering, contactless menu, restaurant POS integration, table booking software, ghost kitchen software, restaurant marketing";
const image = "/photos/Restaurantdolcevita.webp";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Restaurant Website Development",
  "name": "Restaurant Website Design & Online Ordering Systems",
  "description": description,
  "url": "https://codebrand.us/industries/restaurants",
  "provider": {
    "@type": "Organization",
    "name": "Codebrand",
    "url": "https://codebrand.us",
    "logo": "https://codebrand.us/iconcodebrand.svg"
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Restaurant Web Solutions",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Restaurant Website Design", "description": "Custom websites for restaurants and cafes" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Online Ordering Systems", "description": "Food ordering and delivery platforms" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Digital Menu & QR Codes", "description": "Contactless digital menus" }}
    ]
  }
};

// Restaurant FAQ data
const restaurantFaqs = [
  {
    question: "How much does a restaurant website cost?",
    answer: "Restaurant websites start at $2,500 for a professional site with menu, hours, and contact info. Online ordering systems add $3,000-$8,000. Full custom ordering platforms with delivery management are $10,000-$25,000. We provide quotes based on your specific needs."
  },
  {
    question: "Can you build an online ordering system for my restaurant?",
    answer: "Yes. We build custom online ordering systems that integrate with your kitchen workflow. Features include real-time order tracking, scheduled orders, delivery zones, payment processing, and POS integration. Own your platform instead of paying high commission fees."
  },
  {
    question: "Do you create QR code digital menus?",
    answer: "Absolutely. We create beautiful digital menus accessible via QR code. Customers scan and see your full menu with photos, descriptions, and prices. You can update items and prices instantly without reprinting."
  },
  {
    question: "Can you integrate with my POS system?",
    answer: "Yes. We integrate with popular restaurant POS systems including Toast, Square, Clover, and Lightspeed. Online orders sync directly to your kitchen, reducing manual entry and errors."
  },
  {
    question: "How long does it take to build a restaurant website?",
    answer: "A standard restaurant website takes 3-4 weeks. Sites with online ordering take 6-8 weeks. Full delivery platforms with driver management take 10-14 weeks. We can expedite for urgent launches."
  },
  {
    question: "Do you offer table reservation systems?",
    answer: "Yes. We build custom reservation systems or integrate with OpenTable, Resy, and other platforms. Features include table management, waitlist handling, automated confirmations, and no-show tracking."
  }
];

const faqSchema = createFAQSchema(restaurantFaqs);
const breadcrumbSchema = createBreadcrumbSchema([
  { name: "Home", url: "https://codebrand.us" },
  { name: "Industries", url: "https://codebrand.us/industries" },
  { name: "Restaurants", url: "https://codebrand.us/industries/restaurants" }
]);

const stats = [
  { value: "200%", label: "Online Order Increase" },
  { value: "60%", label: "Fewer No-Shows" },
  { value: "24/7", label: "Online Ordering" },
  { value: "0%", label: "Commission Fees" }
];

// Introduction section data
const introParagraphs = [
  "The restaurant industry has transformed dramatically. Today's diners expect to browse menus online, order from their phones, and book tables with a tap. At CodeBrand, we build custom technology solutions that help restaurants thrive in this digital era\u2014from stunning websites to complete online ordering platforms.",
  "We create beautiful, mobile-responsive restaurant websites that showcase your menu, atmosphere, and story. Our online ordering systems integrate seamlessly with your operations, accepting orders 24/7 without third-party commissions. Digital QR code menus, reservation systems, and loyalty programs complete your digital transformation.",
  "Whether you run a fine dining establishment, casual restaurant, cafe, bar, ghost kitchen, or food truck, our solutions are tailored to your unique needs. We've helped restaurants increase online orders by 200%, reduce no-shows by 60%, and build direct relationships with customers."
];

const introHighlights = [
  {
    value: "200%",
    label: "More Online Orders",
    gradient: "from-green-500 to-green-600",
    iconPath: "M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
  },
  {
    value: "0%",
    label: "Third-Party Fees",
    gradient: "from-blue-500 to-blue-600",
    iconPath: "M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"
  },
  {
    value: "800+",
    label: "Restaurants Served",
    gradient: "from-orange-500 to-orange-600",
    iconPath: "M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z"
  }
];

// Services data
const services = [
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>`,
    title: "Online Ordering Systems",
    description: "Accept orders directly from your website with zero commission fees. Custom online ordering platform with menu management, delivery zones, pickup times, and integrated payment processing.",
    features: ["0% commission - keep all profits", "Real-time menu updates", "Delivery & pickup options"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"></path></svg>`,
