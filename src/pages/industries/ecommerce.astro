---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Whyus from "../../components/whyus.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import RelatedServices from "../../components/RelatedServices.astro";
import IndustryHero from "../../components/IndustryHero.astro";
import IndustryIntro from "../../components/IndustryIntro.astro";
import IndustryServices from "../../components/IndustryServices.astro";
import IndustryProcess from "../../components/IndustryProcess.astro";
import IndustryWhyChoose from "../../components/IndustryWhyChoose.astro";
import IndustryTestimonials from "../../components/IndustryTestimonials.astro";
import IndustryTechStack from "../../components/IndustryTechStack.astro";
import IndustryChallenges from "../../components/IndustryChallenges.astro";
import IndustryFAQ from "../../components/IndustryFAQ.astro";
import IndustryCTA from "../../components/IndustryCTA.astro";
import { createFAQSchema, createBreadcrumbSchema } from "../../utils/schema";

const title = "E-commerce Development & Online Store Solutions | CodeBrand";
const description =
  "Transform your online store with custom e-commerce solutions. Shopping cart optimization, payment integrations, inventory management, and conversion-optimized design to maximize online sales.";
const keywords =
  "e-commerce development, online store development, shopping cart software, e-commerce platform, Shopify development, WooCommerce development, custom e-commerce, payment gateway integration, online retail platform, e-commerce website design, product catalog management";
const image = "/photos/bannercodebrand.webp";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "E-commerce Development",
  "name": "E-commerce Development & Online Store Solutions",
  "description": description,
  "url": "https://www.codebrand.us/industries/ecommerce",
  "provider": {
    "@type": "Organization",
    "name": "Codebrand",
    "url": "https://www.codebrand.us",
    "logo": "https://www.codebrand.us/iconcodebrand.svg"
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "E-commerce Solutions",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Custom E-commerce Stores", "description": "Shopify, WooCommerce, and custom online stores" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Payment Integration", "description": "Secure payment gateway integration" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Inventory Management", "description": "Product catalog and inventory systems" }}
    ]
  }
};

// FAQ data for e-commerce industry
const ecommerceFaqs = [
  {
    question: "How much does an e-commerce website cost?",
    answer: "E-commerce websites start at $5,000 for a basic store with essential features. Custom stores with advanced functionality range from $10,000-$25,000+. We provide detailed quotes based on your specific requirements, including product catalog size, payment integrations, and custom features needed."
  },
  {
    question: "Which e-commerce platform do you recommend?",
    answer: "It depends on your needs. For quick launches, Shopify is excellent. For WordPress users, WooCommerce offers flexibility. For high-volume stores, we build custom headless solutions. We'll recommend the best platform after understanding your business goals and budget."
  },
  {
    question: "How long does it take to build an online store?",
    answer: "A standard e-commerce store takes 6-10 weeks. This includes design, development, product upload, payment integration, and testing. Complex custom stores may take 12-16 weeks. We set clear milestones and keep you updated throughout the process."
  },
  {
    question: "Can you integrate with my existing inventory system?",
    answer: "Yes. We integrate with popular inventory management systems, ERPs, and POS systems. Whether you use NetSuite, QuickBooks, Square, or custom software, we can sync your inventory, orders, and customer data seamlessly."
  },
  {
    question: "Do you provide ongoing support after launch?",
    answer: "Absolutely. Every e-commerce project includes 90 days of post-launch support. We also offer monthly maintenance plans that include security updates, performance monitoring, and technical support to keep your store running smoothly."
  },
  {
    question: "Can you help increase my store's conversion rate?",
    answer: "Yes. We build stores optimized for conversions from day one, including streamlined checkout, trust badges, and mobile optimization. We also offer conversion rate optimization (CRO) services with A/B testing and analytics to continuously improve your sales."
  }
];

// Generate FAQ schema
const faqSchema = createFAQSchema(ecommerceFaqs);

// Breadcrumb schema
const breadcrumbSchema = createBreadcrumbSchema([
  { name: "Home", url: "https://www.codebrand.us" },
  { name: "Industries", url: "https://www.codebrand.us/industries" },
  { name: "E-commerce", url: "https://www.codebrand.us/industries/ecommerce" }
]);

// Stats for hero
const stats = [
  { value: "200+", label: "Stores Launched" },
  { value: "87%", label: "Conversion Boost" },
  { value: "$50M+", label: "Revenue Generated" },
  { value: "99.9%", label: "Uptime SLA" }
];

// Intro highlights
const introHighlights = [
  {
    value: "87%",
    label: "Conversion Rate Boost",
    gradient: "from-emerald-500 to-teal-500",
    iconPath: "M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
  },
  {
    value: "99.9%",
    label: "Uptime Guarantee",
    gradient: "from-blue-500 to-indigo-500",
    iconPath: "M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"
  },
  {
    value: "200+",
    label: "Stores Launched",
    gradient: "from-orange-500 to-red-500",
    iconPath: "M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z"
  }
];

// Services data
const services = [
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>`,
    title: "Custom E-commerce Development",
    description: "Build a unique online store tailored to your brand and products. From headless commerce to fully custom platforms.",
    features: ["Custom product catalogs", "Advanced filtering and search", "Mobile-first responsive design"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>`,
    title: "Payment Gateway Integration",
    description: "Accept payments seamlessly with secure integration of multiple payment gateways and digital wallets.",
    features: ["Stripe, PayPal, Square integration", "PCI-DSS compliant security", "Multi-currency support"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>`,
    title: "Inventory Management",
    description: "Keep track of stock levels, automate reordering, and sync inventory across multiple sales channels.",
    features: ["Real-time stock tracking", "Multi-location warehouse support", "Low stock alerts"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>`,
    title: "Conversion Rate Optimization",
    description: "Maximize sales with data-driven optimization strategies and A/B testing to turn browsers into buyers.",
    features: ["Streamlined checkout process", "Cart abandonment recovery", "Personalized recommendations"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path></svg>`,
    title: "Multi-Channel Integration",
    description: "Sell everywhere your customers are. Integrate with Amazon, eBay, and social commerce platforms.",
    features: ["Marketplace integrations", "Facebook/Instagram Shopping", "Centralized order management"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>`,
    title: "Mobile Commerce Apps",
    description: "Reach customers on their favorite devices with cross-platform mobile apps built with Expo React Native.",
    features: ["iOS & Android apps", "Push notification campaigns", "Seamless mobile payments"]
  }
];

// Process steps
const processSteps = [
  { title: "Discovery & Strategy", description: "We analyze your products, target audience, and competitors to develop a comprehensive e-commerce strategy." },
  { title: "UX Design & Prototyping", description: "Our designers create intuitive shopping experiences optimized for conversions." },
  { title: "Development & Integration", description: "We build your store using best-in-class platforms, integrating payments and third-party tools." },
  { title: "Testing & Launch", description: "Comprehensive testing ensures flawless functionality before executing a smooth launch." },
  { title: "Optimization & Growth", description: "Post-launch, we continuously monitor and optimize for better conversions." }
];

// Why choose us reasons
const whyChooseReasons = [
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M3 1a1 1 0 000 2h1.22l.305 1.222a.997.997 0 00.01.042l1.358 5.43-.893.892C3.74 11.846 4.632 14 6.414 14H15a1 1 0 000-2H6.414l1-1H14a1 1 0 00.894-.553l3-6A1 1 0 0017 3H6.28l-.31-1.243A1 1 0 005 1H3zM16 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM6.5 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3z"></path></svg>`,
    title: "E-commerce Specialists",
    description: "We live and breathe e-commerce. Our team has launched 200+ online stores and knows exactly what drives sales."
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"></path></svg>`,
    title: "Lightning-Fast Performance",
    description: "Every second counts in e-commerce. Our stores load in under 2 seconds, improving SEO and conversions."
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>`,
    title: "Bank-Level Security",
    description: "PCI-DSS compliant infrastructure, SSL encryption, and regular security audits protect your business."
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7a1 1 0 00-1 1v6.05A2.5 2.5 0 0115.95 16H17a1 1 0 001-1v-5a1 1 0 00-.293-.707l-2-2A1 1 0 0015 7h-1z"></path></svg>`,
    title: "Infinite Scalability",
    description: "Built to handle traffic spikes during sales and holidays. Our infrastructure scales automatically."
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-2 0c0 .993-.241 1.929-.668 2.754l-1.524-1.525a3.997 3.997 0 00.078-2.183l1.562-1.562C15.802 8.249 16 9.1 16 10zm-5.165 3.913l1.58 1.58A5.98 5.98 0 0110 16a5.976 5.976 0 01-2.516-.552l1.562-1.562a4.006 4.006 0 001.789.027zm-4.677-2.796a4.002 4.002 0 01-.041-2.08l-.08.08-1.53-1.533A5.98 5.98 0 004 10c0 .954.223 1.856.619 2.657l1.54-1.54zm1.088-6.45A5.974 5.974 0 0110 4c.954 0 1.856.223 2.657.619l-1.54 1.54a4.002 4.002 0 00-2.346.033L7.246 4.668zM12 10a2 2 0 11-4 0 2 2 0 014 0z" clip-rule="evenodd"></path></svg>`,
    title: "Data-Driven Decisions",
    description: "Comprehensive analytics help you understand customer behavior and make informed decisions."
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"></path><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"></path></svg>`,
    title: "Proven ROI",
    description: "Our clients see an average 87% increase in conversion rates within 6 months of launching."
  }
];

// Technologies
const technologies = [
  { name: "Shopify", icon: "🛒" },
  { name: "React", icon: "⚛️" },
  { name: "Node.js", icon: "🟢" },
  { name: "Stripe", icon: "💳" },
  { name: "AWS", icon: "☁️" },
  { name: "Security", icon: "🔐" }
];

// Challenges
const challenges = [
  {
    problem: "High Cart Abandonment",
    description: "Complicated checkout, unexpected fees, or slow loading times cause 70% of shoppers to abandon their carts.",
    solution: "Streamlined one-page checkout, guest checkout options, transparent pricing, and abandoned cart recovery emails."
  },
  {
    problem: "Poor Mobile Experience",
    description: "Over 60% of e-commerce traffic comes from mobile, but many stores offer clunky mobile experiences.",
    solution: "Mobile-first design, touch-optimized interfaces, and progressive web app features for app-like experiences."
  },
  {
    problem: "Inventory Mismanagement",
    description: "Selling out-of-stock items or losing track of inventory across multiple channels damages reputation.",
    solution: "Real-time inventory tracking, automated stock updates, and multi-channel synchronization."
  },
  {
    problem: "Limited Payment Options",
    description: "Not accepting customers' preferred payment methods leads to lost sales at checkout.",
    solution: "Multiple payment gateways, digital wallets (Apple Pay, Google Pay), buy now pay later, and international support."
  }
];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <IndustryHero
    badgeText="E-Commerce Technology Solutions"
    headingTop="Scale Your"
    headingBottom="Online Store"
    subtitle="High-converting e-commerce solutions with shopping cart optimization, payment integrations, inventory management, and conversion-optimized design to maximize online sales."
    stats={stats}
    accentGradient="from-emerald-400 via-teal-400 to-cyan-400"
    buttonGradient="from-emerald-500 to-teal-500"
    buttonHoverGradient="hover:from-emerald-600 hover:to-teal-600"
    buttonShadow="shadow-emerald-500/25"
    buttonHoverShadow="hover:shadow-emerald-500/40"
  />

  <Breadcrumbs
    items={[
      { name: "Home", href: "/" },
      { name: "Industries", href: "/industries" },
      { name: "E-commerce", href: "" }
    ]}
    variant="dark"
    class="bg-slate-900 border-y border-slate-800"
  />

  <TrustBadges />

  <IndustryIntro
    title="E-commerce Excellence in the Digital Age"
    paragraphs={[
      "The e-commerce landscape is more competitive than ever. Success requires more than just putting products online. At CodeBrand, we understand the unique challenges online retailers face—from optimizing conversion rates to providing seamless checkout experiences.",
      "We specialize in creating high-performance e-commerce platforms, custom shopping experiences, and integrated solutions that drive sales and delight customers."
    ]}
    highlights={introHighlights}
  />

  <IndustryServices
    title="Specialized E-commerce"
    titleAccent="Services"
    subtitle="Comprehensive solutions designed to help you sell more, serve better, and scale faster"
    services={services}
    accentGradient="from-emerald-500 to-teal-500"
  />

  <IndustryProcess
    title="Our E-commerce Development"
    titleAccent="Process"
    subtitle="A proven methodology that delivers high-converting online stores on time and within budget"
    steps={processSteps}
    accentGradient="from-emerald-500 to-teal-500"
  />

  <IndustryWhyChoose
    title="Why E-commerce Brands"
    titleAccent="Choose CodeBrand"
    subtitle="We combine technical excellence with e-commerce expertise to deliver stores that sell"
    reasons={whyChooseReasons}
    accentGradient="from-emerald-500 to-teal-500"
  />

  <IndustryTestimonials />

  <IndustryTechStack
    title="Built with"
    titleAccent="Best-in-Class Technology"
    subtitle="We use proven platforms and modern frameworks to deliver fast, secure, and scalable stores"
    technologies={technologies}
  />

  <IndustryChallenges
    title="Common E-commerce"
    titleAccent="Challenges We Solve"
    subtitle="Turn obstacles into opportunities with our proven solutions"
    challenges={challenges}
  />

  <IndustryFAQ
    title="E-commerce"
    titleAccent="FAQ"
    subtitle="Common questions about our e-commerce development services"
    faqs={ecommerceFaqs}
  />

  <IndustryCTA
    title="Ready to Boost Your Online Sales?"
    subtitle="Let's discuss how a high-performance e-commerce platform can increase your conversions and scale your business."
    ctaGradient="from-emerald-600 via-teal-600 to-cyan-600"
  />

  <Whyus />

  <RelatedServices currentService="web-development" />
</Layout>
