---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <IndustryHero
    badgeText="Legal Technology Solutions"
    headingTop="Modernize Your"
    headingBottom="Law Practice"
    subtitle="Custom legal technology solutions including case management systems, client portals, document automation, and professional attorney websites designed for law firms."
    stats={stats}
    accentGradient="from-indigo-400 via-purple-400 to-violet-400"
    buttonGradient="from-indigo-500 to-purple-500"
    buttonHoverGradient="hover:from-indigo-600 hover:to-purple-600"
    buttonShadow="shadow-indigo-500/25"
    buttonHoverShadow="hover:shadow-indigo-500/40"
  />

  <Breadcrumbs
    items={[
      { name: "Home", href: "/" },
      { name: "Industries", href: "/industries" },
      { name: "Law Firms", href: "" }
    ]}
    variant="transparent"
    class="bg-slate-900 border-y border-slate-800"
  />

  <TrustBadges />

  <IndustryIntro
    title="Digital Transformation for Law Firms"
    paragraphs={introParagraphs}
    highlights={introHighlights}
  />

  <IndustryServices
    title="Specialized Services for"
    titleAccent="Law Firms"
    subtitle="Comprehensive legal technology solutions tailored to meet the unique demands of modern law practices"
    services={services}
    accentGradient={accentGradient}
  />

  <IndustryProcess
    title="Our Proven"
    titleAccent="Development Process"
    subtitle="A transparent, collaborative approach that ensures your legal technology project is delivered on time and exceeds expectations"
    steps={processSteps}
    accentGradient={accentGradient}
  />

  <IndustryWhyChoose
    title="Why Law Firms Choose"
    titleAccent="CodeBrand"
    subtitle="We're not just developers\u2014we're your legal technology partners committed to your practice's success"
    reasons={whyChooseReasons}
    accentGradient={accentGradient}
  />

  <IndustryTestimonials />

  <IndustryTechStack
    title="Built with"
    titleAccent="Enterprise-Grade Technology"
    subtitle="We use cutting-edge, secure technologies trusted by Fortune 500 companies and law firms worldwide"
    technologies={technologies}
  />

  <IndustryChallenges
    title="Common Challenges"
    titleAccent="We Solve"
    subtitle="Legal practice problems require specialized legal technology solutions"
    challenges={challenges}
  />

  <IndustryFAQ
    title="Legal Website Development"
    titleAccent="FAQ"
    subtitle="Common questions about our law firm website and software development"
    faqs={lawFirmFaqs}
  />

  <IndustryCTA
    title="Ready to Transform Your Law Practice?"
    subtitle="Let's discuss how custom legal technology can increase your billable hours, improve client satisfaction, and give you a competitive advantage. Schedule a confidential consultation with our team today."
    ctaGradient="from-indigo-600 via-purple-600 to-violet-600"
    supportText="Attorney-client privilege protected \u2022 Confidential consultation \u2022 Response within 24 hours"
  />

  <Whyus />

  <RelatedServices currentService="web-development" />
</Layout>
