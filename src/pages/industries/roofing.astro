---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <IndustryHero
    badgeText="Roofing Technology Solutions"
    headingTop="Websites & Software That"
    headingBottom="Book More Roofing Jobs"
    subtitle="Instant roof estimate tools, high-converting websites, lead capture, and job management systems built specifically for roofing contractors, restoration companies, and roofing sales teams."
    stats={stats}
    accentGradient="from-red-400 via-red-400 to-orange-400"
    buttonGradient="from-red-500 to-orange-500"
    buttonHoverGradient="hover:from-red-600 hover:to-orange-600"
    buttonShadow="shadow-red-500/25"
    buttonHoverShadow="hover:shadow-red-500/40"
  />

  <Breadcrumbs
    items={[
      { name: "Home", href: "/" },
      { name: "Industries", href: "/industries" },
      { name: "Roofing", href: "" }
    ]}
    variant="transparent"
    class="bg-slate-900 border-y border-slate-800"
  />

  <TrustBadges />

  <IndustryIntro
    title="Digital Solutions Built for Roofing Contractors"
    paragraphs={[
      "The roofing business moves fast—a storm rolls through and hundreds of homeowners start searching for a roofer at once. The companies that win are the ones that show up first, look trustworthy, and make it effortless to get a quote and book an inspection. At CodeBrand, we build the websites and software that make that happen.",
      "We've worked in the roofing space and understand what actually drives revenue: capturing leads before your competitors do, ranking for local searches, giving homeowners instant estimates, and keeping your crews and office in sync. We don't build generic template sites—we build conversion machines and job-management tools tailored to how roofing companies really operate.",
      "Whether you're a residential roofer, a storm-restoration company, or a commercial roofing contractor, our solutions help you book more inspections, close more jobs, and run a tighter operation. From a single crew to a multi-city outfit, we build technology that grows with you."
    ]}
    highlights={introHighlights}
  />

  <IndustryServices
    title="Specialized Services for"
    titleAccent="Roofing Companies"
    subtitle="Websites, tools, and software engineered to capture roofing leads and turn them into booked jobs"
    services={services}
    accentGradient={accentGradient}
  />

  <IndustryProcess
    title="Our Proven"
    titleAccent="Development Process"
    subtitle="A transparent, collaborative approach that gets your roofing business online and booking jobs—on time"
    steps={processSteps}
    accentGradient={accentGradient}
  />

  <IndustryWhyChoose
    title="Why Roofing Companies Choose"
    titleAccent="CodeBrand"
    subtitle="We're not just developers—we're your growth partners, focused on filling your sales pipeline"
    reasons={whyChooseReasons}
    accentGradient={accentGradient}
  />

  <IndustryTestimonials />

  <IndustryTechStack
    title="Built with Modern,"
    titleAccent="Reliable Technology"
    subtitle="We use cutting-edge tools and frameworks to build fast, secure, and scalable roofing solutions"
    technologies={technologies}
  />

  <IndustryChallenges
    title="Common Challenges"
    titleAccent="We Solve"
    subtitle="Roofing-specific problems require roofing-specific solutions"
    challenges={challenges}
  />

  <IndustryCTA
    title="Ready to Book More Roofing Jobs?"
    subtitle="Let's talk about a website and software setup that captures more leads, ranks in your service area, and keeps your crews and office in sync. Schedule a free consultation with our team today."
    ctaGradient="from-red-600 via-red-600 to-orange-600"
  />

  <IndustryFAQ
    title="Roofing Development"
    titleAccent="FAQ"
    subtitle="Common questions about our roofing website and software development services"
    faqs={roofingFaqs}
  />

  <Whyus />

  <RelatedServices currentService="web-development" />
</Layout>
