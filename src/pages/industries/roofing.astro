const technologies = [
  { name: "React", icon: "atom" },
  { name: "React Native", icon: "smartphone" },
  { name: "Node.js", icon: "server" },
  { name: "PostgreSQL", icon: "database" },
  { name: "AWS", icon: "cloud" },
  { name: "Security", icon: "shield-check" }
];

const challenges = [
  {
    problem: "Slow Lead Response",
    description: "Homeowners call three roofers and hire the first to respond. Leads sitting in an inbox for hours become someone else's job.",
    solution: "Instant lead capture with automated follow-up, text alerts to your sales team, and online booking that lets homeowners self-schedule in seconds."
  },
  {
    problem: "Website That Doesn't Convert",
    description: "A slow, generic template site makes you look like every other roofer and sends visitors straight to a competitor.",
    solution: "A fast, custom, conversion-focused website with click-to-call, instant estimates, real project photos, and reviews that build instant trust."
  },
  {
    problem: "Invisible in Local Search",
    description: "If you don't rank for 'roofers near me' and your service-area cities, you're invisible to homeowners actively searching for a roof.",
    solution: "Local SEO, dedicated city and service-area pages, and Google Business Profile optimization that put you at the top of the map pack."
  },
  {
    problem: "Chaos Between Office & Field",
    description: "Leads, photos, measurements, and job status scattered across texts, emails, and paper cause missed follow-ups and blown deadlines.",
    solution: "A unified CRM and field app that connects your website, crews, and office—one place for every lead, photo, estimate, and job."
  }
