  },
  {
    problem: "No Local Search Visibility",
    description: "Your website doesn't show up when people search for \"homes for sale in [city]\" or other high-value local real estate terms.",
    solution: "Comprehensive local SEO with location-specific pages, schema markup, and optimized property descriptions for local search dominance."
  }
];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <IndustryHero
    badgeText="Real Estate Technology Solutions"
    headingTop="Elevate Your"
    headingBottom="Real Estate Business"
    subtitle="Property listing websites with MLS/IDX integration, virtual tours, CRM systems, and lead capture designed to help agents and brokerages close more deals."
    stats={stats}
    accentGradient="from-amber-400 via-orange-400 to-red-400"
    buttonGradient="from-amber-500 to-orange-500"
    buttonHoverGradient="hover:from-amber-600 hover:to-orange-600"
    buttonShadow="shadow-amber-500/25"
    buttonHoverShadow="hover:shadow-amber-500/40"
  />

  <Breadcrumbs
    items={[
      { name: "Home", href: "/" },
      { name: "Industries", href: "/industries" },
      { name: "Real Estate", href: "" }
    ]}
    variant="transparent"
    class="bg-slate-900 border-y border-slate-800"
  />

  <TrustBadges />

  <IndustryIntro
    title="Digital Innovation for Modern Real Estate Professionals"
    paragraphs={introParagraphs}
    highlights={introHighlights}
  />

  <IndustryServices
    title="Comprehensive Real Estate"
    titleAccent="Technology Solutions"
    subtitle="Everything you need to showcase properties, capture leads, and grow your real estate business"
    services={services}
    accentGradient={accentGradient}
  />

  <IndustryProcess
    title="Our Real Estate"
    titleAccent="Development Process"
    subtitle="A streamlined approach that delivers beautiful, high-converting real estate websites"
    steps={processSteps}
    accentGradient={accentGradient}
  />

  <IndustryWhyChoose
    title="Why Real Estate Professionals Choose"
    titleAccent="CodeBrand"
    subtitle="Proven expertise in real estate technology and digital marketing"
    reasons={whyChooseReasons}
    accentGradient={accentGradient}
  />

  <IndustryTestimonials />

  <IndustryTechStack
    title="Built with Modern"
    titleAccent="Real Estate Technology"
    subtitle="We use proven platforms and cutting-edge tools to build high-performance real estate websites"
    technologies={technologies}
  />

  <IndustryChallenges
    title="Real Estate Challenges"
    titleAccent="We Solve"
    subtitle="Technology solutions designed specifically for real estate professionals"
    challenges={challenges}
  />

  <IndustryFAQ
    title="Real Estate Development"
    titleAccent="FAQ"
    subtitle="Common questions about our real estate website development services"
    faqs={realEstateFaqs}
  />

  <IndustryCTA
    title="Ready to Generate More Real Estate Leads?"
    subtitle="Let's discuss how a modern, IDX-enabled real estate website can showcase your properties, capture more leads, and grow your business. Schedule a free consultation with our real estate technology experts today."
    ctaGradient="from-amber-600 via-orange-600 to-red-600"
    supportText="No commitment required \u2022 Free initial consultation \u2022 Response within 24 hours"
  />

  <Whyus />

  <RelatedServices currentService="web-development" />
</Layout>
