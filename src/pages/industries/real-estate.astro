---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Whyus from "../../components/whyus.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import RelatedServices from "../../components/RelatedServices.astro";
import { createFAQSchema, createBreadcrumbSchema } from "../../utils/schema";
import IndustryHero from "../../components/IndustryHero.astro";
import IndustryIntro from "../../components/IndustryIntro.astro";
import IndustryServices from "../../components/IndustryServices.astro";
import IndustryProcess from "../../components/IndustryProcess.astro";
import IndustryWhyChoose from "../../components/IndustryWhyChoose.astro";
import IndustryTestimonials from "../../components/IndustryTestimonials.astro";
import IndustryTechStack from "../../components/IndustryTechStack.astro";
import IndustryChallenges from "../../components/IndustryChallenges.astro";
import IndustryFAQ from "../../components/IndustryFAQ.astro";
import IndustryCTA from "../../components/IndustryCTA.astro";

const title =
  "Real Estate Software Development & Property Listing Websites | CodeBrand";
const description =
  "Transform your real estate business with custom property listing websites, MLS integration, virtual tour software, and CRM solutions. IDX-enabled platforms designed for realtors, brokers, and property management companies.";
const keywords =
  "real estate software development, property listing website, real estate web development, MLS integration, IDX website, real estate CRM, property management software, virtual tour software, real estate app development, realtor website design, property search platform, real estate portal development, 3D property tours, real estate lead generation";
const image = "/photos/webservice.webp";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Real Estate Software Development",
  "name": "Real Estate Software Development & Property Listing Websites",
  "description": description,
  "url": "https://codebrand.us/industries/real-estate",
  "provider": {
    "@type": "Organization",
    "name": "Codebrand",
    "url": "https://codebrand.us",
    "logo": "https://codebrand.us/iconcodebrand.svg"
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Real Estate Web Solutions",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Property Listing Websites", "description": "IDX-enabled property search platforms" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "MLS Integration", "description": "Real-time MLS data integration" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Virtual Tour Software", "description": "3D property tours and visualization" }}
    ]
  }
};

// Real Estate FAQ data
const realEstateFaqs = [
  {
    question: "How much does a real estate website cost?",
    answer: "Real estate websites start at $5,000 for a professional site with property listings. IDX-enabled sites with MLS integration range from $8,000-$15,000. Custom property portals with advanced search are $15,000-$35,000. We provide detailed quotes based on your needs."
  },
  {
    question: "Can you integrate with MLS/IDX feeds?",
    answer: "Yes. We specialize in MLS and IDX integrations. We can connect your website to local MLS boards, display real-time listings, and keep data synchronized automatically. We work with popular IDX providers and can build custom solutions."
  },
  {
    question: "Do you offer virtual tour and 3D walkthrough features?",
    answer: "Absolutely. We integrate virtual tour software including Matterport, 3DVista, and custom 360\u00B0 solutions. Buyers can explore properties from anywhere, increasing engagement and reducing unnecessary showings."
  },
  {
    question: "How long does it take to build a real estate website?",
    answer: "A standard real estate website takes 6-8 weeks. Sites with full IDX integration take 8-12 weeks due to MLS approval processes. Custom property management platforms take 12-16 weeks depending on features."
  },
  {
    question: "Can agents have their own profiles and listings?",
    answer: "Yes. We build multi-agent platforms where each realtor has a personal profile, their own listings, lead capture forms, and performance dashboards. Perfect for brokerages and real estate teams."
  },
  {
    question: "Do you provide CRM integration for lead management?",
    answer: "Yes. We integrate with popular real estate CRMs like Follow Up Boss, kvCORE, and Salesforce. Leads from your website are automatically captured and synced to your CRM for follow-up."
  }
];

const faqSchema = createFAQSchema(realEstateFaqs);
const breadcrumbSchema = createBreadcrumbSchema([
  { name: "Home", url: "https://codebrand.us" },
  { name: "Industries", url: "https://codebrand.us/industries" },
  { name: "Real Estate", url: "https://codebrand.us/industries/real-estate" }
]);

const stats = [
  { value: "156%", label: "More Leads" },
  { value: "MLS", label: "IDX Integrated" },
  { value: "500+", label: "Properties Listed" },
  { value: "3D", label: "Virtual Tours" }
];

const accentGradient = "from-amber-500 to-orange-500";

const introHighlights = [
  {
    value: "3.5x",
    label: "More Qualified Leads",
    gradient: "from-green-500 to-green-600",
    iconPath: "M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
  },
  {
    value: "85%",
    label: "Lead Response Rate",
    gradient: "from-blue-500 to-blue-600",
    iconPath: "M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"
  },
  {
    value: "500+",
    label: "Real Estate Sites Built",
    gradient: "from-orange-500 to-orange-600",
    iconPath: "M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z"
  }
];

const introParagraphs = [
  "The real estate industry is increasingly digital, and success requires more than just great properties\u2014you need technology that showcases listings beautifully, captures leads effectively, and streamlines your entire sales process. At CodeBrand, we specialize in creating custom real estate software for agents, brokers, property managers, and real estate companies.",
  "We build stunning property listing websites with MLS/IDX integration, virtual tour capabilities, and advanced search features that help buyers find their dream properties. Our CRM and lead management systems ensure no opportunity slips through the cracks, while our property management platforms streamline operations for landlords and property managers.",
  "Our team understands the real estate industry's unique needs\u2014from IDX compliance and MLS data feeds to virtual staging and 3D walkthroughs. We've worked with independent agents, large brokerages, property management companies, and real estate developers to create technology solutions that drive results."
];

const services = [
