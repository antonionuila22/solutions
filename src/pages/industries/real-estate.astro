const technologies = [
  { name: "IDX / MLS", icon: "\uD83C\uDFE0" },
  { name: "React", icon: "\u269B\uFE0F" },
  { name: "Node.js", icon: "\uD83D\uDFE2" },
  { name: "Google Maps", icon: "\uD83D\uDDFA\uFE0F" },
  { name: "AWS", icon: "\u2601\uFE0F" },
  { name: "Matterport", icon: "\uD83D\uDCF8" }
];

const challenges = [
  {
    problem: "Outdated Property Listings",
    description: "Manually updating listings is time-consuming and error-prone. Out-of-date information frustrates buyers and damages your reputation.",
    solution: "MLS/IDX integration with automatic updates ensures listings are always current, accurate, and synchronized."
  },
  {
    problem: "Low Lead Generation",
    description: "Your website gets traffic but doesn't convert visitors into leads. No contact forms, poor calls-to-action, or unclear value proposition.",
    solution: "Strategic lead capture forms, property alerts, saved searches, and compelling CTAs that convert visitors into qualified leads."
  },
  {
    problem: "Poor Mobile Experience",
    description: "Over 70% of property searches happen on mobile, but your site isn't optimized. Slow load times and difficult navigation lose potential buyers.",
