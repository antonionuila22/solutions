    title: "Property Management Software",
    description: "Comprehensive platforms for property managers and landlords. Tenant portals, rent collection, maintenance requests, lease management, and financial reporting\u2014all in one centralized system.",
    features: [
      "Online rent collection",
      "Maintenance request tracking",
      "Tenant screening & applications"
    ]
  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>',
    title: "Lead Generation & Marketing",
    description: "Integrated marketing tools that attract and convert more leads. Landing pages, property alerts, saved searches, market reports, and email campaigns that keep you top-of-mind with prospects.",
    features: [
      "Custom landing pages",
      "Automated property alerts",
      "Email marketing campaigns"
    ]
  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>',
    title: "Real Estate Mobile Apps",
    description: "Cross-platform mobile apps built with Expo React Native for iOS and Android. Push notifications for new listings, saved searches, mortgage calculators, and immersive features for visualizing properties.",
    features: [
      "Expo React Native for iOS & Android",
      "GPS-based property search",
      "Push notifications for new listings"
    ]
  }
];

const processSteps = [
  {
    title: "Market Research & Strategy",
    description: "We analyze your target market, competition, and unique value proposition. Understanding local real estate trends and buyer behavior helps us create a strategy that positions you for success in your specific market."
  },
  {
    title: "Design & User Experience",
    description: "Our designers create stunning, conversion-focused layouts that showcase properties beautifully. We design intuitive search experiences, engaging property detail pages, and compelling calls-to-action that turn visitors into leads."
  },
  {
    title: "MLS/IDX Integration & Development",
    description: "We integrate with your MLS provider for automatic listing updates, ensuring your site always shows current inventory. Our developers build fast, SEO-optimized platforms with advanced search capabilities and mobile responsiveness."
  },
  {
    title: "SEO & Lead Capture Setup",
    description: "We optimize every page for search engines and implement strategic lead capture forms. Property-specific SEO, local search optimization, and conversion-optimized contact forms ensure maximum visibility and lead generation."
  },
  {
    title: "Launch & Ongoing Optimization",
    description: "After thorough testing, we launch your site and monitor performance closely. We provide analytics insights, A/B test improvements, and continuously optimize to increase leads and conversions over time."
  }
];

const whyChooseReasons = [
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path></svg>',
    title: "Real Estate Specialists",
    description: "We've built 500+ real estate websites and understand MLS/IDX requirements, local search SEO, and what converts property searchers into leads."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"></path></svg>',
    title: "Lightning-Fast Load Times",
    description: "Our real estate sites load in under 2 seconds, even with thousands of property listings. Fast sites rank better and convert more visitors."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"></path></svg>',
    title: "Advanced Lead Capture",
    description: "Strategic lead forms, property alerts, and automated follow-ups that capture 3.5x more qualified leads than industry averages."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path><path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"></path></svg>',
