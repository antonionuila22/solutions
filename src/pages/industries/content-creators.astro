---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Whyus from "../../components/whyus.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import RelatedServices from "../../components/RelatedServices.astro";
import IndustryHero from "../../components/IndustryHero.astro";
import IndustryIntro from "../../components/IndustryIntro.astro";
import IndustryServices from "../../components/IndustryServices.astro";
import IndustryProcess from "../../components/IndustryProcess.astro";
import IndustryWhyChoose from "../../components/IndustryWhyChoose.astro";
import IndustryTestimonials from "../../components/IndustryTestimonials.astro";
import IndustryTechStack from "../../components/IndustryTechStack.astro";
import IndustryChallenges from "../../components/IndustryChallenges.astro";
import IndustryFAQ from "../../components/IndustryFAQ.astro";
import IndustryCTA from "../../components/IndustryCTA.astro";
import { createFAQSchema, createBreadcrumbSchema } from "../../utils/schema";

const stats = [
  { value: "500+", label: "Creators Launched" },
  { value: "10x", label: "Brand Visibility" },
  { value: "100%", label: "Custom Design" },
  { value: "24/7", label: "Portfolio Live" }
];

const title = "Content Creator Website Design | Influencer Sites | Codebrand";
const description =
  "Build your personal brand with custom websites for YouTubers, streamers, and content creators. Showcase your content, sell merch, manage memberships, and monetize your audience beyond the platform.";
const keywords =
  "youtuber website design, content creator website, influencer website development, youtube channel website, streamer website design, content creator portfolio, video creator website, influencer landing page, creator platform development, youtube branding website, twitch streamer website, instagram influencer website, content creator merch store, influencer membership platform";
const image = "/photos/bannercodebrand.webp";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Content Creator Website Development",
  "name": "Content Creator Website Design | Influencer Sites",
  "description": description,
  "url": "https://codebrand.us/industries/content-creators",
  "provider": {
    "@type": "Organization",
    "name": "Codebrand",
    "url": "https://codebrand.us",
    "logo": "https://codebrand.us/iconcodebrand.svg"
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Creator Web Solutions",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Creator Portfolio Sites", "description": "Personal brand websites for content creators" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Merch Store Integration", "description": "E-commerce for merchandise sales" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Membership Platforms", "description": "Subscription and membership systems" }}
    ]
  }
};

// Content Creator FAQ data
const creatorFaqs = [
  {
    question: "How much does a content creator website cost?",
    answer: "Creator websites start at $2,500 for a portfolio site with social links and contact form. Sites with merch stores range from $5,000-$10,000. Membership platforms with exclusive content are $10,000-$20,000. We customize based on your brand needs."
  },
  {
    question: "Can I sell merchandise through my website?",
    answer: "Yes. We build custom merch stores integrated with print-on-demand services like Printful and Printify, or fulfillment centers for your own inventory. Accept payments globally and track sales in one dashboard."
  },
  {
    question: "Do you build membership/subscription platforms?",
    answer: "Absolutely. We create membership sites where fans pay monthly for exclusive content, early access, behind-the-scenes, and community features. Own your audience instead of relying on platform algorithms."
  },
  {
    question: "Can you integrate my YouTube and social channels?",
    answer: "Yes. We embed your latest videos, display subscriber counts, link all your platforms, and can even pull content automatically via APIs. Your website becomes your central hub."
  },
  {
    question: "How long does it take to build a creator website?",
    answer: "A portfolio/brand site takes 3-4 weeks. Sites with merch stores take 5-7 weeks. Full membership platforms take 8-12 weeks depending on features and content migration."
  },
  {
    question: "Can I manage my own content after launch?",
    answer: "Yes. We build easy-to-use content management systems. Upload videos, blog posts, and merch without touching code. We also provide training and support to get you comfortable."
  }
];

const faqSchema = createFAQSchema(creatorFaqs);
const breadcrumbSchema = createBreadcrumbSchema([
  { name: "Home", url: "https://codebrand.us" },
  { name: "Industries", url: "https://codebrand.us/industries" },
  { name: "Content Creators", url: "https://codebrand.us/industries/content-creators" }
]);

const accentGradient = "from-pink-500 to-rose-500";

const introHighlights = [
  { value: "380%", label: "More Email Signups", gradient: "from-green-500 to-green-600", iconPath: "M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" },
  { value: "$45K+", label: "Monthly Merch Revenue", gradient: "from-blue-500 to-blue-600", iconPath: "M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z" },
  { value: "1,200+", label: "Creators Served", gradient: "from-orange-500 to-orange-600", iconPath: "M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" }
];

const services = [
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>',
    title: "Creator Portfolio Websites",
    description: "Stunning, brand-focused websites that showcase your best content, highlight your achievements, display media kits for sponsors, and serve as your professional digital headquarters. SEO-optimized to rank for your name and niche.",
    features: ["Custom branding and design", "Video gallery and portfolio showcase", "Press kit and media resources"]
  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>',
    title: "Merch Store Integration",
    description: "Integrated e-commerce stores where you can sell merchandise, digital products, courses, and exclusive content directly to your fans. Keep 100% of profits (minus payment processing) with no platform fees or middlemen.",
    features: ["Print-on-demand integration", "Digital product delivery", "Secure payment processing"]
  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>',
    title: "Membership & Subscription Platform",
    description: "Create your own Patreon-style membership platform. Offer exclusive content, behind-the-scenes videos, early access, and community features to superfans. Recurring revenue without platform fees.",
    features: ["Tiered membership levels", "Exclusive content gating", "Recurring billing management"]
  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>',
    title: "Sponsorship Landing Pages",
    description: "Professional landing pages designed to attract sponsors and brand deals. Display your stats, demographics, engagement rates, previous partnerships, and packages. Make it easy for brands to say yes.",
    features: ["Audience demographics showcase", "Sponsorship package builder", "Case studies and testimonials"]
  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>',
    title: "Email List Building",
    description: "Build and own your email list\u2014your most valuable asset as a creator. Integrated email capture, lead magnets, automated welcome sequences, and newsletter management. Convert subscribers into customers.",
    features: ["Lead magnet creation and delivery", "Email marketing automation", "Subscriber segmentation"]
  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>',
    title: "Content Hub & Video Gallery",
    description: "Centralized content hub that aggregates your latest videos, podcasts, blog posts, and social media in one place. Beautiful video galleries with YouTube/Vimeo embedding and categorization.",
    features: ["Auto-sync with YouTube/Twitch", "Content categorization and search", "SEO-optimized video pages"]
  }
];

const processSteps = [
  { title: "Brand & Audience Analysis", description: "We analyze your brand, content style, target audience, and monetization goals. We review your existing platforms to understand what resonates with your community and how to translate that to your website." },
  { title: "Custom Brand Design", description: "Our designers create a stunning website that reflects your unique brand identity, color scheme, and personality. Every element is designed to convert visitors into fans, subscribers, and customers." },
  { title: "Monetization Integration", description: "We integrate all your monetization streams\u2014merch stores, memberships, digital products, sponsors, and affiliate links. Everything works seamlessly to maximize revenue." },
  { title: "Launch & Promotion Strategy", description: "We help you launch your website with maximum impact. This includes announcement templates, email sequences, and social media promotion strategies to drive traffic from day one." },
  { title: "Optimization & Growth", description: "We track conversion rates, analyze user behavior, and continuously optimize your website for better results. As you grow, we add new features and revenue streams to scale with you." }
];

const whyChooseReasons = [
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z"></path></svg>',
    title: "Creator Economy Experts",
    description: "We've built websites for 1,200+ creators across YouTube, Twitch, Instagram, TikTok, and podcasting. We understand your monetization challenges and opportunities."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"></path><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"></path></svg>',
    title: "Multiple Revenue Streams",
    description: "We help you diversify beyond AdSense/ad revenue. Merch, memberships, digital products, courses, and sponsorships\u2014all integrated seamlessly."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm0 4a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z" clip-rule="evenodd"></path></svg>',
    title: "Own Your Audience",
    description: "Platforms can delete your channel tomorrow. We help you build an email list, membership community, and direct fan relationships that you control forever."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"></path></svg>',
    title: "Brand Deal Magnet",
    description: "A professional website increases your perceived value to sponsors. Our sponsorship pages showcase your stats and make it easy for brands to partner with you."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path><path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"></path></svg>',
    title: "Creator-Friendly Pricing",
    description: "Flexible payment plans designed for creators. Start small and scale as your channel grows. We grow when you grow\u2014we're partners in your success."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-2 0c0 .993-.241 1.929-.668 2.754l-1.524-1.525a3.997 3.997 0 00.078-2.183l1.562-1.562C15.802 8.249 16 9.1 16 10zm-5.165 3.913l1.58 1.58A5.98 5.98 0 0110 16a5.976 5.976 0 01-2.516-.552l1.562-1.562a4.006 4.006 0 001.789.027zm-4.677-2.796a4.002 4.002 0 01-.041-2.08l-.08.08-1.53-1.533A5.98 5.98 0 004 10c0 .954.223 1.856.619 2.657l1.54-1.54zm1.088-6.45A5.974 5.974 0 0110 4c.954 0 1.856.223 2.657.619l-1.54 1.54a4.002 4.002 0 00-2.346.033L7.246 4.668zM12 10a2 2 0 11-4 0 2 2 0 014 0z" clip-rule="evenodd"></path></svg>',
