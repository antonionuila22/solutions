---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import IndustryHero from "../../components/IndustryHero.astro";
import Whyus from "../../components/whyus.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import RelatedServices from "../../components/RelatedServices.astro";
import IndustryIntro from "../../components/IndustryIntro.astro";
import IndustryServices from "../../components/IndustryServices.astro";
import IndustryProcess from "../../components/IndustryProcess.astro";
import IndustryWhyChoose from "../../components/IndustryWhyChoose.astro";
import IndustryTestimonials from "../../components/IndustryTestimonials.astro";
import IndustryTechStack from "../../components/IndustryTechStack.astro";
import IndustryChallenges from "../../components/IndustryChallenges.astro";
import IndustryFAQ from "../../components/IndustryFAQ.astro";
import IndustryCTA from "../../components/IndustryCTA.astro";
import { createFAQSchema, createBreadcrumbSchema } from "../../utils/schema";

const title =
  "Construction Software & Contractor Website Development | CodeBrand";
const description =
  "Transform your construction business with custom web solutions. Project management systems, client portals, bid management, and mobile apps designed specifically for the construction industry.";
const keywords =
  "construction web development, construction software, project management system, contractor websites, construction CRM, building industry technology, construction project management, bid management software, contractor software, construction portal, field management app";
const image = "/photos/bannercodebrand.webp";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Construction Software Development",
  "name": "Construction Software & Contractor Website Development",
  "description": description,
  "url": "https://www.codebrand.us/industries/construction",
  "provider": {
    "@type": "Organization",
    "name": "Codebrand",
    "url": "https://www.codebrand.us",
    "logo": "https://www.codebrand.us/iconcodebrand.svg"
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Construction Web Solutions",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Contractor Websites", "description": "Professional websites for construction companies" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Project Management Systems", "description": "Construction project tracking and management" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Bid Management Software", "description": "Construction bidding and proposal systems" }}
    ]
  }
};

// Construction FAQ data
const constructionFaqs = [
  {
    question: "How much does a construction company website cost?",
    answer: "Construction websites start at $3,500 for a professional site with portfolio and contact forms. Sites with project management features range from $8,000-$20,000. Full bid management platforms are $25,000+. We provide quotes based on your company's needs."
  },
  {
    question: "Can you build project management software for construction?",
    answer: "Yes. We develop custom project management systems with features like timeline tracking, budget management, document storage, subcontractor coordination, and progress reporting. Accessible from the office or job site."
  },
  {
    question: "Do you integrate with construction software like Procore?",
    answer: "Absolutely. We integrate with industry-standard tools including Procore, Buildertrend, CoConstruct, and accounting software like QuickBooks. Data flows seamlessly between your systems."
  },
  {
    question: "Can clients track their project progress online?",
    answer: "Yes. We build client portals where homeowners can view construction progress, photos, timelines, change orders, and communicate with your team. Increases transparency and client satisfaction."
  },
  {
    question: "How long does it take to build a construction website?",
    answer: "A professional construction website takes 4-6 weeks. Sites with project management features take 10-14 weeks. Full custom platforms take 16-24 weeks depending on complexity."
  },
  {
    question: "Do you offer bid management solutions?",
    answer: "Yes. Our bid management systems include RFP tracking, subcontractor databases, cost estimation tools, and proposal generation. Streamline your bidding process and win more projects."
  }
];

const faqSchema = createFAQSchema(constructionFaqs);
const breadcrumbSchema = createBreadcrumbSchema([
  { name: "Home", url: "https://www.codebrand.us" },
  { name: "Industries", url: "https://www.codebrand.us/industries" },
  { name: "Construction", url: "https://www.codebrand.us/industries/construction" }
]);

const stats = [
  { value: "95%", label: "Client Satisfaction" },
  { value: "40%", label: "Faster Estimates" },
  { value: "200+", label: "Contractors Served" },
  { value: "24/7", label: "Project Tracking" }
];

const accentGradient = "from-yellow-500 to-amber-500";

const introHighlights = [
  { value: "40%", label: "Time Savings", gradient: "from-green-500 to-green-600", iconPath: "M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" },
  { value: "98%", label: "Client Satisfaction", gradient: "from-blue-500 to-blue-600", iconPath: "M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z" },
  { value: "50+", label: "Projects Completed", gradient: "from-orange-500 to-orange-600", iconPath: "M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" }
];

const services = [
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>',
    title: "Project Management Systems",
    description: "Custom-built project management platforms that help you track multiple construction projects, manage timelines, budgets, and resources all in one place. Real-time updates keep your entire team aligned and informed.",
    features: ["Task scheduling and assignment", "Budget tracking and forecasting", "Document management"]
  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>',
    title: "Mobile Field Apps",
    description: "Empower your field teams with mobile applications that work offline and sync automatically. Capture photos, update progress, track time, and communicate with the office—all from the job site.",
    features: ["Offline functionality", "Photo and video documentation", "GPS tracking and geolocation"]
  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>',
    title: "Client Portals",
    description: "Build trust and transparency with custom client portals where your customers can view project progress, access documents, review invoices, and communicate with your team 24/7.",
    features: ["Real-time project updates", "Secure document sharing", "Invoice and payment tracking"]
  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>',
    title: "Professional Websites",
    description: "Stand out from competitors with a modern, mobile-responsive website that showcases your portfolio, services, and expertise. Optimized for search engines to attract more leads.",
    features: ["SEO optimization", "Portfolio showcase", "Lead generation forms"]
  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>',
    title: "Estimation Software",
    description: "Speed up your bidding process with custom estimation tools that calculate materials, labor costs, and project timelines accurately. Generate professional proposals in minutes.",
    features: ["Material cost tracking", "Labor calculations", "Professional proposal templates"]
  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>',
    title: "Custom Integrations",
    description: "Connect all your existing tools and software with custom integrations. From accounting software to CRM systems, we ensure all your systems work together seamlessly.",
    features: ["QuickBooks integration", "API development", "Data synchronization"]
  }
];

const processSteps = [
  { title: "Discovery & Planning", description: "We start by understanding your construction business inside and out. We'll meet with your team, observe your workflows, and identify opportunities for improvement. This phase includes defining project scope, goals, and success metrics." },
  { title: "Design & Prototyping", description: "Our design team creates intuitive, user-friendly interfaces tailored to construction professionals. We'll develop interactive prototypes so you can experience the solution before development begins. Your feedback drives refinement." },
  { title: "Development & Testing", description: "Our development team builds your solution using modern, scalable technologies. We follow agile methodologies with regular check-ins and demos. Rigorous testing ensures everything works flawlessly on all devices and scenarios." },
  { title: "Training & Deployment", description: "We provide comprehensive training for your team to ensure smooth adoption. Our deployment process is carefully planned to minimize disruption to your operations. We're with you every step of the way during launch." },
  { title: "Support & Optimization", description: "Our relationship doesn't end at launch. We provide ongoing support, maintenance, and optimization services. As your business grows and evolves, we'll enhance your solution with new features and improvements." }
];

const whyChooseReasons = [
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M10.707 2.293a1 1 0 00-1.414 0l-7 7a1 1 0 001.414 1.414L4 10.414V17a1 1 0 001 1h2a1 1 0 001-1v-2a1 1 0 011-1h2a1 1 0 011 1v2a1 1 0 001 1h2a1 1 0 001-1v-6.586l.293.293a1 1 0 001.414-1.414l-7-7z"></path></svg>',
    title: "Industry Expertise",
    description: "We've worked extensively with construction companies and understand the unique challenges, regulations, and workflows specific to your industry."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"></path></svg>',
    title: "Fast Development",
    description: "Our agile approach and experienced team means faster time-to-market without compromising quality. See results in weeks, not months."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>',
    title: "Security First",
    description: "Your data and your clients' data are protected with enterprise-grade security measures, encryption, and regular security audits."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"></path><path d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7a1 1 0 00-1 1v6.05A2.5 2.5 0 0115.95 16H17a1 1 0 001-1v-5a1 1 0 00-.293-.707l-2-2A1 1 0 0015 7h-1z"></path></svg>',
    title: "Scalable Solutions",
    description: "Our solutions grow with your business. Whether you're managing 5 projects or 500, our systems scale seamlessly to meet your needs."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-2 0c0 .993-.241 1.929-.668 2.754l-1.524-1.525a3.997 3.997 0 00.078-2.183l1.562-1.562C15.802 8.249 16 9.1 16 10zm-5.165 3.913l1.58 1.58A5.98 5.98 0 0110 16a5.976 5.976 0 01-2.516-.552l1.562-1.562a4.006 4.006 0 001.789.027zm-4.677-2.796a4.002 4.002 0 01-.041-2.08l-.08.08-1.53-1.533A5.98 5.98 0 004 10c0 .954.223 1.856.619 2.657l1.54-1.54zm1.088-6.45A5.974 5.974 0 0110 4c.954 0 1.856.223 2.657.619l-1.54 1.54a4.002 4.002 0 00-2.346.033L7.246 4.668zM12 10a2 2 0 11-4 0 2 2 0 014 0z" clip-rule="evenodd"></path></svg>',
    title: "24/7 Support",
    description: "Construction doesn't stop at 5 PM, and neither do we. Our support team is available around the clock to help you succeed."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"></path><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"></path></svg>',
    title: "Cost-Effective",
    description: "We provide transparent pricing with no hidden fees. Our solutions deliver ROI by reducing manual work, minimizing errors, and improving efficiency."
  }
];

const technologies = [
  { name: "React", icon: "\u269B\uFE0F" },
  { name: "React Native", icon: "\uD83D\uDCF1" },
  { name: "Node.js", icon: "\uD83D\uDFE2" },
  { name: "PostgreSQL", icon: "\uD83D\uDD37" },
  { name: "AWS", icon: "\u2601\uFE0F" },
  { name: "Security", icon: "\uD83D\uDD10" }
];

const challenges = [
  {
    problem: "Manual Document Management",
    description: "Piles of paperwork, lost documents, and version control nightmares slow down projects and create liability issues.",
    solution: "Cloud-based document management with version control, e-signatures, and instant access from anywhere."
  },
  {
    problem: "Poor Communication",
    description: "Miscommunication between office staff, field crews, subcontractors, and clients leads to costly delays and rework.",
    solution: "Integrated messaging, notifications, and client portals that keep everyone on the same page in real-time."
  },
  {
    problem: "Inaccurate Estimates",
    description: "Manual calculations lead to estimation errors that eat into profit margins or lose bids to competitors.",
    solution: "Automated estimation software with real-time pricing, labor calculations, and historical data analysis."
  },
  {
    problem: "Disconnected Systems",
    description: "Using separate tools for scheduling, accounting, CRM, and project management creates data silos and duplicate entry.",
    solution: "Custom integrations and unified platforms that connect all your existing tools or replace them entirely."
  }
];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <IndustryHero
    badgeText="Construction Technology Solutions"
    headingTop="Build Your Digital"
    headingBottom="Construction Presence"
    subtitle="Project management tools, portfolio showcases, estimate generators, and client communication platforms designed for contractors, builders, and construction companies."
    stats={stats}
    accentGradient="from-yellow-400 via-amber-400 to-orange-400"
    buttonGradient="from-yellow-500 to-amber-500"
    buttonHoverGradient="hover:from-yellow-600 hover:to-amber-600"
    buttonShadow="shadow-yellow-500/25"
    buttonHoverShadow="hover:shadow-yellow-500/40"
  />

  <Breadcrumbs
    items={[
      { name: "Home", href: "/" },
      { name: "Industries", href: "/industries" },
      { name: "Construction", href: "" }
    ]}
    variant="transparent"
    class="bg-slate-900 border-y border-slate-800"
  />

  <TrustBadges />

  <IndustryIntro
    title="Digital Transformation for the Construction Industry"
    paragraphs={[
      "The construction industry is evolving rapidly, and staying competitive means embracing digital innovation. At CodeBrand, we understand the unique challenges construction companies face\u2014from managing multiple projects simultaneously to coordinating with subcontractors, tracking materials, and maintaining clear communication with clients.",
      "We specialize in creating custom web applications, mobile solutions, and management systems that address the specific needs of construction businesses. Whether you're a general contractor, specialty trade contractor, or construction management firm, our technology solutions help you work smarter, not harder.",
      "Our team has worked with construction companies of all sizes, from small local contractors to large commercial builders. We know that every construction business is unique, which is why we don't believe in one-size-fits-all solutions. Instead, we take the time to understand your workflows, pain points, and goals to create software that truly serves your needs."
    ]}
    highlights={introHighlights}
  />

  <IndustryServices
    title="Specialized Services for"
    titleAccent="Construction Companies"
    subtitle="Comprehensive digital solutions tailored to meet the unique demands of the construction industry"
    services={services}
    accentGradient={accentGradient}
  />

  <IndustryProcess
    title="Our Proven"
    titleAccent="Development Process"
    subtitle="A transparent, collaborative approach that ensures your project is delivered on time and exceeds expectations"
    steps={processSteps}
    accentGradient={accentGradient}
  />

  <IndustryWhyChoose
    title="Why Construction Companies Choose"
    titleAccent="CodeBrand"
    subtitle="We're not just developers\u2014we're your technology partners committed to your success"
    reasons={whyChooseReasons}
    accentGradient={accentGradient}
  />

  <IndustryTestimonials />

  <IndustryTechStack
    title="Built with Modern,"
    titleAccent="Reliable Technology"
    subtitle="We use cutting-edge tools and frameworks to build fast, secure, and scalable solutions"
    technologies={technologies}
  />

  <IndustryChallenges
    title="Common Challenges"
    titleAccent="We Solve"
    subtitle="Construction-specific problems require construction-specific solutions"
    challenges={challenges}
  />

  <IndustryCTA
    title="Ready to Modernize Your Construction Business?"
    subtitle="Let's discuss how custom software solutions can transform your operations, improve profitability, and give you a competitive edge. Schedule a free consultation with our team today."
    ctaGradient="from-yellow-600 via-amber-600 to-orange-600"
  />

  <IndustryFAQ
    title="Construction Development"
    titleAccent="FAQ"
    subtitle="Common questions about our construction software development services"
    faqs={constructionFaqs}
  />

  <Whyus />

  <RelatedServices currentService="web-development" />
</Layout>
