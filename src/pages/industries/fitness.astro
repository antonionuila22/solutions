---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import IndustryHero from "../../components/IndustryHero.astro";
import Whyus from "../../components/whyus.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import RelatedServices from "../../components/RelatedServices.astro";
import IndustryIntro from "../../components/IndustryIntro.astro";
import IndustryServices from "../../components/IndustryServices.astro";
import IndustryProcess from "../../components/IndustryProcess.astro";
import IndustryWhyChoose from "../../components/IndustryWhyChoose.astro";
import IndustryTestimonials from "../../components/IndustryTestimonials.astro";
import IndustryTechStack from "../../components/IndustryTechStack.astro";
import IndustryChallenges from "../../components/IndustryChallenges.astro";
import IndustryFAQ from "../../components/IndustryFAQ.astro";
import IndustryCTA from "../../components/IndustryCTA.astro";
import { createFAQSchema, createBreadcrumbSchema } from "../../utils/schema";

const title = "Gym & Fitness Website Design | Studio Solutions | Codebrand";
const description =
  "Transform your gym or fitness studio with custom websites, online class booking, member management, and workout tracking apps. Increase memberships and retention with professional fitness technology.";
const keywords =
  "gym website design, fitness website development, gym management software, fitness class booking system, gym membership management, personal trainer website, fitness studio software, gym booking system, fitness app development, workout tracking software, gym member portal, fitness center website, online fitness classes, gym scheduling software";
const image = "/photos/bannercodebrand.webp";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Fitness Website Development",
  "name": "Gym & Fitness Website Design | Studio Solutions",
  "description": description,
  "url": "https://www.codebrand.us/industries/fitness",
  "provider": {
    "@type": "Organization",
    "name": "Codebrand",
    "url": "https://www.codebrand.us",
    "logo": "https://www.codebrand.us/iconcodebrand.svg"
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Fitness Web Solutions",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Gym Website Design", "description": "Custom websites for gyms and fitness studios" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Class Booking Systems", "description": "Online class scheduling and reservations" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Member Management", "description": "Membership portals and tracking" }}
    ]
  }
};

// Fitness FAQ data
const fitnessFaqs = [
  {
    question: "How much does a gym website cost?",
    answer: "Gym websites start at $3,000 for a professional site with class schedules and contact forms. Sites with online booking systems range from $5,000-$12,000. Full member management platforms are $15,000+. We provide quotes based on your fitness business needs."
  },
  {
    question: "Can members book classes online?",
    answer: "Yes. We build custom class booking systems where members can view schedules, reserve spots, and manage their bookings. Features include waitlists, recurring bookings, and automatic reminders."
  },
  {
    question: "Do you integrate with gym management software?",
    answer: "Absolutely. We integrate with popular fitness software including Mindbody, ClubReady, PushPress, and Zen Planner. Member data, class schedules, and payments sync seamlessly."
  },
  {
    question: "Can you build a member portal?",
    answer: "Yes. Our member portals include workout tracking, class history, payment management, and progress photos. Members can manage their entire fitness journey from their phone or computer."
  },
  {
    question: "How long does it take to build a fitness website?",
    answer: "A standard gym website takes 4-6 weeks. Sites with booking and member management take 8-12 weeks. Custom fitness apps take 12-16 weeks depending on features."
  },
  {
    question: "Do you build fitness apps?",
    answer: "Yes. We develop custom fitness apps for iOS and Android including workout tracking, video workouts, nutrition logging, and coach communication. Perfect for gyms, personal trainers, and fitness influencers."
  }
];

const faqSchema = createFAQSchema(fitnessFaqs);
const breadcrumbSchema = createBreadcrumbSchema([
  { name: "Home", url: "https://www.codebrand.us" },
  { name: "Industries", url: "https://www.codebrand.us/industries" },
  { name: "Fitness", url: "https://www.codebrand.us/industries/fitness" }
]);

// Stats for hero
const stats = [
  { value: "300+", label: "Gyms & Studios" },
  { value: "85%", label: "Member Retention" },
  { value: "50%", label: "More Bookings" },
  { value: "24/7", label: "Member Access" }
];

// Intro highlights
const introHighlights = [
  {
    value: "58%",
    label: "Better Retention Rate",
    gradient: "from-green-500 to-green-600",
    iconPath: "M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
  },
  {
    value: "94%",
    label: "Member Satisfaction",
    gradient: "from-blue-500 to-blue-600",
    iconPath: "M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"
  },
  {
    value: "600+",
    label: "Fitness Businesses Served",
    gradient: "from-orange-500 to-orange-600",
    iconPath: "M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z"
  }
];

// Services data
const services = [
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>`,
    title: "Professional Gym Websites",
    description: "Stunning, conversion-optimized fitness websites that showcase your facilities, classes, trainers, and membership options. Mobile-responsive designs that turn visitors into members.",
    features: ["Custom design reflecting your brand", "Virtual facility tours and photo galleries", "SEO optimized for local fitness searches"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>`,
    title: "Online Class Booking & Scheduling",
    description: "Powerful class booking systems that let members reserve spots 24/7, reduce no-shows with automated reminders, and optimize class sizes with real-time capacity management.",
    features: ["24/7 online class reservations", "Automated reminders and confirmations", "Waitlist and capacity management"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>`,
    title: "Member Management Portal",
    description: "Comprehensive member portals where members can manage memberships, view workout history, track progress, update payment methods, and access exclusive content.",
    features: ["Self-service membership management", "Workout history and progress tracking", "Payment and billing management"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>`,
    title: "Fitness Mobile Apps",
    description: "Custom mobile apps for iOS and Android that keep members engaged with workout tracking, progress photos, nutrition logging, class schedules, and social features.",
    features: ["Workout and exercise tracking", "Push notifications and engagement", "Social features and challenges"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>`,
    title: "Personal Trainer Booking",
    description: "Enable personal trainers to manage their schedules, accept bookings, process payments, and track client progress. Members can easily book sessions and manage training packages.",
    features: ["Trainer scheduling and availability", "Package and session management", "Client progress tracking"]
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>`,
    title: "Nutrition & Meal Planning",
    description: "Integrated nutrition tracking and meal planning tools that help members achieve their fitness goals faster. Recipe libraries, macronutrient tracking, and customized meal plans.",
    features: ["Macro and calorie tracking", "Custom meal plans and recipes", "Progress and goal tracking"]
  }
];

// Process steps
const processSteps = [
  { title: "Fitness Business Discovery", description: "We start by understanding your fitness business model, target audience, class structure, and growth goals. We'll analyze your current member journey and identify opportunities to improve retention and acquisition." },
  { title: "Member Experience Design", description: "Our design team creates engaging, motivational designs that inspire action. We design every touchpoint—from website to mobile app—to be intuitive, beautiful, and conversion-focused." },
  { title: "Development & Integration", description: "We build your solution with modern technologies and integrate with your existing systems—payment processors, access control, CRM, and marketing tools. Everything works together seamlessly." },
  { title: "Launch & Member Onboarding", description: "We train your staff on the new systems and help migrate your existing members. Our launch strategy includes member communications, tutorials, and support to ensure smooth adoption." },
  { title: "Growth & Optimization", description: "After launch, we monitor key metrics like member retention, class attendance, and booking rates. We continuously optimize to drive better results and add new features as your business grows." }
];

// Why choose us reasons
const whyChooseReasons = [
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 3a1 1 0 000 2v8a2 2 0 002 2h2.586l-1.293 1.293a1 1 0 101.414 1.414L10 15.414l2.293 2.293a1 1 0 001.414-1.414L12.414 15H15a2 2 0 002-2V5a1 1 0 100-2H3zm11.707 4.707a1 1 0 00-1.414-1.414L10 9.586 8.707 8.293a1 1 0 00-1.414 0l-2 2a1 1 0 101.414 1.414L8 10.414l1.293 1.293a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>`,
    title: "Fitness Industry Expertise",
    description: "We've built solutions for 600+ gyms, studios, and fitness businesses. We understand member retention, class dynamics, and the unique challenges of the fitness industry."
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"></path></svg>`,
    title: "Proven Retention Improvement",
    description: "Our clients see an average 58% improvement in member retention through better engagement tools, mobile apps, and automated communication."
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"></path></svg>`,
    title: "Mobile-First Approach",
    description: "Fitness enthusiasts live on their phones. Our mobile-first designs and native apps ensure your members can book, track, and engage anywhere, anytime."
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"></path><path d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7a1 1 0 00-1 1v6.05A2.5 2.5 0 0115.95 16H17a1 1 0 001-1v-5a1 1 0 00-.293-.707l-2-2A1 1 0 0015 7h-1z"></path></svg>`,
    title: "Seamless Integrations",
    description: "We integrate with major fitness software platforms, payment processors (Stripe, PayPal), access control systems, and marketing tools to create a unified ecosystem."
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"></path></svg>`,
    title: "Member Engagement Focus",
    description: "Every feature we build is designed to increase member engagement, attendance, and results—which directly translates to better retention and referrals."
  },
  {
    icon: `<svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-2 0c0 .993-.241 1.929-.668 2.754l-1.524-1.525a3.997 3.997 0 00.078-2.183l1.562-1.562C15.802 8.249 16 9.1 16 10zm-5.165 3.913l1.58 1.58A5.98 5.98 0 0110 16a5.976 5.976 0 01-2.516-.552l1.562-1.562a4.006 4.006 0 001.789.027zm-4.677-2.796a4.002 4.002 0 01-.041-2.08l-.08.08-1.53-1.533A5.98 5.98 0 004 10c0 .954.223 1.856.619 2.657l1.54-1.54zm1.088-6.45A5.974 5.974 0 0110 4c.954 0 1.856.223 2.657.619l-1.54 1.54a4.002 4.002 0 00-2.346.033L7.246 4.668zM12 10a2 2 0 11-4 0 2 2 0 014 0z" clip-rule="evenodd"></path></svg>`,
    title: "Dedicated Support",
    description: "Our support team understands fitness operations. We're here to help with everything from technical issues to strategy and best practices."
  }
];

// Technologies
const technologies = [
  { name: "React", icon: "⚛️" },
  { name: "React Native", icon: "📱" },
  { name: "Node.js", icon: "🟢" },
  { name: "PostgreSQL", icon: "🔷" },
  { name: "AWS", icon: "☁️" },
  { name: "Fitness APIs", icon: "💪" }
];

// Challenges
const challenges = [
  {
    problem: "Poor Member Retention",
    description: "Members sign up but disappear after a few months. Average gym retention is only 71%, meaning you're constantly replacing churned members instead of growing.",
    solution: "Mobile apps with workout tracking, progress visualization, social features, and automated engagement campaigns that keep members motivated and coming back."
  },
  {
    problem: "Class Booking Chaos",
    description: "Managing class bookings via phone calls, spreadsheets, or outdated systems wastes staff time. Members get frustrated when popular classes fill up or they forget to reserve spots.",
    solution: "24/7 online booking system with real-time capacity, waitlists, automated reminders, and easy cancellations that eliminate administrative burden."
  },
  {
    problem: "Competition from Budget Gyms",
    description: "Planet Fitness and other budget gyms compete on price. You need to differentiate through superior service, community, and technology that budget gyms can't match.",
    solution: "Premium technology experience with custom apps, personalized workouts, progress tracking, nutrition guidance, and community features that justify premium pricing."
  },
  {
    problem: "Lack of Member Engagement",
    description: "Members pay but don't attend. Low engagement leads to cancellations. You need ways to keep members motivated, track progress, and celebrate achievements.",
    solution: "Gamification, progress tracking, achievement badges, leaderboards, challenges, and social features that make fitness fun and create accountability."
  }
];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <IndustryHero
    badgeText="Fitness Technology Solutions"
    headingTop="Transform Your Gym"
    headingBottom="& Fitness Business"
    subtitle="Custom gym websites, online class booking, member management, and workout tracking apps. Increase memberships and retention with professional fitness technology."
    stats={stats}
    accentGradient="from-lime-400 via-green-400 to-emerald-400"
    buttonGradient="from-green-500 to-emerald-500"
    buttonHoverGradient="hover:from-green-600 hover:to-emerald-600"
    buttonShadow="shadow-green-500/25"
    buttonHoverShadow="hover:shadow-green-500/40"
  />

  <Breadcrumbs
    items={[
      { name: "Home", href: "/" },
      { name: "Industries", href: "/industries" },
      { name: "Fitness", href: "" }
    ]}
    variant="dark"
    class="bg-slate-900 border-y border-slate-800"
  />

  <TrustBadges />

  <IndustryIntro
    title="Digital Transformation for Gyms & Fitness Studios"
    paragraphs={[
      "The fitness industry has evolved dramatically. Today's fitness enthusiasts expect seamless online booking, mobile apps to track workouts, and 24/7 access to class schedules and membership management. At CodeBrand, we understand that technology is now essential to running a successful gym or fitness studio.",
      "We specialize in creating powerful fitness websites and digital solutions that attract new members, streamline operations, and keep members engaged long-term. Whether you run a boutique yoga studio, CrossFit box, personal training studio, or large gym chain, our technology helps you compete and thrive.",
      "Our team has worked with fitness businesses of all types—from solo personal trainers to multi-location gym franchises. We know the challenges you face: member retention, class scheduling complexity, payment processing, and competition from budget gyms and at-home fitness apps. Our solutions address these challenges head-on."
    ]}
    highlights={introHighlights}
  />

  <IndustryServices
    title="Specialized Services for Fitness"
    titleAccent="Businesses"
    subtitle="Comprehensive fitness technology solutions designed to grow memberships and increase retention"
    services={services}
    accentGradient="from-green-500 to-emerald-500"
  />

  <IndustryProcess
    title="Our Proven Development"
    titleAccent="Process"
    subtitle="A transparent, collaborative approach that ensures your fitness technology project drives results"
    steps={processSteps}
    accentGradient="from-green-500 to-emerald-500"
  />

  <IndustryWhyChoose
    title="Why Fitness Businesses"
    titleAccent="Choose CodeBrand"
    subtitle="We're fitness technology specialists committed to helping gyms and studios thrive"
    reasons={whyChooseReasons}
    accentGradient="from-green-500 to-emerald-500"
  />

  <IndustryTestimonials />

  <IndustryTechStack
    title="Built with Modern,"
    titleAccent="Scalable Technology"
    subtitle="We use cutting-edge tools and frameworks to build fast, reliable fitness technology"
    technologies={technologies}
  />

  <IndustryChallenges
    title="Common Challenges"
    titleAccent="We Solve"
    subtitle="Fitness-specific problems require specialized technology solutions"
    challenges={challenges}
  />

  <IndustryFAQ
    title="Fitness Development"
    titleAccent="FAQ"
    subtitle="Common questions about our gym and fitness website development"
    faqs={fitnessFaqs}
  />

  <IndustryCTA
    title="Ready to Transform Your Fitness Business?"
    subtitle="Let's discuss how custom fitness technology can increase your memberships, boost retention, and grow your revenue. Schedule a free consultation with our fitness technology experts today."
    ctaGradient="from-green-600 via-emerald-600 to-teal-600"
    supportText="Free demo available • No commitment required • Response within 24 hours"
  />

  <Whyus />

  <RelatedServices currentService="web-development" />
</Layout>
