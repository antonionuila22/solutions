---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import Whyus from "../../components/whyus.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import RelatedServices from "../../components/RelatedServices.astro";
import IndustryHero from "../../components/IndustryHero.astro";
import IndustryIntro from "../../components/IndustryIntro.astro";
import IndustryServices from "../../components/IndustryServices.astro";
import IndustryProcess from "../../components/IndustryProcess.astro";
import IndustryWhyChoose from "../../components/IndustryWhyChoose.astro";
import IndustryTestimonials from "../../components/IndustryTestimonials.astro";
import IndustryTechStack from "../../components/IndustryTechStack.astro";
import IndustryChallenges from "../../components/IndustryChallenges.astro";
import IndustryFAQ from "../../components/IndustryFAQ.astro";
import IndustryCTA from "../../components/IndustryCTA.astro";
import { createFAQSchema, createBreadcrumbSchema } from "../../utils/schema";

const stats = [
  { value: "150+", label: "Dealerships Served" },
  { value: "85%", label: "More Online Leads" },
  { value: "3x", label: "Faster Inventory" },
  { value: "24/7", label: "VDP Access" }
];

const title =
  "Car Dealership Website Design & Automotive Software Solutions | CodeBrand";
const description =
  "Transform your dealership with custom automotive websites, vehicle inventory management, online showrooms, and CRM systems. Drive more sales with professional car dealer technology.";
const keywords =
  "car dealership website design, automotive website development, vehicle inventory management software, car dealer CRM, automotive lead management, dealership website builder, auto dealer software, car sales website, vehicle showroom website, automotive digital marketing, online car sales platform, dealer management system, automotive e-commerce, car dealer digital solutions";
const image = "/photos/bannercodebrand.webp";

// Service Schema for Automotive Industry
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Automotive Website Development",
  "name": "Car Dealership Website Design & Automotive Software Solutions",
  "description": description,
  "url": "https://www.codebrand.us/industries/automotive",
  "image": "https://www.codebrand.us/photos/bannercodebrand.webp",
  "provider": {
    "@type": "Organization",
    "name": "Codebrand",
    "url": "https://www.codebrand.us",
    "logo": "https://www.codebrand.us/iconcodebrand.svg"
  },
  "areaServed": {
    "@type": "Country",
    "name": "United States"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Automotive Web Solutions",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Car Dealership Website Design",
          "description": "Custom websites for auto dealers with vehicle inventory integration"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Vehicle Inventory Management",
          "description": "Digital showroom and inventory management software"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Automotive CRM Integration",
          "description": "Lead management and customer relationship systems"
        }
      }
    ]
  }
};

// Automotive FAQ data
const automotiveFaqs = [
  {
    question: "How much does a car dealership website cost?",
    answer: "Dealership websites start at $5,000 for a professional site with vehicle listings. Sites with inventory management and lead tools range from $10,000-$20,000. Full DMS-integrated platforms are $25,000+. We provide detailed quotes based on your dealership's needs."
  },
  {
    question: "Can you integrate with our dealer management system (DMS)?",
    answer: "Yes. We integrate with major DMS providers including CDK, Reynolds and Reynolds, Dealertrack, and RouteOne. Vehicle inventory, pricing, and customer data sync automatically between your website and DMS."
  },
  {
    question: "Do you offer vehicle inventory management?",
    answer: "Absolutely. Our inventory management includes automated photo uploads, window sticker generation, pricing tools, and syndication to third-party sites like AutoTrader and Cars.com. Update inventory once, publish everywhere."
  },
  {
    question: "How long does it take to build a dealership website?",
    answer: "A standard dealership website takes 6-8 weeks. Sites with full DMS integration and custom features take 10-14 weeks. We can expedite for urgent launches while maintaining quality."
  },
  {
    question: "Can customers apply for financing online?",
    answer: "Yes. We integrate secure credit applications with major lenders and your preferred finance partners. Customers can apply 24/7, and applications route directly to your F&I team."
  },
  {
    question: "Do you provide automotive CRM solutions?",
    answer: "Yes. We integrate with automotive CRMs like VinSolutions, DealerSocket, and Elead. Website leads automatically sync to your CRM with full tracking and follow-up automation."
  }
];

const faqSchema = createFAQSchema(automotiveFaqs);
const breadcrumbSchema = createBreadcrumbSchema([
  { name: "Home", url: "https://www.codebrand.us" },
  { name: "Industries", url: "https://www.codebrand.us/industries" },
  { name: "Automotive", url: "https://www.codebrand.us/industries/automotive" }
]);

const accentGradient = "from-cyan-500 to-blue-500";

const introHighlights = [
  { value: "250%", label: "More Online Leads", gradient: "from-green-500 to-green-600", iconPath: "M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" },
  { value: "85%", label: "Lead Response Rate", gradient: "from-blue-500 to-blue-600", iconPath: "M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z" },
  { value: "450+", label: "Dealerships Served", gradient: "from-orange-500 to-orange-600", iconPath: "M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" }
];

