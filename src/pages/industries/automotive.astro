  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>',
    title: "Automotive CRM & Lead Management",
    description: "Powerful CRM systems designed for car dealerships. Track leads from multiple sources, automate follow-ups, manage test drives, and close more deals with intelligent sales pipelines and reporting.",
    features: ["Multi-source lead aggregation", "Automated follow-up sequences", "Sales performance analytics"]
  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>',
    title: "Finance & Payment Calculators",
    description: "Interactive finance calculators, payment estimators, and trade-in valuation tools that help shoppers understand their budget and increase qualified lead generation. Pre-qualify buyers online.",
    features: ["Lease and loan payment calculators", "Real-time trade-in valuations", "Online credit applications"]
  }
];

const processSteps = [
  { title: "Dealership Discovery", description: "We start by understanding your dealership, target market, brand positioning, and competitive landscape. We'll review your current website analytics, inventory system, and lead sources to identify opportunities for improvement." },
  { title: "Design & User Experience", description: "Our design team creates stunning, conversion-focused designs that showcase your inventory beautifully. We design with mobile users in mind (70% of car shoppers browse on mobile) and optimize every page for lead generation." },
  { title: "Development & Integration", description: "We build your solution using modern, fast-loading technologies and integrate with your DMS, inventory feeds, CRM, and lead providers. All systems work together seamlessly to maximize efficiency and lead flow." },
  { title: "Testing & Launch", description: "We rigorously test every feature, form, and integration. Your team receives comprehensive training on managing inventory, responding to leads, and using all features. Launch is carefully coordinated for minimal disruption." },
  { title: "Optimization & Support", description: "After launch, we monitor performance, analyze lead conversion data, and continuously optimize for better results. Our support team is always available to help with updates, inventory management, and new feature additions." }
];

const whyChooseReasons = [
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"></path><path d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7a1 1 0 00-1 1v6.05A2.5 2.5 0 0115.95 16H17a1 1 0 001-1v-5a1 1 0 00-.293-.707l-2-2A1 1 0 0015 7h-1z"></path></svg>',
    title: "Automotive Industry Experts",
    description: "We've built solutions for over 450 dealerships and understand DMS systems, inventory feeds, automotive SEO, and dealership operations inside and out."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"></path></svg>',
    title: "Proven Lead Generation",
    description: "Our dealership websites generate 2-3x more qualified leads than template solutions. We optimize every element for maximum conversions and test drive appointments."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"></path></svg>',
    title: "Fast-Loading Performance",
    description: "Speed matters. Our websites load in under 2 seconds, reducing bounce rates and improving SEO rankings. Faster sites = more leads and better search visibility."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"></path></svg>',
    title: "Mobile-First Design",
    description: "70% of car shoppers browse on smartphones. Our mobile-optimized designs ensure perfect viewing on any device with easy-to-use inventory search and one-tap calling."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3 4a1 1 0 011-1h3a1 1 0 011 1v3a1 1 0 01-1 1H4a1 1 0 01-1-1V4zm2 2V5h1v1H5zM3 13a1 1 0 011-1h3a1 1 0 011 1v3a1 1 0 01-1 1H4a1 1 0 01-1-1v-3zm2 2v-1h1v1H5zM13 3a1 1 0 00-1 1v3a1 1 0 001 1h3a1 1 0 001-1V4a1 1 0 00-1-1h-3zm1 2v1h1V5h-1z" clip-rule="evenodd"></path><path d="M11 4a1 1 0 10-2 0v1a1 1 0 002 0V4zM10 7a1 1 0 011 1v1h2a1 1 0 110 2h-3a1 1 0 01-1-1V8a1 1 0 011-1zM16 9a1 1 0 100 2 1 1 0 000-2zM9 13a1 1 0 011-1h1a1 1 0 110 2v2a1 1 0 11-2 0v-3zM7 11a1 1 0 100-2H4a1 1 0 100 2h3zM17 13a1 1 0 01-1 1h-2a1 1 0 110-2h2a1 1 0 011 1zM16 17a1 1 0 100-2h-3a1 1 0 100 2h3z"></path></svg>',
