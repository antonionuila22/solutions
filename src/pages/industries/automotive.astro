  { name: "React", icon: "\u269B\uFE0F" },
  { name: "Next.js", icon: "\uD83D\uDE80" },
  { name: "Node.js", icon: "\uD83D\uDFE2" },
  { name: "PostgreSQL", icon: "\uD83D\uDD37" },
  { name: "AWS", icon: "\u2601\uFE0F" },
  { name: "Speed", icon: "\u26A1" }
];

const challenges = [
  {
    problem: "Outdated Website Design",
    description: "Old, slow-loading websites with poor mobile experience lose customers to competitors. 70% of car shoppers browse on mobile, and 57% won't recommend a business with a poorly designed mobile site.",
    solution: "Modern, mobile-first dealership websites with stunning vehicle presentation, fast loading speeds, and conversion-optimized design."
  },
  {
    problem: "Not Enough Qualified Leads",
    description: "Your website gets traffic but doesn't convert visitors into leads. Generic contact forms and poor calls-to-action result in missed sales opportunities.",
    solution: "Strategic lead capture forms, click-to-call buttons, test drive schedulers, trade-in valuation tools, and finance calculators that convert browsers into buyers."
  },
  {
    problem: "Manual Inventory Updates",
    description: "Spending hours manually updating inventory listings, uploading photos, and syncing across multiple platforms wastes valuable time and often leads to outdated information.",
