---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <IndustryHero
    badgeText="Automotive Technology Solutions"
    headingTop="Accelerate Your"
    headingBottom="Dealership Growth"
    subtitle="Inventory management, vehicle showcases, financing tools, and lead generation platforms designed to help dealerships sell more cars and connect with buyers."
    stats={stats}
    accentGradient="from-slate-400 via-cyan-400 to-blue-400"
    buttonGradient="from-cyan-500 to-blue-500"
    buttonHoverGradient="hover:from-cyan-600 hover:to-blue-600"
    buttonShadow="shadow-cyan-500/25"
    buttonHoverShadow="hover:shadow-cyan-500/40"
  />

  <Breadcrumbs
    items={[
      { name: "Home", href: "/" },
      { name: "Industries", href: "/industries" },
      { name: "Automotive", href: "" }
    ]}
    variant="transparent"
    class="bg-slate-900 border-y border-slate-800"
  />

  <TrustBadges />

  <IndustryIntro
    title="Digital Transformation for Car Dealerships"
    paragraphs={[
      "Today's car buyers start their journey online. In fact, 95% of car shoppers research vehicles online before visiting a dealership. At CodeBrand, we understand that your dealership's digital presence is now your most important showroom.",
      "We specialize in creating stunning automotive websites and digital solutions that showcase your inventory beautifully, capture quality leads, and turn online browsers into showroom visitors. Whether you're selling new cars, pre-owned vehicles, or running a service department, our technology helps you compete and win in the digital marketplace.",
      "Our team has worked with dealerships of all sizes\u2014from single location independent dealers to multi-franchise automotive groups. We know the automotive industry inside and out, and we build solutions that integrate with your existing DMS, inventory feeds, and lead management systems."
    ]}
    highlights={introHighlights}
  />

  <IndustryServices
    title="Specialized Services for"
    titleAccent="Car Dealerships"
    subtitle="Comprehensive automotive technology solutions designed to drive sales and streamline operations"
    services={services}
    accentGradient={accentGradient}
  />

  <IndustryProcess
    title="Our Proven"
    titleAccent="Development Process"
    subtitle="A transparent, collaborative approach that ensures your dealership website and technology project is delivered on time"
    steps={processSteps}
    accentGradient={accentGradient}
  />

  <IndustryWhyChoose
    title="Why Car Dealerships Choose"
    titleAccent="CodeBrand"
    subtitle="We're automotive technology specialists committed to helping your dealership sell more vehicles"
    reasons={whyChooseReasons}
    accentGradient={accentGradient}
  />

  <IndustryTestimonials />

  <IndustryTechStack
    title="Built with Modern,"
    titleAccent="Fast-Loading Technology"
    subtitle="We use cutting-edge tools and frameworks to build lightning-fast, mobile-optimized automotive websites"
    technologies={technologies}
  />

  <IndustryChallenges
    title="Common Challenges"
    titleAccent="We Solve"
    subtitle="Dealership-specific problems require automotive technology solutions"
    challenges={challenges}
  />

  <IndustryCTA
    title="Ready to Drive More Sales at Your Dealership?"
    subtitle="Let's discuss how a custom automotive website and digital solutions can increase your leads, fill your service bays, and boost vehicle sales. Schedule a free consultation with our dealership technology experts today."
    supportText="Free demo available \u2022 No commitment required \u2022 Response within 24 hours"
    ctaGradient="from-cyan-600 via-blue-600 to-indigo-600"
  />

  <IndustryFAQ
    title="Automotive Development"
    titleAccent="FAQ"
    subtitle="Common questions about our automotive and dealership website development"
    faqs={automotiveFaqs}
  />

  <Whyus />

  <RelatedServices currentService="web-development" />
</Layout>
