const technologies = [
  { name: "React", icon: "\u269B\uFE0F" },
  { name: "React Native", icon: "\uD83D\uDCF1" },
  { name: "Node.js", icon: "\uD83D\uDFE2" },
  { name: "PostgreSQL", icon: "\uD83D\uDD37" },
  { name: "AWS", icon: "\u2601\uFE0F" },
  { name: "Security", icon: "\uD83D\uDD10" }
];

const challenges = [
  {
    problem: "Manual Booking Processes",
    description: "Time-consuming phone and email bookings, manual data entry, and paper forms limit your capacity and create opportunities for errors.",
    solution: "Automated online booking system with instant confirmations, payment processing, and seamless data capture."
  },
  {
    problem: "Limited Online Presence",
    description: "Outdated websites or reliance on third-party platforms means you're losing bookings to competitors with better digital experiences.",
    solution: "Modern, mobile-responsive website with stunning visuals, integrated booking, and SEO optimization."
  },
  {
    problem: "Disconnected Supplier Systems",
    description: "Manually checking availability across multiple suppliers, dealing with overbookings, and outdated pricing information.",
    solution: "Unified platform with API integrations to GDS systems and supplier networks for real-time data."
  },
  {
    problem: "Poor Customer Communication",
    description: "Travelers struggle to get timely updates, access their itineraries, or reach agents when issues arise during trips.",
    solution: "Mobile apps and customer portals with real-time updates, digital itineraries, and instant messaging."
  }
];
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  image={image}
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(serviceSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />

  <IndustryHero
    badgeText="Travel Technology Solutions"
    headingTop="Transform Your"
    headingBottom="Travel Agency"
    subtitle="Booking engines, travel packages, destination showcases, and itinerary management designed to help travel agencies increase bookings and deliver unforgettable experiences."
    stats={stats}
    accentGradient="from-sky-400 via-blue-400 to-indigo-400"
    buttonGradient="from-sky-500 to-blue-500"
    buttonHoverGradient="hover:from-sky-600 hover:to-blue-600"
    buttonShadow="shadow-sky-500/25"
    buttonHoverShadow="hover:shadow-sky-500/40"
  />

  <Breadcrumbs
    items={[
      { name: "Home", href: "/" },
      { name: "Industries", href: "/industries" },
      { name: "Travel Agency", href: "" }
    ]}
    variant="transparent"
    class="bg-slate-900 border-y border-slate-800"
  />

  <TrustBadges />

  <IndustryIntro
    title="Digital Transformation for the Travel Industry"
    paragraphs={[
      "The travel industry is more competitive than ever, and modern travelers expect seamless digital experiences. At CodeBrand, we understand the unique challenges travel agencies face\u2014from managing complex bookings and coordinating with multiple suppliers to providing personalized customer service and staying competitive with online booking platforms.",
      "We specialize in creating custom web applications, mobile solutions, and booking systems that address the specific needs of travel agencies. Whether you're a boutique travel agency, tour operator, or destination management company, our technology solutions help you deliver exceptional experiences while maximizing efficiency and profitability.",
      "Our team has worked with travel agencies of all sizes, from independent agencies to multi-location operations. We know that every travel business is unique, which is why we don't believe in one-size-fits-all solutions. Instead, we take the time to understand your services, target market, and business goals to create software that truly serves your needs."
    ]}
    highlights={introHighlights}
  />

  <IndustryServices
    title="Specialized Services for"
    titleAccent="Travel Agencies"
    subtitle="Comprehensive digital solutions tailored to meet the unique demands of the travel and tourism industry"
    services={services}
    accentGradient={accentGradient}
  />

  <IndustryProcess
    title="Our Proven"
    titleAccent="Development Process"
    subtitle="A transparent, collaborative approach that ensures your project is delivered on time and exceeds expectations"
    steps={processSteps}
    accentGradient={accentGradient}
  />

  <IndustryWhyChoose
    title="Why Travel Agencies Choose"
    titleAccent="CodeBrand"
    subtitle="We're not just developers\u2014we're your technology partners committed to your success in the competitive travel market"
    reasons={whyChooseReasons}
    accentGradient={accentGradient}
  />

  <IndustryTestimonials />

  <IndustryTechStack
    title="Built with Modern,"
    titleAccent="Reliable Technology"
    subtitle="We use cutting-edge tools and frameworks to build fast, secure, and scalable solutions"
    technologies={technologies}
  />

  <IndustryChallenges
    title="Common Challenges"
    titleAccent="We Solve"
    subtitle="Travel agency challenges require specialized digital solutions"
    challenges={challenges}
  />

  <IndustryCTA
    title="Ready to Transform Your Travel Agency?"
    subtitle="Let's discuss how custom digital solutions can boost your bookings, streamline operations, and deliver exceptional travel experiences. Schedule a free consultation with our team today."
    ctaGradient="from-sky-600 via-blue-600 to-indigo-600"
  />

  <IndustryFAQ
    title="Travel Agency"
    titleAccent="FAQ"
    subtitle="Common questions about our travel agency website development"
    faqs={travelFaqs}
  />

  <Whyus />

  <RelatedServices currentService="web-development" />
</Layout>
