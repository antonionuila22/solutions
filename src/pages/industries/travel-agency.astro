---
import Layout from "../../layouts/Layout.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import IndustryHero from "../../components/IndustryHero.astro";
import Whyus from "../../components/whyus.astro";
import TrustBadges from "../../components/TrustBadges.astro";
import RelatedServices from "../../components/RelatedServices.astro";
import IndustryIntro from "../../components/IndustryIntro.astro";
import IndustryServices from "../../components/IndustryServices.astro";
import IndustryProcess from "../../components/IndustryProcess.astro";
import IndustryWhyChoose from "../../components/IndustryWhyChoose.astro";
import IndustryTestimonials from "../../components/IndustryTestimonials.astro";
import IndustryTechStack from "../../components/IndustryTechStack.astro";
import IndustryChallenges from "../../components/IndustryChallenges.astro";
import IndustryFAQ from "../../components/IndustryFAQ.astro";
import IndustryCTA from "../../components/IndustryCTA.astro";
import { createFAQSchema, createBreadcrumbSchema } from "../../utils/schema";

const title =
  "Travel Agency Website Design & Tourism Software Solutions | CodeBrand";
const description =
  "Transform your travel agency with custom digital solutions. Online booking systems, tour packages management, itinerary builders, mobile apps, and customer portals designed specifically for the travel and tourism industry.";
const keywords =
  "travel agency web development, travel booking software, tourism technology, travel agency websites, travel CRM, online booking system, tour package management, travel itinerary builder, tourism website design, vacation booking platform, travel agency portal, tour operator software, travel management system";
const image = "/photos/bannercodebrand.webp";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Travel Agency Website Development",
  "name": "Travel Agency Website Design & Tourism Software Solutions",
  "description": description,
  "url": "https://codebrand.us/industries/travel-agency",
  "provider": {
    "@type": "Organization",
    "name": "Codebrand",
    "url": "https://codebrand.us",
    "logo": "https://codebrand.us/iconcodebrand.svg"
  },
  "areaServed": { "@type": "Country", "name": "United States" },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Travel Web Solutions",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Travel Booking Systems", "description": "Online booking and reservation platforms" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Tour Package Management", "description": "Tour and itinerary management software" }},
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Travel Agency CRM", "description": "Customer relationship management for travel" }}
    ]
  }
};

// Travel Agency FAQ data
const travelFaqs = [
  {
    question: "How much does a travel agency website cost?",
    answer: "Travel agency websites start at $4,000 for a professional site with tour packages. Sites with booking systems range from $8,000-$18,000. Full travel platforms with supplier integrations are $25,000+. We provide quotes based on your agency's needs."
  },
  {
    question: "Can customers book trips directly on the website?",
    answer: "Yes. We build complete booking systems where travelers can search packages, check availability, make reservations, and pay online. Integrates with your back-office for seamless operations."
  },
  {
    question: "Do you integrate with GDS systems like Amadeus or Sabre?",
    answer: "Absolutely. We integrate with major Global Distribution Systems including Amadeus, Sabre, and Travelport. Display real-time flight, hotel, and car rental availability directly on your website."
  },
  {
    question: "Can I manage tour packages and itineraries online?",
    answer: "Yes. Our tour management systems let you create, price, and publish packages easily. Build custom itineraries, manage availability, and update content without technical knowledge."
  },
  {
    question: "How long does it take to build a travel website?",
    answer: "A professional travel website takes 6-8 weeks. Sites with booking systems take 10-14 weeks. Full platforms with GDS integration take 16-24 weeks depending on complexity."
  },
  {
    question: "Do you offer travel CRM solutions?",
    answer: "Yes. Our travel CRMs track customer preferences, booking history, and communications. Automate follow-ups, send targeted offers, and build lasting relationships with travelers."
  }
];

const faqSchema = createFAQSchema(travelFaqs);
const breadcrumbSchema = createBreadcrumbSchema([
  { name: "Home", url: "https://codebrand.us" },
  { name: "Industries", url: "https://codebrand.us/industries" },
  { name: "Travel Agency", url: "https://codebrand.us/industries/travel-agency" }
]);

const stats = [
  { value: "180%", label: "More Bookings" },
  { value: "500+", label: "Destinations" },
  { value: "50%", label: "Less Admin Work" },
  { value: "24/7", label: "Online Booking" }
];

const accentGradient = "from-sky-500 to-blue-500";

const introHighlights = [
  { value: "65%", label: "More Online Bookings", gradient: "from-green-500 to-green-600", iconPath: "M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" },
  { value: "98%", label: "Customer Satisfaction", gradient: "from-blue-500 to-blue-600", iconPath: "M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z" },
  { value: "75+", label: "Travel Agencies Served", gradient: "from-orange-500 to-orange-600", iconPath: "M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" }
];

