  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>',
    title: "Professional Travel Websites",
    description: "Stand out with a stunning, conversion-optimized website that showcases your destinations, packages, and expertise. Mobile-responsive design with SEO optimization to attract more travelers.",
    features: ["SEO-optimized content", "Beautiful destination galleries", "Integrated booking forms"]
  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>',
    title: "Package Management Systems",
    description: "Streamline your operations with custom systems to create, manage, and sell travel packages. Dynamic pricing, inventory management, and supplier coordination\u2014all in one platform.",
    features: ["Dynamic pricing engine", "Inventory and availability tracking", "Supplier management"]
  },
  {
    icon: '<svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path></svg>',
    title: "Travel API Integrations",
    description: "Connect to leading travel suppliers and GDS platforms with custom API integrations. Access real-time inventory for flights, hotels, car rentals, and more from a single interface.",
    features: ["GDS connectivity (Amadeus, Sabre, etc.)", "Hotel and activity supplier APIs", "Payment gateway integration"]
  }
];

const processSteps = [
  { title: "Discovery & Planning", description: "We start by understanding your travel agency's unique value proposition, target market, and business goals. We'll analyze your current processes, identify pain points, and define the scope for your custom solution." },
  { title: "Design & Prototyping", description: "Our design team creates beautiful, conversion-focused interfaces optimized for travelers. We'll develop interactive prototypes that showcase the user experience before development begins, ensuring everything meets your vision." },
  { title: "Development & Testing", description: "Our development team builds your solution using modern, scalable technologies. We follow agile methodologies with regular updates and demos. Comprehensive testing ensures flawless performance across all devices and booking scenarios." },
  { title: "Training & Launch", description: "We provide comprehensive training for your team and create documentation to ensure smooth adoption. Our carefully planned deployment process minimizes disruption while we're with you every step during the launch." },
  { title: "Support & Growth", description: "Our partnership continues beyond launch. We provide ongoing support, maintenance, and optimization services. As your business grows and the travel industry evolves, we'll enhance your solution with new features and integrations." }
];

const whyChooseReasons = [
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M10 2a1 1 0 011 1v1.323l3.954 1.582 1.599-.8a1 1 0 01.894 1.79l-1.233.616 1.738 5.42a1 1 0 01-.285 1.05A3.989 3.989 0 0115 15a3.989 3.989 0 01-2.667-1.019 1 1 0 01-.285-1.05l1.715-5.349L11 6.477V16h2a1 1 0 110 2H7a1 1 0 110-2h2V6.477L6.237 7.582l1.715 5.349a1 1 0 01-.285 1.05A3.989 3.989 0 015 15a3.989 3.989 0 01-2.667-1.019 1 1 0 01-.285-1.05l1.738-5.42-1.233-.617a1 1 0 01.894-1.788l1.599.799L9 4.323V3a1 1 0 011-1z"></path></svg>',
    title: "Travel Industry Expertise",
    description: "We've worked extensively with travel agencies and tour operators, understanding the unique challenges, regulations, and workflows specific to the travel industry."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z" clip-rule="evenodd"></path></svg>',
    title: "Rapid Implementation",
    description: "Our agile approach and experienced team means faster time-to-market without compromising quality. Launch your platform in weeks, not months."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>',
    title: "PCI-DSS Compliant Security",
    description: "Your customers' payment and personal data are protected with enterprise-grade security, PCI-DSS compliance, encryption, and regular security audits."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path d="M8 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM15 16.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0z"></path><path d="M3 4a1 1 0 00-1 1v10a1 1 0 001 1h1.05a2.5 2.5 0 014.9 0H10a1 1 0 001-1V5a1 1 0 00-1-1H3zM14 7a1 1 0 00-1 1v6.05A2.5 2.5 0 0115.95 16H17a1 1 0 001-1v-5a1 1 0 00-.293-.707l-2-2A1 1 0 0015 7h-1z"></path></svg>',
    title: "Scalable Architecture",
    description: "Our solutions grow with your business. Whether you're handling 50 bookings or 5,000 per month, our systems scale seamlessly to meet demand."
  },
  {
    icon: '<svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-2 0c0 .993-.241 1.929-.668 2.754l-1.524-1.525a3.997 3.997 0 00.078-2.183l1.562-1.562C15.802 8.249 16 9.1 16 10zm-5.165 3.913l1.58 1.58A5.98 5.98 0 0110 16a5.976 5.976 0 01-2.516-.552l1.562-1.562a4.006 4.006 0 001.789.027zm-4.677-2.796a4.002 4.002 0 01-.041-2.08l-.08.08-1.53-1.533A5.98 5.98 0 004 10c0 .954.223 1.856.619 2.657l1.54-1.54zm1.088-6.45A5.974 5.974 0 0110 4c.954 0 1.856.223 2.657.619l-1.54 1.54a4.002 4.002 0 00-2.346.033L7.246 4.668zM12 10a2 2 0 11-4 0 2 2 0 014 0z" clip-rule="evenodd"></path></svg>',
