---
import { testimonials } from "../data/testimonials";

const firstRow = testimonials.slice(0, Math.ceil(testimonials.length / 2));
const secondRow = testimonials.slice(Math.ceil(testimonials.length / 2));

const avatarColors = [
  "bg-red-500", "bg-blue-500", "bg-green-500", "bg-yellow-500",
  "bg-purple-500", "bg-pink-500", "bg-indigo-500", "bg-teal-500",
];

function getInitials(name: string) {
  const words = name.trim().split(" ");
  if (words.length >= 2) return (words[0][0] + words[1][0]).toUpperCase();
  return name.slice(0, 2).toUpperCase();
}

function getColorFromName(name: string) {
  let hash = 0;
  for (let i = 0; i < name.length; i++) {
    hash = name.charCodeAt(i) + ((hash << 5) - hash);
  }
  return avatarColors[Math.abs(hash) % avatarColors.length];
}

const REPEAT = 2;
const STAR_PATH = "M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z";
---

<div class="relative flex w-full flex-col items-center justify-center overflow-hidden gap-3 sm:gap-4">
  <!-- Row 1 -->
  <div class="group/marquee flex overflow-hidden p-2 [--duration:45s] sm:[--duration:40s] [--gap:1rem] gap-[var(--gap)] flex-row testimonial-marquee">
    {Array.from({ length: REPEAT }).map(() => (
      <div class="flex shrink-0 justify-around gap-[var(--gap)] will-change-transform animate-marquee flex-row group-hover/marquee:[animation-play-state:paused]">
        {firstRow.map((review) => {
          const isLong = review.body.length > 120;
          return (
            <figure
              class="group/card relative h-full w-[260px] sm:w-[300px] md:w-[320px] cursor-pointer overflow-hidden rounded-2xl border p-4 sm:p-6 border-slate-700/80 bg-slate-800/90 hover:bg-slate-700/90 transition-colors duration-300"
              data-expandable={isLong ? "" : undefined}
            >
              <div class="flex flex-row items-center gap-3">
                <div class={`flex items-center justify-center w-8 h-8 rounded-full ${getColorFromName(review.name)} text-white text-xs font-bold`}>
                  {getInitials(review.name)}
                </div>
                <div class="flex flex-col">
                  <figcaption class="text-sm sm:text-base font-semibold text-white">
                    {review.name}
                  </figcaption>
                  <div class="flex items-center gap-1.5">
                    <div class="flex gap-0.5" role="img" aria-label="5 out of 5 stars rating">
                      {[0,1,2,3,4].map(() => (
                        <svg class="w-3 h-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                          <path d={STAR_PATH} />
                        </svg>
                      ))}
                    </div>
                    <span class="text-xs text-slate-400">• {review.username}</span>
                  </div>
                </div>
              </div>
              <blockquote class="mt-3 text-sm text-slate-300 leading-relaxed">
                <span class:list={[
                  "review-text transition-all duration-300",
                  isLong && "line-clamp-4 sm:group-hover/card:line-clamp-none"
                ]}>
                  {review.body}
                </span>
                {isLong && (
                  <span class="tap-hint mt-2 text-xs text-cyan-400 block sm:group-hover/card:hidden">
                    Tap to read more
                  </span>
                )}
              </blockquote>
            </figure>
          );
        })}
      </div>
    ))}
  </div>

  <!-- Row 2 (reversed) -->
  <div class="group/marquee flex overflow-hidden p-2 [--duration:45s] sm:[--duration:40s] [--gap:1rem] gap-[var(--gap)] flex-row testimonial-marquee">
    {Array.from({ length: REPEAT }).map(() => (
      <div class="flex shrink-0 justify-around gap-[var(--gap)] will-change-transform animate-marquee reverse flex-row group-hover/marquee:[animation-play-state:paused]">
        {secondRow.map((review) => {
          const isLong = review.body.length > 120;
          return (
            <figure
              class="group/card relative h-full w-[260px] sm:w-[300px] md:w-[320px] cursor-pointer overflow-hidden rounded-2xl border p-4 sm:p-6 border-slate-700/80 bg-slate-800/90 hover:bg-slate-700/90 transition-colors duration-300"
              data-expandable={isLong ? "" : undefined}
            >
              <div class="flex flex-row items-center gap-3">
                <div class={`flex items-center justify-center w-8 h-8 rounded-full ${getColorFromName(review.name)} text-white text-xs font-bold`}>
                  {getInitials(review.name)}
                </div>
                <div class="flex flex-col">
                  <figcaption class="text-sm sm:text-base font-semibold text-white">
                    {review.name}
                  </figcaption>
                  <div class="flex items-center gap-1.5">
                    <div class="flex gap-0.5" role="img" aria-label="5 out of 5 stars rating">
                      {[0,1,2,3,4].map(() => (
                        <svg class="w-3 h-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                          <path d={STAR_PATH} />
                        </svg>
                      ))}
                    </div>
                    <span class="text-xs text-slate-400">• {review.username}</span>
                  </div>
                </div>
              </div>
              <blockquote class="mt-3 text-sm text-slate-300 leading-relaxed">
                <span class:list={[
                  "review-text transition-all duration-300",
                  isLong && "line-clamp-4 sm:group-hover/card:line-clamp-none"
                ]}>
                  {review.body}
                </span>
                {isLong && (
                  <span class="tap-hint mt-2 text-xs text-cyan-400 block sm:group-hover/card:hidden">
                    Tap to read more
                  </span>
                )}
              </blockquote>
            </figure>
          );
        })}
      </div>
    ))}
  </div>

  <!-- Gradient overlays -->
  <div class="pointer-events-none absolute inset-y-0 left-0 w-6 sm:w-12 md:w-1/6 lg:w-1/4 bg-gradient-to-r from-slate-950 to-transparent"></div>
  <div class="pointer-events-none absolute inset-y-0 right-0 w-6 sm:w-12 md:w-1/6 lg:w-1/4 bg-gradient-to-l from-slate-950 to-transparent"></div>
</div>

<style>
  @media (prefers-reduced-motion: reduce) {
    .testimonial-marquee .animate-marquee {
      animation-duration: 0s;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-expandable]").forEach((card) => {
    card.addEventListener("click", () => {
      const text = card.querySelector(".review-text");
      if (text) text.classList.toggle("line-clamp-4");
      const hint = card.querySelector(".tap-hint");
      if (hint) hint.classList.toggle("hidden");
    });
  });
</script>
