---
interface Props {
  title: string;
  subtitle: string;
  ctaText?: string;
  ctaLink?: string;
  secondaryText?: string;
  secondaryLink?: string;
  supportText?: string;
  ctaGradient?: string;
}

const {
  title,
  subtitle,
  ctaText = "Schedule Free Consultation",
  ctaLink = "/contact",
  secondaryText = "Call Us Now",
  secondaryLink = "tel:+50432722973",
  supportText = "No commitment required • Free consultation • Response within 24 hours",
  ctaGradient = "from-orange-600 via-amber-600 to-cyan-600",
} = Astro.props;
---

<section class={`py-16 sm:py-20 lg:py-28 bg-gradient-to-br ${ctaGradient} font-poppins relative overflow-hidden`}>
  <div class="absolute inset-0" aria-hidden="true">
    <div class="absolute top-0 left-0 w-full h-full bg-[radial-gradient(circle_at_30%_20%,rgba(255,255,255,0.1),transparent_50%)]"></div>
    <div class="absolute bottom-0 right-0 w-full h-full bg-[radial-gradient(circle_at_70%_80%,rgba(255,255,255,0.1),transparent_50%)]"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative">
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">{title}</h2>
    <p class="text-lg sm:text-xl text-white/90 mb-10 leading-relaxed max-w-2xl mx-auto">{subtitle}</p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href={ctaLink} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white hover:bg-slate-100 text-slate-900 rounded-2xl font-bold text-lg shadow-xl hover:shadow-2xl transform hover:-translate-y-1 transition-all duration-300">
        {ctaText}
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
      <a href={secondaryLink} class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/10 hover:bg-white/20 backdrop-blur-sm text-white rounded-2xl font-bold text-lg border-2 border-white/30 transition-all duration-300">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"></path>
        </svg>
        {secondaryText}
      </a>
    </div>
    <p class="mt-8 text-sm text-white/70">{supportText}</p>
  </div>
</section>
