---
interface Reason {
  icon: string; // inline SVG string
  title: string;
  description: string;
}

interface Props {
  title: string;
  titleAccent: string;
  subtitle: string;
  reasons: Reason[];
  /** Full Tailwind gradient classes, e.g. "from-blue-400 to-cyan-400" */
  accentGradient?: string;
}

const { title, titleAccent, subtitle, reasons, accentGradient = "from-orange-400 to-cyan-400" } = Astro.props;
---

<section class="py-16 sm:py-20 lg:py-28 bg-gradient-to-br from-slate-900 via-slate-950 to-slate-900 font-poppins relative overflow-hidden">
  <div class="absolute inset-0 opacity-20" aria-hidden="true">
    <div class="absolute inset-0" style="background-image: radial-gradient(rgba(255,255,255,0.1) 1px, transparent 1px); background-size: 30px 30px;"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">
        {title} <span class={`bg-gradient-to-r ${accentGradient} bg-clip-text text-transparent`}>{titleAccent}</span>
      </h2>
      <p class="text-lg text-slate-300 max-w-3xl mx-auto">{subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {reasons.map((reason) => (
        <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-6 sm:p-8 border border-white/10 hover:border-orange-500/30 hover:bg-white/10 transition-all duration-300">
          <div class={`w-14 h-14 bg-gradient-to-br ${accentGradient} rounded-2xl flex items-center justify-center mb-6`} set:html={reason.icon}></div>
          <h3 class="text-xl font-semibold text-white mb-3">{reason.title}</h3>
          <p class="text-slate-300 text-sm">{reason.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
