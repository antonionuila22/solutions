---
import { BUSINESS_INFO } from "../configs/business";

const year = new Date().getFullYear();

const services = [
  { label: "Web Development", href: "/services/web-development" },
  { label: "UX/UI Design", href: "/ux-ui-design-agency" },
  { label: "E-commerce", href: "/e-commerce" },
  { label: "SEO Services", href: "/services/seo" },
  { label: "Branding", href: "/services/branding" },
  { label: "Digital Marketing", href: "/digital-marketing" },
  { label: "Landing Pages", href: "/landing-pages" },
];

const solutions = [
  { label: "Custom Software", href: "/custom-software-development" },
  { label: "AI Automation", href: "/ai-automation-agency" },
  { label: "Astro Development", href: "/astro-development-agency" },
  { label: "React Development", href: "/react-development-agency" },
  { label: "Nearshore Teams", href: "/nearshore-development" },
  { label: "Hire Developers", href: "/hire-remote-developers" },
];

const company = [
  { label: "About Us", href: "/history" },
  { label: "Our Team", href: "/team" },
  { label: "Projects", href: "/projects" },
  { label: "Blog", href: "/blog" },
  { label: "Pricing & Quote", href: "/quoter" },
  { label: "Contact", href: "/contact" },
];

const socials = [
  { label: "LinkedIn", href: BUSINESS_INFO.social.linkedin, path: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" },
  { label: "Instagram", href: BUSINESS_INFO.social.instagram, path: "M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" },
  { label: "Facebook", href: BUSINESS_INFO.social.facebook, path: "M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" },
  { label: "X", href: BUSINESS_INFO.social.twitter, path: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" },
];
---

<footer class="relative bg-slate-950 text-slate-300 overflow-hidden border-t border-white/5">
  <!-- ambient glow -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.07]" aria-hidden="true">
    <div class="absolute -top-24 right-1/4 w-[28rem] h-[28rem] bg-orange-500 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-24 left-0 w-[24rem] h-[24rem] bg-cyan-500 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6">
    <!-- ===== CTA band ===== -->
    <div class="py-10 sm:py-12 border-b border-white/10">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-6 text-center lg:text-left">
        <div>
          <h2 class="text-2xl sm:text-3xl font-bold text-white tracking-tight">
            Let's build something that actually <span class="text-orange-400">works.</span>
          </h2>
          <p class="mt-2 text-sm sm:text-base text-slate-400 max-w-xl">
            Free consultation, fixed pricing, no surprises. Tell us what you need — we'll map the path.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 shrink-0">
          <a href="/contact" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 bg-orange-500 hover:bg-orange-600 text-white font-semibold rounded-xl shadow-lg shadow-orange-500/25 hover:shadow-orange-500/40 hover:-translate-y-0.5 transition-all duration-300">
            Start a Project
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a href="/quoter" class="inline-flex items-center justify-center gap-2 px-7 py-3.5 border border-white/15 hover:border-white/30 hover:bg-white/5 text-white font-semibold rounded-xl transition-all duration-300">
            Get a Quote
          </a>
        </div>
      </div>
    </div>

    <!-- ===== Main grid ===== -->
    <div class="grid grid-cols-2 lg:grid-cols-12 gap-8 lg:gap-10 py-12 sm:py-14">
      <!-- Brand -->
      <div class="col-span-2 lg:col-span-4">
        <img src="/iconcodebrand.svg" alt="Codebrand" class="h-11 mb-4" width="44" height="44" loading="lazy" decoding="async" />
        <p class="text-sm leading-relaxed text-slate-400 max-w-xs mb-5">
          Modern web development, design, and digital solutions for growing businesses — US timezone, from San Pedro Sula, Honduras.
        </p>

        <!-- rating badge -->
        <div class="inline-flex items-center gap-2.5 rounded-xl border border-white/10 bg-white/5 px-3.5 py-2.5 mb-6">
          <div class="flex" aria-hidden="true">
            {[0,1,2,3,4].map(() => (
              <svg class="w-4 h-4 text-orange-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            ))}
          </div>
          <span class="text-sm text-slate-200"><strong class="text-white">5.0</strong> · 50 Google reviews</span>
        </div>

        <!-- socials -->
        <div class="flex gap-2.5">
          {socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}
              class="w-10 h-10 flex items-center justify-center rounded-lg bg-white/5 border border-white/10 text-slate-300 hover:bg-orange-500 hover:border-orange-500 hover:text-white transition-all duration-300">
              <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d={s.path}/></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Services -->
      <div class="lg:col-span-2">
        <h3 class="text-white text-xs font-bold uppercase tracking-wider mb-4 flex items-center gap-2">
          <span class="w-5 h-0.5 bg-orange-500 rounded-full"></span>Services
        </h3>
        <ul class="space-y-2.5 text-sm">
          {services.map((l) => (
            <li><a href={l.href} class="text-slate-400 hover:text-orange-400 transition-colors duration-200">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Solutions -->
      <div class="lg:col-span-2">
        <h3 class="text-white text-xs font-bold uppercase tracking-wider mb-4 flex items-center gap-2">
          <span class="w-5 h-0.5 bg-orange-500 rounded-full"></span>Solutions
        </h3>
        <ul class="space-y-2.5 text-sm">
          {solutions.map((l) => (
            <li><a href={l.href} class="text-slate-400 hover:text-orange-400 transition-colors duration-200">{l.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Company -->
      <div class="lg:col-span-2">
        <h3 class="text-white text-xs font-bold uppercase tracking-wider mb-4 flex items-center gap-2">
          <span class="w-5 h-0.5 bg-orange-500 rounded-full"></span>Company
        </h3>
        <ul class="space-y-2.5 text-sm">
          {company.map((l) => (
            <li><a href={l.href} class="text-slate-400 hover:text-orange-400 transition-colors duration-200">{l.label}</a></li>
          ))}
          <li><a href="/hn/" class="inline-flex items-center gap-1.5 text-slate-400 hover:text-orange-400 transition-colors duration-200"><span aria-hidden="true">🇭🇳</span> Honduras (ES)</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="col-span-2 lg:col-span-2">
        <h3 class="text-white text-xs font-bold uppercase tracking-wider mb-4 flex items-center gap-2">
          <span class="w-5 h-0.5 bg-orange-500 rounded-full"></span>Contact
        </h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a href={`tel:${BUSINESS_INFO.us.phoneRaw}`} class="group flex items-center gap-2.5 text-slate-400 hover:text-white transition-colors">
              <svg class="w-4 h-4 text-orange-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              {BUSINESS_INFO.us.phone}
            </a>
          </li>
          <li>
            <a href={`mailto:${BUSINESS_INFO.us.email}`} class="group flex items-center gap-2.5 text-slate-400 hover:text-white transition-colors">
              <svg class="w-4 h-4 text-orange-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              {BUSINESS_INFO.us.email}
            </a>
          </li>
          <li>
            <a href={BUSINESS_INFO.us.whatsappUrl} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-2.5 text-slate-400 hover:text-white transition-colors">
              <svg class="w-4 h-4 text-orange-400 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.817 11.817 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.514 5.26l-.999 3.648 3.974-1.515z"/></svg>
              WhatsApp
            </a>
          </li>
          <li class="flex items-start gap-2.5 text-slate-400">
            <svg class="w-4 h-4 text-orange-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            <span>{BUSINESS_INFO.address.city}, {BUSINESS_INFO.address.region}<br/>Honduras</span>
          </li>
          <li class="flex items-start gap-2.5 text-slate-500 text-xs pt-1">
            <svg class="w-4 h-4 text-slate-600 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span>Mon–Fri 9AM–6PM<br/>Sat 10AM–2PM (CST)</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- ===== Bottom bar ===== -->
    <div class="border-t border-white/10 py-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-slate-500">
      <p>&copy; {year} <span class="text-slate-300 font-semibold">Codebrand</span>. All rights reserved. Made with <span class="text-orange-400">♥</span> in Honduras.</p>
      <ul class="flex items-center gap-5">
        <li><a href="/terms" class="hover:text-orange-400 transition-colors">Terms</a></li>
        <li><a href="/privacy" class="hover:text-orange-400 transition-colors">Privacy</a></li>
        <li><a href="/contact" class="hover:text-orange-400 transition-colors">Contact</a></li>
      </ul>
    </div>
  </div>
</footer>
