---
interface StatItem {
  value: string;
  label: string;
}

interface Props {
  badgeText: string;
  headingTop: string;
  headingBottom: string;
  subtitle: string;
  stats?: StatItem[];
  /** Full Tailwind gradient classes for text, e.g. "from-blue-400 via-cyan-400 to-indigo-400" */
  accentGradient?: string;
  /** Full Tailwind gradient classes for buttons/accents, e.g. "from-blue-500 to-cyan-500" */
  buttonGradient?: string;
  /** Hover gradient for button, e.g. "hover:from-blue-600 hover:to-cyan-600" */
  buttonHoverGradient?: string;
  /** Shadow color class, e.g. "shadow-blue-500/25" */
  buttonShadow?: string;
  /** Hover shadow, e.g. "hover:shadow-blue-500/40" */
  buttonHoverShadow?: string;
}

const {
  badgeText,
  headingTop,
  headingBottom,
  subtitle,
  stats = [],
  accentGradient = "from-cyan-400 via-orange-400 to-amber-400",
  buttonGradient = "from-orange-500 to-amber-500",
  buttonHoverGradient = "hover:from-orange-600 hover:to-amber-600",
  buttonShadow = "shadow-orange-500/25",
  buttonHoverShadow = "hover:shadow-orange-500/40",
} = Astro.props;
---

<section class="relative min-h-[90vh] flex items-center justify-center bg-slate-950 overflow-hidden font-poppins">
  <!-- Animated gradient orbs - hidden on mobile for performance -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="hidden sm:block absolute top-1/4 -left-20 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl motion-safe:animate-pulse"></div>
    <div class="hidden sm:block absolute bottom-1/4 -right-20 w-96 h-96 bg-orange-500/20 rounded-full blur-3xl motion-safe:animate-pulse" style="animation-delay: 1s;"></div>
    <div class="hidden sm:block absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-slate-500/10 rounded-full blur-3xl"></div>
    <!-- Mobile: gradient background -->
    <div class="sm:hidden absolute inset-0 bg-gradient-to-br from-cyan-500/10 via-slate-950 to-orange-500/10"></div>
  </div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <div class="absolute inset-0" style="background-image: linear-gradient(rgba(255,255,255,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.05) 1px, transparent 1px); background-size: 50px 50px;"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="text-center max-w-5xl mx-auto">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-full mb-8 backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-orange-500"></span>
        </span>
        <span class="text-sm font-medium text-slate-300">{badgeText}</span>
      </div>

      <!-- Main heading -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold mb-8 leading-[1.1]">
        <span class="text-white">{headingTop}</span>
        <br />
        <span class={`bg-gradient-to-r ${accentGradient} bg-clip-text text-transparent`}>{headingBottom}</span>
      </h1>

      <!-- Subtitle -->
      <p class="text-lg sm:text-xl text-slate-300 mb-12 max-w-3xl mx-auto leading-relaxed">
        {subtitle}
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
        <a
          href="/contact"
          class={`group inline-flex items-center justify-center gap-3 px-8 py-4 bg-gradient-to-r ${buttonGradient} ${buttonHoverGradient} text-white rounded-2xl font-bold text-lg shadow-lg ${buttonShadow} ${buttonHoverShadow} transform hover:-translate-y-1 transition-all duration-300`}
        >
          Get Started Today
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a
          href="#services"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-white/5 hover:bg-white/10 backdrop-blur-sm text-white rounded-2xl font-bold text-lg border border-white/10 hover:border-white/20 transition-all duration-300"
        >
          View Our Services
        </a>
      </div>

      <!-- Stats Bar -->
      {stats.length > 0 && (
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 sm:gap-6 max-w-4xl mx-auto">
          {stats.map((stat) => (
            <div class="relative group">
              <div class="relative bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-5 sm:p-6 hover:border-orange-500/30 transition-all duration-300">
                <div class={`text-2xl sm:text-3xl font-bold bg-gradient-to-r ${accentGradient} bg-clip-text text-transparent mb-1`}>{stat.value}</div>
                <div class="text-xs sm:text-sm text-slate-400">{stat.label}</div>
              </div>
            </div>
          ))}
        </div>
      )}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce hidden sm:block" aria-hidden="true">
    <div class="w-6 h-10 border-2 border-white/20 rounded-full flex justify-center">
      <div class="w-1 h-3 bg-white/40 rounded-full mt-2"></div>
    </div>
  </div>
</section>
