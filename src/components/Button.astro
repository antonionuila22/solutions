---
interface ButtonProps {
    text: string;
    href: string;
}

const { text, href } = Astro.props;
---

<a
    href={href}
    class="inline-block bg-gradient-to-r from-orange-500 to-orange-600 text-white font-semibold
   py-3.5 px-8 rounded-2xl shadow-lg shadow-orange-500/25
   hover:from-orange-400 hover:to-orange-500 hover:shadow-xl hover:shadow-orange-500/40 hover:brightness-105
   transition-[transform,box-shadow,filter] duration-200 ease-out will-change-transform
   transform hover:scale-[1.03] hover:-translate-y-0.5
   active:scale-[0.97] active:translate-y-0 active:duration-75
   border-none text-sm lg:text-lg"
>
    {text}
</a>
