---
interface Metric {
  label: string;
  value: string;
}

interface CaseStudy {
  industry: string;
  headline: string;
  description: string;
  metrics: Metric[];
  gradient: string;
  badgeColor: string;
}

interface CaseStudiesConfig {
  badge: string;
  title: string;
  titleHighlight: string;
  subtitle: string;
  studies: CaseStudy[];
}

interface Props {
  config?: Partial<CaseStudiesConfig>;
}

const defaults: CaseStudiesConfig = {
  badge: "Results & Case Studies",
  title: "Real Outcomes for",
  titleHighlight: "Real Businesses",
  subtitle: "Every project is built to deliver measurable impact. Here's what our clients achieved.",
  studies: [
    {
      industry: "Restaurant",
      headline: "200% Increase in Online Orders",
      description:
        "Built a custom online ordering platform replacing third-party apps. Zero commission fees meant the client kept 100% of profits.",
      metrics: [
        { label: "Monthly Orders", value: "2,400+" },
        { label: "Commission Saved", value: "$18K/yr" },
        { label: "Launch Time", value: "3 weeks" },
      ],
      gradient: "from-orange-500 to-amber-500",
      badgeColor: "bg-orange-50 text-orange-700 border-orange-200",
    },
    {
      industry: "Healthcare",
      headline: "45% Less Admin Time",
      description:
        "HIPAA-compliant patient portal with automated scheduling, reminders, and billing integration for a multi-location clinic.",
      metrics: [
        { label: "Patients Served", value: "12,000+" },
        { label: "No-Show Rate", value: "-60%" },
        { label: "Staff Hours Saved", value: "25hrs/wk" },
      ],
      gradient: "from-cyan-500 to-blue-500",
      badgeColor: "bg-cyan-50 text-cyan-700 border-cyan-200",
    },
    {
      industry: "E-Commerce",
      headline: "3x Revenue in 6 Months",
      description:
        "Full e-commerce rebuild with SEO optimization, faster checkout, and mobile-first design that tripled monthly revenue.",
      metrics: [
        { label: "Monthly Revenue", value: "$85K+" },
        { label: "Conversion Rate", value: "+180%" },
        { label: "Page Speed", value: "95/100" },
      ],
      gradient: "from-violet-500 to-purple-500",
      badgeColor: "bg-violet-50 text-violet-700 border-violet-200",
    },
  ],
};

const c = { ...defaults, ...Astro.props.config };
---

<section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-10 sm:mb-14 lg:mb-16">
      <span
        class="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-orange-50 to-amber-50 border border-orange-200/60 rounded-full mb-6 shadow-sm"
      >
        <span
          class="flex items-center justify-center w-5 h-5 bg-gradient-to-br from-orange-500 to-amber-500 rounded-full"
        >
          <svg
            class="w-3 h-3 text-white"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
            ></path>
          </svg>
        </span>
        <span class="text-sm font-semibold text-orange-700"
          >{c.badge}</span
        >
      </span>
      <h2
        class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-slate-900 mb-3 sm:mb-5 leading-tight px-2 sm:px-0"
      >
        {c.title}
        <span
          class="bg-gradient-to-r from-orange-500 to-amber-500 bg-clip-text text-transparent"
          >{c.titleHighlight}</span
        >
      </h2>
      <p
        class="text-base sm:text-lg md:text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed px-2 sm:px-0"
      >
        {c.subtitle}
      </p>
    </div>

    <!-- Case Study Cards Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 lg:gap-8">
      {
        c.studies.map((study) => (
          <div class="group relative bg-white rounded-2xl border border-slate-200/80 shadow-sm hover:shadow-xl hover:border-slate-300/80 transition-all duration-300 hover:-translate-y-1 overflow-hidden">
            {/* Accent top border */}
            <div
              class={`h-[3px] bg-gradient-to-r ${study.gradient}`}
              aria-hidden="true"
            />

            <div class="p-6 sm:p-7">
              {/* Industry badge */}
              <span
                class={`inline-block text-xs font-semibold px-3 py-1 rounded-full border mb-4 ${study.badgeColor}`}
              >
                {study.industry}
              </span>

              {/* Headline */}
              <h3 class="text-xl sm:text-2xl font-bold text-slate-900 mb-3 leading-snug">
                {study.headline}
              </h3>

              {/* Description */}
              <p class="text-sm sm:text-base text-slate-600 leading-relaxed mb-6">
                {study.description}
              </p>

              {/* Metrics row */}
              <div class="grid grid-cols-3 gap-3 pt-5 border-t border-slate-100">
                {study.metrics.map((metric) => (
                  <div class="text-center">
                    <p
                      class={`text-lg sm:text-xl font-bold bg-gradient-to-r ${study.gradient} bg-clip-text text-transparent`}
                    >
                      {metric.value}
                    </p>
                    <p class="text-[11px] sm:text-xs text-slate-500 mt-0.5 leading-tight">
                      {metric.label}
                    </p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
