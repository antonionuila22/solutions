---
/**
 * SectionHeading — standardized, animated section header.
 *
 * One consistent eyebrow + word-mask title + lead across the whole site, wired
 * into the GSAP engine via data-attributes (reveals on scroll). Replaces the
 * hand-rolled `<div class="text-center"><h2>…` blocks scattered through pages.
 *
 *   <SectionHeading
 *     eyebrow="Our Process"
 *     title='How We <span class="text-orange-500">Work</span>'
 *     subtitle="A proven methodology that ships on time."
 *   />
 */
interface Props {
  eyebrow?: string;
  title: string; // inline HTML allowed
  subtitle?: string; // inline HTML allowed
  align?: "center" | "left";
  theme?: "light" | "dark";
  eyebrowColor?: "cyan" | "orange";
  class?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  align = "center",
  theme = "light",
  eyebrowColor = "cyan",
  class: cls = "",
} = Astro.props as Props;

const isCenter = align === "center";
const titleColor = theme === "dark" ? "text-white" : "text-cyan-900";
const subColor = theme === "dark" ? "text-slate-300" : "text-slate-600";

const eyebrowClass =
  eyebrowColor === "orange"
    ? "bg-orange-50 text-orange-600 border-orange-200/70"
    : theme === "dark"
      ? "bg-slate-800 text-cyan-300 border-cyan-500/30"
      : "bg-cyan-50 text-cyan-700 border-cyan-200/70";
---

<div class:list={["max-w-3xl", isCenter ? "mx-auto text-center" : "", cls]}>
  {
    eyebrow && (
      <span
        class:list={[
          "inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full text-xs font-semibold tracking-wide uppercase mb-5 border",
          eyebrowClass,
        ]}
        data-anim="fade"
        data-fade-from="top"
        data-fade-offset="20"
      >
        {eyebrow}
      </span>
    )
  }
  <h2
    class:list={["text-display-2", titleColor]}
    data-anim="heading"
    set:html={title}
  />
  {
    subtitle && (
      <p
        class:list={["text-lead mt-4", subColor, isCenter ? "mx-auto" : ""]}
        data-anim="fade"
        data-delay="0.1"
        set:html={subtitle}
      />
    )
  }
</div>
