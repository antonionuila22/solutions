---
interface TechItem {
  name: string;
  icon: string; // emoji
}

interface Props {
  title: string;
  titleAccent: string;
  subtitle: string;
  technologies: TechItem[];
}

const { title, titleAccent, subtitle, technologies } = Astro.props;
---

<section class="py-16 sm:py-20 lg:py-28 bg-white font-poppins">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
        {title} <span class="bg-gradient-to-r from-orange-500 to-cyan-500 bg-clip-text text-transparent">{titleAccent}</span>
      </h2>
      <p class="text-lg text-slate-600 max-w-3xl mx-auto">{subtitle}</p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 sm:gap-6">
      {technologies.map((tech) => (
        <div class="group flex flex-col items-center justify-center p-6 sm:p-8 bg-slate-50 rounded-2xl hover:bg-gradient-to-br hover:from-orange-50 hover:to-cyan-50 border border-slate-100 hover:border-orange-200 transition-all duration-300">
          <div class="text-4xl sm:text-5xl mb-4 group-hover:scale-110 transition-transform duration-300">{tech.icon}</div>
          <div class="text-xs sm:text-sm font-semibold text-slate-700">{tech.name}</div>
        </div>
      ))}
    </div>
  </div>
</section>
