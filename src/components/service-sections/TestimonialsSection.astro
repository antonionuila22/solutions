---
/**
 * Testimonials Section Component for Service Pages
 * Wrapper for Testimonial component with customizable header
 */

import Testimonial from "../Testimonial.astro";

interface Props {
  title?: string;
  titleHighlight?: string;
  subtitle?: string;
}

const {
  title = "What Our",
  titleHighlight = "Clients Say",
  subtitle = "Real reviews from real clients on Google. See why businesses trust Codebrand for their digital needs.",
} = Astro.props;
---

<section class="py-16 sm:py-20 lg:py-28 bg-slate-950 font-poppins">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-8 sm:mb-12">
      <span class="inline-flex items-center gap-2 px-4 py-2 bg-slate-800 border border-yellow-500/30 rounded-full mb-6">
        <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path>
        </svg>
        <span class="text-sm font-medium text-yellow-400">Google Reviews</span>
      </span>
      <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-3 sm:mb-4">
        {title} <span class="text-orange-500">{titleHighlight}</span>
      </h2>
      <p class="text-base sm:text-lg text-slate-300 max-w-2xl mx-auto">{subtitle}</p>
    </div>
  </div>
  <Testimonial />
</section>
