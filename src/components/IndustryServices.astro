---
interface ServiceItem {
  icon: string; // inline SVG string
  title: string;
  description: string;
  features: string[];
}

interface Props {
  title: string;
  titleAccent: string; // gradient-colored word(s)
  subtitle: string;
  services: ServiceItem[];
  accentGradient?: string; // e.g. "from-blue-500 to-cyan-500"
}

const {
  title,
  titleAccent,
  subtitle,
  services,
  accentGradient = "from-orange-500 to-cyan-500",
} = Astro.props;
---

<section id="services" class="py-16 sm:py-20 lg:py-28 bg-slate-950 font-poppins relative overflow-hidden">
  <div class="absolute inset-0" aria-hidden="true">
    <div class="absolute top-1/4 -left-40 w-80 h-80 bg-cyan-500/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 -right-40 w-80 h-80 bg-orange-500/10 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-12 sm:mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-white/5 border border-white/10 rounded-full mb-6">
        <span class="text-sm font-medium text-slate-300">Our Services</span>
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-6">
        {title} <span class={`bg-gradient-to-r ${accentGradient} bg-clip-text text-transparent`}>{titleAccent}</span>
      </h2>
      <p class="text-lg text-slate-400 max-w-3xl mx-auto">{subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service) => (
        <div class="group relative">
          <div class="relative h-full bg-slate-900/50 backdrop-blur-sm border border-slate-800 hover:border-orange-500/30 rounded-2xl p-6 sm:p-8 transition-all duration-300">
            <div class={`w-14 h-14 bg-gradient-to-br ${accentGradient} rounded-2xl flex items-center justify-center mb-6 group-hover:scale-110 transition-transform duration-300`} set:html={service.icon}></div>
            <h3 class="text-xl font-semibold text-white mb-3">{service.title}</h3>
            <p class="text-slate-400 mb-6 text-sm">{service.description}</p>
            <ul class="space-y-2">
              {service.features.map((feature) => (
                <li class="flex items-center gap-2 text-sm text-slate-300">
                  <svg class="w-4 h-4 text-orange-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
