---
interface ValuePropConfig {
  flagLeft: string;
  flagRight: string;
  flagLabel: string;
  title: string;
  titleHighlight: string;
  subtitle: string;
  stats: { value: string; title: string; description: string }[];
  benefitsTitle: string;
  benefits: { title: string; description: string }[];
  priceComparison: {
    competitorLabel: string;
    competitorPrice: string;
    competitorNote: string;
    ourLabel: string;
    ourPrice: string;
    ourNote: string;
    savingsAmount: string;
    savingsPercent: string;
  };
  ctaText: string;
  ctaSubtext: string;
}

interface Props {
  config?: Partial<ValuePropConfig>;
}

const defaults: ValuePropConfig = {
  flagLeft: "\u{1F1ED}\u{1F1F3}",
  flagRight: "\u{1F1FA}\u{1F1F8}",
  flagLabel: "Honduras → United States",
  title: "Premium Web Development",
  titleHighlight: "at 60% Lower Cost",
  subtitle: 'Why pay $25,000+ for <a href="/services/web-development" class="text-cyan-500 hover:text-cyan-600 font-semibold">web development</a> in the US when you can get the same professional quality from our certified team in Honduras for a fraction of the cost?',
  stats: [
    { value: "60%", title: "Cost Savings", description: "Save thousands compared to US agency rates while maintaining the same professional quality standards." },
    { value: "100%", title: "Same Quality", description: "Our certified professionals deliver the exact same quality as US agencies. Same standards, better prices." },
    { value: "CST", title: "US Time Zone", description: "Work seamlessly with our bilingual team. Honduras operates in Central Time (CST) for real-time collaboration." },
  ],
  benefitsTitle: "Why US Companies Choose Codebrand",
  benefits: [
    { title: "Certified Professional Team", description: "Our developers hold certifications from Udemy, Platzi, and Adobe, ensuring cutting-edge expertise in modern technologies." },
    { title: "Export-Quality Services", description: "We specialize in serving international clients with the same standards expected by Fortune 500 companies." },
    { title: "Managed Honduran Talent", description: "We handle all talent management, so you get premium results without the overhead costs." },
    { title: "Bilingual Communication", description: "Fluent English-speaking team ensures clear communication throughout your project lifecycle." },
    { title: "Proven Track Record", description: "50+ successful projects delivered to international clients across various industries." },
  ],
  priceComparison: {
    competitorLabel: "US Agency",
    competitorPrice: "$25,000",
    competitorNote: "Average US market rate for custom websites",
    ourLabel: "Codebrand",
    ourPrice: "$10,000",
    ourNote: "Top quality, Honduras pricing",
    savingsAmount: "$15,000+",
    savingsPercent: "60% cost reduction",
  },
  ctaText: "Get Your Free Quote Today",
  ctaSubtext: "Join 50+ US businesses saving thousands on quality web development",
};

const c = { ...defaults, ...Astro.props.config };
---

<section
  class="py-16 sm:py-20 lg:py-28 bg-white font-poppins overflow-hidden"
  id="value-proposition"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-10 sm:mb-12 lg:mb-16 value-header">
      <div
        class="inline-flex items-center gap-3 px-5 py-2.5 bg-slate-100 rounded-full mb-6"
      >
        <span class="text-2xl">{c.flagLeft}</span>
        <span
          class="text-sm font-semibold text-slate-700 uppercase tracking-wide"
        >
          {c.flagLabel}
        </span>
        <span class="text-2xl">{c.flagRight}</span>
      </div>
      <h2
        class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-bold text-slate-900 mb-4 sm:mb-6 leading-tight px-2 sm:px-0"
      >
        {c.title}<br />
        <span class="text-cyan-600">{c.titleHighlight}</span>
      </h2>
      <p
        class="text-base sm:text-lg lg:text-xl text-slate-600 max-w-3xl mx-auto leading-relaxed px-2 sm:px-0"
      >
        <Fragment set:html={c.subtitle} />
      </p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6 md:gap-8 mb-12 sm:mb-16 lg:mb-20 stats-grid">
      {c.stats.map((stat, i) => (
        <div class="stat-card group">
          <div
            class="bg-gradient-to-br from-slate-50 to-white border border-slate-200 rounded-2xl p-5 sm:p-6 lg:p-8 hover:shadow-xl transition-all duration-300 h-full"
          >
            <div
              class={`flex items-center justify-center w-12 h-12 sm:w-14 sm:h-14 lg:w-16 lg:h-16 ${i === 1 ? "bg-orange-500" : "bg-cyan-900"} rounded-xl mb-4 sm:mb-5 lg:mb-6 group-hover:scale-110 transition-transform duration-300`}
            >
              <svg class="w-6 h-6 sm:w-7 sm:h-7 lg:w-8 lg:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="text-4xl sm:text-5xl font-bold text-slate-900 mb-2 sm:mb-3">{stat.value}</div>
            <h3 class="text-lg sm:text-xl font-semibold text-slate-900 mb-1 sm:mb-2">{stat.title}</h3>
            <p class="text-sm sm:text-base text-slate-600 leading-relaxed">{stat.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Main Content Grid -->
    <div
      class="grid grid-cols-1 lg:grid-cols-5 gap-6 sm:gap-8 lg:gap-12 items-start content-grid"
    >
      <!-- Why Choose Us -->
      <div class="lg:col-span-3 space-y-6">
        <h3 class="text-3xl font-semibold text-slate-900 mb-8">
          {c.benefitsTitle}
        </h3>

        <div class="space-y-4 benefits-list">
          {c.benefits.map((benefit) => (
            <div class="benefit-item flex items-start gap-4 p-5 bg-slate-50 rounded-xl hover:bg-slate-100 transition-colors duration-300">
              <div class="flex-shrink-0 w-10 h-10 bg-cyan-900 rounded-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <h4 class="font-semibold text-slate-900 mb-1">{benefit.title}</h4>
                <p class="text-slate-600 text-sm leading-relaxed">{benefit.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Price Comparison -->
      <div class="lg:col-span-2 price-comparison">
        <div class="sticky top-8">
          <div
            class="bg-gradient-to-br from-slate-50 to-white border-2 border-slate-200 rounded-2xl p-5 sm:p-6 lg:p-8 shadow-lg"
          >
            <div class="text-center mb-8">
              <h3 class="text-2xl font-semibold text-slate-900 mb-2">
                Price Comparison
              </h3>
              <p class="text-sm text-slate-600">
                Professional Website Development
              </p>
            </div>

            <div class="space-y-5">
              <div
                class="bg-white rounded-xl p-6 border-2 border-slate-200 shadow-sm"
              >
                <div class="flex items-center justify-between mb-3">
                  <div>
                    <p class="text-sm text-slate-500 mb-1">{c.priceComparison.competitorLabel}</p>
                    <p class="text-3xl font-bold text-slate-900">
                      {c.priceComparison.competitorPrice}<span class="text-lg text-slate-400">+</span>
                    </p>
                  </div>
                  <div
                    class="flex items-center justify-center w-12 h-12 bg-red-100 rounded-full"
                  >
                    <svg
                      class="w-6 h-6 text-red-600"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                  </div>
                </div>
                <p class="text-xs text-slate-500">
                  {c.priceComparison.competitorNote}
                </p>
              </div>

              <div class="relative">
                <div
                  class="absolute inset-0 flex items-center"
                  aria-hidden="true"
                >
                  <div class="w-full border-t border-slate-300"></div>
                </div>
                <div class="relative flex justify-center">
                  <span
                    class="px-3 bg-slate-50 text-sm font-semibold text-slate-700"
                    >VS</span
                  >
                </div>
              </div>

              <div
                class="bg-cyan-900 rounded-xl p-6 shadow-lg transform hover:scale-105 transition-transform duration-300"
              >
                <div class="flex items-center justify-between mb-3">
                  <div>
                    <p class="text-sm text-cyan-100 mb-1">{c.priceComparison.ourLabel}</p>
                    <p class="text-3xl font-bold text-white">{c.priceComparison.ourPrice}</p>
                  </div>
                  <div
                    class="flex items-center justify-center w-12 h-12 bg-white/20 rounded-full backdrop-blur-sm"
                  >
                    <svg
                      class="w-6 h-6 text-white"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                    >
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"></path>
                    </svg>
                  </div>
                </div>
                <p class="text-xs text-cyan-100">
                  {c.priceComparison.ourNote}
                </p>
              </div>

              <div
                class="bg-gradient-to-r from-emerald-50 to-green-50 rounded-xl p-6 border-2 border-green-200"
              >
                <div class="text-center">
                  <p class="text-sm text-slate-600 mb-2">You Save</p>
                  <p class="text-4xl font-bold text-green-600 mb-1">{c.priceComparison.savingsAmount}</p>
                  <p class="text-xs text-slate-500">{c.priceComparison.savingsPercent}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-16 cta-section">
      <a
        href="/contact"
        class="inline-flex items-center justify-center gap-3 px-8 py-3.5 bg-gradient-to-r from-orange-500 to-orange-600 hover:from-orange-600 hover:to-orange-700 text-white rounded-2xl font-bold text-lg shadow-lg shadow-orange-500/25 hover:shadow-orange-500/40 transform hover:-translate-y-1 transition-all duration-300"
      >
        {c.ctaText}
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
      <p class="text-slate-500 mt-5 text-sm">
        {c.ctaSubtext}
      </p>
    </div>
  </div>
</section>

<style>
  .value-header, .stat-card, .benefit-item, .price-comparison, .cta-section {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }
  .benefit-item { transform: translateX(-30px); }
  .price-comparison { transform: translateX(50px); }
  .animate-visible {
    opacity: 1 !important;
    transform: translateY(0) translateX(0) !important;
  }
</style>

<script is:inline>
  // Check for reduced motion preference
  if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    // Only animate on desktop (768px+)
    const isDesktop = window.matchMedia("(min-width: 768px)").matches;

    if (isDesktop && "IntersectionObserver" in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target;
            el.classList.add('animate-visible');
            observer.unobserve(el);
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.value-header, .stat-card, .benefit-item, .price-comparison, .cta-section')
        .forEach((el, i) => {
          el.style.transitionDelay = `${i * 0.1}s`;
          observer.observe(el);
        });
    } else {
      // Mobile or no IntersectionObserver: show elements immediately
      document.querySelectorAll('.value-header, .stat-card, .benefit-item, .price-comparison, .cta-section')
        .forEach((el) => {
          el.style.opacity = '1';
          el.style.transform = 'none';
        });
    }
  } else {
    // Reduced motion: show elements immediately
    document.querySelectorAll('.value-header, .stat-card, .benefit-item, .price-comparison, .cta-section')
      .forEach((el) => {
        el.style.opacity = '1';
        el.style.transform = 'none';
      });
  }
</script>
