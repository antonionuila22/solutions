---
import type { CollectionEntry } from "astro:content";

interface Props {
  currentId: string;
  projects: CollectionEntry<"projects">[];
  category?: string;
  tags?: string[];
  limit?: number;
}

const { currentId, projects, category, tags = [], limit = 3 } = Astro.props;

const currentTags = new Set(tags);

// Score by same category (2pt) + shared tags (0.5pt each). Featured + newer wins ties.
const scored = projects
  .filter((p) => p.id !== currentId && !p.data.draft)
  .map((p) => {
    let score = 0;
    if (category && p.data.category === category) score += 2;
    for (const t of p.data.tags || []) {
      if (currentTags.has(t)) score += 0.5;
    }
    const ts = p.data.date ? new Date(p.data.date).getTime() : 0;
    const featured = p.data.featured ? 1 : 0;
    return { project: p, score, ts, featured };
  })
  .sort((a, b) => b.score - a.score || b.featured - a.featured || b.ts - a.ts);

const topRelated = scored.slice(0, limit).map((s) => s.project);
const related = topRelated.length === limit
  ? topRelated
  : [
      ...topRelated,
      ...scored
        .slice(limit)
        .sort((a, b) => b.featured - a.featured || b.ts - a.ts)
        .slice(0, limit - topRelated.length)
        .map((s) => s.project),
    ];
---

{
  related.length > 0 && (
    <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 border-t border-slate-100">
      <div class="mb-10">
        <span class="text-orange-500 font-semibold text-sm uppercase tracking-wider">
          More work
        </span>
        <h2 class="text-2xl sm:text-3xl font-bold text-cyan-900 mt-2">
          Related Projects
        </h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {related.map((p) => {
          const { id, data } = p;
          const { title, description, img, category: cat, client } = data;
          const cover = img
            ? img.startsWith("http") || img.startsWith("/")
              ? img
              : `/${img}`
            : "/photos/bannercodebrand.webp";
          return (
            <a
              href={`/projects/${id}`}
              class="group bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm hover:shadow-xl hover:border-cyan-300 transition-all duration-300 flex flex-col"
            >
              <div class="overflow-hidden aspect-16/10 bg-slate-100">
                <img
                  src={cover}
                  alt={title}
                  loading="lazy"
                  decoding="async"
                  width="500"
                  height="312"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
              <div class="p-6 flex flex-col gap-3 flex-1">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="text-xs font-semibold text-cyan-700 bg-cyan-50 px-2 py-1 rounded-full">
                    {cat}
                  </span>
                  {client && (
                    <span class="text-xs font-medium text-slate-500">{client}</span>
                  )}
                </div>
                <h3 class="text-lg font-bold text-cyan-900 group-hover:text-orange-600 transition-colors line-clamp-2">
                  {title}
                </h3>
                {description && (
                  <p class="text-sm text-slate-600 line-clamp-3">{description}</p>
                )}
                <span class="mt-auto pt-3 inline-flex items-center gap-2 text-sm font-semibold text-orange-600 group-hover:gap-3 transition-all">
                  View case study
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  )
}
