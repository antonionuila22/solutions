---
import FAQ from "./FAQ.tsx";

interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  titleAccent: string;
  subtitle: string;
  faqs: FAQItem[];
}

const { title, titleAccent, subtitle, faqs } = Astro.props;
---

<section class="py-16 sm:py-20 lg:py-28 bg-slate-950 font-poppins">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-white mb-4">
        {title} <span class="text-orange-500">{titleAccent}</span>
      </h2>
      <p class="text-lg text-slate-300 max-w-2xl mx-auto">{subtitle}</p>
    </div>
    <FAQ faqs={faqs} theme="dark" client:visible />
  </div>
</section>
